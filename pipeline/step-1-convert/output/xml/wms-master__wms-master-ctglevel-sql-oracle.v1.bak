<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
	
<mapper namespace="com.daiso.wms.master.mapper.CtgLevelMapper">

	<select id="selectCtgLevelCount" resultType="java.lang.Integer">
		/* wms-master-ctglevel-sql-oracle.xml- selectCtgLevelCount */
		WITH RECURSIVE ctg_base AS (
			   SELECT CTG.CTKEY
					, CT.CTNM
					, CTG.OWKEY
					, OW.OWNM
					, CTG.CTGLV
					, CTG.CTGKEY
					, CTG.CTGNM AS CTGTREE
					, CTG.UPRCTGKEY
					, UPR_CTG.CTGNM AS UPRCTGNM
					, CTG.DELYN
					, CTG.INSERTDATE
					, CTG.INSERTURKEY
					, CTG.UPDATEDATE
					, CTG.UPDATEURKEY
				 FROM TWORK_MST_CTG CTG
				INNER JOIN TWORK_MST_CT CT
					ON CT.CTKEY = CTG.CTKEY
				INNER JOIN TWORK_MST_OW OW
					ON OW.OWKEY = CTG.OWKEY
				LEFT JOIN TWORK_MST_CTG UPR_CTG
					ON UPR_CTG.CTKEY = CTG.CTKEY
					AND UPR_CTG.OWKEY = CTG.OWKEY
					AND UPR_CTG.CTGKEY = CTG.UPRCTGKEY

			<where>
				AND CTG.OWKEY = COALESCE(#{OWKEY}, #{sowkey})
				AND CTG.DELYN = 'N'
				AND CTG.CLOSDATE <![CDATA[ >= ]]> #{sysdate}
			</where>
		), ctg_hier AS (
			SELECT b.*, ARRAY[b.CTGKEY] AS path, 1 AS lvl
			  FROM ctg_base b
			 WHERE b.CTKEY = #{CTKEY}
			   AND b.OWKEY = COALESCE(#{OWKEY}, #{sowkey})
			   AND b.CTGLV = '1'
			UNION ALL
			SELECT c.*, h.path || c.CTGKEY, h.lvl + 1
			  FROM ctg_base c
			 INNER JOIN ctg_hier h ON c.UPRCTGKEY = h.CTGKEY
			 WHERE c.CTKEY = #{CTKEY}
			   AND c.OWKEY = COALESCE(#{OWKEY}, #{sowkey})
			   AND c.DELYN = 'N'
			   AND NOT c.CTGKEY = ANY(h.path)
		)
		SELECT COUNT(1)
		  FROM ctg_hier A

		<where>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)">
				AND	#{SEARCH_CONDITION}
			</if>
		</where>
	</select>

	<select id="selectCtgLevelList" resultType="camelMap">
		/* wms-master-ctglevel-sql-oracle.xml- selectCtgLevelList */
		#{GRIDPAGING_ROWNUMTYPE_TOP}
		WITH RECURSIVE ctg_base AS (
			   SELECT CTG.CTKEY
					, CT.CTNM
					, CTG.OWKEY
					, OW.OWNM
			        , CTG.CTGLV
					, CTG.CTGKEY
					, CTG.CTGNM AS CTGTREE
					, CTG.UPRCTGKEY
					, UPR_CTG.CTGNM AS UPRCTGNM
					, CTG.DELYN
					, CTG.INSERTDATE
					, CTG.INSERTURKEY
					, CTG.UPDATEDATE
					, CTG.UPDATEURKEY
				 FROM TWORK_MST_CTG CTG
				INNER JOIN TWORK_MST_CT CT
					ON CT.CTKEY = CTG.CTKEY
				INNER JOIN TWORK_MST_OW OW
					ON OW.OWKEY = CTG.OWKEY
				LEFT JOIN TWORK_MST_CTG UPR_CTG
					ON UPR_CTG.CTKEY = CTG.CTKEY
					AND UPR_CTG.OWKEY = CTG.OWKEY
					AND UPR_CTG.CTGKEY = CTG.UPRCTGKEY

			<where>
				AND CTG.OWKEY = COALESCE(#{OWKEY}, #{sowkey})
				AND CTG.DELYN = 'N'
				AND CTG.CLOSDATE <![CDATA[ >= ]]> #{sysdate}
			</where>
		), ctg_hier AS (
			SELECT b.*, ARRAY[b.CTGKEY] AS path, 1 AS lvl,
			       ARRAY[b.CTKEY DESC, b.OWKEY DESC, b.CTGKEY ASC] AS sort_path
			  FROM ctg_base b
			 WHERE b.CTKEY = #{CTKEY}
			   AND b.OWKEY = COALESCE(#{OWKEY}, #{sowkey})
			   AND b.CTGLV = '1'
			UNION ALL
			SELECT c.*, h.path || c.CTGKEY, h.lvl + 1,
			       h.sort_path || ARRAY[c.CTKEY DESC, c.OWKEY DESC, c.CTGKEY ASC]
			  FROM ctg_base c
			 INNER JOIN ctg_hier h ON c.UPRCTGKEY = h.CTGKEY
			 WHERE c.CTKEY = #{CTKEY}
			   AND c.OWKEY = COALESCE(#{OWKEY}, #{sowkey})
			   AND c.DELYN = 'N'
			   AND NOT c.CTGKEY = ANY(h.path)
		)
		SELECT *
		  FROM ctg_hier A

		<where>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)">
				AND	#{SEARCH_CONDITION}
			</if>
		</where>
		ORDER BY A.path

		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>

	<update id="updateCtgLevelInfo">
		/* wms-master-ctglevel-sql-oracle.xml- updateCtgLevelInfo */
		UPDATE TWORK_MST_CTG
		   SET WRHOUS_SE = #{wrhousSe}
		     , BOL_WRHOUS_SE = #{bolWrhousSe}
		     , UPDATEDATE = #{sysdate}
		     , UPDATEURKEY = #{surkey}
		WHERE CTKEY = #{ctkey}
		  AND OWKEY = #{owkey}
		  AND CTGLEVEL = #{ctglevel}
		  AND CTGKEY = #{ctgkey}
	</update>
</mapper>	