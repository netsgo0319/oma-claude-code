<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.daiso.wms.interfaces.mapper.IfWcsInvnMapper">

	<select id="selectConvertEa" resultType="int">
		/* IfWcsInvnMapper.selectConvertEa - 단위환산 */
		SELECT #{quantityValue} * ICUTXTYPE.ICUTQTY AS EA
		  FROM TWORK_MST_IC 			IC
		 INNER JOIN TWORK_MST_ICUTXTYPE ICUTXTYPE
		    ON IC.CTKEY	  	  = ICUTXTYPE.CTKEY
		   AND IC.OWKEY	  	  = ICUTXTYPE.OWKEY
		   AND IC.ICUTKEY	  = ICUTXTYPE.ICUTKEY
		 WHERE IC.CTKEY = '#{@com.daiso.wms.interfaces.common.WcsPropertyUtil@CTKEY}'
		   AND IC.ICKEY = #{code}
		   AND ICUTXTYPE.ICUTTYPE = #{quantityUnit}
	</select>

	<select id="selectRivmmwcs" resultType="camelMap">
		/* IfWcsInvnMapper.selectRivmmwcs - 재고이동결과 */
		SELECT SIVMMWCS.CTKEY 		 AS CTKEY
		     , SIVMMWCS.OWKEY 		 AS OWKEY
			 , SIVMMWCS.TA_HDKEY 	 AS TA_HDKEY
			 , SIVMMWCS.TA_DTKEY 	 AS TA_DTKEY

			 , COALESCE(RIVMMWCS.DELIVERED_QUANTITY_VALUE * ICUTXTYPE.ICUTQTY, 0) AS COMPLEQTY			/* 기존 완료 수량 */

			 , COALESCE(RIVMMWCS.REQUESTED_QUANTITY_VALUE * ICUTXTYPE.ICUTQTY, 0) AS REQQTY				/* 재고이동 요청 수량 */
	 		 , CASE WHEN RIVMMWCS.REQUESTED_QUANTITY_VALUE <![CDATA[ >= ]]> RIVMMWCS.DELIVERED_QUANTITY_VALUE
	 		 		THEN COALESCE(RIVMMWCS.DELIVERED_QUANTITY_VALUE * ICUTXTYPE.ICUTQTY, 0)
	 		        ELSE COALESCE(RIVMMWCS.REQUESTED_QUANTITY_VALUE * ICUTXTYPE.ICUTQTY, 0) END AS QTY	/* 재고이동 완료 수량 */

			 <!-- , NVL(RIVMMWCS.DELIVERED_QUANTITY_VALUE * ICUTXTYPE.ICUTQTY, 0) AS QTY -->
			 , COALESCE(RIVMMWCS.ABANDONED_QUANTITY_VALUE * ICUTXTYPE.ICUTQTY, 0) AS RJQTY				/* 재고이동 거부 수량 */
			 , CASE WHEN RIVMMWCS.REQUESTED_QUANTITY_VALUE <![CDATA[ >= ]]> RIVMMWCS.DELIVERED_QUANTITY_VALUE
			 		THEN 0
			 		ELSE COALESCE((RIVMMWCS.DELIVERED_QUANTITY_VALUE - RIVMMWCS.REQUESTED_QUANTITY_VALUE) * ICUTXTYPE.ICUTQTY, 0)
			 		END AS RES_QTY																	/* 재고이동 잔여 수량 */
			 , SIVMMWCS.ORDER_TYPE
			 , RIVMMWCS.PROCESS_CODE
			 , RIVMMWCS.STATUS
			 , RIVMMWCS.PROCESS_DESCRIPTION
			 , CASE WHEN RIVMMWCS.DELIVERED_QUANTITY_VALUE > RIVMMWCS.REQUESTED_QUANTITY_VALUE
			 		THEN RIVMMWCS.DESTINATION_LOCATION_CODE
			 		ELSE NULL END AS RES_IB_FLOOR
			 , RIVMMWCS.LICENSE_PLATE_NUMBER
			 , SIVMMWCS.REQ_TYPE_CD
			 , SIVMMWCS.ORIGIN_LOCATION_CODE AS FR_LCKEY
		  FROM TWORK_INTF_SIVMMWCS 		SIVMMWCS
		 INNER JOIN TWORK_INTF_RIVMMWCS RIVMMWCS
		    ON SIVMMWCS.IVMM_NUMBER = RIVMMWCS.IVMM_NUMBER
		   AND SIVMMWCS.IVMM_SEQ = RIVMMWCS.IVMM_SEQ
		 INNER JOIN TWORK_MST_IC 		IC
		    ON SIVMMWCS.CTKEY 		 = IC.CTKEY
		   AND SIVMMWCS.OWKEY 		 = IC.OWKEY
		   AND RIVMMWCS.PRODUCT_CODE = IC.ICKEY
		 INNER JOIN TWORK_MST_ICUTXTYPE ICUTXTYPE
		    ON IC.CTKEY	  	  		 = ICUTXTYPE.CTKEY
		   AND IC.OWKEY	  	  		 = ICUTXTYPE.OWKEY
		   AND IC.ICUTKEY	 		 = ICUTXTYPE.ICUTKEY
		   AND RIVMMWCS.DELIVERED_QUANTITY_UNIT = ICUTXTYPE.ICUTTYPE
		 WHERE RIVMMWCS.R_IVMM_SEQ = #{rIvmmSeq}
		   AND RIVMMWCS.STATUS 	  = #{status}
		   AND SIVMMWCS.SUCCEEDED = 'true' 
	</select>

	<select id="selectIntfSivhdwcsTest" resultType="holdProductItems">
	/* IfWcsInvnMapper.selectIntfSivhdwcsTest - TEST재고이동결과 */
		SELECT SIVHDWCS.IVHD_NUMBER
		     , SIVHDWCS.CODE
			 , SIVHDWCS.LOCATION_CODE
			 , SIVHDWCS.EFFECTIVE_DATE_FROM AS EFFECTIVE_DATE
			 , 2 AS QUANTITY_VALUE
			 , ICUTXTYPE.ICUTTYPE    AS QUANTITY_UNIT
			 , CASE SIVHDWCS.HOLD_STATUS WHEN 'true' THEN 'false' ELSE 'true' END AS PREVIOUS_HOLD_STATUS
			 , SIVHDWCS.HOLD_STATUS AS CURRENT_HOLD_STATUS
			 , 'success' AS PROCESS_STATUS
		  FROM TWORK_INTF_SIVHDWCS 			  SIVHDWCS
		  LEFT OUTER JOIN TWORK_INTF_RIVHDWCS RIVHDWCS
		    ON SIVHDWCS.IVHD_NUMBER = RIVHDWCS.IVHD_NUMBER
		 INNER JOIN TWORK_MST_IC 		IC
		    ON '#{@com.daiso.wms.interfaces.common.WcsPropertyUtil@CTKEY}'	  = IC.CTKEY
		   AND 'WELLFOOD'	  = IC.OWKEY
		   AND SIVHDWCS.CODE  = IC.ICKEY
		 INNER JOIN TWORK_MST_ICUTXTYPE ICUTXTYPE
		    ON IC.CTKEY	  	  = ICUTXTYPE.CTKEY
		   AND IC.OWKEY	  	  = ICUTXTYPE.OWKEY
		   AND IC.ICUTKEY	  = ICUTXTYPE.ICUTKEY
		   AND 'BOX' 		  = ICUTXTYPE.ICUTTYPE
		 WHERE SIVHDWCS.S_IVHD_SEQ = #{S_IVHD_SEQ}
		   AND SIVHDWCS.SUCCEEDED = 'true'
		   AND RIVHDWCS.IVHD_NUMBER IS NULL
	</select>

	<select id="selectIntfSivmmwcsTest" resultType="wcsInvnMoveReqDTO">
		/* IfWcsInvnMapper.selectIntfSivmmwcsTest - TESTWCS재고이동 조회 */
		SELECT IVMM_SEQ
			 , CTKEY
			 , OWKEY
			 , ORDER_TYPE
			 , TA_HDKEY
			 , TA_DTKEY
			 , REQ_TYPE_CD
			 , IVMM_NUMBER
			 , PRODUCT_CODE
			 , QUANTITY_VALUE
			 , QUANTITY_UNIT
			 , EFFECTIVE_DATE
			 , ORIGIN_LOCATION_CODE
			 , DESTINATION_LOCATION_CODE
			 , INVENTORY_STATUS
			 , LICENSE_PLATE_NUMBER
			 , CANCEL_IVMM_SEQ
			 , SUCCEEDED
			 , ERROR_VALUE
			 , ERROR_REASON
			 , INSERTDATE
			 , INSERTURKEY
			 , UPDATEDATE
			 , UPDATEURKEY
		  FROM TWORK_INTF_SIVMMWCS 	  	    SIVMMWCS
		 WHERE SIVMMWCS.IVMM_SEQ   = #{IVMM_SEQ}
	</select>

	<select id="selectIntfSivwcsTest" resultType="camelMap">
	/* IfWcsInvnMapper.selectIntfSivwcsTest - TEST재고현황결과 */
		SELECT #{IV_NUMBER} AS IV_NUMBER
			 , 'HEADTAIL'          AS STATUS
		     , IVATXLCXULC.ICKEY   AS CODE
		     , IVATXLCXULC.TTQTY / ICUTXTYPE.ICUTQTY AS QUANTITY_VALUE
		     , ICUTXTYPE.ICUTTYPE AS QUANTITY_UNIT
		 , TO_CHAR(TO_DATE(SUBSTR(IVAT.EXPIREDATE,1, 8),'YYYYMMDD'), 'YYYY-MM-DD') AS EFFECTIVE_DATE
		 , IVATXLCXULC.LCKEY   AS LOCATION_CODE
		 , 'false'    AS HOLD_STATUS
		  FROM TWORK_INFO_IVATXLCXULC   IVATXLCXULC
		 INNER JOIN TWORK_MST_IC  MSTIC
		    ON IVATXLCXULC.CTKEY   = MSTIC.CTKEY
		   AND IVATXLCXULC.OWKEY   = MSTIC.OWKEY
		   AND IVATXLCXULC.ICKEY   = MSTIC.ICKEY
		 INNER JOIN TWORK_INFO_IVAT IVAT
		    ON IVATXLCXULC.CTKEY   = IVAT.CTKEY
		   AND IVATXLCXULC.OWKEY   = IVAT.OWKEY
		   AND IVATXLCXULC.IVATKEY = IVAT.IVATKEY
		   AND IVATXLCXULC.ICKEY = IVAT.ICKEY
		 INNER JOIN TWORK_MST_ICUT  ICUT
		    ON MSTIC.CTKEY  = ICUT.CTKEY
		   AND MSTIC.OWKEY  = ICUT.OWKEY
		   AND MSTIC.ICUTKEY = ICUT.ICUTKEY
		 INNER JOIN TWORK_MST_ICUTXTYPE	ICUTXTYPE
		    ON ICUT.CTKEY  = ICUTXTYPE.CTKEY
		   AND ICUT.OWKEY  = ICUTXTYPE.OWKEY
		   AND ICUT.ICUTKEY  = ICUTXTYPE.ICUTKEY
		   AND IVAT.UOM      = ICUTXTYPE.ICUTTYPE
		 WHERE IVATXLCXULC.CTKEY = '#{@com.daiso.wms.interfaces.common.WcsPropertyUtil@CTKEY}'
		   AND IVATXLCXULC.OWKEY = '#{@com.daiso.wms.interfaces.common.WcsPropertyUtil@OWKEY}'
		   AND IVATXLCXULC.LCKEY = 'ASRS'
		   AND (IVATXLCXULC.TTQTY / ICUTXTYPE.ICUTQTY) > 1
	</select>

	<select id="selectIntfRivmscwcsTest" resultType="camelMap">
	/* IfWcsInvnMapper.selectIntfRivmscwcsTest - TEST MSC 재고 처리 데이터 */
		SELECT CASE WHEN 'S' = #{id} THEN 'RECEPT' ELSE 'REJECTED' END AS TYPE
			 , TO_CHAR(CURRENT_TIMESTAMP, 'YYYY-MM-DD') AS CURRENT_DATE
			 , IVATXLCXULC.ICKEY   AS PRODUCT_CODE
		     , IVATXLCXULC.TTQTY / ICUTXTYPE.ICUTQTY AS QUANTITY_VALUE
		     , ICUTXTYPE.ICUTTYPE  AS QUANTITY_UNIT
			 , TO_CHAR(TO_DATE(SUBSTR(IVAT.EXPIREDATE,1, 8),'YYYYMMDD'), 'YYYY-MM-DD') AS EFFECTIVE_DATE
			 , IVATXLCXULC.LCKEY   AS LOCATION_CODE
			 , 'false' 			   AS HOLD_STATUS
			 , 'CONV1' AS REJECT_LINE_NO
		  FROM TWORK_INFO_IVATXLCXULC   IVATXLCXULC
		 INNER JOIN TWORK_MST_IC 	 	MSTIC
		    ON IVATXLCXULC.CTKEY   = MSTIC.CTKEY
		   AND IVATXLCXULC.OWKEY   = MSTIC.OWKEY
		   AND IVATXLCXULC.ICKEY   = MSTIC.ICKEY
		 INNER JOIN TWORK_INFO_IVAT 	IVAT
		    ON IVATXLCXULC.CTKEY   = IVAT.CTKEY
		   AND IVATXLCXULC.OWKEY   = IVAT.OWKEY
		   AND IVATXLCXULC.IVATKEY = IVAT.IVATKEY
		 INNER JOIN TWORK_MST_ICUT 	 	ICUT
		    ON MSTIC.CTKEY 	 = ICUT.CTKEY
		   AND MSTIC.OWKEY 	 = ICUT.OWKEY
		   AND MSTIC.ICUTKEY = ICUT.ICUTKEY
		 INNER JOIN TWORK_MST_ICUTXTYPE	ICUTXTYPE
		    ON ICUT.CTKEY 	 = ICUTXTYPE.CTKEY
		   AND ICUT.OWKEY 	 = ICUTXTYPE.OWKEY
		   AND ICUT.ICUTKEY  = ICUTXTYPE.ICUTKEY
		   AND IVAT.UOM      = ICUTXTYPE.ICUTTYPE
		 WHERE IVATXLCXULC.LCKEY = 'ASRS'
		   AND IVATXLCXULC.CTKEY = '#{@com.daiso.wms.interfaces.common.WcsPropertyUtil@CTKEY}'
		   AND IVATXLCXULC.OWKEY = '#{@com.daiso.wms.interfaces.common.WcsPropertyUtil@OWKEY}'
		   AND IVATXLCXULC.TTQTY > 0
	</select>

	<select id="selectIntfRivrvwcsTest" resultType="camelMap">
	/* IfWcsInvnMapper.selectIntfRivrvwcsTest - TEST WCS재고조정 데이터 */
	SELECT IVATXLCXULC.ICKEY   AS PRODUCT_CODE
	     , IVATXLCXULC.TTQTY / ICUTXTYPE.ICUTQTY AS QUANTITY_VALUE
	     , ICUTXTYPE.ICUTTYPE  AS QUANTITY_UNIT
		 , TO_CHAR(TO_DATE(SUBSTR(IVAT.EXPIREDATE,1, 8),'YYYYMMDD'), 'YYYY-MM-DD') AS EFFECTIVE_DATE
		 , IVATXLCXULC.LCKEY   AS LOCATION_CODE
		 , '몰라' 			   AS REASON
		 , 'L1'  		 	   AS CARGO_LOCATION
		 , 'false' 			   AS HOLD_STATUS
	  FROM TWORK_INFO_IVATXLCXULC   IVATXLCXULC
	 INNER JOIN TWORK_MST_IC 	 	MSTIC
	    ON IVATXLCXULC.CTKEY   = MSTIC.CTKEY
	   AND IVATXLCXULC.OWKEY   = MSTIC.OWKEY
	   AND IVATXLCXULC.ICKEY   = MSTIC.ICKEY
	 INNER JOIN TWORK_INFO_IVAT 	IVAT
	    ON IVATXLCXULC.CTKEY   = IVAT.CTKEY
	   AND IVATXLCXULC.OWKEY   = IVAT.OWKEY
	   AND IVATXLCXULC.IVATKEY = IVAT.IVATKEY
	 INNER JOIN TWORK_MST_ICUT 	 	ICUT
	    ON MSTIC.CTKEY 	 = ICUT.CTKEY
	   AND MSTIC.OWKEY 	 = ICUT.OWKEY
	   AND MSTIC.ICUTKEY = ICUT.ICUTKEY
	 INNER JOIN TWORK_MST_ICUTXTYPE	ICUTXTYPE
	    ON ICUT.CTKEY 	 = ICUTXTYPE.CTKEY
	   AND ICUT.OWKEY 	 = ICUTXTYPE.OWKEY
	   AND ICUT.ICUTKEY  = ICUTXTYPE.ICUTKEY
	   AND IVAT.UOM      = ICUTXTYPE.ICUTTYPE
	 WHERE IVATXLCXULC.LCKEY = 'ASRS'
	   AND IVATXLCXULC.CTKEY = '#{@com.daiso.wms.interfaces.common.WcsPropertyUtil@CTKEY}'
	   AND IVATXLCXULC.OWKEY = '#{@com.daiso.wms.interfaces.common.WcsPropertyUtil@OWKEY}'
	   AND IVATXLCXULC.TTQTY > 0
	</select>

	<select id="selectInventoryCancelList" resultType="WcsInvnMoveReqDTO">
		/* IfWcsInvnMapper.selectInventoryCancelList - 재고이동 취소 조회 */
		SELECT SIVMMWCS.IVMM_SEQ
			 , SIVMMWCS.CTKEY
			 , SIVMMWCS.OWKEY
			 , SIVMMWCS.ORDER_TYPE
			 , SIVMMWCS.TA_HDKEY
			 , SIVMMWCS.TA_DTKEY
			 , SIVMMWCS.REQ_TYPE_CD
			 , SIVMMWCS.IVMM_NUMBER
			 , SIVMMWCS.PRODUCT_CODE
			 , SIVMMWCS.QUANTITY_VALUE
			 , SIVMMWCS.QUANTITY_UNIT
			 , SIVMMWCS.EFFECTIVE_DATE
			 , SIVMMWCS.ORIGIN_LOCATION_CODE
			 , SIVMMWCS.DESTINATION_LOCATION_CODE
			 , SIVMMWCS.INVENTORY_STATUS
			 , SIVMMWCS.LICENSE_PLATE_NUMBER
			 , SIVMMWCS.CANCEL_IVMM_SEQ
			 , SIVMMWCS.SUCCEEDED
			 , SIVMMWCS.ERROR_VALUE
			 , SIVMMWCS.ERROR_REASON
			 , SIVMMWCS.INSERTDATE
			 , SIVMMWCS.INSERTURKEY
			 , SIVMMWCS.UPDATEDATE
			 , SIVMMWCS.UPDATEURKEY
		FROM TWORK_INTF_SIVMMWCS SIVMMWCS
		WHERE SIVMMWCS.IVMM_SEQ   = #{IVMM_SEQ}
		  AND SIVMMWCS.CANCEL_IVMM_SEQ IS NULL
		  AND NOT EXISTS (
			SELECT 1
			FROM TWORK_INTF_RIVMMWCS RIVMMWCS
			WHERE SIVMMWCS.IVMM_SEQ = RIVMMWCS.IVMM_SEQ
			)
		  AND SIVMMWCS.REQ_TYPE_CD = 'C'
		  AND SIVMMWCS.SUCCEEDED   = 'true'
	</select>

	<update id="updateInvnMoverOrderStatus">
		/* IfWcsInvnMapper.updateInvnMoverOrderStatus - 재전송 상태 변경 */
		UPDATE TWORK_INTF_SIVMMWCS
		   SET SUCCEEDED = 'false'
		     , IVMM_NUMBER = '*' || IVMM_NUMBER
		 WHERE IVMM_SEQ = #{IVMM_SEQ}
	</update>
</mapper>