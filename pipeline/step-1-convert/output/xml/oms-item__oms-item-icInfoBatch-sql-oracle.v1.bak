<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
	
<mapper namespace="com.daiso.oms.api.in.mapper.ItemApiBatchMapper">
	<sql id="repListSubQuery">
		( SELECT 'repList empty guard dummy row' AS ASRTREPKEY
		<foreach collection="repList" item="rep" separator=" union all "  open=" union all ">
			SELECT #{rep} AS ASRTREPKEY
		</foreach> )
	</sql>

	<insert id="insertIntfTableIcInfo">
		/* oms-item-icInfoBatch-sql-oracle.xml - insertIntfTableIcInfo */
		INSERT INTO TORDER_INTF_MAL_IC (
		     INSERTSYSTM
		   , PD_NO
		   , ONLD_PD_NO
		   , PD_GRAD
		   , SLE_ATR
		   , ODR_PSBL_YN
		   , SLE_STS_CD
		   , EXH_YN
		   , PDS_OR_PSBL_YN
		   , PKG_YN
		   , DLVY_LMT_YN
		   , NOT_HDL_RSN_CD
		   , DIST_DDLN_RTE
		   , RPS_IMG_URL
		   , EXISTSYN
		   , REQUESTDT
		   , IFID
		   , INSERTDATE
		   , INSERTURKEY
		   , UPDATEDATE
		   , UPDATEURKEY
		) VALUES (
		   #{insertsystm}
		 , #{ickey}
         , #{olnickey}
         , #{olnicdiv}
         , #{olnipkoticcont}
         , #{poableyn}
         , #{salestatus}
         , #{dspyn}
         , #{dlvryyn}
         , #{olnpkotyn} <!--0219--> 
         , #{oblimityn}
         , #{uniccd}
         , #{obimpscritrt}
         , #{repimgurl}
         , #{existsyn}
		 , #{requestDt}
		 , #{interfaceId}
		 , #{sysdate}
		 , #{interfaceUrkey}
		 , #{sysdate}
		 , #{interfaceUrkey}
		)
	</insert>
	
	<update id="updateMalItemIntfIcInfo">
		/* oms-item-icInfoBatch-sql-oracle.xml - updateMalItemIntfIcInfo */	
		UPDATE TORDER_MST_IC
		   SET OLNICDIV     = #{olnicdiv}
		     , OLNIPKOTICCONT = #{olnipkoticcont}
		     , POABLEYN     = #{poableyn}
		     , SALESTATUS   = #{salestatus}
		     , DSPYN        = #{dspyn}
		     , DLVRYYN      = #{dlvryyn}
		     , OLNPKOTYN    = #{olnpkotyn} <!--0219-->
		     , OBLIMITYN    = #{oblimityn}
		     , UNICCD       = #{uniccd}
		     , UNICYN       = #{unicyn}
		     , OBIMPSCRITRT = #{obimpscritrt}
		     , ICIMGURL    = #{repimgurl}
		     , UPDATEDATE   = #{sysdate}
		     , UPDATEURKEY  = #{interfaceUrkey}
	     WHERE OWKEY = #{owkey}
	       AND ICKEY = #{ickey}
	</update>

	<update id="updateMalItemIntfIcOrgInfo">
		/* oms-item-icInfoBatch-sql-oracle.xml - updateMalItemIntfIcOrgInfo */
		UPDATE TORDER_MST_IC_ORG
		   SET OLNICDIV     = #{olnicdiv}
		     , OLNIPKOTICCONT = #{olnipkoticcont}
		     , POABLEYN     = #{poableyn}
		     , SALESTATUS   = #{salestatus}
		     , DSPYN        = #{dspyn}
		     , DLVRYYN      = #{dlvryyn}
		     , OLNPKOTYN    = #{olnpkotyn} <!--0219-->
		     , OBLIMITYN    = #{oblimityn}
		     , UNICCD       = #{uniccd}
		     , UNICYN       = #{unicyn}
		     , OBIMPSCRITRT = #{obimpscritrt}
		     , REPIMGURL    = #{repimgurl}
		     , UPDATEDATE   = #{sysdate}
		     , UPDATEURKEY  = #{interfaceUrkey}
	     WHERE OWKEY = #{owkey}
	       AND ICKEY = #{ickey}
	</update>
	
	<update id="updateIntfItemErpStatus">
		/* oms-master-icInfoBatch-sql-oracle.xml - updateIntfItemErpStatus */
		UPDATE TORDER_EAI_IC_BATCH
           SET SND_PROC_TYP = 'Y'
		 WHERE TRN_ID = #{trnId}
		   AND SND_ROW BETWEEN #{minrow} AND #{maxrow}
	</update>
	
	<insert id="insertIntfWmsItemCbm">
		/* oms-item-icInfoBatch-sql-oracle.xml - insertIntfWmsItemCbm */
		INSERT INTO TORDER_INTF_WMS_ICUTXTYPE (
		  INSERTSYSTM
		, CTKEY
		, OWKEY
		, ICKEY
		, ICUNITTYPE
		, BARCODE
		, WIDTH
		, DEPTH
		, HEIGHT
		, VOL
		, WEIGHT
		, CUSHNMEPCKGYN
		, ROBSORTERICYN
		, POLYBAGPCKGYN
		, PCKGOVLPYN
		, OVLPPCKGWIDTHVAL
		, OVLPPCKGDEPTHVAL
		, OVLPPCKGHEIGHTVAL
		, COMPYN
		, COMPCONT
		, BARCODEATTACHYN
		, HIGHFRQNCYDMGYN
		, PCKGFOLDYN
		, REQUESTDT
		, IFID
		, INSERTDATE
		, INSERTURKEY
		, UPDATEDATE
		, UPDATEURKEY
		) VALUES (
		  'WMS'
		, #{ctkey}
		, #{owkey}
		, #{ickey}
		, #{icunittypecd}
		, #{barcode}
		, #{width}
		, #{depth}
		, #{height}
		, #{vol}
		, #{weight}
		, #{cushnmepckgyn}
		, #{robsortericyn}
		, #{polybagpckgyn}
		, #{pckgovlpyn}
		, #{ovlppckgwidthval}
		, #{ovlppckgdepthval}
		, #{ovlppckgheightval}
		, #{compyn}
		, #{compcont}
		, #{barcodeattachyn}
		, #{highfrqncydmgyn}
		, #{pckgfoldyn}
		, #{requestDt}
		, #{interfaceId}
		, #{sysdate}
		, #{interfaceUrkey}
		, #{sysdate}
		, #{interfaceUrkey}
		)
	</insert>
	
	<insert id="insertIntfErpTableItemCbm">
		/* oms-item-icInfoBatch-sql-oracle.xml - insertIntfErpTableItemCbm */
		INSERT INTO TORDER_EAI_ICUTXTYPE_BATCH
		(
		     SND_NO
		   , SND_ROW
		   , SND_TOT_ROW
		   , SND_DATE
		   , SND_DT
		   , SND_TRSN_TYP
		   , SND_PROC_TYP
		   , CTKEY
		   , ICKEY
		   , UNITTYPE
		   , BARCODE
		   , WIDTH
		   , DEPTH
		   , HEIGHT
		   , WEIGHT
		   , VOL
		   , CUSHNMEPCKGYN
		   , OLNROBSORTERICYN
		   , OLNCUSHNMEPCKGYN
		   , PCKGOVLPYN
		   , OVLPPCKGWIDTHVAL
		   , OVLPPCKGDEPTHVAL
		   , OVLPPCKGHEIGHTVAL
		   , COMPCONT
		   , BARCODEATTACHYN
		   , POLYBACKPCKGYN
		   , CMT
		   , INSERTDATE
		)
		   SELECT #{interfaceId} AS SND_NO
		        , ROWNUM
		        , COUNT(1) AS SND_TOT_ROW
		        , TO_CHAR(CURRENT_TIMESTAMP,'YYYYMMDD')   AS SND_DATE
		        , CURRENT_TIMESTAMP AS SND_DT
		        , 'I'
		        , 'N' AS SND_PROC_TYP
		        , IC.CTKEY
		        , IC.ICKEY
		        , IC.ICUNITTYPE AS UNITTYPE
		        , IC.BARCODE
		        , (IC.WIDTH / 10) AS WIDTH
		        , (IC.DEPTH / 10) AS DEPTH
		        , (IC.HEIGHT / 10) AS HEIGHT
		        , (IC.WEIGHT / 1000) AS WEIGHT
		        , IC.VOL
		        , IC.CUSHNMEPCKGYN
		        , IC.ROBSORTERICYN
		        , IC.CUSHNMEPCKGYN
		        , IC.PCKGOVLPYN
		        , IC.OVLPPCKGWIDTHVAL
		        , IC.OVLPPCKGDEPTHVAL
		        , IC.OVLPPCKGHEIGHTVAL
		        , IC.COMPCONT
		        , IC.BARCODEATTACHYN
			    , IC.POLYBAGPCKGYN AS POLYBACKPCKGYN
			    , '' AS CMT
			    , TO_CHAR(CURRENT_TIMESTAMP, 'YYYYMMDD') AS INSERTDATE
		   FROM TORDER_INTF_WMS_ICUTXTYPE IC
		   INNER JOIN TORDER_MST_IC I
		           ON IC.OWKEY = I.OWKEY
		          AND IC.ICKEY = I.ICKEY
		   WHERE IC.IFID = #{interfaceId}
		   GROUP BY ROWNUM
		          , IC.CTKEY
		          , IC.ICKEY
		          , IC.ICUNITTYPE
		          , IC.BARCODE
		          , IC.WIDTH
		          , IC.DEPTH
		          , IC.HEIGHT
		          , IC.WEIGHT
		          , IC.VOL
		          , IC.CUSHNMEPCKGYN
		          , IC.ROBSORTERICYN
		          , IC.CUSHNMEPCKGYN
		          , IC.PCKGOVLPYN
		          , IC.OVLPPCKGWIDTHVAL
		          , IC.OVLPPCKGDEPTHVAL
		          , IC.OVLPPCKGHEIGHTVAL
		          , IC.COMPCONT
		          , IC.BARCODEATTACHYN
			      , IC.POLYBAGPCKGYN
	</insert>
	
	<insert id="insertIntfWmsItemLc">
		/* oms-item-icInfoBatch-sql-oracle.xml - insertIntfWmsItemLc */
		INSERT INTO TORDER_INTF_WMS_ICXCT (
		    OWKEY
          , CTKEY
          , ICKEY
          , LCKEY
		  , REQUESTDT
		  , IFID
		  , INSERTDATE
		  , INSERTURKEY
		  , UPDATEDATE
		  , UPDATEURKEY
		) VALUES (
		    #{owkey}
          , #{ctkey}
          , #{ickey}
          , #{lckey}
		  , #{requestDt}
		  , #{interfaceId}
		  , #{sysdate}
		  , #{interfaceUrkey}
		  , #{sysdate}
		  , #{interfaceUrkey}
		)
	</insert>
	
	<update id="updateIntfCommonCodeErpStatus">
		/* oms-item-icInfoBatch-sql-oracle.xml - updateIntfCommonCodeErpStatus */
		UPDATE TORDER_EAI_ICUTXCTPLT_BATCH
           SET SND_PROC_TYP = 'Y'
		WHERE TRN_ID IN
				<foreach item="trnId" index="index" collection="trnId"    open="(" separator="," close=")">
					#{trnId}
				</foreach>
	</update>
	
	<insert id="insertErpItemIntfIcInfo">
		/* oms-item-icInfoBatch-sql-oracle.xml - insertErpItemIntfIcInfo */
		INSERT INTO TORDER_MST_IC
		(
		  OWKEY
		, ICGRPKEY
		, UOM
		, ICKEY
		, ICNM
		, ASRTREPKEY
		, ICUNITKEY
		, OLNICKEY
		, ERPIMGURL
		, CTGKEY
		, OLNICTYPE
		, OFLNICTYPE
		, EXPCKYN
		, DNGMGMTYN
		, CUSHNMEPCKGYN
		, ICORIGIN
		, ACKEY
		, ICMGMTUSR
		, SLPRC
		, ASRTYN
		, DIRCDLVYICYN
		, ICSTATUSDIV
		, PKOTICYN
		, ROBSORTERICYN
		, MTR
		, EXPCKDAYS
		, B2BGRADE
		, ORGASRTYN
		, IFYN
		, INSERTDATE
		, INSERTURKEY
		, UPDATEDATE
		, UPDATEURKEY
		)
		VALUES
		(
		  #{owkey}
		, 'GR'
		, 'EA'
		, #{ickey}
		, #{icnm}
		, #{ickey}
		, #{repkey}
		, #{olnickey}
		, #{icimgurl}
		, #{ctgkey}
		, #{olnictype}
		, #{oflnictype}
		, COALESCE(#{expckyn}, 'N')
		, #{dngmgmtyn}
		, #{cushnmepckgyn}
		, #{icorigin}
		, #{ackey}
		, #{icmgmtusr}
		, #{slprc}
		, CASE WHEN  #{asrtrepkey} IS NULL THEN   'N' ELSE #{asrtyn} END
		, #{dircdlvyicyn}
		, #{icstatusdiv}
		, #{pkoticyn}
		, #{robsortericyn}
		, #{mtr}
		, #{expdays}
		, #{b2bgrade}
		, #{asrtyn}
		, 'Y'
		, #{sysdate}
		, #{interfaceUrkey}
		, #{sysdate}
		, 'ErpItemIntfIcInfo'
		)
	</insert>
	
	<update id="updateErpItemIntfIcInfo">
		/* oms-item-icInfoBatch-sql-oracle.xml - updateErpItemIntfIcInfo */
		UPDATE TORDER_MST_IC A
		   SET ICNM          = #{icnm}
		     , OLNICKEY      = #{olnickey}
		     , ASRTREPKEY    = #{repkey}
		     , ERPIMGURL     = #{icimgurl}
		     , CTGKEY        = #{ctgkey}
		     , OLNICTYPE     = #{olnictype}
		     , OFLNICTYPE    = #{oflnictype}
		     , EXPCKYN       = #{expckyn}
		     , DNGMGMTYN     = #{dngmgmtyn}
		     , ICORIGIN      = #{icorigin}
		     , ACKEY         = #{ackey}
		     , ICMGMTUSR     = #{icmgmtusr}
		     , SLPRC         = #{slprc}
		     , DIRCDLVYICYN  = #{dircdlvyicyn}
		     , ICSTATUSDIV   = #{icstatusdiv}
		     , MTR           = #{mtr}
		     , EXPCKDAYS     = #{expdays}
		     , B2BGRADE      = #{b2bgrade}
		     , ASRTYN        = CASE WHEN #{asrtrepkey} IS NULL THEN 'N' ELSE ASRTYN END
		     , ORGASRTYN     = #{asrtyn}
		     , PKOTICYN      = #{pkoticyn}
		     , ROBSORTERICYN = CASE
		                          WHEN EXISTS (
		                              SELECT 1
		                                FROM TORDER_MST_ICUTXTYPE B
		                               WHERE B.ICKEY = A.ICKEY
		                                 AND B.ICUNITTYPE = 'EA'
		                                 AND B.MEASUREMENTYN = 'Y'
		                          )
		                          THEN ROBSORTERICYN
		                          ELSE #{robsortericyn}
		                       END
		
		     , CUSHNMEPCKGYN = CASE
		                          WHEN EXISTS (
		                              SELECT 1
		                                FROM TORDER_MST_ICUTXTYPE B
		                               WHERE B.ICKEY = A.ICKEY
		                                 AND B.ICUNITTYPE = 'EA'
		                                 AND B.MEASUREMENTYN = 'Y'
		                          )
		                          THEN CUSHNMEPCKGYN
		                          ELSE #{cushnmepckgyn}
		                       END
		
		     , UPDATEDATE    = #{sysdate}
		     , UPDATEURKEY   = 'ErpItemIntfIcInfo'
		 WHERE A.OWKEY = #{owkey}
		   AND A.ICKEY = #{ickey}
	</update>
	
