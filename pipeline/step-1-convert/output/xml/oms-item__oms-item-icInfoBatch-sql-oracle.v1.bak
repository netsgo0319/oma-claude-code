	<update id="updateErpItemIntfIcOrgInfo">
		/* oms-item-icInfoBatch-sql-oracle.xml - updateErpItemIntfIcOrgInfo */
		UPDATE TORDER_MST_IC_ORG
		   SET ICNM         = #{icnm}
			 , OLNICKEY     = #{olnickey}
			 , ASRTREPKEY   = #{repkey}
			 , ICIMGURL     = #{icimgurl}
			 , CTGKEY       = #{ctgkey}
			 , OLNICTYPE    = #{olnictype}
			 , OFLNICTYPE   = #{oflnictype}
			 , EXPCKYN      = #{expckyn}
			 , DNGMGMTYN    = #{dngmgmtyn}
			 , CUSHNMEPCKGYN = #{cushnmepckgyn}
			 , ICORIGIN     = #{icorigin}
			 , ACKEY        = #{ackey}
			 , ICMGMTUSR    = #{icmgmtusr}
			 , SLPRC        = #{slprc}
			 , ASRTYN       = #{asrtyn}
			 , DIRCDLVYICYN = #{dircdlvyicyn}
			 , ICSTATUSDIV  = #{icstatusdiv}
			 , PKOTICYN     = #{pkoticyn}
			 , ROBSORTERICYN = #{robsortericyn}
			 , MTR          = #{mtr}
			 , EXPCKDAYS    = #{expdays}
		  	 , B2BGRADE     = #{b2bgrade}
			 , PCSBARCODE = #{pcsbarcode}
			 , IPCBARCODE = #{ipcbarcode}
			 , CARTBARCODE = #{cartbarcode}
			 , QTYPERIPC   = #{qtyperipc}
			 , QTYPERCARTON   = #{qtypercarton}
			 , UPDATEDATE   = #{sysdate}
			 , UPDATEURKEY  = #{interfaceUrkey}
	   WHERE OWKEY = #{owkey}
	     AND ICKEY = #{ickey}
	</update>
	
	<insert id="insertErpItemIntfIcutxtypeInfo">
		/* oms-item-icInfoBatch-sql-oracle.xml - insertErpItemIntfIcutxtypeInfo */
		INSERT INTO TORDER_MST_ICUTXTYPE
		(
		  OWKEY
		, ICKEY
		, ICUNITTYPE
		, ICUNITORDER
		, ICUNITQTY
		, DEPTH
		, WIDTH
		, HEIGHT
		, SIZEUNIT
		, WEIGHT
		, WEIGHTUNIT
		, VOL
		, VOLUNIT
		, PLTROW
		, PLTCOL
		, CPP
		, INSERTDATE
		, INSERTURKEY
		, UPDATEDATE
		, UPDATEURKEY
		)
		VALUES
		(
		  #{owkey}
		, #{ickey}
		, #{icunittype}
		, #{icunitorder}
		, #{icunitqty}
		, #{depth}
		, #{width}
		, #{height}
		, 'MM'
		, #{weight}
		, 'G'
		, #{vol}
		, 'M3'
		, #{pltrow}
		, #{pltcol}
		, #{cpp}
		, #{sysdate}
		, #{interfaceUrkey}
		, #{sysdate}
		, #{interfaceUrkey}
		)
	</insert>
	
	<update id="updateErpItemIntfIcutxtypeInfo">
		/* oms-item-icInfoBatch-sql-oracle.xml - updateErpItemIntfIcutxtypeInfo */
		UPDATE TORDER_MST_ICUTXTYPE
		   SET WIDTH  = CASE WHEN MEASUREMENTYN = 'N' THEN #{width}  ELSE WIDTH  END
		     , DEPTH  = CASE WHEN MEASUREMENTYN = 'N' THEN #{depth}  ELSE DEPTH  END
		     , HEIGHT = CASE WHEN MEASUREMENTYN = 'N' THEN #{height} ELSE HEIGHT END
		     , WEIGHT = CASE WHEN MEASUREMENTYN = 'N' THEN #{weight} ELSE WEIGHT END
		     , VOL    = CASE WHEN MEASUREMENTYN = 'N' THEN #{vol}    ELSE VOL    END
		     , PLTROW = #{pltrow}
		     , PLTCOL = #{pltcol}
		     , CPP    = #{cpp}
		     , ICUNITQTY = #{icunitqty}
		     , UPDATEDATE = #{sysdate}
		     , UPDATEURKEY = #{interfaceUrkey}
		 WHERE OWKEY = #{owkey}
		   AND ICKEY = #{ickey}
		   AND ICUNITORDER = #{icunitorder}
		   AND ICUNITTYPE = #{icunittype}
	</update>
	
	<update id="updateErpItemIntfIcutxtypeMstReqorder">
		/* oms-item-icInfoBatch-sql-oracle.xml - updateErpItemIntfIcutxtypeMstReqorder */
		UPDATE TORDER_MST_REQORDER
		SET
		    EAUOM = CASE WHEN #{icunittype} = 'EA' THEN COALESCE(#{icunitqty}, 0) ELSE COALESCE(EAUOM, 0) END
		  , INNUOM = CASE WHEN #{icunittype} = 'INN' THEN COALESCE(#{icunitqty}, 0) ELSE COALESCE(INNUOM, 0) END
		  , CTNUOM = CASE WHEN #{icunittype} = 'CTN' THEN COALESCE(#{icunitqty}, 0) ELSE COALESCE(CTNUOM, 0) END
		  , CPPUOM = CASE WHEN #{icunittype} = 'CTN' THEN COALESCE(#{cpp}, 0) ELSE COALESCE(CPPUOM, 0) END
		  , VOL = CASE WHEN #{icunittype} = 'INN' THEN COALESCE(#{vol}, 0) ELSE COALESCE(VOL, 0) END
		  , UPDATEDATE = #{sysdate}
		  , UPDATEURKEY = #{interfaceUrkey}
		WHERE OWKEY = #{owkey}
		  AND ICKEY = #{ickey}
	</update>
	
	<insert id="insertErpItemIntfIcbarcodeInfo">
		/* oms-item-icInfoBatch-sql-oracle.xml - insertErpItemIntfIcbarcodeInfo */
		MERGE INTO TORDER_MST_ICBACODE T
			USING (
				SELECT
					  #{owkey}   AS OWKEY
					, #{ickey}   AS ICKEY
					, #{barcode} AS BARCODE
					, #{uom}     AS UOM
			) S
			ON (
				   T.OWKEY   = S.OWKEY
			   AND T.ICKEY   = S.ICKEY
			   AND T.BARCODE = S.BARCODE
			   AND T.UOM     = S.UOM
			   AND T.DELYN   = 'N'
			)

			WHEN NOT MATCHED THEN
			INSERT (
				  OWKEY
				, ICKEY
				, SEQ          -- 자동 증가 (IDENTITY or SEQUENCE)
				, BARCODE
				, UOM
				, DELYN
				, INSERTDATE
				, INSERTURKEY
				, UPDATEDATE
				, UPDATEURKEY
			)
			VALUES (
				  S.OWKEY
				, S.ICKEY
				, DEFAULT      -- 🔥 자동 증가
				, S.BARCODE
				, S.UOM
				, 'N'
				, #{sysdate}
				, #{interfaceUrkey}
				, #{sysdate}
				, #{interfaceUrkey}
			)
	</insert>


	<!-- 1. TORDER_MST_ASRT UPDATE -->
	<update id="updateAsrtStatus" parameterType="map">
		/* oms-item-icInfoBatch-sql-oracle.xml - updateAsrtStatus */
		UPDATE TORDER_MST_ASRT
		   SET ASRTSTATUS =
				   CASE
					   WHEN #{casetype} IN ('A' ,'B') AND #{masteryn} ='Y' THEN '00'  /*단품화 건 */
		               WHEN #{casetype} IN ('A' ,'B') AND #{masteryn} ='N' THEN '01'  /*단종건 */
					   WHEN #{casetype} = 'C' AND #{orgqty} = 0 THEN '01'
					   WHEN #{casetype} = 'C' AND #{orgqty} != 0 THEN NULL
						ELSE ASRTSTATUS
				   END,
			   QTY =
				   CASE
					   WHEN #{casetype} = 'B' AND #{orgqty} > 0 THEN 0
					   ELSE QTY
				   END,
			   UPDATEDATE  = #{sysdate},
			   UPDATEURKEY = #{urkey}
		 WHERE ASRTKEY = #{asrtkey}
	</update>


	<!-- 2. TORDER_MST_IC UPDATE - 자상품용 'A' 인 경우 아소트 여부는 'N'으로 판단함. -->
	<!-- 변경 내역 입수량 0, 이고, 원상품주문이 존재하면,  단품화 , 아닌경우는 단종 -->
	<!-- CASEB는 ERP로 부터 받지 않음. -->
	<update id="updateIcByAsrtKey" parameterType="map">
		/* oms-item-icInfoBatch-sql-oracle.xml - updateIcByAsrtKey */
		UPDATE TORDER_MST_IC
		   SET ASRTYN =
				   CASE
					   WHEN #{casetype} IN ('A' ,'B') AND #{masteryn} ='Y' THEN 'N'
		               WHEN #{casetype} IN ('A' ,'B') AND #{masteryn} ='N' THEN 'Y'
					   WHEN #{casetype} = 'C' THEN 'Y'
					   ELSE ASRTYN
				   END,
			   REQORDEREXCEPTYN =
				   CASE
				  	   WHEN #{casetype} IN ('A' ,'B') AND #{masteryn} ='Y' THEN 'N'
					   WHEN #{casetype} IN ('A' ,'B') AND #{masteryn} ='N' THEN 'Y'
					   WHEN #{casetype} = 'C' THEN 'Y'
					   ELSE REQORDEREXCEPTYN
				   END,
			   UPDATEDATE  = #{sysdate},
			   UPDATEURKEY ='IcByAsrtKey'
		 WHERE ICKEY = #{asrtkey}
	</update>


	<!-- 3. TORDER_MST_IC UPDATE - 대표코드용 -->
	<update id="updateIcRepKey" parameterType="map">
		/* oms-item-icInfoBatch-sql-oracle.xml - updateIcRepKey */
		UPDATE TORDER_MST_IC
		   SET ASRTYN = #{repasrtyn},
		       ORGASRTYN = ASRTYN ,
		       REQORDEREXCEPTYN = CASE
					WHEN #{repasrtyn} = 'Y' THEN 'N'   /* 아소트 유지 → 발주 가능*/
					ELSE 'Y'     END   ,                    /* 해체 → 발주 불가 */
			   UPDATEDATE  = #{sysdate},
			   UPDATEURKEY = #{urkey}
		 WHERE ICKEY = #{asrtrepkey}
	</update>



	<update id="updateAsrtBatchStatusBySet">
		/* oms-item-icInfoBatch-sql-oracle.xml - updateAsrtBatchStatusBySet */
		UPDATE TORDER_WMS_ASRT_BATCH A
		SET SENDSTATUS  = CASE WHEN SEQ =#{seq} THEN 'N' ELSE  'Y' END
		, UPDATEDATE  = #{sysdate}
		, UPDATEURKEY = #{urkey}
		WHERE A.REQDATE     = #{reqdate}
		AND A.ASRTREPKEY  = #{asrtrepkey}
		AND A.SENDSTATUS  = 'W'
		AND A.SEQ       <![CDATA[ <= ]]> #{seq}
	</update>

	<insert id="insertWmsIcBatch" parameterType="map">
		/* oms-item-icInfoBatch-sql-oracle.xml - insertWmsIcBatch */
		INSERT INTO TORDER_WMS_IC_BATCH (
			REQDATE,
			ICKEY,
			SENDYN,
			INSERTDATE,
			INSERTURKEY,
			UPDATEDATE,
			UPDATEURKEY
		)
		SELECT
			#{reqdate},
			#{ickey},
			'N',
			TO_CHAR(CURRENT_TIMESTAMP, 'YYYYMMDDHH24MISS'),
			#{interfaceUrkey},
			TO_CHAR(CURRENT_TIMESTAMP, 'YYYYMMDDHH24MISS'),
			#{interfaceUrkey}
		WHERE NOT EXISTS (
			SELECT 1
			  FROM TORDER_WMS_IC_BATCH
			 WHERE REQDATE = #{reqdate}
			   AND ICKEY   = #{ickey}
		       AND SENDYN ='N'
		)
	</insert>

	<insert id="insertSendWmsIcxctTaget" parameterType="map">
		/* oms-item-icInfoBatch-sql-oracle.xml - insertSendWmsIcxctTaget */
		INSERT INTO TORDER_MST_ICXCT
		(
			  OWKEY
			, ICKEY
			, CTKEY
			, INSERTDATE
			, INSERTURKEY
			, UPDATEDATE
			, UPDATEURKEY
		)
		SELECT #{owkey}
			, #{ickey}
			, #{ctkey}
			, #{sysdate}
			, #{interfaceUrkey}
			, #{sysdate}
			, #{interfaceUrkey}
			WHERE NOT EXISTS (
					SELECT 1
						FROM TORDER_MST_ICXCT
						WHERE OWKEY = #{owkey}
						AND ICKEY = #{ickey}
						AND CTKEY = #{ctkey}
					)
	</insert>

	<update id="updateErpAsrtDelete">
		/* oms-item-icInfoBatch-sql-oracle.xml - updateErpAsrtDelete */
		UPDATE TORDER_MST_ICBACODE
			SET DELYN  ='Y'
			  , UPDATEDATE = #{sysdate}
			  , UPDATEURKEY	= 'ErpAsrtDelete'
		WHERE OWKEY = #{owkey}
		AND ICKEY = #{ickey}
		AND UOM   = #{uom}
		AND BARCODE != #{barcode}
	</update>

</mapper>	