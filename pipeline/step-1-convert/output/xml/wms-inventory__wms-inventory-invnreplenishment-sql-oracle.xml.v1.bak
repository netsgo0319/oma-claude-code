<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
	
<mapper namespace="com.daiso.wms.inventory.mapper.InvnReplenishmentMapper">


	<sql id="selectInvnMscReplenishmenRefSql">
	/* wms-inventory-invnreplenishment-sql-oracle.xml - selectInvnMscReplenishmenRefSql - 재고 보충 조회  SQL */
		SELECT 	A.*
          FROM 	(
			SELECT '0' AS CHK
			     , IV.CTKEY
				 , IV.OWKEY
				 , IV.ICKEY 
				 , IV.LCKEY 
				 , IV.IVATKEY 
				 , IV.ULCKEY 
				 , IC.ICNAME 
				 , IC.SPEC
				 , IVAT.UOM
				 , IV.TTQTY 
				 , IV.AVQTY 
				 , IV.TTQTY/ICUT.ICUTQTY AS TTQTY_UNIT
				 , IV.AVQTY/ICUT.ICUTQTY AS AVQTY_UNIT
				 , IVAT.EXPIREDATE
				 , CASE WHEN REP.WKSTATUS = '10' OR REP.WKSTATUS = '30' THEN COALESCE(REP.REQQTY, 0)
				 		ELSE 0 END AS REQQTY
				 , CASE WHEN REP.WKSTATUS = '10' OR REP.WKSTATUS = '30' THEN COALESCE(REP.REQQTY, 0)/ICUT.ICUTQTY
				 		ELSE 0 END AS REQQTY_UNIT
				 , COALESCE(REP.REQQTY, 0) AS ORG_REQQTY
				 , COALESCE(REP.REQQTY, 0)/ICUT.ICUTQTY AS ORG_REQQTY_UNIT
				 , COALESCE(REP.DELIQTY, 0) AS DELIQTY
				 , COALESCE(REP.DELIQTY, 0)/ICUT.ICUTQTY AS DELIQTY_UNIT
				 , REP.WKSTATUS
				 , ICUT.ICUTQTY
				 , REP.REQ_NUMBER
				 , REP.IF_STATUS
				 , REP.IF_STATUS_MSG
				 , IV.IVATSTATUS
				 , IC.MSCSTORETYPE
		         , IC.WRHOUS_SE
				 , IV.INSERTDATE
			     , IV.INSERTURKEY
			     , IV.UPDATEDATE
			     , IV.UPDATEURKEY
			  FROM TWORK_INFO_IVATXLCXULC IV
			 INNER JOIN TWORK_INFO_IVAT IVAT
			  	ON IV.CTKEY = IVAT.CTKEY
			   AND IV.OWKEY = IVAT.OWKEY
			   AND IV.ICKEY = IVAT.ICKEY
			   AND IV.IVATKEY = IVAT.IVATKEY
			 INNER JOIN TWORK_MST_IC IC
			    ON IV.CTKEY = IC.CTKEY
			   AND IV.ICKEY = IC.ICKEY
			 INNER JOIN TWORK_MST_ICUTXTYPE ICUT
			  	ON IC.CTKEY = ICUT.CTKEY
			   AND IC.OWKEY = ICUT.OWKEY
			   AND IC.ICUTKEY = ICUT.ICUTKEY
			   AND ICUT.ICUTTYPE = IVAT.UOM
			  LEFT OUTER JOIN TWORK_INFO_REPLENISHMENT_REQ REP
			  	ON IV.CTKEY = REP.CTKEY
			   AND IV.OWKEY = REP.OWKEY
			   AND IV.ICKEY = REP.ICKEY
			   AND IV.IVATKEY = REP.IVATKEY
			   AND IV.ULCKEY = REP.ULCKEY
			 INNER JOIN TWORK_MST_LC TMLC
			    ON IV.CTKEY = TMLC.CTKEY
			   AND IV.LCKEY = TMLC.LCKEY
			 WHERE TMLC.LCSTORTYPE = '40'
		) A
		 WHERE 	1=1
		   AND AVQTY <![CDATA[ > ]]> 0
		   AND MSCSTORETYPE = 'BOX'
		   AND WRHOUS_SE = 'ATMC'
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
	       AND  #{SEARCH_CONDITION}
		</if>    
	</sql>




	<select id="selectInvnMscReplenishment" resultType="camelMap">
		#{GRIDPAGING_ROWNUMTYPE_TOP}
			<include refid="selectInvnMscReplenishmenRefSql"/>
			<choose>
				<when test='sortValue !=null and sortValue != ""'>	
					<if test='sortValue == "DESC" and colName !=null'>
					ORDER BY #{colName} DESC
					</if>
					<if test='sortValue == "ASC" and colName !=null'>
					ORDER BY #{colName} ASC
					</if>	
				</when>	
				<otherwise>
					ORDER BY OWKEY , ICKEY, LCKEY, EXPIREDATE    
				</otherwise>
			</choose>
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>
	
	<select id="selectInvnMscReplenishmentCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
		  FROM (
			<include refid="selectInvnMscReplenishmenRefSql"/>
		  ) 
	</select>
	
	<select id="selectInvnReplenishmentReq" resultType="camelMap" >
	/* wms-inventory-invnreplenishment-sql-oracle.xml - selectInvnReplenishmentReq - 재고 보충 요청 조회  SQL */
		SELECT A.CTKEY
		     , A.OWKEY
		     , A.ICKEY
		     , A.LCKEY
		     , A.IVATKEY
		     , A.ULCKEY
		     , A.REQ_NUMBER
		     , A.REQ_NUMBER 	AS ORG_REQ_NUMBER
		     , #{reqqty} 	AS REQQTY
		     , #{deliqty}	AS DELIQTY
		     , #{rejqty} 	AS REJQTY
		     , #{canqty} 	AS CANQTY
		     , #{abaqty} 	AS ABAQTY
		     , A.WKSTATUS
		     , A.IF_STATUS
		     , A.IF_STATUS_MSG
		     , A.COMMENTS
		     , B.LOGGRPCD
		     , A.INSERTDATE
		     , A.INSERTURKEY
		     , A.UPDATEDATE
		     , A.UPDATEURKEY
		  FROM TWORK_INFO_REPLENISHMENT_REQ A
		 INNER JOIN TWORK_MST_IC B
		    ON A.CTKEY = B.CTKEY
		   AND A.OWKEY = B.OWKEY
		   AND A.ICKEY = B.ICKEY
		 WHERE 1=1
	<choose>
		<when test='reqNumber ==null or reqNumber == ""'>	
		   AND A.CTKEY = #{ctkey}
		   AND A.OWKEY = #{owkey}
		   AND A.ICKEY = #{ickey}
		   AND A.LCKEY = #{lckey}
		   AND A.IVATKEY = #{ivatkey}
		   AND A.ULCKEY = #{ulckey}
		</when>	
		<otherwise>
		   AND A.REQ_NUMBER = #{reqNumber}
		</otherwise>
	</choose>		  
	</select>
	
	<select id="selectInfoIvatxlcxulcStatus" resultType="camelMap" >
	/* wms-inventory-invnreplenishment-sql-oracle.xml - selectInfoIvatxlcxulcStatus - 재고 조회  SQL */
		SELECT IVATSTATUS
			 , TTQTY
			 , AVQTY
		  FROM TWORK_INFO_IVATXLCXULC
		 WHERE CTKEY = #{ctkey}
		   AND OWKEY = #{owkey}
		   AND ICKEY = #{ickey}
		   AND IVATKEY = #{ivatkey}
		   AND LCKEY = #{lckey}		   
	</select>
	
	<insert id="insertInvnReplenishmentReq">
		/* wms-inventory-invnreplenishment-sql-oracle.xml - insertInvnReplenishmentReq - 재고 보충 요청 정보 등록  SQL */
		INSERT INTO TWORK_INFO_REPLENISHMENT_REQ 
			   (
			     CTKEY
			   , OWKEY
			   , ICKEY
			   , LCKEY
			   , IVATKEY
			   , ULCKEY
			   , REQ_NUMBER
			   , REQQTY
			   , DELIQTY
			   , REJQTY
			   , CANQTY
			   , ABAQTY
			   , WKSTATUS
			   , IF_STATUS
			   , IF_STATUS_MSG
			   , COMMENTS
			   , INSERTDATE
			   , INSERTURKEY
			   , UPDATEDATE
			   , UPDATEURKEY
			   ) VALUES (
			     #{ctkey}
			   , #{owkey}  
			   , #{ickey}
			   , #{lckey}
			   , #{ivatkey}
			   , #{ulckey}
			   , #{reqNumber}
			   , #{reqqty}
			   , #{deliqty}
			   , #{rejqty}
			   , #{canqty}
			   , #{abaqty}
			   , #{reqWkstatus}
			   , #{ifStatus}
			   , #{ifStatusMsg}
			   , #{comments}
			   , #{sysdate}
			   , #{surkey}
			   , #{sysdate}
			   , #{surkey}
			   )
	</insert>
	
	<update id="updateInvnReplenishmentReq">
	/* wms-inventory-invnreplenishment-sql-oracle.xml - updateInvnReplenishmentReq - 재고 보충 요청 정보 수정  SQL */
		 UPDATE TWORK_INFO_REPLENISHMENT_REQ
		    SET REQQTY			= #{reqqty}
			  , DELIQTY			= #{deliqty}
			  , REJQTY			= #{rejqty}
			  , CANQTY			= #{canqty}
			  , ABAQTY			= #{abaqty} 
			  , WKSTATUS		= #{reqWkstatus}
			  , IF_STATUS	  	= #{ifStatus}
			  , IF_STATUS_MSG 	= #{ifStatusMsg}
			  , REQ_NUMBER 		= #{reqNumber}
			  , UPDATEDATE		= #{sysdate}
			  , UPDATEURKEY		= #{surkey}
		  WHERE 1=1
		<choose>
			<when test='orgReqNumber ==null || orgReqNumber == ""'>	
			   AND CTKEY = #{ctkey}
			   AND OWKEY = #{owkey}
			   AND ICKEY = #{ickey}
			   AND LCKEY = #{lckey}
			   AND IVATKEY = #{ivatkey}
			   AND ULCKEY = #{ulckey}
			</when>	
			<otherwise>
			   AND REQ_NUMBER = #{orgReqNumber}
			</otherwise>
		</choose>
	</update>
	
	<select id="selectInfoIvatxlcxulcCount" resultType="java.lang.Integer" >
	/* wms-inventory-invnreplenishment-sql-oracle.xml - selectInfoIvatxlcxulcCount - 재고 조회  SQL */
		SELECT COUNT(*)
		  FROM TWORK_INFO_IVATXLCXULC
		 WHERE CTKEY = #{ctkey}
		   AND OWKEY = #{owkey}
		   AND ICKEY = #{ickey}
		   AND IVATKEY = #{ivatkey}
		   AND LCKEY = #{lckey}		   
	</select>
	
	<update id="updateIvatxlcxulcIncreQty">
	/* wms-inventory-invnreplenishment-sql-oracle.xml - updateIvatxlcxulcIncreQty - 재고 수량 추가  SQL */
		UPDATE TWORK_INFO_IVATXLCXULC
		   SET TTQTY = COALESCE(TTQTY, 0) + COALESCE(#{deliqty}, 0)
		     , AVQTY = COALESCE(AVQTY, 0) + COALESCE(#{deliqty}, 0)
		     , ALQTY = COALESCE(ALQTY, 0) + COALESCE(#{alqty}, 0)
		     , PIQTY = COALESCE(PIQTY, 0) + COALESCE(#{piqty}, 0)
		     , PAQTY = COALESCE(PAQTY, 0) + COALESCE(#{paqty}, 0)
		     , LOQTY = COALESCE(LOQTY, 0) + COALESCE(#{loqty}, 0)
		     , HOQTY = COALESCE(HOQTY, 0) + COALESCE(#{hoqty}, 0)
		     , UPDATEDATE = #{sysdate}
			 , UPDATEURKEY = #{surkey}
		 WHERE CTKEY = #{ctkey}
		   AND OWKEY = #{owkey}
		   AND ICKEY = #{ickey}
		   AND IVATKEY = #{ivatkey}
		   AND LCKEY = #{lckey}
	</update>
	
	<update id="updateIvatxlcxulcDecreQty">
	/* wms-inventory-invnreplenishment-sql-oracle.xml - updateIvatxlcxulcDecreQty - 재고 수량 추가  SQL */
		UPDATE TWORK_INFO_IVATXLCXULC
		   SET TTQTY = COALESCE(TTQTY, 0) - COALESCE(#{deliqty}, 0)
		     , AVQTY = COALESCE(AVQTY, 0) - COALESCE(#{deliqty}, 0)
		     , ALQTY = COALESCE(ALQTY, 0) + COALESCE(#{alqty}, 0)
		     , PIQTY = COALESCE(PIQTY, 0) + COALESCE(#{piqty}, 0)
		     , PAQTY = COALESCE(PAQTY, 0) + COALESCE(#{paqty}, 0)
		     , LOQTY = COALESCE(LOQTY, 0) + COALESCE(#{loqty}, 0)
		     , HOQTY = COALESCE(HOQTY, 0) + COALESCE(#{hoqty}, 0)
		     , UPDATEDATE = #{sysdate}
			 , UPDATEURKEY = #{surkey}
		 WHERE CTKEY = #{ctkey}
		   AND OWKEY = #{owkey}
		   AND ICKEY = #{ickey}
		   AND IVATKEY = #{ivatkey}
		   AND LCKEY = #{lckey}
	</update>
	
	<insert id="insertIvatxlcxulcQty">
	/* wms-inventory-invnreplenishment-sql-oracle.xml - insertIvatxlcxulcQty - 재고 등록  SQL */
    	INSERT INTO TWORK_INFO_IVATXLCXULC   
		(
		  CTKEY      
		, IVATKEY    
		, LCKEY      
		, ULCKEY     
		, OWKEY      
		, ICKEY      
		, TTQTY      
		, AVQTY      
		, ALQTY      
		, PIQTY      
		, PAQTY      
		, LOQTY      
		, HOQTY      
		, IVATSTATUS 
		, LOGGRPCD
		, INSERTDATE 
		, INSERTURKEY
		, UPDATEDATE 
		, UPDATEURKEY
		)
		VALUES
		(
		  #{ctkey}              
		, #{ivatkey}           
		, #{lckey}            
		, #{ulckey}                               
		, #{owkey}           
		, #{ickey}                
		, COALESCE(#{deliqty}, 0)
		, COALESCE(#{deliqty}, 0)
		, '0'                                   
		, '0'              
		, '0'                                   
		, '0'                                   
		, '0'                                   
		, '10'        
		, #{loggrpcd}                   
		, #{sysdate}
		, #{surkey}
		, #{sysdate}
		, #{surkey}
		)
    </insert>
    
    <select id="selectIvat" resultType="camelMap">
	/* wms-inventory-invnreplenishment-sql-oracle.xml - selectIvat - 재고 정보 조회 SQL */
		SELECT *
		  FROM TWORK_INFO_IVAT A
		 INNER JOIN TWORK_INFO_IVATXLCXULC B
		    ON A.CTKEY = B.CTKEY
		   AND A.OWKEY = B.OWKEY
		   AND A.ICKEY = B.ICKEY
		   AND A.IVATKEY = B.IVATKEY 
		 INNER JOIN TWORK_MST_IC C
		    ON A.CTKEY = C.CTKEY
		   AND A.ICKEY = C.ICKEY
		 WHERE A.CTKEY            = #{ctkey}
           AND A.OWKEY            = #{owkey}
           AND B.LCKEY 			  = #{lckey}
           AND A.IVATKEY 		  = #{ivatkey}
           
	</select>
	
	<update id="callSpIcIvatReplenishmentBefore" statementType="CALLABLE" parameterType="java.util.HashMap">
	/* wms-inventory-invnreplenishment-sql-oracle.xml - callSpIcIvatReplenishmentBefore - 보충 조회 프로시저 SQL */
    	{
    		CALL SP_IC_IVAT_REPLENISHMENT_BEFORE(
				 #{ctkey,mode=IN,jdbcType=VARCHAR}
			   , #{owkey,mode=IN,jdbcType=VARCHAR}
			   , #{urkey,mode=IN,jdbcType=VARCHAR}
			)
		}
	</update>
	
	<select id="selectReplenishmentBefore" resultType="camelMap">
	/* wms-inventory-invnreplenishment-sql-oracle.xml - selectReplenishmentBefore - 보충지시 조회 SQL */
		SELECT CTKEY
			 , OWKEY
			 , ICKEY
			 , LCKEY
			 , IVATKEY
			 , ULCKEY
			 , UOM
			 , QTY
			 , UNITQTY
			 , INSERTDATE
			 , INSERTURKEY
			 , UPDATEDATE
			 , UPDATEURKEY
		  FROM TWORK_INFO_REPLENISHMENT_BEFORE
         WHERE CTKEY            = #{ctkey}
           AND OWKEY            = #{owkey}
	</select>

	<resultMap id="invnReplenishmentRefMap" type="java.util.HashMap">
		<result property="owkey" column="OWKEY" />
		<result property="owname" column="OWNAME" />
		<result property="ickey" column="ICKEY" />
		<result property="spec"  column="SPEC" />
		<result property="ctkey" column="CTKEY" />
		<result property="ctname" column="CTNAME" />
		<result property="icname" column="ICNAME" />
		<result property="to_lckey" column="TO_LCKEY" />
		<result property="piznkey" column="PIZNKEY" />
		<result property="minqty" column="MINQTY" />
		<result property="maxqty" column="MAXQTY" />
		<result property="exqty" column="EXQTY" />
		<result property="calmaxqty" column="CALMAXQTY" />
		<result property="uom" column="UOM" />
		<result property="uom_desc" column="UOM_DESC" typeHandler="CodeDescTypeHandler"/>
		<result property="fr_lckey_avqty" column="FR_LCKEY_AVQTY" />
		<result property="cal_fr_lckey_avqty" column="CAL_FR_LCKEY_AVQTY" />
		<result property="to_lckey_avqty" column="TO_LCKEY_AVQTY" />
		<result property="fr_lckey" column="FR_LCKEY" />
		<result property="bundlekey" column="BUNDLEKEY" />
		<result property="ivatkey" column="IVATKEY" />
		<result property="icutkey" column="ICUTKEY" />
		<result property="ta_hdkey" column="TA_HDKEY" />
		<result property="ta_dtkey" column="TA_DTKEY" />
		<result property="qty" column="QTY" />
		<result property="wkstatus" column="WKSTATUS" />
		<result property="wkstatus_desc" column="WKSTATUS_DESC" typeHandler="CodeDescTypeHandler"/>
		<result property="ta_dttype" column="TA_DTTYPE" />
		<result property="ta_dttype_desc" column="TA_DTTYPE_DESC" typeHandler="CodeDescTypeHandler"/>		
		<result property="icutqty" column="ICUTQTY" />
		<result property="loggrpcd" column="LOGGRPCD" />
		<result property="loggrpcd_desc" column="LOGGRPCD_DESC" typeHandler="CodeDescTypeHandler"/>
		<result property="fr_ivatkey" column="FR_IVATKEY" />
		<result property="reasontype" column="REASONTYPE" />
		<result property="reasontype_desc" column="REASONTYPE_DESC" typeHandler="CodeDescTypeHandler"/>
		<result property="wahdkey" column="WAHDKEY" />
		<result property="ackey" column="ACKEY" />
		<result property="acname" column="ACNAME" />
		<result property="urkey" column="URKEY" />
		<result property="urkey_desc" column="URKEY_DESC" typeHandler="UrMstDescTypeHandler"/>
