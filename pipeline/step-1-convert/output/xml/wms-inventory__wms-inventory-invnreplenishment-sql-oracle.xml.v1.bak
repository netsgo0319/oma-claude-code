		<result property="piznname" column="PIZNNAME"/>
	</resultMap>
	
	<resultMap id="invnReplenishmentMap" type="java.util.HashMap" extends="invnReplenishmentRefMap" >
		<result property="productdate" column="PRODUCTDATE" typeHandler="GmtDateTimeTypeHandler"  />
		<result property="expiredate" column="EXPIREDATE" typeHandler="GmtDateTimeTypeHandler"  />
		<result property="shelflifedate" column="SHELFLIFEDATE" typeHandler="GmtDateTimeTypeHandler"  />
		<result property="ta_startdate" column="TA_STARTDATE" typeHandler="GmtDateTimeTypeHandler"  />
		<result property="ta_enddate" column="TA_ENDDATE" typeHandler="GmtDateTimeTypeHandler"  />
	</resultMap>
	 

	<resultMap id="invnReplenishmentExcelMap" type="java.util.HashMap" extends="invnReplenishmentRefMap" >
		<result property="productdate" column="PRODUCTDATE" typeHandler="GmtDateTimeFormatTypeHandler"  />
		<result property="expiredate" column="EXPIREDATE" typeHandler="GmtDateFormatTypeHandler"  />
		<result property="shelflifedate" column="SHELFLIFEDATE" typeHandler="GmtDateTimeFormatTypeHandler"  />
		<result property="ta_startdate" column="TA_STARTDATE" typeHandler="GmtDateTimeFormatTypeHandler"  />
		<result property="ta_enddate" column="TA_ENDDATE" typeHandler="GmtDateTimeFormatTypeHandler"  />
	</resultMap> 
	
	<sql id="selectInvnReplenishmentRefSql">
		SELECT 	A.*
          FROM 	(
			SELECT 	A.OWKEY 
					,(SELECT OWNAME FROM TWORK_MST_OW OW WHERE OW.OWKEY = A.OWKEY) AS OWNAME
					,A.ICKEY 
					,D.ICNAME
					,D.SPEC
					,A.LCKEY AS TO_LCKEY
					,K.PIZNKEY
					,A.MINQTY AS MINQTY
					,A.MAXQTY AS MAXQTY
					,COALESCE((A.MAXQTY - COALESCE(F.AVQTY, 0)), 0) AS CALMAXQTY
					,A.UOM 
					,A.CTKEY || ';' || 'ICUTTYPE'|| ';' || A.UOM AS UOM_DESC 
					,B.PRODUCTDATE 
					,B.EXPIREDATE
					,(C.AVQTY + C.HOQTY) AS FR_LCKEY_AVQTY
					,(C.AVQTY + C.HOQTY) AS CAL_FR_LCKEY_AVQTY
					,H.ICUTQTY
					,COALESCE(F.AVQTY, 0)  AS TO_LCKEY_AVQTY
					,A.ICKEY || A.LCKEY AS BUNDLEKEY
					,C.LCKEY AS FR_LCKEY
					,CASE WHEN D.SHELFLIFECODETYPE = 'PRODUCTDATE_NOTUSE' 
						THEN B.PRODUCTDATE
				      	ELSE B.EXPIREDATE
					END  AS SHELFLIFEDATE
					,A.CTKEY
					,(SELECT CTNAME FROM TWORK_MST_CT CT WHERE CT.CTKEY = A.CTKEY) AS CTNAME
					,B.IVATKEY
					,A.ICUTKEY
                    ,I.ACKEY
                    ,I.ACNAME
                    ,J.URKEY
                    ,J.URKEY AS URKEY_DESC
                    ,D.LOGGRPCD
                    ,#{ctkey} || ';' || 'LOGGRPCD' || ';' || D.LOGGRPCD AS LOGGRPCD_DESC	                              
		  	  FROM 	TWORK_MST_LCXIC A 
					,TWORK_INFO_IVAT B
					,TWORK_INFO_IVATXLCXULC C  
					,TWORK_MST_IC D 
					,TWORK_MST_LC E 
                    ,(  
	                    SELECT 	TB1.CTKEY, TB1.OWKEY, TB1.ICKEY, TB1.LCKEY, SUM(AVQTY) AS AVQTY
                     	  FROM 	(
	                        SELECT A.CTKEY,
	                           A.OWKEY,
	                           A.ICKEY,
	                           A.LCKEY,
	                           SUM (A.AVQTY) AS AVQTY
	                         FROM TWORK_INFO_IVATXLCXULC A,
	                           TWORK_MST_LCXIC B
	                        WHERE     A.CTKEY = #{ctkey}
	                           AND A.CTKEY = B.CTKEY
	                           AND A.OWKEY = B.OWKEY
	                           AND A.LCKEY = B.LCKEY
	                           AND A.ICKEY = B.ICKEY
	                        GROUP BY A.CTKEY, A.OWKEY, A.ICKEY, A.LCKEY
	                        UNION ALL
	                        SELECT CTKEY, OWKEY, ICKEY, TO_LCKEY, COALESCE(SUM(QTY), 0) AS TAQTY
	                         FROM TWORK_INFO_TA_DT 
	                        WHERE CTKEY = #{ctkey}  
	                            AND TA_DTTYPE IN ('40', '90')
	                            AND WKSTATUS = '00'
	                        GROUP BY CTKEY, OWKEY, ICKEY, TO_LCKEY
	                        ) TB1
	                    GROUP BY TB1.CTKEY, TB1.OWKEY, TB1.ICKEY, TB1.LCKEY
                    ) F
					,TWORK_MST_ICUT G 
					,TWORK_MST_ICUTXTYPE H
					,TWORK_MST_AC I
					,TWORK_MST_ACXUR J 
					,TWORK_MST_LC K
					,TWORK_INFO_IB_DT L
			 WHERE
					A.CTKEY = B.CTKEY
			   AND 	A.OWKEY = B.OWKEY 
			   AND  A.ICKEY = B.ICKEY
			   AND  B.CTKEY = C.CTKEY
			   AND  B.OWKEY = C.OWKEY
			   AND  B.IVATKEY = C.IVATKEY
			   AND  A.CTKEY = D.CTKEY
			   AND  A.OWKEY = D.OWKEY
			   AND  A.ICKEY = D.ICKEY
			   AND  C.CTKEY = E.CTKEY 
			   AND  C.LCKEY = E.LCKEY 
			   AND  E.LCTYPE = '90'
			   AND  A.CTKEY = F.CTKEY(+)
			   AND  A.OWKEY = F.OWKEY(+)
			   AND  A.LCKEY = F.LCKEY(+)
			   AND  A.ICKEY = F.ICKEY(+)
			   AND  A.MINQTY > COALESCE(F.AVQTY, 0)
			   AND  A.CTKEY = G.CTKEY
			   AND  A.OWKEY = G.OWKEY
			   AND  A.ICUTKEY = G.ICUTKEY
			   AND  A.CTKEY = H.CTKEY
			   AND  A.OWKEY = H.OWKEY
			   AND  A.ICUTKEY = H.ICUTKEY
			   AND  A.UOM = H.ICUTTYPE
			   AND  (C.AVQTY + C.HOQTY) > 0 
               <!-- AND  D.CTKEY = I.CTKEY(+)
               AND  D.ACKEY = I.ACKEY(+)
               AND  D.OWKEY = I.OWKEY(+) -->
               AND  D.CTKEY = J.CTKEY(+)
               AND  D.ACKEY = J.ACKEY(+)
               AND  D.LOGGRPCD = J.LOGGRPCD(+)
               AND  D.OWKEY = J.OWKEY(+)
               AND  G.CLOSDATE >= #{CLOSDATE, typeHandler=GmtDateTimeTypeHandler }
		       AND  A.CTKEY = #{ctkey}
		       AND  A.LCKEY != C.LCKEY 	
		       AND A.CTKEY = K.CTKEY
		       AND A.LCKEY = K.LCKEY
		       AND B.CTKEY = L.CTKEY
		       AND B.IVATKEY = L.TO_IVATKEY
		       AND I.CTKEY = L.CTKEY
		       AND I.OWKEY = L.OWKEY
		       AND I.ACKEY = L.ACKEY	       
		) A
		 WHERE 	1=1
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
	       AND  #{SEARCH_CONDITION}
		</if>    
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)" >
	       AND  A.OWKEY = #{owkey}
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ickey)" >
	       AND  A.ICKEY = #{ickey}
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(to_lckey)" >
	       AND  A.TO_LCKEY = #{to_lckey}
		</if>                  
	</sql>
	
	<select id="selectInvnReplenishment" resultMap="invnReplenishmentMap">
		<include refid="selectInvnReplenishmentRefSql"/>
		 ORDER BY A.BUNDLEKEY ,A.SHELFLIFEDATE ,A.FR_LCKEY
		                     
	</select>

	<select id="selectInvnReplenishmentCount" resultType="java.lang.Integer" >
		SELECT 	COUNT(1)
		  FROM  (
		  	<include refid="selectInvnReplenishmentRefSql"/>   
		)
	</select>
	
	<select id="selectInvnReplenishmentExcel" resultMap="invnReplenishmentExcelMap">
		<include refid="selectInvnReplenishmentRefSql"/>                     
		 ORDER BY 
		 	A.BUNDLEKEY
		 	,A.SHELFLIFEDATE
		 	,A.FR_LCKEY
	</select>	
	
	<sql id="selectTaskInvnReplenishmentRefSql">
		SELECT *
		  FROM (
				SELECT  A.CTKEY 
						,(SELECT CTNAME FROM TWORK_MST_CT CT WHERE CT.CTKEY = A.CTKEY) AS CTNAME
						,A.TA_HDKEY
						,A.TA_DTKEY
						,A.OWKEY
						,(SELECT OWNAME FROM TWORK_MST_OW OW WHERE OW.OWKEY = A.OWKEY) AS OWNAME
						,A.WKSTATUS
						,A.CTKEY || ';' || 'TA_WKSTATUS'|| ';' || A.WKSTATUS AS WKSTATUS_DESC  
						,A.TA_DTTYPE
						,A.CTKEY || ';' || 'TA_DTTYPE'|| ';' || A.TA_DTTYPE AS TA_DTTYPE_DESC  
						,A.ICKEY
						,B.ICNAME
						,B.SPEC
						,A.TO_LCKEY
						,A.QTY / D.ICUTQTY AS QTY
						,A.FR_LCKEY
						,A.UOM
						,A.CTKEY || ';' || 'ICUTTYPE'|| ';' || A.UOM AS UOM_DESC
						,D.ICUTQTY
						,A.LOGGRPCD
						,A.CTKEY || ';' || 'LOGGRPCD'|| ';' || A.LOGGRPCD AS LOGGRPCD_DESC 
						,A.FR_IVATKEY
						,A.TA_STARTDATE
						,A.TA_ENDDATE
						,A.REASONTYPE
						,A.CTKEY || ';' || 'REASONTYPE'|| ';' || A.REASONTYPE AS REASONTYPE_DESC 
						,A.WAHDKEY
		                ,E.ACKEY
		                ,E.ACNAME
		                ,F.URKEY
		                ,F.URKEY AS URKEY_DESC
		                ,H.PIZNKEY
		                ,H.PIZNNAME                              
				  FROM  TWORK_INFO_TA_DT A
						,TWORK_MST_IC  B
						,TWORK_MST_ICUT C 
						,TWORK_MST_ICUTXTYPE D
		                ,TWORK_MST_AC E
		                ,TWORK_MST_ACXUR F
		                ,TWORK_MST_LC G
		                ,TWORK_MST_PIZN H
		                ,TWORK_MST_LC I
				 WHERE
					    A.CTKEY = B.CTKEY
				   AND  A.OWKEY = B.OWKEY
				   AND  A.ICKEY = B.ICKEY
				   AND  A.CTKEY = C.CTKEY
				   AND  A.OWKEY = C.OWKEY
				   AND  A.ICUTKEY = C.ICUTKEY
				   AND  A.CTKEY = D.CTKEY
				   AND  A.OWKEY = D.OWKEY
				   AND  A.ICUTKEY = D.ICUTKEY
				   AND  A.UOM = D.ICUTTYPE
				   AND  A.TA_DTTYPE IN ('40','90')
		           AND  B.CTKEY = E.CTKEY(+)
		           AND  B.ACKEY = E.ACKEY(+)
		           AND  B.OWKEY = E.OWKEY(+)
		           AND  B.CTKEY = F.CTKEY(+)
		           AND  B.ACKEY = F.ACKEY(+)
                   AND  B.LOGGRPCD = F.LOGGRPCD(+)
                   AND  B.OWKEY = F.OWKEY(+)
		           AND A.CTKEY  = G.CTKEY
		           AND A.FR_LCKEY = G.LCKEY
		           AND A.CTKEY = I.CTKEY
		           AND A.TO_LCKEY = I.LCKEY
		           AND I.CTKEY = H.CTKEY(+)
		           AND I.PIZNKEY = H.PIZNKEY(+)
				   AND C.CLOSDATE >= #{closdate}
				   AND A.CTKEY = #{ctkey}
				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
				   AND 	#{SEARCH_CONDITION}
				</if>		  
		  )
	</sql>	
	
	
	<select id="selectTaskInvnReplenishment" resultMap="invnReplenishmentMap">
		#{GRIDPAGING_ROWNUMTYPE_TOP}
			<include refid="selectTaskInvnReplenishmentRefSql"/>
			<choose>
				<when test='sortValue !=null and sortValue != ""'>	
					<if test='sortValue == "DESC" and colName !=null'>
					ORDER BY #{colName} DESC
					</if>
					<if test='sortValue == "ASC" and colName !=null'>
					ORDER BY #{colName} ASC
					</if>	
				</when>	
				<otherwise>
					ORDER BY TA_HDKEY , TA_DTKEY DESC
				</otherwise>
			</choose>
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}

	</select>

	<select id="selectTaskInvnReplenishmentCount" resultType="java.lang.Integer" >
		SELECT  COUNT(1)
		  FROM  (
			<include refid="selectTaskInvnReplenishmentRefSql"/>
		  )
	</select>	
	
	<select id="selectTaskInvnReplenishmentExcel" resultMap="invnReplenishmentExcelMap">
		<include refid="selectTaskInvnReplenishmentRefSql"/>
		 ORDER BY 
		 	TA_HDKEY 
		 	,TA_DTKEY DESC 		
	</select>
    <resultMap id="selectInvnReplenishmentReportHDMap" type="camelMap">
		<result property="owkey" column="OWKEY" />
		<result property="owname" column="OWNAME" />
		<result property="ta_hdkey" column="TA_HDKEY" />
		<result property="ta_dttype" column="TA_DTTYPE" typeHandler="CodeDescTypeHandler" />
		<result property="piznkey" column="PIZNKEY" />
		<result property="piznname" column="PIZNNAME" />
		<result property="urname" column="URNAME" />
		<result property="urkey" column="URKEY" />
		<result property="ctkey" column="CTKEY" />
	</resultMap> 

	<select id="selectInvnReplenishmentReportHD" resultMap="selectInvnReplenishmentReportHDMap">
	        SELECT A.OWKEY
	        	  ,(SELECT OWNAME FROM TWORK_MST_OW OW WHERE OW.OWKEY = A.OWKEY) AS OWNAME
	              ,A.TA_HDKEY
	              ,A.CTKEY || ';' || 'TA_DTTYPE'|| ';' || A.TA_DTTYPE AS TA_DTTYPE
	              ,C.PIZNKEY AS PIZNKEY
	              ,COALESCE(C.PIZNNAME, 'NA') AS PIZNNAME
			      ,#{urname} as URNAME
			      ,#{urkey} as URKEY
	              ,A.CTKEY
	          FROM TWORK_INFO_TA_DT A  
	              ,TWORK_MST_LC B
	              ,TWORK_MST_PIZN C                          
	         WHERE
	               A.CTKEY = #{ctkey}
	           AND A.WKSTATUS = '00'
	           AND A.TA_DTTYPE IN ('40','90')   
	           AND A.CTKEY = B.CTKEY
	           AND A.TO_LCKEY = B.LCKEY
	           AND B.CTKEY = C.CTKEY(+) 
	           AND B.PIZNKEY = C.PIZNKEY(+)
				<if test="ta_dtkeyList != null and ta_dtkeyList.size() > 0" >
			       AND 	A.TA_HDKEY IN 
					<foreach item="ta_dtkeyList" index="index" collection="ta_dtkeyList" open="(" separator="," close=")">
						#{ta_dtkeyList}
					</foreach>
				</if>	
	      GROUP BY A.CTKEY
	              ,A.OWKEY
	              ,A.TA_HDKEY
	              ,A.TA_DTTYPE
	              ,C.PIZNKEY 
	              ,C.PIZNNAME 
	      ORDER BY A.TA_HDKEY
	      		  ,A.OWKEY
	              ,C.PIZNKEY	
	</select>	

	<resultMap id="selectInvnReplenishmentReportDTMap" type="camelMap">
		<result property="to_lckey" column="TO_LCKEY" />
		<result property="ickey" column="ICKEY" />
		<result property="icname" column="ICNAME" />
		<result property="spec" column="SPEC" />
		<result property="fr_lckey" column="FR_LCKEY" />
		<result property="icutqty" column="ICUTQTY" />
		<result property="baesu" column="BAESU" />
		<result property="uom" column="UOM" typeHandler="CodeDescTypeHandler"/>
		<result property="ctkey" column="CTKEY" />
		<result property="owkey" column="OWKEY" />
		<result property="ta_hdkey" column="TA_HDKEY" />
		<result property="ta_dttype" column="TA_DTTYPE" typeHandler="CodeDescTypeHandler" />
		<result property="piznkey" column="PIZNKEY" />
		<result property="piznname" column="PIZNNAME" />
		<result property="urkey" column="URKEY" typeHandler="UrMstDescTypeHandler"/>
		<result property="shelflifecodetype" column="SHELFLIFECODETYPE" />
		<result property="product_expiredate" column="PRODUCT_EXPIREDATE" />
	</resultMap> 

	<select id="selectInvnReplenishmentReportDT" resultMap="selectInvnReplenishmentReportDTMap">
	        SELECT  COALESCE(I.LCKEYDISP, A.TO_LCKEY) AS TO_LCKEY
	               ,A.ICKEY
	               ,B.ICNAME
	               ,B.SPEC
	               ,COALESCE(E.LCKEYDISP, A.FR_LCKEY) AS FR_LCKEY
	               ,D.ICUTQTY
	               ,A.QTY / D.ICUTQTY AS BAESU
	               ,A.CTKEY || ';' || 'ICUTTYPE'|| ';' || A.UOM AS UOM
	               ,A.CTKEY
	               ,A.OWKEY
	               ,A.TA_HDKEY
	               ,A.CTKEY || ';' || 'TA_DTTYPE'|| ';' || A.TA_DTTYPE AS TA_DTTYPE
	               ,F.PIZNKEY
	               ,F.PIZNNAME
	               ,G.URKEY
	               ,'E' SHELFLIFECODETYPE 
	               ,H.EXPIREDATE  AS PRODUCT_EXPIREDATE
	          FROM TWORK_INFO_TA_DT A
	              ,TWORK_MST_IC  B
	              ,TWORK_MST_ICUT C 
	              ,TWORK_MST_ICUTXTYPE D
	              ,TWORK_MST_LC E
	              ,TWORK_MST_PIZN F 
	              ,TWORK_MST_ACXUR G
	              ,TWORK_INFO_IVAT H
	              ,TWORK_MST_LC I
	         WHERE
		                A.CTKEY = #{ctkey}
		       AND  A.TA_DTTYPE IN ('40','90')
		       AND  C.CLOSDATE >= #{closdate}
		       AND  A.WKSTATUS = '00'
		   		<if test="ta_dtkeyList != null and ta_dtkeyList.size() > 0" >
			       AND 	A.TA_HDKEY IN 
					<foreach item="ta_dtkeyList" index="index" collection="ta_dtkeyList" open="(" separator="," close=")">
						#{ta_dtkeyList}
					</foreach>
				</if>	             
	           AND A.CTKEY = B.CTKEY
	           AND A.OWKEY = B.OWKEY
	           AND A.ICKEY = B.ICKEY
	           AND A.CTKEY = C.CTKEY
	           AND A.ICUTKEY = C.ICUTKEY
	           AND A.CTKEY = D.CTKEY
	           AND A.ICUTKEY = D.ICUTKEY
	           AND A.UOM = D.ICUTTYPE  
	           AND A.CTKEY = E.CTKEY
	           AND A.TO_LCKEY = E.LCKEY
	           AND E.CTKEY = F.CTKEY(+)
	           AND E.PIZNKEY = F.PIZNKEY(+)
	           AND B.CTKEY = G.CTKEY(+)
	           AND B.ACKEY = G.ACKEY(+)
               AND B.LOGGRPCD = G.LOGGRPCD(+)
               AND B.OWKEY = G.OWKEY(+)
	           AND A.CTKEY = H.CTKEY
	           AND A.OWKEY = H.OWKEY
	           AND A.FR_IVATKEY = H.IVATKEY
	           AND A.CTKEY = I.CTKEY
	           AND A.FR_LCKEY = I.LCKEY
	      ORDER BY A.TA_HDKEY
	      		  ,A.CTKEY
	              ,A.OWKEY
	              ,F.PIZNKEY
	              ,A.FR_LCKEY
	              ,A.TO_LCKEY
	              ,A.ICKEY	
	</select>

	<select id="selectUrgentReplenishment" resultType="taskDtVO">		
			SELECT TB1.CTKEY, TB1.OWKEY, TB1.ICKEY, TB1.ICUTKEY
			    , TB1.LCKEY AS FR_LCKEY
			    , TB2.LCKEY AS TO_LCKEY
			    , TB1.IVATKEY AS FR_IVATKEY
			    , TB1.EXQTY - COALESCE(TB3.TAQTY, 0) AS QTY
			    , TB2.UOM, TB4.ICUTQTY
			    , TB1.LOGGRPCD
			    , TB1.WAHDKEY
			 FROM ( 
			    SELECT A.CTKEY, A.OWKEY, A.ICKEY, A.ICUTKEY, A.LCKEY, A.IVATKEY, A.ULCKEY, SUM(A.EXQTY) AS EXQTY
			          ,A.LOGGRPCD, C.WAHDKEY
			     FROM TWORK_INFO_PI_DT A
			        , TWORK_MST_LCXIC B
			        , TWORK_INFO_WA_DT C
			    WHERE A.CTKEY=#{ctkey}
			        AND A.WKSTATUS='00'
			        AND A.CTKEY=B.CTKEY(+)
			        AND A.LCKEY=B.LCKEY(+)
			        AND A.OWKEY=B.OWKEY(+)
			        AND A.ICKEY=B.ICKEY(+)
			        AND B.CTKEY IS NULL
				    AND A.CTKEY=C.CTKEY
				    AND A.OBHDKEY=C.OBHDKEY		        
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(wahdkey)" >
					AND C.WAHDKEY = #{wahdkey} 
			</if>	
			<if test="listWahdkey != null and listWahdkey.size() > 0" >
					AND C.WAHDKEY IN 
				<foreach item="listWahdkey" index="index" collection="listWahdkey"
					open="(" separator="," close=")">
					#{listWahdkey}
				</foreach>						 
			</if>								        
			    GROUP BY A.CTKEY, A.OWKEY, A.ICKEY, A.ICUTKEY, A.LCKEY, A.IVATKEY, A.ULCKEY, A.LOGGRPCD, C.WAHDKEY
			   ) TB1
			   , TWORK_MST_LCXIC TB2
			   , (
			    SELECT CTKEY, OWKEY, ICKEY, FR_LCKEY, FR_IVATKEY, SUM(QTY) AS TAQTY
			     FROM TWORK_INFO_TA_DT
			    WHERE CTKEY=#{ctkey}
			        AND TA_DTTYPE='90'
			        AND WKSTATUS='00'
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(wahdkey)" >
					AND WAHDKEY = #{wahdkey} 
			</if>
			<if test="listWahdkey2 != null and listWahdkey2.size() > 0" >
					AND WAHDKEY IN 
				<foreach item="listWahdkey2" index="index" collection="listWahdkey2"
					open="(" separator="," close=")">
					#{listWahdkey2}
				</foreach>						 
			</if>							        
			    GROUP BY CTKEY, OWKEY, ICKEY, FR_LCKEY, FR_IVATKEY
			    ) TB3
			   , TWORK_MST_ICUTXTYPE TB4
			   , TWORK_INFO_IVATXLCXULC TB5
			WHERE TB1.CTKEY=TB2.CTKEY
			    AND TB1.OWKEY=TB2.OWKEY
			    AND TB1.ICKEY=TB2.ICKEY
			    AND TB1.CTKEY=TB3.CTKEY(+)
			    AND TB1.OWKEY=TB3.OWKEY(+)
			    AND TB1.LCKEY=TB3.FR_LCKEY(+)
			    AND TB1.IVATKEY = TB3.FR_IVATKEY(+)
			    AND TB2.CTKEY=TB4.CTKEY
			    AND TB2.OWKEY=TB4.OWKEY
			    AND TB2.ICUTKEY=TB4.ICUTKEY
			    AND TB2.UOM=TB4.ICUTTYPE
                AND TB1.CTKEY=TB5.CTKEY
                AND TB1.IVATKEY=TB5.IVATKEY
                AND TB1.LCKEY=TB5.LCKEY
                AND TB1.ULCKEY=TB5.ULCKEY
                AND TB1.OWKEY=TB5.OWKEY
                AND TB1.ICKEY=TB5.ICKEY			    
		<![CDATA[	
			    AND TB1.EXQTY - COALESCE(TB3.TAQTY, 0) > 0
		]]>
	</select>		
	
	
	<select id="selectListTadtkeyListForReport" resultType="java.lang.String" >
		SELECT  A.TA_DTKEY AS TA_DTKEY
		  FROM  TWORK_INFO_TA_DT A
				,TWORK_MST_IC  B
				,TWORK_MST_ICUT C 
				,TWORK_MST_ICUTXTYPE D
		 WHERE
			    A.CTKEY = B.CTKEY
		   AND  A.OWKEY = B.OWKEY
		   AND  A.ICKEY = B.ICKEY
		   AND  A.CTKEY = C.CTKEY
		   AND  A.ICUTKEY = C.ICUTKEY
		   AND  A.CTKEY = D.CTKEY
		   AND  A.ICUTKEY = D.ICUTKEY
		   AND  A.UOM = D.ICUTTYPE
		   AND  A.WKSTATUS = '00'
		   AND  A.TA_DTTYPE IN ('40','90')
		   AND  C.CLOSDATE >= #{closdate}
		   AND  A.CTKEY = #{ctkey}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ta_dtkeyList)" > 
		   AND 	A.TA_DTKEY IN
				<foreach item="ta_dtkeyList" index="index" collection="ta_dtkeyList" open="(" separator="," close=")">
					#{ta_dtkeyList}
			  	</foreach>
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
		   AND 	#{SEARCH_CONDITION}
		</if>
	</select>
</mapper>	