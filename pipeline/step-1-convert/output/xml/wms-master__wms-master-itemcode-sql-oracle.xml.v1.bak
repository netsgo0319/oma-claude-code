	<sql id="selectItemCodeRefSql">
   		SELECT 	*
		  FROM 	(
			SELECT 	A.CTKEY
			        ,A.ORDTYPE
			        ,A.CTKEY ||';'|| 'ORDTYPE' ||';'|| A.ORDTYPE AS ORDTYPE_DESC
					,A.WIDTH
					,A.WEIGHT
					,A.VOLUME
					,A.UPDATEURKEY
					,A.UPDATEDATE
					,A.UOM
					,A.CTKEY ||';'|| 'ICUTTYPE' ||';'|| A.UOM AS UOM_DESC
					,A.UDF5
					,A.UDF4
					,A.UDF3
					,A.UDF2
					,A.UDF1
					,A.SHELFLIFEINDICATOR
					,A.CTKEY  ||';'|| 'YESORNO' ||';'|| A.SHELFLIFEINDICATOR AS SHELFLIFEINDICATOR_DESC
					,A.SHELFLIFECODETYPE
					,A.CTKEY  ||';'|| 'SHELFLIFECODETYPE' ||';'|| A.SHELFLIFECODETYPE AS SHELFLIFECODETYPE_DESC
					,A.SHELFLIFE
					,A.OWKEY
					,(SELECT OWNAME FROM TWORK_MST_OW OW WHERE OW.OWKEY = A.OWKEY) AS OWNAME
					,A.LENGTH
					,A.INSERTURKEY
					,A.INSERTDATE
					,A.ICUTKEY
					,A.ICNAME
					,A.ICKEY
					,A.ICGRTYPE
					,A.ICGRKEY
					,A.HEIGHT
					,A.CLOSDATE
					,A.BRANDCODE
					,A.COSTPRICE
					,A.SALEPRICE		
					,A.TO_LCKEY 
					,A.TO_ARKEY 
					,A.ABC
					,A.CTKEY  ||';'|| 'ABC' ||';'|| A.ABC AS ABC_DESC 
					,A.SAFE_INVQTY				
					,A.SERIALINPUTTYPE
					,A.CTKEY  ||';'|| 'SERIALINPUTTYPE' ||';'|| A.SERIALINPUTTYPE AS SERIALINPUTTYPE_DESC
					,A.ACKEY
					,D.ACNAME
					,A.PO_LEADTIME
					,A.LOGGRPCD
					,A.CTKEY  ||';'|| 'LOGGRPCD' ||';'|| A.LOGGRPCD AS LOGGRPCD_DESC
					,A.TAXYN
					,A.CTKEY  ||';'|| 'YESORNO' ||';'|| A.TAXYN AS TAXYN_DESC
					,A.BOXPRICE
					,A.BOTTLEPRICE
					,A.RETURNOR
					,A.CTKEY  ||';'|| 'RETURNOR' ||';'|| A.RETURNOR AS RETURNOR_DESC
					,A.ORDSTOPDATE
					,A.RELEASEDAYS
					,A.LO_NON_STOCK_TYPE
					,A.CTKEY  ||';'|| 'LO_NON_STOCK_TYPE' ||';'|| A.LO_NON_STOCK_TYPE AS LO_NON_STOCK_TYPE_DESC
					,A.DISPSHELFKEY
					,A.SPEC
					,A.ICTYPE
					,A.CTKEY  ||';'|| 'ICTYPE' ||';'|| A.ICTYPE AS ICTYPE_DESC
					,A.FOODYN
					,A.CTKEY  ||';'|| 'YESORNO' ||';'|| A.FOODYN AS FOODYN_DESC
					,C.ICGRNAME
					,A.VOLTYPE
					,A.CTKEY  ||';'|| 'VOLTYPE' ||';'|| A.VOLTYPE AS  VOLTYPE_DESC
                    ,(SELECT CTGNAME
                      FROM  TWORK_MST_CTG
                     WHERE  CTGLEVEL = '1'
                       AND  CTKEY = A.CTKEY
                       AND  OWKEY = A.OWKEY  
                       AND  CTGKEY = 
						(SELECT UPPERCTGKEY
						  FROM  TWORK_MST_CTG 
                         WHERE 	CTGLEVEL = '2'
						   AND 	CTKEY = A.CTKEY
                           AND 	OWKEY = A.OWKEY
                           AND 	CTGKEY = 
							(SELECT UPPERCTGKEY 
							  FROM 	TWORK_MST_CTG
							 WHERE  CTGLEVEL = '3' 
							   AND  CTKEY = A.CTKEY
							   AND  OWKEY = A.OWKEY
							   AND  CTGKEY = A.CTGKEY
							)
                        )
                      ) AS CTG_LEVEL_NM1
					,(SELECT CTGNAME 
					  FROM  TWORK_MST_CTG
					 WHERE  CTGLEVEL = '2' 
					   AND  CTKEY = A.CTKEY
					   AND  OWKEY = A.OWKEY
					   AND  CTGKEY = 
						(SELECT UPPERCTGKEY 
						  FROM 	TWORK_MST_CTG
						 WHERE  CTGLEVEL = '3' 
						   AND  CTKEY = A.CTKEY
						   AND  OWKEY = A.OWKEY
						   AND  CTGKEY = A.CTGKEY
						)
					) AS CTG_LEVEL_NM2 
					,(SELECT CTGNAME
					  FROM  TWORK_MST_CTG
					 WHERE  CTGLEVEL = '3' 
					   AND  CTKEY = A.CTKEY
					   AND  OWKEY = A.OWKEY
					   AND  CTGKEY = A.CTGKEY
					) AS CTG_LEVEL_NM3 
				   ,E.URKEY
				   ,E.URKEY AS URKEY_DESC
				   ,A.MAXOVERQTY AS MAXOVERQTY
				   ,F.LCKEY AS PICK_LCKEY
				   ,A.SHELFDAY
				   ,A.DELYN
				   ,A.CTKEY  ||';'|| 'YESORNO' ||';'|| A.DELYN AS DELYN_DESC
				   ,A.WGT_CF_YN
              FROM 	TWORK_MST_IC A 
                  	,TWORK_MST_ICSB B
                  	,TWORK_MST_ICGR C 
                  	,TWORK_MST_AC D
                    ,TWORK_MST_ACXUR E
                    ,TWORK_MST_LCXIC F
             WHERE  A.CTKEY = B.CTKEY(+)
               AND 	A.OWKEY = B.OWKEY(+)
               AND 	A.ICKEY = B.ICKEY(+)
               AND 	A.CTKEY = C.CTKEY(+)
               AND 	A.OWKEY = C.OWKEY(+)
               AND	A.ICGRKEY = C.ICGRKEY(+)
               AND  A.CTKEY = E.CTKEY(+)
               AND  A.ACKEY = E.ACKEY(+)
               AND  A.LOGGRPCD = E.LOGGRPCD(+)
               AND 	A.OWKEY = E.OWKEY(+)
               AND  A.CTKEY = F.CTKEY(+)
               AND  A.OWKEY = F.OWKEY(+)
               AND  A.ICKEY = F.ICKEY(+)
               AND 	A.CTKEY = D.CTKEY(+)
               AND 	A.ACKEY = D.ACKEY(+)
               AND 	A.OWKEY = D.OWKEY(+)
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
			   AND 	#{SEARCH_CONDITION}
			</if>
 			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)" >
			   AND  A.OWKEY = #{owkey}
			</if>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ickey)" >
			   AND  A.ICKEY = #{ickey}
			</if>
            )
          GROUP BY 	CTKEY
          			,WIDTH
					,WEIGHT
					,VOLUME
					,UPDATEURKEY
					,UPDATEDATE
					,UOM
					,UOM_DESC
					,UDF5
					,UDF4
					,UDF3
					,UDF2
					,UDF1
					,SHELFLIFEINDICATOR
					,SHELFLIFEINDICATOR_DESC
					,SHELFLIFECODETYPE
					,SHELFLIFECODETYPE_DESC
					,SHELFLIFE
					,OWKEY
					,OWNAME
					,LENGTH
					,INSERTURKEY
					,INSERTDATE
					,ICUTKEY
					,ICNAME
					,ICKEY
					,ICGRTYPE
					,ICGRKEY
					,HEIGHT
					,CLOSDATE
					,BRANDCODE
					,COSTPRICE
					,SALEPRICE
					,TO_LCKEY
					,TO_ARKEY
					,ABC
					,ABC_DESC
					,SAFE_INVQTY
					,SERIALINPUTTYPE
					,SERIALINPUTTYPE_DESC
					,ACKEY
					,ACNAME
					,PO_LEADTIME
					,LOGGRPCD
					,LOGGRPCD_DESC
					,TAXYN
					,TAXYN_DESC
					,BOXPRICE
					,BOTTLEPRICE
					,RETURNOR
					,RETURNOR_DESC
					,ORDSTOPDATE
					,RELEASEDAYS
					,LO_NON_STOCK_TYPE
					,LO_NON_STOCK_TYPE_DESC
					,DISPSHELFKEY
					,SPEC
					,ICTYPE
					,ICTYPE_DESC
					,FOODYN
					,FOODYN_DESC
					,ICGRNAME
					,VOLTYPE
					,VOLTYPE_DESC	
					,CTG_LEVEL_NM1
					,CTG_LEVEL_NM2
					,CTG_LEVEL_NM3
					,ORDTYPE
					,ORDTYPE_DESC
					,URKEY
					,URKEY_DESC
					,MAXOVERQTY
					,PICK_LCKEY
					,SHELFDAY
					,DELYN
					,DELYN_DESC
					,WGT_CF_YN
	</sql>
	
	<sql id="selectListItemCodeDtRefSql">
		SELECT	A.CTKEY
				,A.OWKEY
				,(SELECT OWNAME FROM TWORK_MST_OW OW WHERE OW.OWKEY = A.OWKEY) AS OWNAME
				,A.ICKEY
				,A.ICNAME
				,A.SPEC
				,B.ICUTKEY
				,B.ICUTTYPE
				,A.CTKEY  ||';'|| 'ICUTTYPE' ||';'|| B.ICUTTYPE AS ICUTTYPE_DESC
				,B.ICUTQTY
				,C.SBKEY
				,B.ICUTORDER
  	      FROM 	TWORK_MST_IC A
  	      		,TWORK_MST_ICUTXTYPE B
  	      		,TWORK_MST_ICSB C
 		 WHERE  A.CTKEY = B.CTKEY
	       AND  A.OWKEY = B.OWKEY
	       AND  A.ICUTKEY = B.ICUTKEY
	       AND  B.CTKEY = C.CTKEY(+)
	       AND  B.OWKEY = C.OWKEY(+)
	       AND  B.ICUTKEY = C.ICKEY(+)
	       AND  B.ICUTTYPE = C.ICUTTYPE(+)
	       AND  A.CTKEY = #{ctkey}
	       AND  A.OWKEY = #{owkey}
	       AND  A.ICKEY = #{ickey}	
	       
	</sql>
	

	
	<select id="selectPkItemCode" resultMap="itemCodeMap">
		<include refid="selectItemCodeRefSql"/>
	</select>
	

	
 	<update id="updateTWorkMstIc">
 		UPDATE 	TWORK_MST_IC
 		   SET	TO_LCKEY    = #{to_lckey}
				,TO_ARKEY    = #{to_arkey}
				,ABC         = #{abc}
				,VOLTYPE     = #{voltype}
				,MAXOVERQTY  = #{maxoverqty}
				,UPDATEDATE  = #{sysdate}
				,UPDATEURKEY = #{surkey}
		 WHERE	
		 		CTKEY = #{ctkey}
		   AND  OWKEY = #{owkey}
		   AND  ICKEY = #{ickey}
 	</update>	
 	
 	<update id="updateTWorkMstIcFromExcelupload">
 		UPDATE 	TWORK_MST_IC
 		   SET	UPDATEDATE  = #{sysdate}
				,UPDATEURKEY = #{surkey}
 		   	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(to_lckey)" >
   		   		,TO_LCKEY    = #{to_lckey}
			</if>
 		   	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(to_arkey)" >
   		   		,TO_ARKEY    = #{to_arkey}
			</if>
 		   	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(abc)" >
   		   		,ABC         = #{abc}
			</if>
 		   	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(voltype)" >
   		   		,VOLTYPE     = #{voltype}
			</if>
 		   	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(maxoverqty)" >
   		   		,MAXOVERQTY  = #{maxoverqty}
			</if>		
		 WHERE	
		 		CTKEY = #{ctkey}
		   AND  OWKEY = #{owkey}
		   AND  ICKEY = #{ickey}
 	</update>

	
	<select id="selectItemCodeManageListCount" resultType="java.lang.Integer">
	    		SELECT  COUNT(1)
				FROM 	TWORK_TEMP_ICUP
				WHERE 1 = 1
				<choose>
						<when test="ulhskey != null">
							AND ULHSKEY = #{ulhskey}
						</when>
						<otherwise>
				        	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
					   		 AND	#{SEARCH_CONDITION}
							</if>
						</otherwise>
					</choose>
  	</select>	
	
	<select id="selectItemCodeManageList" resultMap="privateOrderManagerListMap">
		#{GRIDPAGING_ROWNUMTYPE_TOP}
			SELECT   SESSIONID
			        ,SEQ
			        ,ULHSKEY
			        ,CTKEY
					,OWKEY
					,ICKEY
					,TO_LCKEY
					,TO_ARKEY
					,ABC
					,VOLTYPE
					,MAXOVERQTY
					,UOM
					,LOGGRPCD
			        ,IFSTATUS
			        ,'IFSTATUS' ||';'|| IFSTATUS AS IFSTATUS_DESC
			        ,IFMESSAGE
			        ,INSERTDATE
			        ,INSERTURKEY
			        ,UPDATEDATE
			        ,UPDATEURKEY
			   FROM TWORK_TEMP_ICUP
				WHERE 1 = 1
				<choose>
						<when test="ulhskey != null">
							AND ULHSKEY = #{ulhskey}
						</when>
						<otherwise>
				        	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
					   		 AND	#{SEARCH_CONDITION}
							</if>
						</otherwise>
					</choose>
			     <choose>
				<when test='sortValue !=null and sortValue != ""'>	
					<if test='sortValue == "DESC" and colName !=null'>
					ORDER BY #{colName} DESC
					</if>
					<if test='sortValue == "ASC" and colName !=null'>
					ORDER BY #{colName} ASC
					</if>	
				</when>	
				<otherwise>
					ORDER BY UPDATEDATE DESC
				</otherwise>
			</choose>
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>

	<insert id="insertItemCodeTempCount">
		INSERT INTO TWORK_TEMP_ICUP
		(
			 SESSIONID,
			 ULHSKEY,
			 SEQ,
			 CTKEY,
             OWKEY,
             ICKEY,
             TO_LCKEY,
             TO_ARKEY,
             ABC,
             VOLTYPE,
             MAXOVERQTY,
             UOM,
             LOGGRPCD,
			 IFSTATUS,
			 IFMESSAGE,
			 INSERTDATE,
			 INSERTURKEY,
			 UPDATEDATE,
			 UPDATEURKEY
		)
		VALUES 
		( 
			#{sessionid},
			#{ulhskey},
			#{seq},
            #{ctkey},
            #{owkey},
            #{ickey},
            #{to_lckey},
            #{to_arkey},
            #{abc},
            #{voltype},
            #{maxoverqty},
            #{uom},
            #{loggrpcd},
			#{ifstatus},
			#{ifmessage},
			#{sysdate},
			#{surkey},
			#{sysdate},
			#{surkey}
		)	
	</insert>	
	
	<insert id="insertItemCodeCountUlhs">
		INSERT INTO TWORK_INFO_ULHS
		(
			 ULHSKEY
			,CTKEY
			,UPLOADFILENAME
			,INSERTDATE
			,INSERTURKEY
			,UPDATEDATE
			,UPDATEURKEY
			,ULHSTYPE
		) VALUES (
			 #{ulhskey}
			,#{ctkey}                  
			,#{uploadfilename}            
			,#{sysdate}
			,#{surkey}
			,#{sysdate}
			,#{surkey}
		    ,#{ulhstype}                  
		)
	</insert>
	
	<update id="updateItemCodeTempCountUp">
		UPDATE 	TWORK_TEMP_ICUP
	   	SET 	IFSTATUS             = #{ifstatus}
		   		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ifmessage)" >
		   		,IFMESSAGE = #{ifmessage}
				</if>
		       	,UPDATEDATE         = #{sysdate}
		       	,UPDATEURKEY        = #{surkey}
	 	WHERE	ULHSKEY = #{ulhskey}
	 	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(seq)" >
		AND		SEQ = #{seq}
		</if>
	</update>

	<select id="selectTworkMstIcInfo" resultType="com.daiso.wms.api.out.dto.ItemRequestDTO">
		/* wms-master-itemcode-sql-oracle.xml - selectTworkMstIcInfo */
		SELECT IC.CTKEY				/* 센터코드 */
			 , IC.OWKEY				/* 화주코드 */
			 , IC.ICKEY				/* 상품코드 */
			 , ICTP.ICUNITTYPECD	/* 상품단위 */
			 , ICTP.WIDTH			/* 가로 */
			 , ICTP.DEPTH			/* 세로 */
			 , ICTP.HEIGHT			/* 높이 */
			 , ICTP.WEIGHT			/* 중량 */
			 , ICTP.VOL				/* 볼륨 */
			 , IC.DFSHPMTRYN		/* 이형물여부 */
			 , IC.ROBSORTERICYN		/* 로봇소터 여부 */
			 , IC.CUSHNMEPCKGYN		/* 완충재 포장여부 */
			 , IC.PCKGOVLPYN		/* 포장 겹침여부 */
			 , IC.OVLPPCKGWIDTHVAL	/* 포장 겹침 시 가로증가값 */
			 , IC.OVLPPCKGDEPTHVAL	/* 포장 겹침 시 세로증가값 */
			 , IC.OVLPPCKGHEIGHTVAL	/* 포장 겹침 시 높이증가값 */
			 , IC.PCKGFOLDYN		/* 상품접기 여부 */
			 , IC.BARCODEATTACHYN	/* 상품 QR 바코드 부착여부 */
			 , IC.POLYBAGPCKGYN	    /* 폴리백포장여부 */
			 , IC.HIGHFRQNCYDMGYN	/* 고빈도파손여부 */
			 , IC.COMPYN			/* 구성품 여부 */
			 , IC.COMPCONT			/* 구성품 정보 */
		  FROM TWORK_MST_IC IC
		 INNER JOIN TWORK_MST_CT CT
			ON CT.CTKEY = IC.CTKEY
		 INNER JOIN TWORK_MST_OW OW
			ON OW.OWKEY = IC.OWKEY
		 INNER JOIN TWORK_MST_ICUTXTYPE ICTP
			ON ICTP.CTKEY = IC.CTKEY
		   AND ICTP.OWKEY = IC.OWKEY
		   AND ICTP.ICKEY = IC.ICKEY
		   AND ICTP.ICUNITTYPECD =  IC.UOM
		 WHERE IC.CTKEY = #{ctkey}
		   AND IC.OWKEY = #{owkey}
		   AND IC.ICKEY = #{ickey}
	</select>

	<select id="selectIfSendItemLocationList" resultType="camelMap">
		/* wms-master-itemcode-sql-oracle.xml - selectIfSendItemLocationList */
		SELECT IC.LCKEY
			 , LC.ARKEY || LC.RACKNO AS LCZONE
			 , IC.ICKEY
			 , ICBC_EA.BARCODE AS EABARCODE
			 , ICBC_INN.BARCODE AS INNBARCODE
			 , ICBC_CTN.BARCODE AS CTNBARCODE
			 , IC.ICNM
		  FROM TWORK_MST_IC IC
		 INNER JOIN TWORK_MST_LC LC
			ON LC.CTKEY = IC.CTKEY
		   AND LC.LCKEY = IC.LCKEY
		 INNER JOIN TWORK_MST_AR AR
		    ON AR.ZNKEY = LC.ZNKEY
		   AND AR.ARKEY = LC.ARKEY
		  LEFT JOIN TWORK_MST_ICBARCODE ICBC_EA
			ON ICBC_EA.CTKEY = IC.CTKEY
		   AND ICBC_EA.OWKEY = IC.OWKEY
		   AND ICBC_EA.ICKEY = IC.ICKEY
		   AND ICBC_EA.UOM = 'EA'
		  LEFT JOIN TWORK_MST_ICBARCODE ICBC_INN
			ON ICBC_INN.CTKEY = IC.CTKEY
		   AND ICBC_INN.OWKEY = IC.OWKEY
		   AND ICBC_INN.ICKEY = IC.ICKEY
		   AND ICBC_INN.UOM = 'INN'
		  LEFT JOIN TWORK_MST_ICBARCODE ICBC_CTN
			ON ICBC_CTN.CTKEY = IC.CTKEY
		   AND ICBC_CTN.OWKEY = IC.OWKEY
		   AND ICBC_CTN.ICKEY = IC.ICKEY
		   AND ICBC_CTN.UOM = 'CTN'
		 WHERE IC.CTKEY = #{ctkey}
		   AND IC.OWKEY = #{owkey}

		<choose>
			<when test="@com.kns.framework.util.StringUtil@isNotEmpty(icList)">
				AND IC.ICKEY IN (
					<foreach collection="icList" item="item" separator=",">
						#{item.ickey}
					</foreach>
				  )
			</when>
			<otherwise>
				AND 1 = 2
			</otherwise>
		</choose>

	</select>

	<select id="selectItemList" resultType="camelMap">
		/* wms-master-itemcode-sql-oracle.xml - selectItemList (상품이 아소트일때 아소트 모상품 and 자상품까지 조회) */
		  WITH T_ITEM AS (
				SELECT IC.CTKEY
					 , IC.OWKEY
					 , IC.ICKEY
				  FROM TWORK_MST_IC IC
				  LEFT JOIN TWORK_MST_ASRT ASRT
					ON ASRT.CTKEY = IC.CTKEY
				   AND ASRT.OWKEY = IC.OWKEY
				   AND ASRT.ASRTMASICKEY = IC.ICKEY
				 WHERE IC.CTKEY = #{ctkey}
				   AND IC.OWKEY = #{owkey}
				   AND (
						IC.ICKEY = #{ickey}
						OR
						ASRT.ASRTMASICKEY = #{ickey}
						OR
						ASRT.ASRTDTICKEY = #{ickey}
					 )
				 GROUP BY
					   IC.CTKEY
					 , IC.OWKEY
					 , IC.ICKEY
			 )
		SELECT CTKEY
			 , OWKEY
			 , ICKEY
		  FROM T_ITEM
		 UNION
		SELECT A.CTKEY
			 , A.OWKEY
			 , B.ASRTDTICKEY AS ICKEY
		  FROM T_ITEM A
		 INNER JOIN TWORK_MST_ASRT B
			ON B.CTKEY = A.CTKEY
		   AND B.OWKEY = A.OWKEY
		   AND B.ASRTMASICKEY = A.ICKEY
	</select>


















	<update id="updateItemLocExcelTempVaild">
		/* wms-master-itemcode-sql-oracle.xml - updateItemLocExcelTempVaild */
		<![CDATA[
		UPDATE TWORK_UPLOAD_ICLC TUM
		   SET (TUM.ERROR_CD) = (
				SELECT T.ERROR_CD
				  FROM (
						SELECT ULHSKEY
							 , SEQ
						    , CASE WHEN ICLC.CTKEY IS NULL THEN 'TXT_UPLOAD_VALID_CTKEY_NULL'
								   WHEN CT.CTKEY IS NULL THEN 'TXT_UPLOAD_VALID_CTKEY_INVALID'
								   WHEN ICLC.ICKEY IS NULL THEN 'TXT_UPLOAD_VALID_ICKEY_NULL'
								   WHEN IC.ICKEY IS NULL THEN 'TXT_UPLOAD_VALID_ICKEY_INVALID'
-- 								   WHEN ICLC.LCKEY IS NULL THEN 'TXT_UPLOAD_VALID_LCKEY_NULL'
								   WHEN ICLC.LCKEY IS NOT NULL AND LC.LCKEY IS NULL THEN 'TXT_UPLOAD_VALID_LCKEY_INVALID'
									END AS ERROR_CD
						  FROM TWORK_UPLOAD_ICLC ICLC
						  LEFT JOIN TWORK_MST_CT CT
							ON CT.CTKEY = ICLC.CTKEY
						  LEFT JOIN TWORK_MST_IC IC
							ON IC.CTKEY = ICLC.CTKEY
						   AND IC.OWKEY = ICLC.OWKEY
						   AND IC.ICKEY = ICLC.ICKEY
						  LEFT JOIN TWORK_MST_LC LC
							ON LC.CTKEY = ICLC.CTKEY
						   AND LC.LCKEY = ICLC.LCKEY
						 WHERE ULHSKEY = #{uploadKey}
					) T
				WHERE TUM.ULHSKEY = T.ULHSKEY
				  AND TUM.SEQ = T.SEQ
			 )
		 WHERE TUM.ULHSKEY = #{uploadKey}
		]]>
	</update>

	<select id="selectItemLocExcelTempCount" resultType="java.lang.Integer">
		/* wms-master-itemcode-sql-oracle.xml - selectItemLocExcelTempCount */
		SELECT COUNT(1)
		  FROM TWORK_UPLOAD_ICLC
		 WHERE ULHSKEY = #{uploadKey}

		<if test='@com.kns.framework.util.StringUtil@isNotEmpty(filter) and filter=="Y"'>
			AND ERROR_CD IS NOT NULL
		</if>
	</select>

	<select id="selectItemLocExcelTempList" resultType="camelMap">
		/* wms-master-itemcode-sql-oracle.xml - selectItemLocExcelTempList */
		<include refid="sql_pagingTop"/>
		SELECT '0' AS CHK
		     , ULHSKEY
			 , SEQ
			 , CTKEY
			 , OWKEY
			 , ICKEY
			 , ICNM
			 , LCKEY
			 , ERROR_CD
			 , ERROR_COMMENTS
			 , INSERTDATE
			 , INSERTURKEY
			 , UPDATEDATE
			 , UPDATEURKEY
		  FROM TWORK_UPLOAD_ICLC
		 WHERE ULHSKEY = #{uploadKey}

		<if test='@com.kns.framework.util.StringUtil@isNotEmpty(filter) and filter=="Y"'>
			AND ERROR_CD IS NOT NULL
		</if>

		 ORDER BY SEQ
		<include refid="sql_pagingBottom"/>
	</select>

	<delete id="deleteItemLocExcelUploadTemp">
		/* wms-master-itemcode-sql-oracle.xml - deleteItemLocExcelUploadTemp */
		DELETE
		  FROM TWORK_UPLOAD_ICLC
		 WHERE ULHSKEY = #{ulhskey}
		   AND SEQ = #{seq}
	</delete>

	<update id="updateItemLocExcelUploadList">
		/* wms-master-itemcode-sql-oracle.xml - updateItemLocExcelUploadList */
		<![CDATA[
		UPDATE TWORK_MST_IC TUM
		   SET (
		       TUM.LCKEY
		     , TUM.UPDATEDATE
		     , TUM.UPDATEURKEY) = (
								  SELECT A.LCKEY
									   , #{sysdate} AS UPDATEDATE
									   , #{surkey} AS UPDATEURKEY
									FROM TWORK_UPLOAD_ICLC A
								   WHERE A.ULHSKEY = #{uploadKey}
									 AND A.ERROR_CD IS NULL
									 AND TUM.CTKEY = A.CTKEY
							  		 AND TUM.OWKEY = A.OWKEY
							  		 AND TUM.ICKEY = A.ICKEY)
		 WHERE EXISTS (
					  SELECT 'X'
					    FROM TWORK_UPLOAD_ICLC B
					   WHERE B.ULHSKEY = #{uploadKey}
					     AND B.CTKEY = TUM.CTKEY
					     AND B.OWKEY = TUM.OWKEY
					     AND B.ICKEY = TUM.ICKEY
					)
		]]>
	</update>

	<select id="selectItemLocExcelUploadList" resultType="camelMap">
		/* wms-master-itemcode-sql-oracle.xml - selectItemLocExcelUploadList */
		SELECT ICLC.CTKEY
			 , ICLC.OWKEY
			 , ICLC.ICKEY
			 , ZN.ZNKEY AS RECOZNKEY
			 , LC.LCKEY AS RECOLCKEY
		  FROM TWORK_UPLOAD_ICLC ICLC
		  JOIN TWORK_MST_IC IC
			ON IC.CTKEY = ICLC.CTKEY
		   AND IC.OWKEY = ICLC.OWKEY
		   AND IC.ICKEY = ICLC.ICKEY
		  LEFT JOIN TWORK_MST_LC LC
			ON LC.CTKEY = ICLC.CTKEY
		   AND LC.LCKEY = ICLC.LCKEY
		  LEFT JOIN TWORK_MST_AR AR
			ON AR.CTKEY = LC.CTKEY
		   AND AR.ZNKEY = LC.ZNKEY
		   AND AR.ARKEY = LC.ARKEY
		  LEFT JOIN TWORK_MST_ZN ZN
			ON ZN.CTKEY = LC.CTKEY
		   AND ZN.ZNKEY = LC.ZNKEY
		WHERE ICLC.ULHSKEY = #{uploadKey}
	</select>

	<select id="selectTWorkMstIcResetLckeyExcelUpload" resultType="camelMap">
		/* wms-master-itemcode-sql-oracle.xml - selectTWorkMstIcResetLckeyExcelUpload */
		SELECT IC.CTKEY												/* 센터코드 */
		     , IC.OWKEY												/* 화주코드 */
			 , IC.ICKEY												/* 상품코드 */
			 , IC.ICNM												/* 상품명 */
			 , ICBC.BARCODE AS EABARCODE							/* 상품바코드(낱개) */
			 , ICBC_INN.BARCODE AS INNBARCODE						/* 상품바코드(중포) */
			 , ICBC_CTN.BARCODE AS CTNBARCODE						/* 상품바코드(카톤) */
			 , IC.LCKEY												/* 상품 대표 로케이션코드 */
			 , LC.ARKEY || LC.RACKNO AS LCZONE						/* 구역 + 랙번호 */
		  FROM TWORK_MST_IC IC
		 INNER JOIN TWORK_MST_CT CT
			ON CT.CTKEY = IC.CTKEY
		 LEFT OUTER JOIN TWORK_MST_ICBARCODE ICBC
			ON ICBC.CTKEY = IC.CTKEY
		   AND ICBC.OWKEY = IC.OWKEY
		   AND ICBC.ICKEY = IC.ICKEY
		   AND ICBC.UOM = IC.UOM
		  LEFT JOIN TWORK_MST_ICBARCODE ICBC_INN
			ON ICBC_INN.CTKEY = IC.CTKEY
		   AND ICBC_INN.OWKEY = IC.OWKEY
		   AND ICBC_INN.ICKEY = IC.ICKEY
		   AND ICBC_INN.UOM = 'INN'
		  LEFT JOIN TWORK_MST_ICBARCODE ICBC_CTN
			ON ICBC_CTN.CTKEY = IC.CTKEY
		   AND ICBC_CTN.OWKEY = IC.OWKEY
		   AND ICBC_CTN.ICKEY = IC.ICKEY
		   AND ICBC_CTN.UOM = 'CTN'
		  LEFT JOIN TWORK_MST_LC LC
			ON LC.LCKEY = IC.LCKEY

        <where>
            AND IC.CLOSDATE <![CDATA[ >= ]]> #{sysdate}
            AND IC.DELYN <![CDATA[ <> ]]> 'Y'
            AND IC.CTKEY = #{ctkey}
            AND IC.OWKEY = #{owkey}

			AND IC.LCKEY IN (
					SELECT DISTINCT
						   ICLC.LCKEY
					  FROM TWORK_UPLOAD_ICLC ICLC
					  JOIN TWORK_MST_LC LC
						ON LC.CTKEY = ICLC.CTKEY
					   AND LC.LCKEY = ICLC.LCKEY
					 WHERE ICLC.ULHSKEY = #{uploadKey}
					   AND ICLC.CTKEY = #{ctkey}
					   AND ICLC.OWKEY = #{owkey}
					   AND ICLC.ERROR_CD IS NULL
					   AND LC.ZNKEY <![CDATA[ <> ]]> 'P'	/* PLT랙 보관존 */
					   AND LC.ZNKEY <![CDATA[ <> ]]> 'SM'	/* 부자재 보관존 */
			  )

			AND IC.ICKEY NOT IN (
					SELECT ICKEY
					  FROM TWORK_UPLOAD_ICLC
					 WHERE ULHSKEY = #{uploadKey}
					   AND CTKEY = #{ctkey}
					   AND OWKEY = #{owkey}
					   AND ERROR_CD IS NULL
			  )
		</where>
	</select>

	<update id="updateTWorkMstIcResetLckeyExcelUpload">
		/* wms-master-itemcode-sql-oracle.xml - updateTWorkMstIcResetLckeyExcelUpload */
		UPDATE TWORK_MST_IC
		   SET LCKEY = null
		     , UPDATEDATE = #{sysdate}
		     , UPDATEURKEY = #{surkey}
		 WHERE CTKEY = #{ctkey}
		   AND OWKEY = #{owkey}
		   AND LCKEY IN (
					SELECT DISTINCT
						   ICLC.LCKEY
					  FROM TWORK_UPLOAD_ICLC ICLC
					  JOIN TWORK_MST_LC LC
						ON LC.CTKEY = ICLC.CTKEY
					   AND LC.LCKEY = ICLC.LCKEY
					 WHERE ICLC.ULHSKEY = #{uploadKey}
					   AND ICLC.CTKEY = #{ctkey}
					   AND ICLC.OWKEY = #{owkey}
					   AND ICLC.ERROR_CD IS NULL
					   AND LC.ZNKEY <![CDATA[ <> ]]> 'P'	/* PLT랙 보관존 */
					   AND LC.ZNKEY <![CDATA[ <> ]]> 'SM'	/* 부자재 보관존 */
			  )

			AND ICKEY NOT IN (
					SELECT ICKEY
					  FROM TWORK_UPLOAD_ICLC
					 WHERE ULHSKEY = #{uploadKey}
					   AND CTKEY = #{ctkey}
					   AND OWKEY = #{owkey}
					   AND ERROR_CD IS NULL
			  )

	</update>

	<select id="selectIfSendItemLocationExcelUploadList" resultType="camelMap">
		/* wms-master-itemcode-sql-oracle.xml - selectIfSendItemLocationExcelUploadList */
		SELECT IC.LCKEY
			 , LC.ARKEY || LC.RACKNO AS LCZONE
			 , IC.ICKEY
			 , ICBC_EA.BARCODE AS EABARCODE
			 , ICBC_INN.BARCODE AS INNBARCODE
			 , ICBC_CTN.BARCODE AS CTNBARCODE
			 , IC.ICNM
		  FROM TWORK_MST_IC IC
		 INNER JOIN TWORK_MST_LC LC
			ON LC.CTKEY = IC.CTKEY
		   AND LC.LCKEY = IC.LCKEY
		 INNER JOIN TWORK_MST_AR AR
		    ON AR.ZNKEY = LC.ZNKEY
		   AND AR.ARKEY = LC.ARKEY
		  LEFT JOIN TWORK_MST_ICBARCODE ICBC_EA
			ON ICBC_EA.CTKEY = IC.CTKEY
		   AND ICBC_EA.OWKEY = IC.OWKEY
		   AND ICBC_EA.ICKEY = IC.ICKEY
		   AND ICBC_EA.UOM = 'EA'
		  LEFT JOIN TWORK_MST_ICBARCODE ICBC_INN
			ON ICBC_INN.CTKEY = IC.CTKEY
		   AND ICBC_INN.OWKEY = IC.OWKEY
		   AND ICBC_INN.ICKEY = IC.ICKEY
		   AND ICBC_INN.UOM = 'INN'
		  LEFT JOIN TWORK_MST_ICBARCODE ICBC_CTN
			ON ICBC_CTN.CTKEY = IC.CTKEY
		   AND ICBC_CTN.OWKEY = IC.OWKEY
		   AND ICBC_CTN.ICKEY = IC.ICKEY
		   AND ICBC_CTN.UOM = 'CTN'
		 WHERE IC.CTKEY = #{ctkey}
		   AND IC.OWKEY = #{owkey}
		   AND IC.ICKEY IN (
					SELECT ICKEY
					  FROM TWORK_UPLOAD_ICLC
					 WHERE ULHSKEY = #{uploadKey}
					   AND CTKEY = #{ctkey}
					   AND OWKEY = #{owkey}
					   AND ERROR_CD IS NULL
			  )

	</select>

</mapper>	