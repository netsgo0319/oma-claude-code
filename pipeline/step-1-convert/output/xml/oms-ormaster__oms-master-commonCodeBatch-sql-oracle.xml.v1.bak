<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
				   
<mapper namespace="com.daiso.oms.api.in.mapper.CommonCodeApiMapper">

	<insert id="insertIntfTableCommonCode">
		/* oms-master-commonCodeBatch-sql-oracle.xml - insertIntfTableCommonCode */
		INSERT INTO TORDER_INTF_MAL_COM (
		     OWKEY
		   , COMHDKEY
		   , INSERTSYSTM
		   , COMHDNM
		   , UPRCOMHDKEY
		   , COMDTKEY
		   , COMDTNM
		   , UPRCOMDTKEY
		   , HDDELYN
		   , DTDELYN
		   , DELYN
		   , REQUESTDT
		   , IFID
		   , INSERTDATE
		   , INSERTURKEY
		   , UPDATEDATE
		   , UPDATEURKEY
		) VALUES (
		     #{owkey}
		   , #{comhdkey}
		   , #{insertsystm}
		   , #{comhdnm}
		   , #{uprcomhdkey}
		   , #{comdtkey}
		   , #{comdtnm}
		   , #{uprcomdtkey}
		   , #{hddelyn}
		   , #{dtdelyn}
		   , COALESCE(#{delyn}, 'N')
		   , #{requestDt}
		   , #{interfaceId}
		   , #{sysdate}
		   , #{interfaceUrkey}
		   , #{sysdate}
		   , #{interfaceUrkey}

		)


	</insert>


	<insert id="insertErpCommonCodeIntfInfo">
		/* oms-master-commonCodeBatch-sql-oracle.xml - insertErpCommonCodeIntfInfo */
		MERGE INTO TORDER_MST_COM_HD COM_HD
		USING
		(
		   SELECT DISTINCT
		          #{owkey}       AS OWKEY
		        , COMHDKEY
		        , #{insertsystm} AS INSERTSYSTM
		        , COMHDNM
		   FROM TORDER_EAI_COMCD_BATCH
		   WHERE TRN_ID = #{trnId}
		) IN_COM_HD
		ON
		(
		      IN_COM_HD.OWKEY = COM_HD.OWKEY
		  AND IN_COM_HD.COMHDKEY = COM_HD.COMHDKEY
		  AND IN_COM_HD.INSERTSYSTM = COM_HD.INSERTSYSTM
		)
		WHEN MATCHED THEN
		  UPDATE SET
		     COM_HD.COMHDNM    = IN_COM_HD.COMHDNM
		   , COM_HD.UPDATEDATE = #{sysdate}
		   , COM_HD.UPDATEURKEY =  #{interfaceUrkey}
		  WHEN NOT MATCHED THEN
		INSERT
		(
		     COM_HD.OWKEY
		   , COM_HD.COMHDKEY
		   , COM_HD.INSERTSYSTM
		   , COM_HD.COMHDNM
		   , COM_HD.WMSIFYN
		   , COM_HD.TMSIFYN
		   , COM_HD.DELYN
		   , COM_HD.INSERTDATE
		   , COM_HD.INSERTURKEY
		   , COM_HD.UPDATEDATE
		   , COM_HD.UPDATEURKEY
		)
		VALUES
		(
		     IN_COM_HD.OWKEY
		   , IN_COM_HD.COMHDKEY
		   , IN_COM_HD.INSERTSYSTM
		   , IN_COM_HD.COMHDNM
		   , 'Y'
		   , 'Y'
		   , 'N'
		   , #{sysdate}
		   , #{interfaceUrkey}
		   , #{sysdate}
		   , #{interfaceUrkey}
		)

	</insert>

	<insert id="insertErpDetailCommonCodeIntfInfo">
		/* oms-master-commonCodeBatch-sql-oracle.xml - insertErpDetailCommonCodeIntfInfo */
		MERGE INTO TORDER_MST_COM_DT COM_DT
		USING
		(
		   SELECT #{owkey}  AS OWKEY
		        , COMHDKEY
		        , COMDTKEY
		        , #{insertsystm} AS INSERTSYSTM
		        , 'KOR' AS LAKEY
		        , COMDTNM
		   FROM TORDER_EAI_COMCD_BATCH
		   WHERE TRN_ID = #{trnId}
		) IN_COM_DT
		ON
		(
		      IN_COM_DT.OWKEY = COM_DT.OWKEY
		  AND IN_COM_DT.COMHDKEY = COM_DT.COMHDKEY
		  AND IN_COM_DT.INSERTSYSTM = COM_DT.INSERTSYSTM
		  AND IN_COM_DT.COMDTKEY = COM_DT.COMDTKEY
		  AND IN_COM_DT.LAKEY = COM_DT.LAKEY
		)
		WHEN MATCHED THEN
		 UPDATE SET
		   COM_DT.COMDTNM     = IN_COM_DT.COMDTNM
		 , COM_DT.UPDATEDATE  = #{sysdate}
	     , COM_DT.UPDATEURKEY =  #{interfaceUrkey}
		WHEN NOT MATCHED THEN
		 INSERT
		 (
		      COM_DT.OWKEY
		    , COM_DT.COMHDKEY
		    , COM_DT.COMDTKEY
		    , COM_DT.INSERTSYSTM
		    , COM_DT.LAKEY
		    , COM_DT.COMDTNM
		    , COM_DT.DELYN
		    , COM_DT.INSERTDATE
		    , COM_DT.INSERTURKEY
		    , COM_DT.UPDATEDATE
		    , COM_DT.UPDATEURKEY
		 )
		 VALUES
		 (
		      IN_COM_DT.OWKEY
		    , IN_COM_DT.COMHDKEY
		    , IN_COM_DT.COMDTKEY
		    , IN_COM_DT.INSERTSYSTM
		    , IN_COM_DT.LAKEY
		    , IN_COM_DT.COMDTNM
		    , 'N'
		    , #{sysdate}
		    , #{interfaceUrkey}
		    , #{sysdate}
		    , #{interfaceUrkey}
		 )
	</insert>

	<insert id="insertMalCommonCodeIntfInfo">
		/* oms-master-commonCodeBatch-sql-oracle.xml - insertMalCommonCodeIntfInfo */
		MERGE INTO TORDER_MST_COM_HD COM_HD
		USING
		(
		   SELECT #{owkey}       AS OWKEY
		        , COMHDKEY
		        , #{insertsystm} AS INSERTSYSTM
		        , COMHDNM
		        , UPRCOMHDKEY
		        , HDDELYN
		   FROM TORDER_INTF_MAL_COM
		   WHERE IFID = #{interfaceId}
		   GROUP BY OWKEY, COMHDKEY, INSERTSYSTM, COMHDNM, UPRCOMHDKEY, HDDELYN
		) IN_COM_HD
		ON
		(
		       IN_COM_HD.OWKEY = COM_HD.OWKEY
		   AND IN_COM_HD.COMHDKEY = COM_HD.COMHDKEY
		   AND IN_COM_HD.INSERTSYSTM = COM_HD.INSERTSYSTM
		)
		WHEN MATCHED THEN
		 UPDATE SET
		   COM_HD.COMHDNM     = IN_COM_HD.COMHDNM
		 , COM_HD.UPRCOMHDKEY = IN_COM_HD.UPRCOMHDKEY
		 , COM_HD.DELYN       = IN_COM_HD.HDDELYN
		 , COM_HD.UPDATEDATE  = #{sysdate}
	     , COM_HD.UPDATEURKEY = #{interfaceUrkey}
		WHEN NOT MATCHED THEN
		 INSERT
		 (
		      COM_HD.OWKEY
		    , COM_HD.COMHDKEY
		    , COM_HD.INSERTSYSTM
		    , COM_HD.COMHDNM
		    , COM_HD.UPRCOMHDKEY
		    , COM_HD.WMSIFYN
		    , COM_HD.TMSIFYN
		    , COM_HD.DELYN
		    , COM_HD.INSERTDATE
		    , COM_HD.INSERTURKEY
		    , COM_HD.UPDATEDATE
		    , COM_HD.UPDATEURKEY
		 )
		 VALUES
		 (
		      IN_COM_HD.OWKEY
		    , IN_COM_HD.COMHDKEY
		    , IN_COM_HD.INSERTSYSTM
		    , IN_COM_HD.COMHDNM
		    , IN_COM_HD.UPRCOMHDKEY
		    , 'Y'
		    , 'Y'
		    , IN_COM_HD.HDDELYN
		    , #{sysdate}
		    , #{interfaceUrkey}
		    , #{sysdate}
		    , #{interfaceUrkey}
		 )
	</insert>

	<insert id="insertMalDetailCommonCodeIntfInfo">
		/* oms-master-commonCodeBatch-sql-oracle.xml - insertMalDetailCommonCodeIntfInfo */
		MERGE INTO TORDER_MST_COM_DT COM_DT
		USING
		(
		   SELECT #{owkey}  AS OWKEY
		        , COMHDKEY
		        , COMDTKEY
		        , #{insertsystm} AS INSERTSYSTM
		        , 'KOR'          AS LAKEY
		        , COMDTNM
		        , UPRCOMDTKEY
		        , DTDELYN
		        , ROW_NUMBER() OVER(PARTITION BY COMHDKEY ORDER BY COMDTKEY ) AS DTKEYORD
		   FROM TORDER_INTF_MAL_COM
		   WHERE IFID = #{interfaceId}
		   GROUP BY OWKEY, COMHDKEY, COMDTKEY, INSERTSYSTM, COMDTNM, UPRCOMDTKEY, DTDELYN
		) IN_COM_DT
		ON
		(
		       IN_COM_DT.OWKEY = COM_DT.OWKEY
		   AND IN_COM_DT.COMHDKEY = COM_DT.COMHDKEY
		   AND IN_COM_DT.INSERTSYSTM = COM_DT.INSERTSYSTM
		   AND IN_COM_DT.COMDTKEY = COM_DT.COMDTKEY
		   AND IN_COM_DT.LAKEY = COM_DT.LAKEY
		)
		WHEN MATCHED THEN
		 UPDATE SET
		   COM_DT.COMDTNM     = IN_COM_DT.COMDTNM
		 , COM_DT.UPRCOMDTKEY = IN_COM_DT.UPRCOMDTKEY
		 , COM_DT.DTKEYORD    = IN_COM_DT.DTKEYORD
		 , COM_DT.DELYN       = IN_COM_DT.DTDELYN
		 , COM_DT.UPDATEDATE  = #{sysdate}
	     , COM_DT.UPDATEURKEY = #{interfaceUrkey}
		WHEN NOT MATCHED THEN
		 INSERT
		 (
		      COM_DT.OWKEY
		    , COM_DT.COMHDKEY
		    , COM_DT.COMDTKEY
		    , COM_DT.INSERTSYSTM
		    , COM_DT.LAKEY
		    , COM_DT.COMDTNM
		    , COM_DT.UPRCOMDTKEY
		    , COM_DT.DTKEYORD
		    , COM_DT.DELYN
		    , COM_DT.INSERTDATE
		    , COM_DT.INSERTURKEY
		    , COM_DT.UPDATEDATE
		    , COM_DT.UPDATEURKEY
		 )
		 VALUES
		 (
		      IN_COM_DT.OWKEY
		    , IN_COM_DT.COMHDKEY
		    , IN_COM_DT.COMDTKEY
		    , IN_COM_DT.INSERTSYSTM
		    , IN_COM_DT.LAKEY
		    , IN_COM_DT.COMDTNM
		    , IN_COM_DT.UPRCOMDTKEY
		    , IN_COM_DT.DTKEYORD
		    , IN_COM_DT.DTDELYN
		    , #{sysdate}
		    , #{interfaceUrkey}
		    , #{sysdate}
		    , #{interfaceUrkey}
		 )
	</insert>
	
	<insert id="insertOrderMstGradeIfNotExists">
		/* oms-master-commonCodeBatch-sql-oracle.xml - insertOrderMstGradeIfNotExists */
		INSERT INTO TORDER_MST_GRADE
	    (
	        OWKEY
	        , CTKEY
	        , OLNICDIV
	        , NEEDDAYS
	        , INSERTDATE
		    , INSERTURKEY
		    , UPDATEDATE
		    , UPDATEURKEY
	    )
	    SELECT DT.OWKEY
	         , CT.CTKEY
	         , DT.COMDTKEY
	         , 0
	         , #{sysdate}
		     , #{interfaceUrkey}
		     , #{sysdate}
		     , #{interfaceUrkey}
	    FROM TORDER_MST_COM_DT DT
	    CROSS JOIN TORDER_MST_CT CT
	    LEFT JOIN TORDER_MST_GRADE GR
	        ON DT.OWKEY = GR.OWKEY
	       AND DT.COMDTKEY = GR.OLNICDIV
	       AND CT.CTKEY = GR.CTKEY
	    WHERE DT.OWKEY = #{owkey}
	      AND DT.COMHDKEY = 'CD_00577'
	      AND CT.MANAGEMENTYN = 'Y'
	      AND GR.OLNICDIV IS NULL
		  AND DT.DELYN='N'
	</insert>

	<insert id="insertWmsCommonCodeIntfInfo" parameterType="com.daiso.oms.api.out.dto.CommonCodeOutDTO$CmcdRsVO">
		/* oms-master-commonCodeBatch-sql-oracle.xml - insertWmsCommonCodeIntfInfo */
		INSERT INTO TORDER_INTF_WMS_COM
		 (
		      CTKEY
			, OWKEY
            , COMHDKEY
            , COMHDNM
            , UPRCOMHDKEY
            , COMDTKEY
            , COMDTNM
            , UPRCOMDTKEY
            , DELYN
		    , REQUESTDT
		    , IFID
		    , INSERTDATE
		    , INSERTURKEY
		    , UPDATEDATE
		    , UPDATEURKEY
		) VALUES (
              #{ctkey}
		    , #{owkey}
            , #{comhdkey}
            , #{comhdnm}
            , #{uprcomhdkey}
            , #{comdtkey}
            , #{comdtnm}
            , #{uprcomdtkey}
            , COALESCE(#{delyn}, 'N')
		    , #{requestDt}
		    , #{interfaceId}
			, TO_CHAR(CURRENT_TIMESTAMP,'YYYYMMDDHH24MISS')
	        , #{urkey}
		    , TO_CHAR(CURRENT_TIMESTAMP,'YYYYMMDDHH24MISS')
	        , #{urkey}
		)
	</insert>

	<insert id="insertErpCommonCodeCtgIntfInfo">
		/* oms-master-commonCodeBatch-sql-oracle.xml - insertErpCommonCodeCtgIntfInfo */
		MERGE INTO TORDER_MST_CTG CTG
		USING
		(
		   SELECT COMDTKEY AS CTGKEY
		        , CASE WHEN LENGTH(COMDTKEY) = '4' THEN '3'
		               WHEN LENGTH(COMDTKEY) = '2' THEN '2'
		               WHEN LENGTH(COMDTKEY) = '1' THEN '1'
		          END CTGLV
		        , CASE WHEN LENGTH(COMDTKEY) = '4' THEN SUBSTR(COMDTKEY, 0, 2)
		               WHEN LENGTH(COMDTKEY) = '2' THEN SUBSTR(COMDTKEY, 0, 1)
		               WHEN LENGTH(COMDTKEY) = '1' THEN NULL
		          END UPPERCTGKEY
		        , COMDTNM   AS CTGNM
		        , #{owkey}  AS OWKEY
		   FROM TORDER_EAI_COMCD_BATCH
		   WHERE COMHDKEY IN ('DIV_MIN','DIV_MID', 'DIV_MAX')
		     AND TRN_ID = #{trnId}
		) IN_CTG
		ON
		(
		      IN_CTG.OWKEY = CTG.OWKEY
		  AND IN_CTG.CTGKEY = CTG.CTGKEY
		)
		WHEN MATCHED THEN
		 UPDATE SET
		     CTG.CTGLV       = IN_CTG.CTGLV
		   , CTG.UPPERCTGKEY = IN_CTG.UPPERCTGKEY
		   , CTG.CTGNM       = IN_CTG.CTGNM
	       , CTG.UPDATEDATE  = #{sysdate}
	       , CTG.UPDATEURKEY = #{interfaceUrkey}
		 WHEN NOT MATCHED THEN
		 INSERT
		 (
		      CTG.CTGKEY
		    , CTG.CTGLV
		    , CTG.OWKEY
		    , CTG.CTGNM
		    , CTG.UPPERCTGKEY
		    , CTG.IFYN
		    , CTG.INSERTDATE
		    , CTG.INSERTURKEY
		    , CTG.UPDATEDATE
		    , CTG.UPDATEURKEY
		 )
		 VALUES
		 (
		      IN_CTG.CTGKEY
		    , IN_CTG.CTGLV
		    , IN_CTG.OWKEY
		    , IN_CTG.CTGNM
		    , IN_CTG.UPPERCTGKEY
		    , 'Y'
		    , #{sysdate}
		    , #{interfaceUrkey}
		    , #{sysdate}
		    , #{interfaceUrkey}
		 )
	</insert>

	<insert id="insertWmsCommonCodeCtgIntfInfo" parameterType="com.daiso.oms.api.out.dto.CtgDTO">
		/* oms-master-commonCodeBatch-sql-oracle.xml - insertWmsCommonCodeCtgIntfInfo */
		INSERT INTO TORDER_INTF_WMS_CTG
		 (
		      CTKEY
		    , OWKEY
		    , CTGKEY
		    , CTGNM
		    , CTGLV
		    , UPPERCTGKEY
		    , REQUESTDT
		    , IFID
		    , INSERTDATE
		    , INSERTURKEY
		    , UPDATEDATE
		    , UPDATEURKEY
		) VALUES (
		      #{ctkey}
		    , #{owkey}
		    , #{ctgkey}
		    , #{ctgnm}
		    , #{ctglv}
		    , #{upperctgkey}
		    , #{requestDt}
		    , #{interfaceId}
			, TO_CHAR(CURRENT_TIMESTAMP,'YYYYMMDDHH24MISS')
	        , #{urkey}
		    , TO_CHAR(CURRENT_TIMESTAMP,'YYYYMMDDHH24MISS')
	        , #{urkey}
		)
	</insert>

	<insert id="insertWmsCommonCodeCtgIntfInfo_BACKUP">
		/* oms-master-commonCodeBatch-sql-oracle.xml - insertWmsCommonCodeCtgIntfInfo */
		INSERT INTO TORDER_INTF_WMS_CTG
		 (
		      CTKEY
		    , OWKEY
		    , CTGKEY
		    , CTGNM
		    , CTGLV
		    , UPPERCTGKEY
		    , REQUESTDT
		    , IFID
		    , INSERTDATE
		    , INSERTURKEY
		    , UPDATEDATE
		    , UPDATEURKEY
		) SELECT #{ctkey}
		       , CTG.OWKEY
		       , CTG.CTGKEY
               , CTG.CTGNM
               , CTG.CTGLV
               , CTG.UPPERCTGKEY
		       , #{requestDt}
		       , #{interfaceId}
			   , #{sysdate}
	           , #{interfaceUrkey}
		       , #{sysdate}
	           , #{interfaceUrkey}
		FROM TORDER_MST_CTG CTG
		INNER JOIN TORDER_EAI_COMCD_BATCH BAT
		       ON CTG.CTGKEY = BAT.COMDTKEY
		WHERE BAT.COMHDKEY IN ('DIV_MIN','DIV_MID', 'DIV_MAX')
          AND BAT.TRN_ID = #{trnId}

	</insert>


	<select id="selectIntfTOrderMstCtg" resultType="com.daiso.oms.api.out.dto.CtgDTO" >
		/* oms-master-commonCodeBatch-sql-oracle.xml - selectIntfTOrderMstCtg */
		SELECT CTG.OWKEY
		     , CTG.CTGKEY
             , CTG.CTGLV
             , CTG.CTGNM
             , CTG.UPPERCTGKEY
		FROM TORDER_MST_CTG CTG
		INNER JOIN TORDER_EAI_COMCD_BATCH BAT
		       ON CTG.CTGKEY = BAT.COMDTKEY
		WHERE BAT.COMHDKEY IN ('DIV_MIN','DIV_MID', 'DIV_MAX')

		  AND BAT.TRN_ID IN
		<foreach item="id" collection="trnId"    open="(" separator="," close=")">
			#{id}
		</foreach>
	</select>

	<update id="updateIntfCommonCodeErpStatus">
		/* oms-master-commonCodeBatch-sql-oracle.xml - updateIntfCommonCodeErpStatus */
		UPDATE TORDER_EAI_COMCD_BATCH
           SET SND_PROC_TYP = 'Y'
		 WHERE TRN_ID = #{trnId}
	</update>
</mapper>
