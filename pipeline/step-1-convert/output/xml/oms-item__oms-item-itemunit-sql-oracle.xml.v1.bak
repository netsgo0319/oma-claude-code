<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
	
<mapper namespace="com.daiso.oms.item.mapper.ItemUnitMapper">

	<select id="selectItemUnitCount" resultType="java.lang.Integer" >
		/* oms-item-itemunit-sql-oracle.xml - selectItemUnitCount */
		SELECT COUNT(1)
			FROM (
					SELECT  A.OWKEY
					    ,C.OWNM
						,A.ICUNITKEY 
				        ,B.ICUNITTYPE
				        ,'ICUTTYPE' ||';'|| B.ICUNITTYPE AS ICUTTYPE_DESC
				        ,B.ICUNITQTY
				        ,A.CLOSDATE
				        ,B.INSERTDATE 
				        ,B.UPDATEDATE
				        ,B.INSERTURKEY
 						,B.UPDATEURKEY
				        ,B.ICUNITORDER
				        ,A.ASRTYN -- 아소트여부 05.12 추가
				        ,A.DELYN -- 삭제여부 05.12 추가
				        ,A.ICNM
				        ,A.ICKEY
				  FROM 	TORDER_MST_IC A
				  INNER JOIN TORDER_MST_ICUTXTYPE B
				      	  ON A.OWKEY = B.OWKEY
						 AND A.ICKEY = B.ICKEY
		                 AND B.DELYN ='N'
				  INNER JOIN TORDER_MST_OW C
				  	  	  ON A.OWKEY = C.OWKEY
				  LEFT OUTER JOIN TORDER_MST_ICBACODE D
				   		ON A.OWKEY = D.OWKEY
					   AND A.ICKEY = D.ICKEY
					   AND D.UOM = B.ICUNITTYPE
					   AND D.DELYN ='N'
				  WHERE A.DELYN ='N'
			   ) A
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
			   WHERE 	#{SEARCH_CONDITION}
			</if>		
			<choose>
				<when test='sortValue !=null and sortValue != ""'>	
					<if test='sortValue == "DESC" and colName !=null'>
					ORDER BY #{colName} DESC
					</if>
					<if test='sortValue == "ASC" and colName !=null'>
					ORDER BY #{colName} ASC
					</if>	
				</when>	
				<otherwise>
					ORDER BY UPDATEDATE DESC
				</otherwise>
			</choose>     	       
	</select>
	
	<select id="selectItemIcutCount" resultType="java.lang.Integer" >
		/* oms-item-itemunit-sql-oracle.xml - selectItemIcutCount */
		SELECT COUNT(1)
			FROM (
					SELECT  A.OWKEY
						,A.ICUNITKEY 
				        ,B.ICUNITTYPE
				        ,'ICUTTYPE' ||';'|| B.ICUNITTYPE AS ICUTTYPE_DESC
				        ,B.ICUNITQTY
				        ,A.CLOSDATE
				        ,B.INSERTDATE 
				        ,B.INSERTURKEY 
				        ,B.UPDATEDATE 
				        ,B.UPDATEURKEY
				        ,B.ICUNITORDER
				        ,(SELECT MAX(C.ICNM) FROM TADMIN_MST_IC C WHERE C.ICKEY = A.ICUNITKEY) ICNM
				  FROM 	TADMIN_MST_ICUT A
				  INNER JOIN TADMIN_MST_ICUTXTYPE B
				  		  ON A.OWKEY = B.OWKEY
						 AND  A.ICUNITKEY = B.ICUNITKEY
				  INNER JOIN TADMIN_MST_OW C
						  ON A.OWKEY = C.OWKEY
				  LEFT OUTER JOIN TADMIN_MST_IC IC
							   ON A.OWKEY = IC.OWKEY
							  AND A.ICUNITKEY = IC.ICUNITKEY
				  WHERE IC.DELYN ='N'
			)
	</select>

	<select id="selectItemUnit" resultType="camelMap">
		/* oms-item-itemunit-sql-oracle.xml - selectItemUnit */
		#{GRIDPAGING_ROWNUMTYPE_TOP}
		SELECT A.* 
		FROM (
				SELECT '0' AS CHK
				    ,A.OWKEY -- 화주코드
				    ,C.OWNM -- 화주명
			        ,A.SPEC -- 규격
			        ,D.BARCODE -- 바코드정보
			        ,B.ICUNITTYPE -- 상품단위유형
			        ,B.ICUNITORDER -- 상품단위순서
			        ,B.ICUNITQTY -- 상품단위수량
 					,B.WIDTH -- 가로
			        ,B.DEPTH -- 세로
			        ,B.HEIGHT -- 높이
			        ,B.SIZEUNIT -- 사이즈단위
			        ,B.WEIGHT -- 중량
			        ,B.WEIGHTUNIT -- 중량단위
			        ,B.VOL -- 부피
			        ,B.VOLUNIT -- 부피단위
			        ,A.INSERTDATE -- 입력일시
			        ,A.INSERTURKEY -- 입력자
			        ,A.UPDATEDATE -- 수정일시
			        ,A.UPDATEURKEY -- 수정자
			        ,A.ASRTYN -- 아소트여부 05.12 추가
			        ,A.DELYN -- 삭제여부 05.12 추가
			        ,A.ICNM
			        ,A.ICKEY
			        , B.PLTROW      /*PLT 단*/
				    , B.PLTCOL      /*PLT 열 (한단 수량)*/
				    , B.CPP         /*PLT 구성(CPP)*/
				FROM TORDER_MST_IC A
			    INNER JOIN TORDER_MST_ICUTXTYPE B
				   		ON A.OWKEY = B.OWKEY
					   AND  A.ICKEY = B.ICKEY
		               AND  B.DELYN ='N'
			    INNER JOIN TORDER_MST_OW C
				    	ON A.OWKEY = C.OWKEY
                LEFT OUTER JOIN TORDER_MST_ICBACODE D
				   		ON A.OWKEY = D.OWKEY
					   AND A.ICKEY = D.ICKEY
					   AND D.UOM = B.ICUNITTYPE
					   AND D.DELYN ='N'
			 	WHERE 	A.DELYN ='N'
		   ) A
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
		   WHERE 	#{SEARCH_CONDITION}
		</if>		
		<choose>
			<when test='sortValue !=null and sortValue != ""'>	
				<if test='sortValue == "DESC" and colName !=null'>
				ORDER BY #{colName} DESC
				</if>
				<if test='sortValue == "ASC" and colName !=null'>
				ORDER BY #{colName} ASC
				</if>	
			</when>	
			<otherwise>
				ORDER BY UPDATEDATE DESC , ICKEY ASC
			</otherwise>
		</choose>       
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>

	
	<select id="selectTOmsinMstIcutxtypexctCount" resultType="java.lang.Integer" >
		/* oms-item-itemunit-sql-oracle.xml - selectTOmsinMstIcutxtypexctCount */
		SELECT 	COUNT(1) 
		  FROM 	TADMIN_MST_ICUTXTYPEXCT
		 WHERE 	CTKEY = #{ctkey}
		   AND  OWKEY = #{owkey}
		   AND	ICUNITKEY = #{icunitkey}
		   AND	ICUNITTYPE = #{icunittype}
	</select>

	<select id="selectTOmsinMstIcutxtypexct" resultType="camelMap">
		/* oms-item-itemunit-sql-oracle.xml - selectTOmsinMstIcutxtypexct */
		SELECT  '0' AS CHK
		    	,A.OWKEY
				,A.ICUNITKEY
		      	,A.CTKEY
		      	,B.CTNM
		      	,A.ICUNITTYPE
		  FROM 	TADMIN_MST_ICUTXTYPEXCT A
		  INNER JOIN TADMIN_MST_CT B
		  		  ON A.CTKEY = B.CTKEY
				 AND B.DELYN = 'N'
		 WHERE	A.OWKEY = #{owkey}
		   AND  A.ICUNITKEY = #{icunitkey}
		   AND  A.ICUNITTYPE = #{icunittype}
		   AND  B.MANAGEMENTYN = 'Y'
	</select>

	<select id="selectItemUnitType" resultType="camelMap">
		/* oms-item-itemunit-sql-oracle.xml - selectItemUnitType */
		SELECT  A.OWKEY
				,C.MASTERUPDATEIMPOS AS FN_GET_MASTER_IMPOS
				,A.ICUNITKEY
		        ,B.ICUNITTYPE
		        ,B.ICUNITQTY
		        ,A.CLOSDATE
		        ,B.INSERTDATE
		        ,B.INSERTURKEY
		        ,B.ICUNITORDER
		        ,(SELECT MAX(C.ICNM) FROM TADMIN_MST_IC C WHERE C.ICKEY = A.ICUNITKEY) ICNM
		  FROM 	TADMIN_MST_ICUT A
		  INNER JOIN TADMIN_MST_ICUTXTYPE B
		      	  ON A.OWKEY = B.OWKEY
				 AND  A.ICUNITKEY = B.ICUNITKEY
		  INNER JOIN TADMIN_MST_OW C
		  	  	  ON A.OWKEY = C.OWKEY
		 WHERE  A.OWKEY = #{owkey}
		   AND 	A.ICUNITKEY = #{icunitkey}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(icunittype)" >
		   AND  B.ICUNITTYPE = #{icunittype}
		</if>
	</select>

	<select id="selectTAdminMstIcut" resultType="camelMap">
		/* oms-item-itemunit-sql-oracle.xml - selectTAdminMstIcut */
		SELECT
				INSERTDATE
				,UPDATEDATE
				,INSERTURKEY
 				,UPDATEURKEY
				,ICUNITKEY
				,CLOSDATE
		  FROM 	TADMIN_MST_ICUT
		 WHERE 	OWKEY = #{owkey}
		   AND	ICUNITKEY = #{icunitkey}
	</select>

	<select id="selecticuttypeChk" resultType="camelMap">
		/* oms-item-itemunit-sql-oracle.xml - selecticuttypeChk */
		SELECT I.ICUNITTYPE, T.ICUNITKEY
          FROM (
                SELECT OWKEY
                     , ICUNITKEY
                     , CASE WHEN ICUNITKEY=#{icunitkey} THEN 0 ELSE 1 END AS KEYORDER
                     , SUM(CASE WHEN ICUNITTYPE='EA' AND ICUNITQTY=1 THEN 1 ELSE 0 END) AS EA_CNT
                     , SUM(CASE WHEN ICUNITTYPE='CS' AND ICUNITQTY=COALESCE(#{boxqtyset}, 1) THEN 1 ELSE 0 END) AS BOX_CNT
                     , SUM(CASE WHEN ICUNITTYPE='BOL' AND ICUNITQTY=COALESCE(#{bolqtyset}, 1) THEN 1 ELSE 0 END) AS BOL_CNT
                  FROM TADMIN_MST_ICUTXTYPE
                 WHERE OWKEY = #{owkey}
                 GROUP BY OWKEY, ICUNITKEY
                HAVING COUNT(1) = 3 /*ea, cs, bol 이 모두 있어야 set로 봄*/
               ) T
          JOIN TADMIN_MST_ICUTXTYPE I
            ON T.OWKEY = I.OWKEY
           AND T.ICUNITKEY = I.ICUNITKEY
           AND I.ICUNITORDER = 1
         WHERE 1=1
           AND T.EA_CNT > 0
           AND T.BOX_CNT > 0
           AND T.BOL_CNT > 0
         ORDER BY T.KEYORDER
                , T.ICUNITKEY DESC
	</select>

	<insert id="insertTOmsinMstIcut">
		/* oms-item-itemunit-sql-oracle.xml - insertTOmsinMstIcut */
		INSERT INTO TADMIN_MST_ICUT
		(
		      OWKEY    /*화주 코드*/
		    , ICUNITKEY    /*상품 단위 코드*/
		    , CLOSDATE    /*종료 일시*/
		    , INSERTDATE    /*입력 일시*/
		    , INSERTURKEY    /*입력 사용자 ID*/
		    , UPDATEDATE    /*수정 일시*/
		    , UPDATEURKEY    /*수정 사용자 ID*/
		)
		SELECT OWKEY    /*화주 코드*/
		     , ICUNITKEY    /*상품 단위 코드*/
		     , SUBSTR(#{closdate}, 0, 14)
			 , #{sysdate}
			 , #{surkey}
			 , #{sysdate}
			 , #{surkey}
		  FROM (
		  		SELECT T.OWKEY
		  		     , T.ICUNITKEY
		  		     , CASE WHEN IU.ICUNITKEY IS NULL THEN 'Y' ELSE 'N' END AS SAVEYN
		  		  FROM (
		  		  		SELECT #{owkey} AS OWKEY
		  		  		     , #{icunitkey} AS ICUNITKEY
		  		  	   ) T
		  		  LEFT JOIN TADMIN_MST_ICUT IU
		  		    ON T.OWKEY = IU.OWKEY
		  		   AND T.ICUNITKEY = IU.ICUNITKEY
		  	   ) TT
		 WHERE SAVEYN = 'Y'
	</insert>


	<select id="selectTOmsinMstIcutxtype" resultType="camelMap">
		/* oms-item-itemunit-sql-oracle.xml - selectTOmsinMstIcutxtype */
		SELECT OWKEY
                ,ICUNITKEY
                ,ICUNITTYPE
                ,ICUNITORDER
                ,ICUNITQTY
                ,INSERTDATE
                ,UPDATEDATE
                ,INSERTURKEY
 				,UPDATEURKEY
                ,(SELECT MAX(C.ICNM) FROM TADMIN_MST_IC C WHERE C.ICKEY = A.ICUNITKEY) ICNM
            FROM (
          SELECT     A.OWKEY
                ,A.ICUNITKEY
                ,A.ICUNITTYPE
                ,A.ICUNITORDER
                ,A.ICUNITQTY
                ,A.INSERTDATE
                ,A.UPDATEDATE
                ,A.INSERTURKEY
 				,A.UPDATEURKEY
          FROM  TADMIN_MST_ICUTXTYPE A
          ) A
	     WHERE  OWKEY = #{owkey}
		   AND  ICUNITKEY = #{icunitkey}
		<if test="icuttype != null">
		   AND ICUNITTYPE = #{icunittype}
		</if>
	</select>

	<update id="updateTOmsinMstIcut">
		/* oms-item-itemunit-sql-oracle.xml - updateTOmsinMstIcut */
		UPDATE 	TADMIN_MST_ICUT
		   SET 	CLOSDATE = SUBSTR(#{closdate}, 0, 14)
			  	,UPDATEDATE = #{sysdate}
			  	,UPDATEURKEY = #{surkey}
		 WHERE  OWKEY = #{owkey}
		   AND	ICUNITKEY = #{icunitkey}
	</update>

	<insert id="insertTOmsinMstIcutxtype">
		/* oms-item-itemunit-sql-oracle.xml - insertTOmsinMstIcutxtype */
		INSERT INTO TADMIN_MST_ICUTXTYPE
		(
			OWKEY
			,ICUNITKEY
			,ICUNITTYPE
			,ICUNITORDER
			,ICUNITQTY
			,INSERTDATE
			,INSERTURKEY
			,UPDATEDATE
			,UPDATEURKEY
			,LENGTH
			,WIDTH
			,HEIGHT
			,WEIGHT
			,VOL
			,SIZEUNIT
			,VOLUNIT
			,WEIGHTUNIT
		 )	VALUES	(
		 	#{owkey}
			,#{icunitkey}
			,#{icunittype}
			,#{icunitorder}
			,#{icunitqty}
			,#{sysdate}
			,#{surkey}
			,#{sysdate}
			,#{surkey}
			,#{lengthuom}
			,#{width}
			,#{height}
			,#{weight}
			,#{vol}
			,#{sizeunit}
			,#{volunit}
			,#{weightunit}
		 )
	</insert>

	<update id="updateTOmsinMstIcutxtype">
		/* oms-item-itemunit-sql-oracle.xml - updateTOmsinMstIcutxtype */
		UPDATE 	TADMIN_MST_ICUTXTYPE
		   SET 	ICUNITORDER = #{icunitorder}
		   		,ICUNITQTY = #{icunitqty}
		   		,UPDATEDATE = #{sysdate}
			  	,UPDATEURKEY = #{surkey}
		 WHERE  OWKEY = #{owkey}
		   AND	ICUNITKEY = #{icunitkey}
		   AND 	ICUNITTYPE = #{icunittype}
	</update>

	<delete id="deleteTOmsinMstIcutxtype">
		/* oms-item-itemunit-sql-oracle.xml - deleteTOmsinMstIcutxtype */
		DELETE
		  FROM 	TADMIN_MST_ICUTXTYPE
		 WHERE 	OWKEY = #{owkey}
		   AND	ICUNITKEY = #{icunitkey}
		   AND 	ICUNITTYPE = #{icunittype}
	</delete>

	<insert id="insertTOmsinMstIcutxtypexct">
		/* oms-item-itemunit-sql-oracle.xml - insertTOmsinMstIcutxtypexct */
		INSERT INTO TADMIN_MST_ICUTXTYPEXCT
		(
			OWKEY
			,ICUNITKEY
			,ICUNITTYPE
			,CTKEY
			,INSERTDATE
			,INSERTURKEY
			,UPDATEDATE
			,UPDATEURKEY
		 )	VALUES	(
		 	#{owkey}
		 	,#{icunitkey}
			,#{icunittype}
			,#{ctkey}
		 	,#{sysdate}
			,#{surkey}
			,#{sysdate}
			,#{surkey}
		 )
	</insert>

	<insert id="insertTOmsinMstByOmsIcutxtypexct">
		/* oms-item-itemunit-sql-oracle.xml - insertTOmsinMstByOmsIcutxtypexct */
		INSERT INTO TADMIN_MST_ICUTXTYPEXCT
		(
			  OWKEY    /*화주 코드*/
			, ICUNITKEY    /*물품 단위 코드*/
			, ICUNITTYPE    /*물품 단위 유형*/
			, CTKEY    /*센터 코드*/
			, INSERTDATE    /*입력 일시*/
			, INSERTURKEY    /*입력 사용자 ID*/
			, UPDATEDATE    /*수정 일시*/
			, UPDATEURKEY    /*수정 사용자 ID*/
		)
		SELECT TT.OWKEY    /*화주 코드*/
			 , TT.ICUNITKEY    /*물품 단위 코드*/
			 , TT.ICUNITTYPE    /*물품 단위 유형*/
			 , #{ctkey} AS CTKEY    /*센터 코드*/
			 , #{sysdate} AS INSERTDATE       /*입력 일시*/
		     , #{surkey} AS INSERTURKEY       /*입력 사용자 ID*/
		     , #{sysdate} AS UPDATEDATE       /*수정 일시*/
		     , #{surkey} AS UPDATEURKEY       /*수정 사용자 ID*/
		  FROM (
		  		SELECT IC.OWKEY    /*화주 코드*/
					 , IC.ICUNITKEY    /*물품 단위 코드*/
					 , IU.ICUNITTYPE    /*물품 단위 유형*/
					 , CASE WHEN M.OWKEY IS NULL THEN 'Y' ELSE 'N' END AS SAVEYN
				  FROM TADMIN_MST_IC IC
				  JOIN TADMIN_MST_ICUTXTYPE IU
				    ON IC.OWKEY = IU.OWKEY
				   AND IC.ICUNITKEY = IU.ICUNITKEY
				  LEFT JOIN TADMIN_MST_ICUTXTYPEXCT M
				    ON IU.OWKEY = M.OWKEY
				   AND IU.ICUNITKEY = M.ICUNITKEY
				   AND IU.ICUNITTYPE = M.ICUNITTYPE
				   AND M.CTKEY = #{ctkey}
				 WHERE IC.OWKEY = #{owkey}
				   AND IC.ICKEY = #{ickey}
		  	   ) TT
		 WHERE TT.SAVEYN = 'Y'
	</insert>

	<delete id="deleteTOmsinMstIcutxtypexct">
		/* oms-item-itemunit-sql-oracle.xml - deleteTOmsinMstIcutxtypexct */
		DELETE
		  FROM 	TADMIN_MST_ICUTXTYPEXCT
		 WHERE 	OWKEY = #{owkey}
		   AND	ICUNITKEY = #{icunitkey}
		   AND 	ICUNITTYPE =  #{icunittype}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ctkey)" >
		   AND 	CTKEY = #{ctkey}
		</if>
	</delete>

	<select id="selectItemUnitUseYn" resultType="camelMap">
		/* oms-item-itemunit-sql-oracle.xml - selectItemUnitUseYn */
		SELECT
		    A.ICUNITKEY
		FROM
		    TADMIN_MST_IC A
		LEFT OUTER JOIN TADMIN_MST_ICSB B
					 ON A.OWKEY = B.OWKEY
				    AND A.ICKEY = B.ICKEY
		INNER JOIN TADMIN_MST_OW C
				ON A.OWKEY = C.OWKEY
		LEFT OUTER JOIN TADMIN_MST_AC D
					 ON A.OWKEY = D.OWKEY
				    AND A.ACKEY = D.ACKEY
		WHERE   A.OWKEY = #{owkey}
		    AND A.DELYN = 'N'
		    AND A.ICUNITKEY IN (#{icunitkeyAry})
	</select>

	<insert id="mergeTOmsinMstIcutxtype">
		/* oms-item-itemunit-sql-oracle.xml - mergeTOmsinMstIcuttype */
		INSERT INTO TADMIN_MST_ICUTXTYPE (
					OWKEY
				,ICUNITKEY
				,ICUNITTYPE
				,ICUNITORDER
				,ICUNITQTY
				,INSERTDATE
				,INSERTURKEY
				,UPDATEDATE
				,UPDATEURKEY
				,LENGTH
				,WIDTH
				,HEIGHT
				,WEIGHT
				,VOL
				,SIZEUNIT
				,VOLUNIT
				,WEIGHTUNIT
				) VALUES (
								 #{owkey}
							   ,#{icunitkey}
							   ,#{icunittype}
							   ,#{icunitorder}
							   ,#{icunitqty}
							   ,#{sysdate}
							   ,#{surkey}
							   ,#{sysdate}
							   ,#{surkey}
							   ,#{lengthunit}
							   ,#{widthunit}
							   ,#{heightunit}
							   ,#{weight}
							   ,#{vol}
							   ,#{sizeunit}
							   ,#{volunit}
							   ,'G'
							   )
			ON CONFLICT (OWKEY, ICUNITKEY, ICUNITTYPE) DO UPDATE SET
					  ICUNITQTY 	= #{icunitqty}
					, ICUNITORDER 	= #{icunitorder}
					, LENGTH    	= #{lengthunit}
					, WIDTH	    = #{widthunit}
					, HEIGHT 		= #{heightunit}
					, WEIGHT 		= #{weight}
					, VOL 		= #{vol}
					, WEIGHTUNIT  = 'G'
					, UPDATEURKEY = #{surkey}
					, UPDATEDATE  = #{sysdate}
	</insert>

	<insert id="mergeTOmsinMstIcutxtypexct">
		/* oms-item-itemunit-sql-oracle.xml - mergeTOmsinMstIcutxtypexct */
		INSERT INTO TADMIN_MST_ICUTXTYPEXCT (
					 OWKEY
				,ICUNITKEY
				,ICUNITTYPE
				,CTKEY
				,INSERTDATE
				,INSERTURKEY
				,UPDATEDATE
				,UPDATEURKEY
				) VALUES (
					 #{owkey}
				   ,#{icunitkey}
				   ,#{icunittype}
				   ,#{ctkey}
				   ,#{sysdate}
				   ,#{surkey}
				   ,#{sysdate}
				   ,#{surkey}
				   )
			ON CONFLICT (OWKEY, CTKEY, ICUNITKEY, ICUNITTYPE) DO UPDATE SET
					UPDATEDATE	= #{sysdate}
				   ,UPDATEURKEY = #{surkey}
	</insert>
	
	<insert id="insertTAdminMstIcxctBak">
		/* oms-item-itemunit-sql-oracle.xml - insertTAdminMstIcxctBak */
		INSERT INTO TORDER_MST_ICXCT
		(
			  OWKEY    /*화주 코드*/
			, ICKEY    /*물품 단위 코드*/
			--, ICUNITTYPE    /*물품 단위 유형*/
			, CTKEY    /*센터 코드*/
			, ORDTYPE
			, DELYN
			, INSERTDATE    /*입력 일시*/
			, INSERTURKEY    /*입력 사용자 ID*/
			, UPDATEDATE    /*수정 일시*/
			, UPDATEURKEY    /*수정 사용자 ID*/
		)
		SELECT TT.OWKEY    /*화주 코드*/
			 , TT.ICKEY    /*물품 단위 코드*/
			 --, TT.ICUNITTYPE    /*물품 단위 유형*/
			 , #{ctkey} AS CTKEY    /*센터 코드*/
			 , '0' AS ORDTYPE
			 , 'N' AS DELYN
			 , #{sysdate} AS INSERTDATE       /*입력 일시*/
		     , #{surkey} AS INSERTURKEY       /*입력 사용자 ID*/
		     , #{sysdate} AS UPDATEDATE       /*수정 일시*/
		     , #{surkey} AS UPDATEURKEY       /*수정 사용자 ID*/
		  FROM (
		  		SELECT IC.OWKEY    /*화주 코드*/
					 , IC.ICKEY    /*물품 단위 코드*/
					 , M.CTKEY
					 , CASE WHEN M.OWKEY IS NULL THEN 'Y' ELSE 'N' END AS SAVEYN
				  FROM TORDER_MST_IC IC
				  LEFT JOIN TORDER_MST_ICXCT M
				    ON IC.OWKEY = M.OWKEY
				   AND IC.ICKEY = M.ICKEY
				   AND M.CTKEY = #{ctkey}
				 WHERE IC.OWKEY = #{owkey}
				   AND IC.ICKEY = #{ickey}
		  	   ) TT
		 WHERE TT.SAVEYN = 'Y'
	</insert>
	
	<insert id="insertTAdminMstIcxct">
		/* oms-item-itemunit-sql-oracle.xml - insertTAdminMstIcxct */
		INSERT INTO TORDER_MST_ICXCT (
				 OWKEY    /*화주 코드*/
				, ICKEY    /*물품 단위 코드*/
				, CTKEY    /*센터 코드*/
                , DSBTGRADE
                , ROBSORTERICYN
                , DFSHPMTRYN
				, DELYN
				, INSERTDATE    /*입력 일시*/
				, INSERTURKEY    /*입력 사용자 ID*/
				, UPDATEDATE    /*수정 일시*/
				, UPDATEURKEY    /*수정 사용자 ID*/
			  )
			  SELECT
				 IC.OWKEY    /*화주 코드*/
				, IC.ICKEY    /*물품 단위 코드*/
				, #{ctkey} /*센터 코드*/
                , #{dbstgrade}
                , #{robsortericyn}
                , #{dfshpmtryn}
				, 'N' -- DELYN
				, #{sysdate}    /*입력 일시*/
				, #{surkey}    /*입력 사용자 ID*/
				, #{sysdate}    /*수정 일시*/
				, #{surkey}    /*수정 사용자 ID*/
			  FROM TORDER_MST_IC IC
			  WHERE IC.OWKEY = #{owkey}
			    AND IC.ICKEY = #{ickey}
			  ON CONFLICT (OWKEY, ICKEY, CTKEY) DO UPDATE SET
				 DELYN 		= 'N'
        		,UPDATEDATE	= #{sysdate}
				,UPDATEURKEY = #{surkey}
	</insert>
	
</mapper>
