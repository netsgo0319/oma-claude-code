	<insert id="insertTAdminMstIcxctExcel">
		/* oms-item-itemcode-sql-oracle.xml - insertTAdminMstIcxctExcel */
		INSERT INTO TADMIN_MST_ICXCT (
			  OWKEY
			, ICKEY
			, CTKEY
			, LOGGRPCD
			, NEWYN
			, ACKEY
			, ORDTYPE
			, ICGRPKEY
			, DELYN
			, INSERTDATE
			, INSERTURKEY
			, UPDATEDATE
			, UPDATEURKEY
		)
		SELECT #{owkey} AS OWKEY
			 , A.ICKEY
			 , C.CTKEY
			 , A.LOGGRPCD
			 , 'Y' AS NEWYN
			 , A.ACKEY
		     , '0' AS ORDTYPE
			 , A.ICGRPKEY
			 , 'N' AS DELYN
			 , A.INSERTDATE
			 , A.INSERTURKEY
			 , A.UPDATEDATE
			 , A.UPDATEURKEY
		FROM (   SELECT UPLDKEY
					  , ICKEY
					  , MIN(UPLDSEQ) AS UPLDSEQ
				 FROM TADMIN_UPLOAD_IC
				 WHERE UPLDKEY = #{upldkey}
				   AND DELYN = 'N'
				 GROUP BY UPLDKEY, ICKEY ) B
				 INNER JOIN TADMIN_UPLOAD_IC A
						 ON A.UPLDKEY = B.UPLDKEY
						AND A.UPLDSEQ = B.UPLDSEQ
						AND A.ICKEY 	= B.ICKEY
			 INNER JOIN TADMIN_MST_ICGRXCT C
					 ON C.OWKEY = #{owkey}
					AND C.ICGRPKEY = A.ICGRPKEY
					AND C.ICGRPTYPE = 'CATEGORY'
		WHERE A.UPLDKEY = #{upldkey}
		  AND A.DELYN = 'N'
		  AND A.ERRCD IS NULL
	</insert>

	<insert id="insertTTMstIcxctExcel">
		/* oms-item-itemcode-sql-oracle.xml - insertTTMstIcxctExcel */
		INSERT INTO TT_MST_ICXCT (
			  OWKEY
			, ICKEY
			, CTKEY
			, LOGGRPCD
			, VOLTYPE
			, NEWYN
			, ORDTYPE
			, ICGRKEY
			, DCKEY
			, DELYN
			, INSERTDATE
			, INSERTURKEY
			, UPDATEDATE
			, UPDATEURKEY
		)
		SELECT #{owkey} AS OWKEY
			 , A.ICKEY
			 , C.CTKEY
			 , A.LOGGRPCD
			 , '0' AS VOLTYPE
			 , 'Y' AS NEWYN
			 , '0' AS ORDTYPE
			 , A.ICGRPKEY
			 , '1' AS DCKEY
			 , 'N' AS DELYN
			 , A.INSERTDATE    /*입력일자*/
			 , A.INSERTURKEY    /*입력사용자*/
			 , A.UPDATEDATE    /*수정일자*/
			 , A.UPDATEURKEY    /*수정사용자*/
		FROM (   SELECT UPLDKEY
					  , ICKEY
					  , MIN(UPLDSEQ) AS UPLDSEQ
				 FROM TADMIN_UPLOAD_IC
				 WHERE UPLDKEY = #{upldkey}
				   AND DELYN = 'N'
				 GROUP BY UPLDKEY, ICKEY ) B
				 INNER JOIN TADMIN_UPLOAD_IC A
						 ON A.UPLDKEY = B.UPLDKEY
						AND A.UPLDSEQ = B.UPLDSEQ
						AND A.ICKEY 	= B.ICKEY
			 INNER JOIN TADMIN_MST_ICGRXCT C
					 ON C.OWKEY = #{owkey}
					AND C.ICGRPKEY = A.ICGRPKEY
					AND C.ICGRPTYPE = 'CATEGORY'
		WHERE A.UPLDKEY = #{upldkey}
		  AND A.DELYN = 'N'
		  AND A.ERRCD IS NULL
	</insert>

	<insert id="insertTAdminMstCtxAcXIcxctExcel">
		/* oms-item-itemcode-sql-oracle.xml - insertTAdminMstCtxAcXIcxctExcel */
		INSERT INTO TADMIN_MST_CTXACXIC (
		  	  OWKEY
			, CTKEY
			, ICKEY
			, ACKEY
			, CP
			, PODDLNTIME
			, POICUTTYPE
			, SMPOMLP
			, ASNAUTOYN
			, POHDTYPE
			, CTPOYN
			, POSTOPYN
			, DELYN
			, IBTIME
			, HOLD
			, INSERTDATE
			, INSERTURKEY
			, UPDATEDATE
			, UPDATEURKEY )
		SELECT #{owkey}
			 , C.CTKEY
			 , A.ICKEY
			 , A.ACKEY
			 ,  0
			 ,  '140000'
			 ,  'EA'
			 ,  '1'
			 ,  'N'
			 ,  '140'
			 ,  'N'
			 ,  'N'
			 ,  'N'
			 ,  '110000'
			 ,  'N'
			 , A.INSERTDATE    /*입력일자*/
			 , A.INSERTURKEY    /*입력사용자*/
			 , A.UPDATEDATE    /*수정일자*/
			 , A.UPDATEURKEY    /*수정사용자*/
		FROM (	 SELECT T.UPLDKEY
		              , T.UPLDSEQ
		              , CASE WHEN T.ACKEY IS NULL THEN 'Y' ELSE 'N' END AS SAVEYN
				   FROM (   SELECT UPLDKEY
								 , ICKEY
								 , MIN(UPLDSEQ) AS UPLDSEQ
							FROM TADMIN_UPLOAD_IC
							WHERE UPLDKEY = #{upldkey}
							  AND DELYN = 'N'
							GROUP BY UPLDKEY, ICKEY ) B
							INNER JOIN TADMIN_UPLOAD_IC T
									ON T.UPLDKEY = B.UPLDKEY
								   AND T.UPLDSEQ = B.UPLDSEQ
								   AND T.ICKEY 	   = B.ICKEY
				 WHERE T.UPLDKEY = #{upldkey}
				   AND T.DELYN = 'N'
				   AND T.ERRCD IS NULL ) B
			INNER JOIN TADMIN_UPLOAD_IC A
					ON B.UPLDKEY = A.UPLDKEY
				   AND B.UPLDSEQ = A.UPLDSEQ
			INNER JOIN TADMIN_MST_ICGRXCT C
					ON C.OWKEY = #{owkey}
				   AND C.ICGRPKEY = A.ICGRPKEY
				   AND C.ICGRPTYPE = 'CATEGORY'
		WHERE A.UPLDKEY = #{upldkey}
		  AND B.SAVEYN = 'N'
	</insert>

	<insert id="insertTAdminMstIcutxtypexct">
		/* oms-item-itemcode-sql-oracle.xml - insertTAdminMstIcutxtypexct */
		INSERT INTO TADMIN_MST_ICUTXTYPEXCT (
			  OWKEY    /*화주 코드*/
			, ICUNITKEY    /*물품 단위 코드*/
			, ICUNITTYPE    /*물품 단위 유형*/
			, CTKEY    /*센터 코드*/
			, INSERTDATE    /*입력 일시*/
			, INSERTURKEY    /*입력 사용자 ID*/
			, UPDATEDATE    /*수정 일시*/
			, UPDATEURKEY    /*수정 사용자 ID*/
		)
		SELECT #{owkey} AS OWKEY
			 , A.ICUNITKEY    /*물품 단위 코드*/
			 , A.ICUNITTYPE    /*물품 단위 유형*/
			 , B.CTKEY    /*센터 코드*/
			 , A.INSERTDATE    /*입력 일시*/
			 , A.INSERTURKEY    /*입력 사용자 ID*/
			 , A.UPDATEDATE    /*수정 일시*/
			 , A.UPDATEURKEY    /*수정 사용자 ID*/
		FROM TADMIN_UPLOAD_IC A
			 INNER JOIN TADMIN_MST_ICGRXCT B
					 ON B.OWKEY = #{owkey}
					AND B.ICGRPKEY = A.ICGRPKEY
					AND B.ICGRPTYPE = 'CATEGORY'
		WHERE A.UPLDKEY = #{upldkey}
		  AND A.DELYN = 'N'
		  AND A.ERRCD IS NULL
	</insert>
	
	<select id="selectAsrtMst" resultType="camelMap">
		/* oms-item-itemcode-sql-oracle.xml - selectAsrtMst */
		SELECT B.OWKEY
		     , B.ASRTKEY 
		     , B.ASRTREPKEY 
			 , B.ASRTNM 
			 , CTG.SCTGCD 
			 , CTG.SCTGNM
			 , CTG.MCTGCD
			 , CTG.MCTGNM
			 , CTG.LCTGCD
			 , CTG.LCTGNM
			 , B.QTY 
			 , B.ASRTSTATUS 
			 , B.ASRTREPKEY AS ICKEY
			 , #{icgrpkey} AS ICGRPKEY
			 , CASE WHEN AC.ICKEY IS NOT NULL THEN 'Y' ELSE 'N' END AS ASRTICYN
			 , B.INSERTDATE 
			 , B.INSERTURKEY
			 , B.UPDATEDATE 
			 , B.UPDATEURKEY
		FROM (SELECT MB.OWKEY
                   , MB.ASRTKEY AS ICKEY
                FROM TORDER_MST_ASRT MA
                JOIN TORDER_MST_ASRT MB
                  ON MA.OWKEY = MB.OWKEY
                 AND MA.ASRTREPKEY = MB.ASRTREPKEY
               WHERE MA.OWKEY = #{owkey}
                 AND MA.ASRTKEY = #{ickey}
               UNION ALL
              SELECT MB.OWKEY
                   , MB.ASRTKEY AS ICKEY
                FROM TORDER_MST_IC MA
                JOIN TORDER_MST_ASRT MB
                  ON MA.OWKEY = MB.OWKEY
                 AND MA.ICKEY = MB.ASRTREPKEY
               WHERE MA.OWKEY = #{owkey}
                 AND MA.ICKEY = #{ickey}
             ) A
        INNER JOIN TORDER_MST_ASRT B
        ON A.OWKEY = B.OWKEY 
        AND A.ICKEY = B.ASRTKEY -- ERP에서 받는 데이터 정합하지 않을 경우 대비 -- MST_IC.ASRTREPKEY 변경 및 삭제
		LEFT OUTER JOIN TORDER_MST_IC AC
		ON B.OWKEY = AC.OWKEY
		AND B.ASRTKEY = AC.ICKEY
		LEFT OUTER JOIN (
						SELECT A.CTGKEY AS SCTGCD
							 , A.CTGNM AS SCTGNM
							 , A.UPPERCTGKEY AS MCTGCD
							 , B.CTGNM AS MCTGNM
							 , C.CTGKEY AS LCTGCD
							 , C.CTGNM AS LCTGNM
						FROM TORDER_MST_CTG A
						LEFT OUTER JOIN TORDER_MST_CTG B
						ON A.UPPERCTGKEY = B.CTGKEY
						LEFT OUTER JOIN TORDER_MST_CTG C
						ON B.UPPERCTGKEY = C.CTGKEY
						WHERE A.DELYN = 'N' 
						AND A.CTGKEY = #{ctgkey}
						) CTG
		ON 1 = 1
		WHERE 1 = 1
	</select>
	
	<select id="selectAsrtHst" resultType="camelMap">
		/* oms-item-itemcode-sql-oracle.xml - selectAsrtHst */
		SELECT B.ASRTKEY 
		     , B.ASRTNM 
		     , B.UPDATEDATE 
		     , B.ASRTSTATUS 
		     , B.QTY 
		     , '비고' AS BIGO
		     , B.SEQ 
		     , B.INSERTDATE 
			 , B.INSERTURKEY
			 , B.UPDATEDATE 
			 , B.UPDATEURKEY
		FROM TORDER_MST_ASRT A
		INNER JOIN TORDER_HIST_ASRT B
		ON A.OWKEY = B.OWKEY 
		AND A.ASRTKEY = B.ASRTKEY
		WHERE 1 = 1
		AND A.OWKEY = #{owkey}
		AND A.ASRTKEY = #{asrtkey}
		ORDER BY B.SEQ
	</select>
	
	<insert id="mergeTAdminMstIcutxtype">
		/* oms-item-itemcode-sql-oracle.xml - mergeTAdminMstIcutxtype */
		MERGE INTO TADMIN_MST_ICUTXTYPE A
			 USING DUAL
				ON (OWKEY = #{owkey}
			   AND ICUNITKEY = #{icunitkey}
			   AND ICUNITTYPE = #{icunittype})
			WHEN MATCHED THEN
				UPDATE
					SET ICUNITQTY 	= #{icunitqty}
					  , ICUNITORDER 	= #{icunitorder}
					  , LENGTH    	= #{lengthunit}
					  , WIDTH	    = #{widthunit}
					  , HEIGHT 		= #{heightunit}
					  , WEIGHT 		= #{weight}
					  , VOL 		= #{vol}
					  , WEIGHTUNIT  = 'G'
					  , UPDATEURKEY = #{surkey}
					  , UPDATEDATE  = #{sysdate}
			WHEN NOT MATCHED THEN
				INSERT (
						OWKEY
						,ICUNITKEY
						,ICUNITTYPE
						,ICUNITORDER
						,ICUNITQTY
						,INSERTDATE
						,INSERTURKEY
						,UPDATEDATE
						,UPDATEURKEY
						,LENGTH
						,WIDTH
						,HEIGHT
						,WEIGHT
						,VOL
						,SIZEUNIT
						,VOLUNIT
						,WEIGHTUNIT
					)	
					VALUES	
					(
					 #{owkey}
				   ,#{icunitkey}
				   ,#{icunittype}
				   ,#{icunitorder}
				   ,#{icunitqty}
				   ,#{sysdate}
				   ,#{surkey}
				   ,#{sysdate}
				   ,#{surkey}
				   ,#{lengthunit}
				   ,#{widthunit}
				   ,#{heightunit}
				   ,#{weight}
				   ,#{vol}
				   ,#{sizeunit}
				   ,#{volunit}
				   ,'G'
				   )
	</insert>
	
	<select id="getTAdminMstCtList" resultType="camelMap">
		/* oms-item-itemcode-sql-oracle.xml - getTAdminMstCtList */
		SELECT 	'0' AS CHK
		    	,CTKEY
				,CTNM
		  FROM 	TORDER_MST_CT
		 WHERE	CLOSDATE >= #{sysdate}
		   AND	DELYN = 'N'
		   AND  MANAGEMENTYN = 'Y'
	</select>
	
	<insert id="mergeTAdminMstIcutxtypexct">
		/* oms-item-itemcode-sql-oracle.xml - mergeTAdminMstIcutxtypexct */
		MERGE INTO TORDER_MST_ICUTXTYPE
			USING DUAL
			ON (
				OWKEY = #{owkey}
				AND ICKEY = #{ickey}
				AND ICUNITTYPE = #{icunittype}
			   )
			WHEN MATCHED THEN
				UPDATE
				   SET ICUNITORDER = #{icunitorder}
				     , ICUNITQTY = #{icunitqty}
				     , DEPTH = #{depth}
				     , WIDTH = #{width}
				     , HEIGHT = #{height}				     
				     , SIZEUNIT = #{sizeunit}
				     , DELYN = #{delyn}
				     , UPDATEDATE = #{sysdate}
					 , UPDATEURKEY = #{surkey}
			WHEN NOT MATCHED THEN
				INSERT  
				(
				 OWKEY
			    ,ICKEY
				,ICUNITTYPE
				,ICUNITORDER
				,ICUNITQTY
				,DEPTH
				,WIDTH
				,HEIGHT
				,SIZEUNIT
				,INSERTDATE
				,INSERTURKEY
				,UPDATEDATE
				,UPDATEURKEY
				)	
				VALUES	
				(
				 #{owkey}
			    ,#{ickey}
			    ,#{icunittype}
			    ,#{icunitorder}
			    ,#{icunitqty}
			    ,#{depth}
			    ,#{width}
			    ,#{height}
			    ,#{sizeunit}
			    ,#{sysdate}
			    ,#{surkey}
			    ,#{sysdate}
			    ,#{surkey}
			   )
	</insert>
	
	<insert id="insertTorderMstIcutxtypexct">
		/* oms-item-itemcode-sql-oracle.xml - insertTorderMstIcutxtypexct */
		INSERT INTO TORDER_MST_ICUTXTYPE	
				(
				 OWKEY
			    ,ICKEY
				,ICUNITTYPE
				,ICUNITORDER
				,ICUNITQTY
				,DEPTH
				,WIDTH
				,HEIGHT
				,SIZEUNIT
				,INSERTDATE
				,INSERTURKEY
				,UPDATEDATE
				,UPDATEURKEY
				)	
				VALUES	
				(
				 #{owkey}
			    ,#{ickey}
			    ,#{icunittype}
			    ,#{icunitorder}
			    ,#{icunitqty}
			    ,#{depth}
			    ,#{width}
			    ,#{height}
			    ,#{sizeunit}
			    ,#{sysdate}
			    ,#{surkey}
			    ,#{sysdate}
			    ,#{surkey}
			   )
	</insert>
	
	<update id="updateTAdminMstIcutxtypexct">
		/* oms-item-itemcode-sql-oracle.xml - updateTAdminMstIcutxtypexct */
		UPDATE TORDER_MST_ICUTXTYPE		
		   SET ICUNITORDER = #{icunitorder}
		     , ICUNITQTY = #{icunitqty}
		     , DEPTH = #{depth}
		     , WIDTH = #{width}
		     , HEIGHT = #{height}				     
		     , SIZEUNIT = #{sizeunit}
		     , DELYN = #{delyn}
		     , UPDATEDATE = #{sysdate}
			 , UPDATEURKEY = #{surkey}
			WHERE OWKEY = #{owkey}
				AND ICKEY = #{ickey}
				AND ICUNITTYPE = #{icunittype}
	</update>
	
	<insert id="insertTAdminMstByAmsIcutxtypexct">
		/* adm-item-itemunit-sql-oracle.xml - insertTAdminMstByAmsIcutxtypexct */
		INSERT INTO TADMIN_MST_ICUTXTYPEXCT
		(
			  OWKEY    /*화주 코드*/
			, ICUNITKEY    /*물품 단위 코드*/
			, ICUNITTYPE    /*물품 단위 유형*/
			, CTKEY    /*센터 코드*/
			, INSERTDATE    /*입력 일시*/
			, INSERTURKEY    /*입력 사용자 ID*/
			, UPDATEDATE    /*수정 일시*/
			, UPDATEURKEY    /*수정 사용자 ID*/
		)
		SELECT TT.OWKEY    /*화주 코드*/
			 , TT.ICUNITKEY    /*물품 단위 코드*/
			 , TT.ICUNITTYPE    /*물품 단위 유형*/
			 , #{ctkey} AS CTKEY    /*센터 코드*/
			 , #{sysdate} AS INSERTDATE       /*입력 일시*/
		     , #{surkey} AS INSERTURKEY       /*입력 사용자 ID*/
		     , #{sysdate} AS UPDATEDATE       /*수정 일시*/
		     , #{surkey} AS UPDATEURKEY       /*수정 사용자 ID*/
		  FROM (
		  		SELECT IC.OWKEY    /*화주 코드*/
					 , IC.ICUNITKEY    /*물품 단위 코드*/
					 , IU.ICUNITTYPE    /*물품 단위 유형*/
					 , CASE WHEN M.OWKEY IS NULL THEN 'Y' ELSE 'N' END AS SAVEYN
				  FROM TADMIN_MST_IC IC
				  JOIN TADMIN_MST_ICUTXTYPE IU
				    ON IC.OWKEY = IU.OWKEY
				   AND IC.ICUNITKEY = IU.ICUNITKEY
				  LEFT JOIN TADMIN_MST_ICUTXTYPEXCT M
				    ON IU.OWKEY = M.OWKEY
				   AND IU.ICUNITKEY = M.ICUNITKEY
				   AND IU.ICUNITTYPE = M.ICUNITTYPE
				   AND M.CTKEY = #{ctkey}
				 WHERE IC.OWKEY = #{owkey}
				   AND IC.ICKEY = #{ickey}
		  	   ) TT
		 WHERE TT.SAVEYN = 'Y'
	</insert>

	<select id="checkItemAckey" resultType="java.lang.Integer">
		/* oms-item-itemcode-sql-oracle.xml - checkItemAckey */
		SELECT COUNT(1)
		FROM TORDER_MST_IC
		WHERE OWKEY = #{owkey}
		  AND ICKEY = #{ickey}
		  AND ACKEY = #{ackey}
	</select>

    <select id="selectItemCodeNoraml" resultType="camelMap">
        /* oms-item-itemcode-sql-oracle.xml - selectItemCodeNoraml */
		SELECT A.OWKEY
             , A.ICKEY
             , A.ICNM
             , COALESCE(REP.ICKEY, A.ICKEY) AS ASRTREPKEY
             , COALESCE(REP.ICNM, A.ICNM) AS ASRTREPNM
             , A.ICGRPKEY
             , A.ICGRPTYPE
             , A.ICUNITKEY
             , A.UOM
             , A.EXPCKYN
             , A.EXPCKTYPE
             , A.UDF2
             , A.UDF5
             , A.ACKEY
		     , D.ACNM
             , A.DELYN
             , A.ICTYPE
             , A.SPEC
             , A.CTGKEY
             , A.CLOSDATE
             , A.ORDSTARTDATE
             , A.FOODYN
             , A.SHELFDAY
             , A.MDTEAM
             , A.MDNM
             , #{domain} || A.ICIMGURL as ICIMGURL
             , A.OLNICKEY
             , A.OLNICTYPE
             , A.OFLNICTYPE
             , A.B2BGRADE
             , A.SEASON
             , A.DNGMGMTYN
             , A.CUSHNMEPCKGYN
             , A.EACHPCKGYN
             , A.ICORIGIN
             , A.ICMGMTUSR
             , A.SLPRC
             , A.ASRTYN
             , A.DIRCDLVYICYN
             , A.ICSTATUSDIV
             , A.PKOTICYN
             , A.ROBSORTERICYN
             , A.MTR
             , A.OBIMPSCRITRT
             , A.RENEWISTYN
             , A.CHGBFIC
             , A.CHGAFIC
             , A.IFYN
             , A.UNICYN
             , A.DSPYN
             , A.DLVRYYN
             , A.SALESTATUS
             , A.POABLEYN
             , A.OLNICDIV
             , A.OBLIMITYN
             , A.OLNIPKOTICYN
             , A.OLNIPKOTICCONT
             , A.SALESCHARA
             , A.UNICCD
             , A.EXPCKDAYS
             , A.POLYBACKPCKGYN
             , A.OVLPPCKGWIDTHVAL
             , A.OVLPPCKGDEPTHVAL
             , A.OVLPPCKGHEIGHTVAL
             , A.COMPYN
             , A.COMPCONT
             , A.PURPRC
             , A.PCKGOVLPYN
             , A.OBIMPSCRITDAYS
             , A.PCKGFOLDYN
             , A.DFSHPMTRYN
             , A.BARCODEATTACHYN
             , A.EXPRATE
             , A.HIGHFRQNCYDMGYN
             , A.LEADTIME
             , A.CMT
		     , CASE WHEN A.PKOTICYN = 'Y' AND A.DSPYN = 'Y' THEN 'Y'
		            ELSE 'N'
		        END AS PKOTDIS
		     , A.OLNPKOTYN
             , CTG.LV1
		     , CTG.LV2
		     , CTG.LV3
             , A.INSERTDATE
             , A.INSERTURKEY
             , A.UPDATEDATE
             , A.UPDATEURKEY
		FROM TORDER_MST_IC A
		LEFT JOIN TORDER_MST_ASRT ASRT
          ON A.OWKEY = ASRT.OWKEY
         AND A.ICKEY = ASRT.ASRTKEY
        LEFT JOIN TORDER_MST_IC REP
          ON ASRT.OWKEY = REP.OWKEY
         AND ASRT.ASRTREPKEY = REP.ICKEY
		    INNER JOIN TORDER_MST_OW B
		    		ON A.OWKEY = B.OWKEY
			LEFT OUTER JOIN TORDER_MST_AC D
			    		 ON D.OWKEY = A.OWKEY
					    AND D.ACKEY = A.ACKEY
			LEFT JOIN (
                SELECT A.OWKEY
                     , A.CTGKEY AS CTGKEY_LV3
                     , A.CTGNM AS LV3
                     , B.CTGKEY AS CTGKEY_LV2
                     , B.CTGNM AS LV2
                     , C.CTGKEY AS CTGKEY_LV1
                     , C.CTGNM AS LV1
                  FROM TORDER_MST_CTG A
                       INNER JOIN TORDER_MST_CTG B
                         ON A.OWKEY = B.OWKEY
                        AND A.UPPERCTGKEY = B.CTGKEY
                        AND B.DELYN = 'N'
                       INNER JOIN TORDER_MST_CTG C
                         ON B.OWKEY = C.OWKEY
                        AND B.UPPERCTGKEY = C.CTGKEY
                        AND C.DELYN = 'N'
                 WHERE A.DELYN = 'N'
             ) CTG
               ON A.OWKEY = CTG.OWKEY
              AND A.CTGKEY = CTG.CTGKEY_LV3
		WHERE A.OWKEY = #{owkey}
		  AND A.ICKEY = #{ickey}
		  AND B.DELYN = 'N'
    </select>

    <update id="updateTorderIcutxtype">
        /* oms-item-itemcode-sql-oracle.xml - updateTorderIcutxtype */
        UPDATE TORDER_MST_ICUTXTYPE
           SET PLTROW = #{pltrow}
             , PLTCOL = #{pltcol}
             , CPP = #{cpp}
         WHERE OWKEY = #{owkey}
           AND ICKEY = #{ickey}
    </update>
    
    
    <insert id="insertOmsMstIcbarcode">

		/* oms-item-itemcode-sql-oracle.xml - insertOmsMstIcbarcode */
			
			INSERT INTO TORDER_MST_ICBACODE (
				    OWKEY
				  , ICKEY
				  , SEQ
				  , BARCODE
				  , UOM
				  , INSERTDATE
				  , INSERTURKEY
				  , UPDATEDATE
				  , UPDATEURKEY
			)
			VALUES (				
				   #{owkey}
				 , #{ickey}
				 , (SELECT COALESCE(MAX(SEQ), 0) +1 
				 	  FROM TORDER_MST_ICBACODE 
				 	 WHERE OWKEY = #{owkey}
				 	   AND  ICKEY = #{ickey})
				 , #{icbarcode}
				 , #{uom}
				 , #{sysdate}
				 , #{surkey}
				 , #{sysdate}
				 , #{surkey}	   
			  )
	</insert>
	
	<update id ="updateOmsMstIcbarcode">
		UPDATE TORDER_MST_ICBACODE
		  SET      DELYN = #{delyn}			
				 , UPDATEDATE = #{sysdate}
				 , UPDATEURKEY = #{surkey}
				 <if test="@com.kns.framework.util.StringUtil@isNotEmpty(icbarcode)">
				 , BARCODE = #{icbarcode}
				 </if>
		WHERE OWKEY = #{owkey} 
		  AND ICKEY = #{ickey}
		  AND UOM = #{uom}
		  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(seq)">
		  AND SEQ  = #{seq}			   		 	
		  </if>
	</update>
	
	<!--상품 바코드 삭제 -->
	<delete id="deleteTOderMstIcbarcode">
		/* oms-item-itemcode-sql-oracle.xml - deleteTOderMstIcbarcode */
		UPDATE TORDER_MST_ICBACODE
		   SET DELYN = #{delyn}	 
	   	     , UPDATEDATE = #{sysdate}
		     , UPDATEURKEY = #{surkey}
		 WHERE OWKEY = #{owkey}
		   AND ICKEY = #{ickey}
		   <if test="@com.kns.framework.util.StringUtil@isNotEmpty(seq)">
		   AND SEQ = #{seq}
		   </if>
		   <if test="@com.kns.framework.util.StringUtil@isNotEmpty(uom)">
		   AND UOM = #{uom}
		   </if>
	</delete>
	
	<!--상품 바코드 중복체크-->
	<select id="selectDupliCountOmsMstIcbarcode" resultType="camelMap">
		SELECT OWKEY, ICKEY, UOM, SEQ, BARCODE, DELYN 
		  FROM TORDER_MST_ICBACODE		 
		 WHERE BARCODE = #{icbarcode}		  		  		 
	</select>

	<!--상품 단위 삭제-->
	<delete id="deleteICUnitType">
			/* oms-item-itemcode-sql-oracle.xml - deleteICUnitType */
			UPDATE TORDER_MST_ICUTXTYPE
			   SET DELYN = #{delyn}
			   	 , UPDATEDATE = #{sysdate}
			   	 , UPDATEURKEY = #{surkey}
			WHERE OWKEY = #{owkey}
			  AND ICKEY = #{ickey}
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(icunittype)">
				AND ICUNITTYPE = #{icunittype}
			</if>
	</delete>
	
	<!--상품 관리 센터 삭제 여부 체크-->
	<select id="selectItemCodeUnitTypeUseCheck">
		SELECT COUNT(*)
		  FROM TORDER_MST_ICUTXTYPE		 
		WHERE OWKEY = #{owkey}
		  AND ICKEY = #{ickey}	
		  AND DELYN != 'Y'	  		  
	</select>


    <insert id="insertTorderWmsIcBatch" parameterType="map">
        /* oms-item-itemcode-sql-oracle.xml - insertTorderWmsIcBatch */
        INSERT INTO TORDER_WMS_IC_BATCH
        (
          REQDATE
        , ICKEY
        , SENDYN
        , INSERTDATE
        , INSERTURKEY
        , UPDATEDATE
        , UPDATEURKEY
        )
        VALUES
        (
          TO_CHAR(CURRENT_TIMESTAMP,'YYYYMMDD')
        , #{ickey}
        , 'N'
        , #{sysdate}
        , #{surkey}
        , #{sysdate}
        , #{surkey}
        )
    </insert>


</mapper>	