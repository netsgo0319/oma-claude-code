                SUM(CASE WHEN TASKDAY = #{wrkYm} || '20' THEN IBSUM - OBSUM ELSE 0 END) AS SUM20,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '21' THEN CNFRMQTYDM ELSE 0 END) AS CNFRMQTYDM21,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '21' THEN CNFRMQTYMV ELSE 0 END) AS CNFRMQTYMV21,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '21' THEN CNFRMQTYET ELSE 0 END) AS CNFRMQTYET21,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '21' THEN QTYUP ELSE 0 END) AS QTYUP21,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '21' THEN IBSUM ELSE 0 END) AS IBSUM21,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '21' THEN OBDMQTY ELSE 0 END) AS OBDMQTY21,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '21' THEN OBMVQTY ELSE 0 END) AS OBMVQTY21,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '21' THEN OBETQTY ELSE 0 END) AS OBETQTY21,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '21' THEN QTYDOWN ELSE 0 END) AS QTYDOWN21,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '21' THEN OBSUM ELSE 0 END) AS OBSUM21,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '21' THEN IBSUM - OBSUM ELSE 0 END) AS SUM21,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '22' THEN CNFRMQTYDM ELSE 0 END) AS CNFRMQTYDM22,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '22' THEN CNFRMQTYMV ELSE 0 END) AS CNFRMQTYMV22,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '22' THEN CNFRMQTYET ELSE 0 END) AS CNFRMQTYET22,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '22' THEN QTYUP ELSE 0 END) AS QTYUP22,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '22' THEN IBSUM ELSE 0 END) AS IBSUM22,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '22' THEN OBDMQTY ELSE 0 END) AS OBDMQTY22,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '22' THEN OBMVQTY ELSE 0 END) AS OBMVQTY22,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '22' THEN OBETQTY ELSE 0 END) AS OBETQTY22,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '22' THEN QTYDOWN ELSE 0 END) AS QTYDOWN22,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '22' THEN OBSUM ELSE 0 END) AS OBSUM22,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '22' THEN IBSUM - OBSUM ELSE 0 END) AS SUM22,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '23' THEN CNFRMQTYDM ELSE 0 END) AS CNFRMQTYDM23,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '23' THEN CNFRMQTYMV ELSE 0 END) AS CNFRMQTYMV23,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '23' THEN CNFRMQTYET ELSE 0 END) AS CNFRMQTYET23,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '23' THEN QTYUP ELSE 0 END) AS QTYUP23,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '23' THEN IBSUM ELSE 0 END) AS IBSUM23,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '23' THEN OBDMQTY ELSE 0 END) AS OBDMQTY23,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '23' THEN OBMVQTY ELSE 0 END) AS OBMVQTY23,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '23' THEN OBETQTY ELSE 0 END) AS OBETQTY23,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '23' THEN QTYDOWN ELSE 0 END) AS QTYDOWN23,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '23' THEN OBSUM ELSE 0 END) AS OBSUM23,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '23' THEN IBSUM - OBSUM ELSE 0 END) AS SUM23,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '24' THEN CNFRMQTYDM ELSE 0 END) AS CNFRMQTYDM24,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '24' THEN CNFRMQTYMV ELSE 0 END) AS CNFRMQTYMV24,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '24' THEN CNFRMQTYET ELSE 0 END) AS CNFRMQTYET24,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '24' THEN QTYUP ELSE 0 END) AS QTYUP24,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '24' THEN IBSUM ELSE 0 END) AS IBSUM24,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '24' THEN OBDMQTY ELSE 0 END) AS OBDMQTY24,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '24' THEN OBMVQTY ELSE 0 END) AS OBMVQTY24,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '24' THEN OBETQTY ELSE 0 END) AS OBETQTY24,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '24' THEN QTYDOWN ELSE 0 END) AS QTYDOWN24,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '24' THEN OBSUM ELSE 0 END) AS OBSUM24,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '24' THEN IBSUM - OBSUM ELSE 0 END) AS SUM24,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '25' THEN CNFRMQTYDM ELSE 0 END) AS CNFRMQTYDM25,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '25' THEN CNFRMQTYMV ELSE 0 END) AS CNFRMQTYMV25,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '25' THEN CNFRMQTYET ELSE 0 END) AS CNFRMQTYET25,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '25' THEN QTYUP ELSE 0 END) AS QTYUP25,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '25' THEN IBSUM ELSE 0 END) AS IBSUM25,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '25' THEN OBDMQTY ELSE 0 END) AS OBDMQTY25,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '25' THEN OBMVQTY ELSE 0 END) AS OBMVQTY25,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '25' THEN OBETQTY ELSE 0 END) AS OBETQTY25,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '25' THEN QTYDOWN ELSE 0 END) AS QTYDOWN25,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '25' THEN OBSUM ELSE 0 END) AS OBSUM25,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '25' THEN IBSUM - OBSUM ELSE 0 END) AS SUM25,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '26' THEN CNFRMQTYDM ELSE 0 END) AS CNFRMQTYDM26,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '26' THEN CNFRMQTYMV ELSE 0 END) AS CNFRMQTYMV26,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '26' THEN CNFRMQTYET ELSE 0 END) AS CNFRMQTYET26,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '26' THEN QTYUP ELSE 0 END) AS QTYUP26,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '26' THEN IBSUM ELSE 0 END) AS IBSUM26,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '26' THEN OBDMQTY ELSE 0 END) AS OBDMQTY26,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '26' THEN OBMVQTY ELSE 0 END) AS OBMVQTY26,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '26' THEN OBETQTY ELSE 0 END) AS OBETQTY26,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '26' THEN QTYDOWN ELSE 0 END) AS QTYDOWN26,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '26' THEN OBSUM ELSE 0 END) AS OBSUM26,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '26' THEN IBSUM - OBSUM ELSE 0 END) AS SUM26,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '27' THEN CNFRMQTYDM ELSE 0 END) AS CNFRMQTYDM27,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '27' THEN CNFRMQTYMV ELSE 0 END) AS CNFRMQTYMV27,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '27' THEN CNFRMQTYET ELSE 0 END) AS CNFRMQTYET27,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '27' THEN QTYUP ELSE 0 END) AS QTYUP27,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '27' THEN IBSUM ELSE 0 END) AS IBSUM27,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '27' THEN OBDMQTY ELSE 0 END) AS OBDMQTY27,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '27' THEN OBMVQTY ELSE 0 END) AS OBMVQTY27,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '27' THEN OBETQTY ELSE 0 END) AS OBETQTY27,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '27' THEN QTYDOWN ELSE 0 END) AS QTYDOWN27,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '27' THEN OBSUM ELSE 0 END) AS OBSUM27,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '27' THEN IBSUM - OBSUM ELSE 0 END) AS SUM27,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '28' THEN CNFRMQTYDM ELSE 0 END) AS CNFRMQTYDM28,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '28' THEN CNFRMQTYMV ELSE 0 END) AS CNFRMQTYMV28,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '28' THEN CNFRMQTYET ELSE 0 END) AS CNFRMQTYET28,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '28' THEN QTYUP ELSE 0 END) AS QTYUP28,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '28' THEN IBSUM ELSE 0 END) AS IBSUM28,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '28' THEN OBDMQTY ELSE 0 END) AS OBDMQTY28,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '28' THEN OBMVQTY ELSE 0 END) AS OBMVQTY28,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '28' THEN OBETQTY ELSE 0 END) AS OBETQTY28,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '28' THEN QTYDOWN ELSE 0 END) AS QTYDOWN28,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '28' THEN OBSUM ELSE 0 END) AS OBSUM28,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '28' THEN IBSUM - OBSUM ELSE 0 END) AS SUM28,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '29' THEN CNFRMQTYDM ELSE 0 END) AS CNFRMQTYDM29,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '29' THEN CNFRMQTYMV ELSE 0 END) AS CNFRMQTYMV29,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '29' THEN CNFRMQTYET ELSE 0 END) AS CNFRMQTYET29,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '29' THEN QTYUP ELSE 0 END) AS QTYUP29,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '29' THEN IBSUM ELSE 0 END) AS IBSUM29,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '29' THEN OBDMQTY ELSE 0 END) AS OBDMQTY29,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '29' THEN OBMVQTY ELSE 0 END) AS OBMVQTY29,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '29' THEN OBETQTY ELSE 0 END) AS OBETQTY29,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '29' THEN QTYDOWN ELSE 0 END) AS QTYDOWN29,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '29' THEN OBSUM ELSE 0 END) AS OBSUM29,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '29' THEN IBSUM - OBSUM ELSE 0 END) AS SUM29,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '30' THEN CNFRMQTYDM ELSE 0 END) AS CNFRMQTYDM30,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '30' THEN CNFRMQTYMV ELSE 0 END) AS CNFRMQTYMV30,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '30' THEN CNFRMQTYET ELSE 0 END) AS CNFRMQTYET30,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '30' THEN QTYUP ELSE 0 END) AS QTYUP30,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '30' THEN IBSUM ELSE 0 END) AS IBSUM30,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '30' THEN OBDMQTY ELSE 0 END) AS OBDMQTY30,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '30' THEN OBMVQTY ELSE 0 END) AS OBMVQTY30,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '30' THEN OBETQTY ELSE 0 END) AS OBETQTY30,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '30' THEN QTYDOWN ELSE 0 END) AS QTYDOWN30,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '30' THEN OBSUM ELSE 0 END) AS OBSUM30,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '30' THEN IBSUM - OBSUM ELSE 0 END) AS SUM30,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '31' THEN CNFRMQTYDM ELSE 0 END) AS CNFRMQTYDM31,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '31' THEN CNFRMQTYMV ELSE 0 END) AS CNFRMQTYMV31,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '31' THEN CNFRMQTYET ELSE 0 END) AS CNFRMQTYET31,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '31' THEN QTYUP ELSE 0 END) AS QTYUP31,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '31' THEN IBSUM ELSE 0 END) AS IBSUM31,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '31' THEN OBDMQTY ELSE 0 END) AS OBDMQTY31,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '31' THEN OBMVQTY ELSE 0 END) AS OBMVQTY31,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '31' THEN OBETQTY ELSE 0 END) AS OBETQTY31,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '31' THEN QTYDOWN ELSE 0 END) AS QTYDOWN31,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '31' THEN OBSUM ELSE 0 END) AS OBSUM31,
                SUM(CASE WHEN TASKDAY = #{wrkYm} || '31' THEN IBSUM - OBSUM ELSE 0 END) AS SUM31,
                SUM(CASE WHEN SUBSTR(TASKDAY, 0, 6) = #{wrkYm} THEN CNFRMQTYDM ELSE 0 END) AS CNFRMQTYDM,
                SUM(CASE WHEN SUBSTR(TASKDAY, 0, 6) = #{wrkYm} THEN CNFRMQTYMV ELSE 0 END) AS CNFRMQTYMV,
                SUM(CASE WHEN SUBSTR(TASKDAY, 0, 6) = #{wrkYm} THEN CNFRMQTYET ELSE 0 END) AS CNFRMQTYET,
                SUM(CASE WHEN SUBSTR(TASKDAY, 0, 6) = #{wrkYm} THEN QTYUP ELSE 0 END) AS QTYUP,
                SUM(CASE WHEN SUBSTR(TASKDAY, 0, 6) = #{wrkYm} THEN IBSUM ELSE 0 END) AS IBSUM,
                SUM(CASE WHEN SUBSTR(TASKDAY, 0, 6) = #{wrkYm} THEN OBDMQTY ELSE 0 END) AS OBDMQTY,
                SUM(CASE WHEN SUBSTR(TASKDAY, 0, 6) = #{wrkYm} THEN OBMVQTY ELSE 0 END) AS OBMVQTY,
                SUM(CASE WHEN SUBSTR(TASKDAY, 0, 6) = #{wrkYm} THEN OBETQTY ELSE 0 END) AS OBETQTY,
                SUM(CASE WHEN SUBSTR(TASKDAY, 0, 6) = #{wrkYm} THEN QTYDOWN ELSE 0 END) AS QTYDOWN,
                SUM(CASE WHEN SUBSTR(TASKDAY, 0, 6) = #{wrkYm} THEN OBSUM ELSE 0 END) AS OBSUM,
                SUM(CASE WHEN SUBSTR(TASKDAY, 0, 6) = #{wrkYm} THEN IBSUM-OBSUM ELSE 0 END) AS SUMYM,
                SUM(IBSUM-OBSUM) AS SUMTOT
            FROM (
                SELECT
                    COALESCE(COALESCE(B.OWKEY, C.OWKEY), D.OWKEY) AS OWKEY
                    ,COALESCE(COALESCE(B.CTKEY, C.CTKEY), D.CTKEY) AS CTKEY
                    ,COALESCE(G.ICKEY, E.ICKEY) AS ICKEYM
                    ,COALESCE(G.ICNM, E.ICNM) AS ICNMM
                    ,F.ASRTDTICKEY AS ICKEYA
                    ,(CASE WHEN F.ASRTMASICKEY IS NOT NULL THEN COALESCE(F.ASRTNM, E.ICNM) ELSE NULL END) AS ICNMA
                    ,COALESCE(CNFRMQTY_DM, 0) AS CNFRMQTYDM -- 입고EA/이고입고
                    ,COALESCE(CNFRMQTY_MV, 0) AS CNFRMQTYMV -- 입고EA/직납입고
                    ,COALESCE(CNFRMQTY_ET, 0) AS CNFRMQTYET -- 입고EA/기타입고
                    ,COALESCE(QTY_UP, 0) AS QTYUP
                    ,(COALESCE(CNFRMQTY_DM, 0) + COALESCE(CNFRMQTY_MV, 0) + COALESCE(CNFRMQTY_ET, 0) + COALESCE(QTY_UP, 0)) AS IBSUM
                    ,COALESCE(OB_DM_QTY, 0) AS OBDMQTY -- 출고EA/주문출고
                    ,COALESCE(OB_MV_QTY, 0) AS OBMVQTY -- 출고EA/이고출고
                    ,COALESCE(OB_ET_QTY, 0) AS OBETQTY -- 출고EA/기타출고
                    ,COALESCE(QTY_DOWN, 0) AS QTYDOWN
                    ,(COALESCE(OB_DM_QTY, 0) + COALESCE(OB_MV_QTY, 0) + COALESCE(OB_ET_QTY, 0) + COALESCE(QTY_DOWN, 0)) AS OBSUM
                    ,COALESCE(COALESCE(B.TASKDAY, C.TASKDAY), D.TASKDAY) AS TASKDAY
                FROM (
                    -- 출고 현황
                    SELECT    CTKEY /*센터코드*/
                            , CTNM /*센터명*/
                            , OWKEY /*화주코드*/
                            , ICKEYA
                            , SUM(OB_DM_QTY) AS OB_DM_QTY /*출고EA/주문출고*/
                            , SUM(OB_MV_QTY) AS OB_MV_QTY /*출고EA/이고출고*/
                            , SUM(OB_ET_QTY) AS OB_ET_QTY /*출고EA/기타출고*/
                            , TASKDAY
                    FROM (
                        SELECT * FROM (
                            SELECT    OH.CTKEY AS CTKEY /*센터코드*/
                                    , CT.CTNM /*센터명*/
                                    , OH.OWKEY /*화주코드*/
                                    , IC_A.ICKEY AS ICKEYA
                                    , CASE WHEN OH.OBHDTYPECD = '10' AND OD.CNFRMQTY > 0 THEN OD.CNFRMQTY ELSE 0 END AS OB_DM_QTY /*출고EA/주문출고*/
                                    , CASE WHEN OH.OBHDTYPECD = '30' AND OD.CNFRMQTY > 0 THEN OD.CNFRMQTY ELSE 0 END AS OB_MV_QTY /*출고EA/이고출고*/
                                    , CASE WHEN OH.OBHDTYPECD = '50' AND OD.CNFRMQTY > 0 THEN OD.CNFRMQTY ELSE 0 END AS OB_ET_QTY /*출고EA/기타출고*/
                                    , SUBSTR(OH.OBCNFRMDATE, 0, 8) AS TASKDAY
                            FROM TWORK_INFO_OB_HD OH
                            INNER JOIN TWORK_INFO_OB_DT OD
                            ON OH.CTKEY = OD.CTKEY
                            AND OH.OWKEY = OD.OWKEY
                            AND OH.OBHDKEY = OD.OBHDKEY
                            INNER JOIN TWORK_MST_IC IC_A
                            ON OD.CTKEY = IC_A.CTKEY
                            AND OD.OWKEY = IC_A.OWKEY
                            AND OD.ICKEY = IC_A.ICKEY
                            INNER JOIN TWORK_MST_CT CT
                            ON OH.CTKEY = CT.CTKEY
                            WHERE OH.OBHDTYPECD IN ('10', '30', '50')
                            AND OH.OBSTATUSCD = '70'
                        ) WHERE 1=1
                        <if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
                            AND #{SEARCH_CONDITION}
                        </if>
                    ) A
                    GROUP BY
                    CTKEY   /*센터코드*/
                    , CTNM    /*센터명*/
                    , OWKEY   /*화주코드*/
                    , ICKEYA /*자품번*/
                    , TASKDAY /*일자*/
                ) B
                FULL OUTER JOIN (
                    -- 입고 현황
                    SELECT
                        OWKEY,
                        CTKEY,
                        ICKEYA,
                        SUM(CNFRMQTY_DM) AS CNFRMQTY_DM,
                        SUM(CNFRMQTY_MV) AS CNFRMQTY_MV,
                        SUM(CNFRMQTY_ET) AS CNFRMQTY_ET,
                        TASKDAY
                    FROM (
                        SELECT *
                        FROM (
                            SELECT    A.CTKEY
                                    , L.CTNM
                                    , A.OWKEY
                                    , B.IBHDTYPECD
                                    , SUBSTR(B.IBDDLNDATE, 0, 8) AS TASKDAY
                                    , C.ICKEY AS ICKEYA
                                    , (CASE WHEN B.IBHDTYPECD = '30' THEN COALESCE(A.CNFRMQTY, 0) ELSE 0 END) AS CNFRMQTY_DM
                                    , (CASE WHEN B.IBHDTYPECD = '40' THEN COALESCE(A.CNFRMQTY, 0) ELSE 0 END) AS CNFRMQTY_MV
                                    , (CASE WHEN B.IBHDTYPECD = '50' THEN COALESCE(A.CNFRMQTY, 0) ELSE 0 END) AS CNFRMQTY_ET
                                    , CASE WHEN A.IBDTSTATUSCD = '91' THEN 'Y' ELSE 'N' END AS CLOSEYN
                                    , A.IBDTSTATUSCD
                            FROM TWORK_INFO_IB_DT A
                            INNER JOIN TWORK_INFO_IB_HD B
                            ON A.CTKEY = B.CTKEY
                            AND A.OWKEY = B.OWKEY
                            AND A.IBHDKEY = B.IBHDKEY
                            INNER JOIN TWORK_MST_IC C
                            ON A.CTKEY = C.CTKEY
                            AND A.OWKEY = C.OWKEY
                            AND A.ICKEY = C.ICKEY
                            INNER JOIN TWORK_MST_CT L
                            ON A.CTKEY = L.CTKEY
                        ) A
                        WHERE 1=1
                        <if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
                            AND #{SEARCH_CONDITION}
                        </if>
                        AND IBHDTYPECD IN ('30', '40', '50')
                        AND IBDTSTATUSCD = '91'
                        AND CLOSEYN = 'Y'
                        AND TASKDAY IS NOT NULL
                    ) GROUP BY
                        OWKEY,
                        CTKEY,
                        ICKEYA,
                        TASKDAY
            ) C
                ON B.OWKEY = C.OWKEY
                AND B.CTKEY = C.CTKEY
                AND B.ICKEYA = C.ICKEYA
                AND B.TASKDAY = C.TASKDAY
            FULL OUTER JOIN (
                -- 재고조정 (증가, 감소)
                SELECT  CTKEY,
                        OWKEY,
                        ICKEYA,
                        SUM(QTY_UP) AS QTY_UP,
                        SUM(QTY_DOWN) AS QTY_DOWN,
                        TASKDAY
                FROM (
                    SELECT * FROM (
                        SELECT A.CTKEY
                        , H.CTNM
                        , A.OWKEY
                        , I.ICKEY AS ICKEYA
                        , CASE WHEN A.IVHSTYPECD = '130' THEN A.QTY ELSE 0 END AS QTY_UP
                        , CASE WHEN A.IVHSTYPECD = '140' THEN A.QTY ELSE 0 END AS QTY_DOWN
                        , A.IVHSTYPECD
                        , SUBSTR(A.IVCHGDATE, 0, 8) AS TASKDAY
                        FROM TWORK_INFO_IVHS A
                        LEFT OUTER JOIN TWORK_MST_LC B
                        ON A.CTKEY = B.CTKEY
                        AND A.FRLCKEY = B.LCKEY
                        LEFT OUTER JOIN TWORK_MST_ZN C
                        ON B.CTKEY = C.CTKEY
                        AND B.ZNKEY = C.ZNKEY
                        LEFT OUTER JOIN TWORK_MST_AR D
                        ON B.CTKEY = D.CTKEY
                        AND B.ARKEY = D.ARKEY
                        AND B.ZNKEY = D.ZNKEY
                        LEFT OUTER JOIN TWORK_MST_LC E
                        ON A.CTKEY = E.CTKEY
                        AND A.TOLCKEY = E.LCKEY
                        LEFT OUTER JOIN TWORK_MST_ZN F
                        ON E.CTKEY = F.CTKEY
                        AND E.ZNKEY = F.ZNKEY
                        LEFT OUTER JOIN TWORK_MST_AR G
                        ON E.CTKEY = G.CTKEY
                        AND E.ARKEY = G.ARKEY
                        AND E.ZNKEY = G.ZNKEY
                        INNER JOIN TWORK_MST_CT H
                        ON A.CTKEY = H.CTKEY
                        INNER JOIN TWORK_MST_IC I
                        ON A.CTKEY = I.CTKEY
                        AND A.OWKEY = I.OWKEY
                        AND A.ICKEY = I.ICKEY
                    )
                    WHERE 1=1
                    <if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
                        AND #{SEARCH_CONDITION}
                    </if>
                    AND ( IVHSTYPECD IN ('130', '140'))
                )
                GROUP BY CTKEY,
                        OWKEY,
                        ICKEYA,
                        TASKDAY
            ) D
            ON  B.OWKEY = D.OWKEY
            AND C.OWKEY = D.OWKEY
            AND B.CTKEY = D.CTKEY
            AND C.CTKEY = D.CTKEY
            AND B.ICKEYA = D.ICKEYA
            AND C.ICKEYA = D.ICKEYA
            AND B.TASKDAY = D.TASKDAY
            AND C.TASKDAY = D.TASKDAY
            INNER JOIN TWORK_MST_IC E -- 자
            ON COALESCE(COALESCE(B.OWKEY, C.OWKEY), D.OWKEY) = E.OWKEY
            AND COALESCE(COALESCE(B.CTKEY, C.CTKEY), D.CTKEY) = E.CTKEY
            AND COALESCE(COALESCE(B.ICKEYA, C.ICKEYA), D.ICKEYA) = E.ICKEY
            LEFT JOIN TWORK_MST_ASRT F
            ON COALESCE(COALESCE(B.OWKEY, C.OWKEY), D.OWKEY) = F.OWKEY
            AND COALESCE(COALESCE(B.CTKEY, C.CTKEY), D.CTKEY) = F.CTKEY
            AND COALESCE(COALESCE(B.ICKEYA, C.ICKEYA), D.ICKEYA) = F.ASRTDTICKEY
            AND E.ICKEY = F.ASRTDTICKEY
            LEFT JOIN TWORK_MST_IC G
            ON G.CTKEY = F.CTKEY
            AND G.OWKEY = F.OWKEY
            AND G.ICKEY = F.ASRTMASICKEY
            INNER JOIN TWORK_MST_AC F
            ON E.ACKEY = F.ACKEY
            )
            WHERE 1=1
            <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ctkey)">
                AND CTKEY = #{ctkey}
            </if>
            <if test="@com.kns.framework.util.StringUtil@isNotEmpty(wrkYm)">
                AND SUBSTR(TASKDAY, 0, 6) >= #{wrkYm}
            </if>
            <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ickeyArr)">
                AND (ICKEYM IN (#{ickeyArr}) OR ICKEYA IN (#{ickeyArr}))
            </if>
            GROUP BY OWKEY, CTKEY, ICKEYM, ICKEYA
            ) A FULL OUTER JOIN (
                SELECT CTKEY
                    , OWKEY
                    , ASRTMASICKEY AS ICKEYM
                    , ASRTMASICNM AS ICNMM
                    , ASRTDTICKEY AS ICKEYA
                    , ASRTDTICNM AS ICNMA
                    , SUM(AVZNTOTQTY) AS AVZNTOTQTY								/* 가용존 총수량 */
                    , SUM(NAVZNTOTQTY) AS NAVZNTOTQTY								/* 불용존 총수량 */
                    , SUM(AVZNTOTQTY) + SUM(NAVZNTOTQTY) AS SUMCUR               /* 총수량 */
                FROM (
                    SELECT IVLC.CTKEY													/* 센터코드 */
                    , CT.CTNM														/* 센터명 */
                    , IVLC.OWKEY													/* 화주코드 */
                    , COALESCE(ASTMST.ASRTMASICKEY, IVLC.ICKEY) AS ASRTMASICKEY			/* (모)상품코드 */
                    , COALESCE(ASTMST.ASRTMASICNM, IC.ICNM) AS ASRTMASICNM				/* (모)상품명 */
                    , ASTDTL.ASRTDTICKEY											/* (자)상품코드 */
                    , CASE WHEN ASTDTL.ASRTDTICKEY IS NOT NULL THEN IC.ICNM
                    ELSE '' END AS ASRTDTICNM								/* (자)상품명 */
                    , CASE ZN.ZNTYPECD WHEN '10' THEN IVLC.TOTQTY ELSE 0 END AS AVZNTOTQTY      /* 가용존 총재고*/
                    , CASE ZN.ZNTYPECD WHEN '10' THEN 0 ELSE IVLC.TOTQTY END AS NAVZNTOTQTY     /* 불용존 총재고*/
                FROM TWORK_INFO_IVATXLC IVLC
                INNER JOIN TWORK_MST_CT CT
                ON CT.CTKEY = IVLC.CTKEY
                INNER JOIN TWORK_MST_OW OW
                ON OW.OWKEY = IVLC.OWKEY
                INNER JOIN TWORK_MST_IC IC
                ON IC.CTKEY = IVLC.CTKEY
                AND IC.OWKEY = IVLC.OWKEY
                AND IC.ICKEY = IVLC.ICKEY
                INNER JOIN TWORK_INFO_IVAT IV
                ON IV.CTKEY = IVLC.CTKEY
                AND IV.OWKEY = IVLC.OWKEY
                AND IV.IVATKEY = IVLC.IVATKEY
                INNER JOIN TWORK_MST_LC LC
                ON LC.CTKEY = IVLC.CTKEY
                AND LC.LCKEY = IVLC.LCKEY
                INNER JOIN TWORK_MST_ZN ZN
                ON ZN.CTKEY = IVLC.CTKEY
                AND ZN.ZNKEY = LC.ZNKEY
                INNER JOIN TWORK_MST_AR AR
                ON AR.CTKEY = IVLC.CTKEY
                AND AR.ZNKEY = LC.ZNKEY
                AND AR.ARKEY = LC.ARKEY
                LEFT JOIN TWORK_MST_ASRT ASTDTL
                ON ASTDTL.CTKEY = IC.CTKEY
                AND ASTDTL.OWKEY = IC.OWKEY
                AND ASTDTL.ASRTDTICKEY = IC.ICKEY
                AND ASTDTL.QTY   >   0
                AND IC.ASRTYN = 'Y'
                LEFT JOIN (
                SELECT AST.CTKEY
                , AST.OWKEY
                , AST.ASRTMASICKEY
                , IC.ICNM AS ASRTMASICNM
                FROM TWORK_MST_ASRT AST
                INNER JOIN TWORK_MST_IC IC
                ON IC.CTKEY = AST.CTKEY
                AND IC.OWKEY = AST.OWKEY
                AND IC.ICKEY = AST.ASRTMASICKEY
                WHERE IC.ASRTYN = 'Y'
                GROUP BY
                AST.CTKEY
                , AST.OWKEY
                , AST.ASRTMASICKEY
                , IC.ICNM
                ) ASTMST
                ON ASTMST.CTKEY = ASTDTL.CTKEY
                AND ASTMST.OWKEY = ASTDTL.OWKEY
                AND ASTMST.ASRTMASICKEY = ASTDTL.ASRTMASICKEY
                WHERE  IVLC.TOTQTY  >  0
                <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ctkey)">
                    AND ( IVLC.CTKEY = #{ctkey})
                </if>
                <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ickeyArr)">
                    AND ( COALESCE(ASTMST.ASRTMASICKEY, IVLC.ICKEY) IN #{ickeyArr} OR ASTDTL.ASRTDTICKEY IN #{ickeyArr} )
                </if>
        )
        GROUP BY
        CTKEY
        , OWKEY
        , ASRTMASICKEY
        , ASRTMASICNM
        , ASRTDTICKEY
        , ASRTDTICNM
        ) B ON A.OWKEY = B.OWKEY
        AND A.CTKEY = B.CTKEY
        AND A.ICKEYM = B.ICKEYM
        AND COALESCE(A.ICKEYA, 1) = COALESCE(B.ICKEYA, 1)
    </sql>

    <select id="selectinXObPeriodMonthStatusCount" resultType="java.lang.Integer">
        /* wms-report-selectinXObPeriodMonthStatusList-sql-oracle.xml - selectinXObPeriodMonthStatusCount */
        SELECT COUNT(1)
        FROM (
            <include refid="selectinXObPeriodMonthStatusSql"/>
        )
    </select>

    <select id="selectinXObPeriodMonthStatusList" resultType="camelMap">
        <include refid="sql_pagingTop"/>
            SELECT *
            /* wms-report-selectinXObPeriodMonthStatusList-sql-oracle.xml - selectinXObPeriodMonthStatusList */
            FROM (
                <include refid="selectinXObPeriodMonthStatusSql"/>
            )
        <include refid="sql_pagingBottom"/>
    </select>

    <sql id="selectinXObPeriodMonthStatusSql">
        SELECT
                SUBSTR(B.TASKDATE, 0, 4) AS TASKYEAR,
                SUBSTR(B.TASKDATE, 5, 2) AS TASKMONTH,
                <if test='"20".equals(div)'>
                    B.TASKDATE,
                </if>
                SUM(COALESCE(CNFRMQTYDM, 0)) AS CNFRMQTYDM,
                SUM(COALESCE(CNFRMQTYMV, 0)) AS CNFRMQTYMV,
                SUM(COALESCE(CNFRMQTYET, 0)) AS CNFRMQTYET,
                SUM(COALESCE(QTYUP, 0)) AS QTYUP,
                SUM(COALESCE(IBSUM, 0)) AS IBSUM,
                SUM(COALESCE(IBSLPRC, 0)) AS IBSLPRC,
                SUM(COALESCE(OBDMQTY, 0)) AS OBDMQTY,
                SUM(COALESCE(OBMVQTY, 0)) AS OBMVQTY,
                SUM(COALESCE(OBETQTY, 0)) AS OBETQTY,
                SUM(COALESCE(QTYDOWN, 0)) AS QTYDOWN,
                SUM(COALESCE(OBSUM, 0)) AS OBSUM,
                SUM(COALESCE(OBSLPRC, 0)) AS OBSLPRC
        FROM (
            SELECT
                 COALESCE(COALESCE(B.OWKEY, C.OWKEY), D.OWKEY) AS OWKEY
                ,COALESCE(COALESCE(B.CTKEY, C.CTKEY), D.CTKEY) AS CTKEY
                ,SUBSTR(COALESCE(COALESCE(B.TASKDATE, C.TASKDATE), D.TASKDATE), 0, 4) AS TASKYEAR
                ,SUBSTR(COALESCE(COALESCE(B.TASKDATE, C.TASKDATE), D.TASKDATE), 5, 2) AS TASKMONTH
                ,COALESCE(COALESCE(B.TASKDATE, C.TASKDATE), D.TASKDATE) AS TASKDATE
                ,COALESCE(CNFRMQTY_DM, 0) AS CNFRMQTYDM -- 입고EA/이고입고
                ,COALESCE(CNFRMQTY_MV, 0) AS CNFRMQTYMV -- 입고EA/직납입고
                ,COALESCE(CNFRMQTY_ET, 0) AS CNFRMQTYET -- 입고EA/기타입고
                ,COALESCE(QTY_UP, 0) AS QTYUP -- 입고EA/재고조정(입고)
                ,(COALESCE(CNFRMQTY_DM, 0) + COALESCE(CNFRMQTY_MV, 0) + COALESCE(CNFRMQTY_ET, 0) + COALESCE(QTY_UP, 0)) AS IBSUM -- 입고EA/합계
                ,COALESCE(IB_SLPRC, 0) + COALESCE(PRC_UP, 0) AS IBSLPRC -- 입고/총금액
                ,COALESCE(OB_DM_QTY, 0) AS OBDMQTY -- 출고EA/주문출고
                ,COALESCE(OB_MV_QTY, 0) AS OBMVQTY -- 출고EA/이고출고
                ,COALESCE(OB_ET_QTY, 0) AS OBETQTY -- 출고EA/기타출고
                ,COALESCE(QTY_DOWN, 0) AS QTYDOWN -- 출고EA/재고조정(출고)
                ,(COALESCE(OB_DM_QTY, 0) + COALESCE(OB_MV_QTY, 0) + COALESCE(OB_ET_QTY, 0) + COALESCE(QTY_DOWN, 0)) AS OBSUM -- 출고EA/합계
                ,COALESCE(OB_SLPRC, 0) + COALESCE(PRC_DOWN, 0) AS OBSLPRC -- 출고/총금액
            FROM (
                -- 출고 현황
                SELECT    CTKEY /*센터코드*/
                        , OWKEY /*화주코드*/
                        , ICKEYA
                        , SUM(OB_DM_QTY) AS OB_DM_QTY /*출고EA/주문출고*/
                        , SUM(OB_MV_QTY) AS OB_MV_QTY /*출고EA/이고출고*/
                        , SUM(OB_ET_QTY) AS OB_ET_QTY /*출고EA/기타출고*/
                        , SUM(OB_SLPRC) AS OB_SLPRC
                        , TASKDATE
                FROM (
                    SELECT * FROM (
                        SELECT    OH.CTKEY AS CTKEY /*센터코드*/
                                , CT.CTNM /*센터명*/
                                , OH.OWKEY /*화주코드*/
                                , IC_A.ICKEY AS ICKEYA
                                , CASE WHEN OH.OBHDTYPECD = '10' AND OD.CNFRMQTY > 0 THEN OD.CNFRMQTY ELSE 0 END AS OB_DM_QTY /*출고EA/주문출고*/
                                , CASE WHEN OH.OBHDTYPECD = '30' AND OD.CNFRMQTY > 0 THEN OD.CNFRMQTY ELSE 0 END AS OB_MV_QTY /*출고EA/이고출고*/
                                , CASE WHEN OH.OBHDTYPECD = '50' AND OD.CNFRMQTY > 0 THEN OD.CNFRMQTY ELSE 0 END AS OB_ET_QTY /*출고EA/기타출고*/
                                , CASE WHEN OH.OBHDTYPECD IN ('10', '30', '50') AND OD.CNFRMQTY > 0 THEN OD.CNFRMQTY * IC_A.SLPRC ELSE 0 END AS OB_SLPRC /*출고/총금액*/
                                , SUBSTR(OH.OBCNFRMDATE, 0, 8) AS TASKDATE
                        FROM TWORK_INFO_OB_HD OH
                        INNER JOIN TWORK_INFO_OB_DT OD
                        ON OH.CTKEY = OD.CTKEY
                        AND OH.OWKEY = OD.OWKEY
                        AND OH.OBHDKEY = OD.OBHDKEY
                        INNER JOIN TWORK_MST_IC IC_A
                        ON OD.CTKEY = IC_A.CTKEY
                        AND OD.OWKEY = IC_A.OWKEY
                        AND OD.ICKEY = IC_A.ICKEY
                        INNER JOIN TWORK_MST_CT CT
                        ON OH.CTKEY = CT.CTKEY
                        WHERE OH.OBHDTYPECD IN ('10', '30', '50')
                        AND OH.OBSTATUSCD = '70'
                ) WHERE 1=1
                <if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)" >
                    AND OWKEY = #{owkey}
                </if>
                <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ctkey)" >
                    AND CTKEY = #{ctkey}
                </if>
                <if test="@com.kns.framework.util.StringUtil@isNotEmpty(wrkStartDate+wrkEndDate)" >
                    AND TASKDATE BETWEEN #{wrkStartDate} AND #{wrkEndDate}
                </if>
            ) A
            GROUP BY
                  CTKEY   /*센터코드*/
                , OWKEY   /*화주코드*/
                , ICKEYA /*자품번*/
                , TASKDATE
            ) B FULL OUTER JOIN (
                -- 입고 현황
                SELECT
                    OWKEY,
                    CTKEY,
                    ICKEYA,
                    TASKDATE,
                    SUM(CNFRMQTY_DM) AS CNFRMQTY_DM,
                    SUM(CNFRMQTY_MV) AS CNFRMQTY_MV,
                    SUM(CNFRMQTY_ET) AS CNFRMQTY_ET,
                    SUM(IB_SLPRC) AS IB_SLPRC
                FROM (
                    SELECT *
                    FROM (
                        SELECT    A.CTKEY
                                , L.CTNM
                                , A.OWKEY
                                , B.IBHDTYPECD
                                , SUBSTR(B.IBDDLNDATE, 0, 8) AS TASKDATE
                                , C.ICKEY AS ICKEYA
                                , (CASE WHEN B.IBHDTYPECD = '30' THEN COALESCE(A.CNFRMQTY, 0) ELSE 0 END) AS CNFRMQTY_DM
                                , (CASE WHEN B.IBHDTYPECD = '40' THEN COALESCE(A.CNFRMQTY, 0) ELSE 0 END) AS CNFRMQTY_MV
                                , (CASE WHEN B.IBHDTYPECD = '50' THEN COALESCE(A.CNFRMQTY, 0) ELSE 0 END) AS CNFRMQTY_ET
                                , (CASE WHEN B.IBHDTYPECD IN ('30', '40', '50') AND COALESCE(A.CNFRMQTY, 0) > 0 THEN COALESCE(A.CNFRMQTY, 0) * C.SLPRC ELSE 0 END) AS IB_SLPRC /*입고/총금액*/
                                , CASE WHEN A.IBDTSTATUSCD = '91' THEN 'Y' ELSE 'N' END AS CLOSEYN
                                , A.IBDTSTATUSCD
                        FROM TWORK_INFO_IB_DT A
                        INNER JOIN TWORK_INFO_IB_HD B
                        ON A.CTKEY = B.CTKEY
                        AND A.OWKEY = B.OWKEY
                        AND A.IBHDKEY = B.IBHDKEY
                        INNER JOIN TWORK_MST_IC C
                        ON A.CTKEY = C.CTKEY
                        AND A.OWKEY = C.OWKEY
                        AND A.ICKEY = C.ICKEY
                        INNER JOIN TWORK_MST_CT L
                        ON A.CTKEY = L.CTKEY
                    ) A
                    WHERE 1=1
                    <if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)" >
                        AND OWKEY = #{owkey}
                    </if>
                    <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ctkey)" >
                        AND CTKEY = #{ctkey}
                    </if>
                    <if test="@com.kns.framework.util.StringUtil@isNotEmpty(wrkStartDate+wrkEndDate)" >
                        AND TASKDATE BETWEEN #{wrkStartDate} AND #{wrkEndDate}
                    </if>
                    AND IBHDTYPECD IN ('30', '40', '50')
                    AND IBDTSTATUSCD = '91'
                    AND CLOSEYN = 'Y'
                ) GROUP BY
                OWKEY,
                CTKEY,
                ICKEYA,
                TASKDATE
            ) C
            ON B.OWKEY = C.OWKEY
            AND B.CTKEY = C.CTKEY
            AND B.ICKEYA = C.ICKEYA
            FULL OUTER JOIN (
                -- 재고조정 (증가, 감소)
                SELECT  CTKEY,
                        OWKEY,
                        ICKEYA,
                        TASKDATE,
                        SUM(QTY_UP) AS QTY_UP,
                        SUM(QTY_DOWN) AS QTY_DOWN,
                        SUM(PRC_UP) AS PRC_UP,
                        SUM(PRC_DOWN) AS PRC_DOWN
                FROM (
                    SELECT * FROM (
                        SELECT A.CTKEY
                        , H.CTNM
                        , A.OWKEY
                        , I.ICKEY AS ICKEYA
                        , CASE WHEN A.IVHSTYPECD = '130' THEN A.QTY ELSE 0 END AS QTY_UP
                        , CASE WHEN A.IVHSTYPECD = '140' THEN A.QTY ELSE 0 END AS QTY_DOWN
                        , CASE WHEN A.IVHSTYPECD = '130' THEN A.QTY * I.SLPRC ELSE 0 END AS PRC_UP
                        , CASE WHEN A.IVHSTYPECD = '140' THEN A.QTY * I.SLPRC ELSE 0 END AS PRC_DOWN
                        , A.IVHSTYPECD
                        , SUBSTR(A.IVCHGDATE, 0, 8) AS TASKDATE
                    FROM TWORK_INFO_IVHS A
                    LEFT OUTER JOIN TWORK_MST_LC B
                    ON A.CTKEY = B.CTKEY
                    AND A.FRLCKEY = B.LCKEY
                    LEFT OUTER JOIN TWORK_MST_ZN C
                    ON B.CTKEY = C.CTKEY
                    AND B.ZNKEY = C.ZNKEY
                    LEFT OUTER JOIN TWORK_MST_AR D
                    ON B.CTKEY = D.CTKEY
                    AND B.ARKEY = D.ARKEY
                    AND B.ZNKEY = D.ZNKEY
                    LEFT OUTER JOIN TWORK_MST_LC E
                    ON A.CTKEY = E.CTKEY
                    AND A.TOLCKEY = E.LCKEY
                    LEFT OUTER JOIN TWORK_MST_ZN F
                    ON E.CTKEY = F.CTKEY
                    AND E.ZNKEY = F.ZNKEY
                    LEFT OUTER JOIN TWORK_MST_AR G
                    ON E.CTKEY = G.CTKEY
                    AND E.ARKEY = G.ARKEY
                    AND E.ZNKEY = G.ZNKEY
                    INNER JOIN TWORK_MST_CT H
                    ON A.CTKEY = H.CTKEY
                    INNER JOIN TWORK_MST_IC I
                    ON A.CTKEY = I.CTKEY
                    AND A.OWKEY = I.OWKEY
                    AND A.ICKEY = I.ICKEY
                    )
                    WHERE 1=1
                    <if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)" >
                        AND OWKEY = #{owkey}
                    </if>
                    <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ctkey)" >
                        AND CTKEY = #{ctkey}
                    </if>
                    <if test="@com.kns.framework.util.StringUtil@isNotEmpty(wrkStartDate+wrkEndDate)" >
                        AND TASKDATE BETWEEN #{wrkStartDate} AND #{wrkEndDate}
                    </if>
                    AND ( IVHSTYPECD IN ('130', '140'))
                )
                GROUP BY CTKEY,
                OWKEY,
                ICKEYA,
                TASKDATE
            ) D ON B.OWKEY = D.OWKEY
            AND C.OWKEY = D.OWKEY
            AND B.CTKEY = D.CTKEY
            AND C.CTKEY = D.CTKEY
            AND B.ICKEYA = D.ICKEYA
            AND C.ICKEYA = D.ICKEYA
        ) A RIGHT OUTER JOIN
        (
            SELECT TO_CHAR(TASKDATE, 'YYYYMMDD') AS TASKDATE
            FROM
            (
                SELECT
                    TO_DATE(#{wrkStartDate},'YYYYMMDD') + LEVEL - 1 AS TASKDATE
                CONNECT BY LEVEL <![CDATA[<]]>= (TO_DATE(#{wrkEndDate},'YYYYMMDD')
                - TO_DATE(#{wrkStartDate},'YYYYMMDD') + 1)
            ) b
        ) B
        ON A.TASKDATE = B.TASKDATE
        WHERE 1=1
        GROUP BY
             SUBSTR(B.TASKDATE, 0, 4)
            ,SUBSTR(B.TASKDATE, 5, 2)
        <if test='"20".equals(div)'>
            ,B.TASKDATE
        </if>
        ORDER BY
             SUBSTR(B.TASKDATE, 0, 4)
            ,SUBSTR(B.TASKDATE, 5, 2)
        <if test='"20".equals(div)'>
            ,B.TASKDATE
        </if>
    </sql>
</mapper>