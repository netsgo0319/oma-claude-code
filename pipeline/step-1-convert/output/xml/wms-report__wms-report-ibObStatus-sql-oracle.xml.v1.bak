<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
    
<mapper namespace="com.daiso.wms.report.mapper.InXObStatusMapper">

    <sql id="sql_pagingTop">
        #{GRIDPAGING_ROWNUMTYPE_TOP}
    </sql>

    <sql id="sql_pagingBottom">
        #{GRIDPAGING_ROWNUMTYPE_BOTTOM}
    </sql>

    <select id="selectinXObIcStatusCount" resultType="java.lang.Integer">
        /* wms-report-selectinXObStatus-sql-oracle.xml - selectinXObIcStatusCount */
        SELECT COUNT(1)
        FROM (
            <include refid="selectinXObIcStatusSql"/>
        )
    </select>

    <select id="selectinXObIcStatusList" resultType="camelMap">
        <include refid="sql_pagingTop"/>
            SELECT *
            /* wms-report-selectinXObStatus-sql-oracle.xml - selectinXObIcStatusList */
            FROM (
                <include refid="selectinXObIcStatusSql"/>
            )
        <include refid="sql_pagingBottom"/>
    </select>

    <sql id="selectinXObIcStatusSql">
        SELECT * FROM (
            SELECT
                 COALESCE(COALESCE(COALESCE(A.OWKEY, B.OWKEY), C.OWKEY), D.OWKEY) AS OWKEY
                ,COALESCE(COALESCE(COALESCE(A.CTKEY, B.CTKEY), C.CTKEY), D.CTKEY) AS CTKEY
                ,COALESCE(G.ICKEY, E.ICKEY) AS ICKEYM
                ,COALESCE(G.ICNM, E.ICNM) AS ICNMM
                ,F.ASRTDTICKEY AS ICKEYA
                ,(CASE WHEN F.ASRTMASICKEY IS NOT NULL THEN COALESCE(F.ASRTNM, E.ICNM) ELSE NULL END) AS ICNMA
                ,CTG3.CTGNM AS LV1CTGNM
                ,CTG2.CTGNM AS LV2CTGNM
                ,CTG1.CTGNM AS LV3CTGNM
                ,F.ACNM
                ,E.SLPRC
                ,E.ASRTYN
                ,E.ROBSORTERICYN
                ,E.EXPCKYN
                ,E.PKOTICYN
                ,COALESCE(CNFRMQTY_DM, 0) AS CNFRMQTYDM -- 입고EA/이고입고
                ,COALESCE(CNFRMQTY_MV, 0) AS CNFRMQTYMV -- 입고EA/직납입고
                ,COALESCE(CNFRMQTY_ET, 0) AS CNFRMQTYET -- 입고EA/기타입고
                ,COALESCE(QTY_UP, 0) AS QTYUP
                ,(COALESCE(CNFRMQTY_DM, 0) + COALESCE(CNFRMQTY_MV, 0) + COALESCE(CNFRMQTY_ET, 0) + COALESCE(QTY_UP, 0)) AS IBSUM
                ,COALESCE(OB_DM_QTY, 0) AS OBDMQTY -- 출고EA/주문출고
                ,COALESCE(OB_MV_QTY, 0) AS OBMVQTY -- 출고EA/이고출고
                ,COALESCE(OB_ET_QTY, 0) AS OBETQTY -- 출고EA/기타출고
                ,COALESCE(QTY_DOWN, 0) AS QTYDOWN
                ,(COALESCE(OB_DM_QTY, 0) + COALESCE(OB_MV_QTY, 0) + COALESCE(OB_ET_QTY, 0) + COALESCE(QTY_DOWN, 0)) AS OBSUM
                ,COALESCE(QTY_MIN, 0) AS BFIV -- 직전 재고
                ,COALESCE(QTY_MIN, 0) + ((COALESCE(CNFRMQTY_DM, 0) + COALESCE(CNFRMQTY_MV, 0) + COALESCE(CNFRMQTY_ET, 0) + COALESCE(QTY_UP, 0))) - ((COALESCE(OB_DM_QTY, 0) + COALESCE(OB_MV_QTY, 0) + COALESCE(OB_ET_QTY, 0) + COALESCE(QTY_DOWN, 0))) AS TOTALIV
                ,(COALESCE(QTY_MIN, 0) + ((COALESCE(CNFRMQTY_DM, 0) + COALESCE(CNFRMQTY_MV, 0) + COALESCE(CNFRMQTY_ET, 0) + COALESCE(QTY_UP, 0))) - ((COALESCE(OB_DM_QTY, 0) + COALESCE(OB_MV_QTY, 0) + COALESCE(OB_ET_QTY, 0) + COALESCE(QTY_DOWN, 0)))) - COALESCE(QTY_MIN, 0) AS DIFF
                ,#{wrkStartDate} || '000000' AS TASKDATE
            FROM (
                -- (1) 직전 재고
                SELECT  OWKEY,
                        CTKEY,
                        ICKEYA,
                        SUM(CASE WHEN RANK_MIN = 1 THEN QTY WHEN RANK_MIN IS NULL AND RANK_MAX IS NULL THEN QTY ELSE 0 END) AS QTY_MIN,
                        MIN(TASKDATE) AS TASKDATE
                    FROM (
                        SELECT  B.OWKEY,
                        B.CTKEY,
                        IVHSKEY,
                        RANK_MIN,
                        RANK_MAX,
                        B.ICKEY ICKEYA,
                        (CASE WHEN A.QTY IS NULL THEN B.AVQTY ELSE A.QTY END) QTY,
                        B.LCKEY,
                        TASKDATE
                    FROM (
                        SELECT * FROM (
                            SELECT
                                OWKEY,
                                CTKEY,
                                IVHSKEY,
                                RANK_MIN,
                                RANK_MAX,
                                ICKEY AS ICKEYA,
                                QTY,
                                TOLCKEY,
                                INSERTDATE AS TASKDATE
                            FROM (
                                SELECT  IVHS.OWKEY,
                                    LC.CTKEY,
                                    RANK() OVER (PARTITION BY TOLCKEY, ICKEY ORDER BY IVHSKEY) AS RANK_MIN,
                                    RANK() OVER (PARTITION BY TOLCKEY, ICKEY ORDER BY IVHSKEY DESC) AS RANK_MAX,
                                    IVHSKEY,
                                    ICKEY,
                                    TOBFCHGQTY + QTY AS QTY,
                                    TOLCKEY,
                                    IVHS.INSERTDATE
                                FROM TWORK_INFO_IVHS IVHS, TWORK_MST_LC LC
                                WHERE IVHS.CTKEY = LC.CTKEY
                                AND IVHS.TOLCKEY = LC.LCKEY
                                AND LC.LCTYPECD = '90'
                            )
                )
                WHERE 1=1
                <if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
                    AND #{SEARCH_CONDITION}
                </if>
                AND (RANK_MIN = 1 OR RANK_MAX = 1)
            ) A RIGHT OUTER JOIN (
                SELECT  IVATXLC.OWKEY,
                    LC.CTKEY,
                    IVATXLC.ICKEY, LC.LCKEY, IVATXLC.AVQTY
                FROM TWORK_INFO_IVATXLC IVATXLC, TWORK_MST_LC LC
                WHERE IVATXLC.CTKEY = LC.CTKEY
                AND IVATXLC.LCKEY = LC.LCKEY
                AND LC.LCTYPECD = '90'
            ) B
            ON A.OWKEY = B.OWKEY
            AND A.CTKEY = B.CTKEY
            AND A.ICKEYA = B.ICKEY
            AND A.TOLCKEY = B.LCKEY
            )
            GROUP BY OWKEY, CTKEY, ICKEYA
        ) A
        FULL OUTER JOIN (
            -- 출고 현황
            SELECT    CTKEY /*센터코드*/
                , CTNM /*센터명*/
                , OWKEY /*화주코드*/
                , ICKEYA
                , SUM(OB_DM_QTY) AS OB_DM_QTY /*출고EA/주문출고*/
                , SUM(OB_MV_QTY) AS OB_MV_QTY /*출고EA/이고출고*/
                , SUM(OB_ET_QTY) AS OB_ET_QTY /*출고EA/기타출고*/
                , MIN(TASKDATE) AS TASKDATE
            FROM (
                SELECT * FROM (
                SELECT    OH.CTKEY AS CTKEY /*센터코드*/
                , CT.CTNM /*센터명*/
                , OH.OWKEY /*화주코드*/
                , IC_A.ICKEY AS ICKEYA
                , CASE WHEN OH.OBHDTYPECD = '10' AND OD.CNFRMQTY > 0 THEN OD.CNFRMQTY ELSE 0 END AS OB_DM_QTY /*출고EA/주문출고*/
                , CASE WHEN OH.OBHDTYPECD = '30' AND OD.CNFRMQTY > 0 THEN OD.CNFRMQTY ELSE 0 END AS OB_MV_QTY /*출고EA/이고출고*/
                , CASE WHEN OH.OBHDTYPECD = '50' AND OD.CNFRMQTY > 0 THEN OD.CNFRMQTY ELSE 0 END AS OB_ET_QTY /*출고EA/기타출고*/
                , OH.OBCNFRMDATE AS TASKDATE
                FROM TWORK_INFO_OB_HD OH
                INNER JOIN TWORK_INFO_OB_DT OD
                ON OH.CTKEY = OD.CTKEY
                AND OH.OWKEY = OD.OWKEY
                AND OH.OBHDKEY = OD.OBHDKEY
                INNER JOIN TWORK_MST_IC IC_A
                ON OD.CTKEY = IC_A.CTKEY
                AND OD.OWKEY = IC_A.OWKEY
                AND OD.ICKEY = IC_A.ICKEY
                INNER JOIN TWORK_MST_CT CT
                ON OH.CTKEY = CT.CTKEY
                WHERE OH.OBHDTYPECD IN ('10', '30', '50')
                AND OH.OBSTATUSCD = '70'
            ) WHERE 1=1
            <if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
                AND #{SEARCH_CONDITION}
            </if>
            ) A
            GROUP BY
                CTKEY   /*센터코드*/
                , CTNM    /*센터명*/
                , OWKEY   /*화주코드*/
                , ICKEYA /*자품번*/
        ) B
        ON A.OWKEY = B.OWKEY
        AND A.CTKEY = B.CTKEY
        AND A.ICKEYA = B.ICKEYA
        FULL OUTER JOIN (
                -- 입고 현황
                SELECT
                    OWKEY,
                    CTKEY,
                    ICKEYA,
                    SUM(CNFRMQTY_DM) AS CNFRMQTY_DM,
                    SUM(CNFRMQTY_MV) AS CNFRMQTY_MV,
                    SUM(CNFRMQTY_ET) AS CNFRMQTY_ET,
                    MIN(TASKDATE) AS TASKDATE
                FROM (
                    SELECT *
                    FROM (
                        SELECT    A.CTKEY
                                , L.CTNM
                                , A.OWKEY
                                , B.IBHDTYPECD
                                , B.IBDDLNDATE AS TASKDATE
                                , C.ICKEY AS ICKEYA
                                , (CASE WHEN B.IBHDTYPECD = '30' THEN COALESCE(A.CNFRMQTY, 0) ELSE 0 END) AS CNFRMQTY_DM
                                , (CASE WHEN B.IBHDTYPECD = '40' THEN COALESCE(A.CNFRMQTY, 0) ELSE 0 END) AS CNFRMQTY_MV
                                , (CASE WHEN B.IBHDTYPECD = '50' THEN COALESCE(A.CNFRMQTY, 0) ELSE 0 END) AS CNFRMQTY_ET
                                , CASE WHEN A.IBDTSTATUSCD = '91' THEN 'Y' ELSE 'N' END AS CLOSEYN
                                , A.IBDTSTATUSCD
                        FROM TWORK_INFO_IB_DT A
                        INNER JOIN TWORK_INFO_IB_HD B
                        ON A.CTKEY = B.CTKEY
                        AND A.OWKEY = B.OWKEY
                        AND A.IBHDKEY = B.IBHDKEY
                        INNER JOIN TWORK_MST_IC C
                        ON A.CTKEY = C.CTKEY
                        AND A.OWKEY = C.OWKEY
                        AND A.ICKEY = C.ICKEY
                        INNER JOIN TWORK_MST_CT L
                        ON A.CTKEY = L.CTKEY
                    ) A
                    WHERE 1=1
                    <if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
                        AND #{SEARCH_CONDITION}
                    </if>
                    AND IBHDTYPECD IN ('30', '40', '50')
                    AND IBDTSTATUSCD = '91'
                    AND CLOSEYN = 'Y'
                ) GROUP BY
                    OWKEY,
                    CTKEY,
                    ICKEYA
        ) C
        ON A.OWKEY = C.OWKEY
        AND B.OWKEY = C.OWKEY
        AND A.CTKEY = C.CTKEY
        AND B.CTKEY = C.CTKEY
        AND A.ICKEYA = C.ICKEYA
        AND B.ICKEYA = C.ICKEYA
        FULL OUTER JOIN (
            -- 재고조정 (증가, 감소)
            SELECT  CTKEY,
                OWKEY,
                ICKEYA,
                SUM(QTY_UP) AS QTY_UP,
                SUM(QTY_DOWN) AS QTY_DOWN,
                MIN(TASKDATE) AS TASKDATE
            FROM (
                SELECT * FROM (
                    SELECT A.CTKEY
                            , H.CTNM
                            , A.OWKEY
                            , I.ICKEY AS ICKEYA
                            , CASE WHEN A.IVHSTYPECD = '130' THEN A.QTY ELSE 0 END AS QTY_UP
                            , CASE WHEN A.IVHSTYPECD = '140' THEN A.QTY ELSE 0 END AS QTY_DOWN
                            , A.IVHSTYPECD
                            , A.IVCHGDATE AS TASKDATE
                    FROM TWORK_INFO_IVHS A
                    LEFT OUTER JOIN TWORK_MST_LC B
                    ON A.CTKEY = B.CTKEY
                    AND A.FRLCKEY = B.LCKEY
                    LEFT OUTER JOIN TWORK_MST_ZN C
                    ON B.CTKEY = C.CTKEY
                    AND B.ZNKEY = C.ZNKEY
                    LEFT OUTER JOIN TWORK_MST_AR D
                    ON B.CTKEY = D.CTKEY
                    AND B.ARKEY = D.ARKEY
                    AND B.ZNKEY = D.ZNKEY
                    LEFT OUTER JOIN TWORK_MST_LC E
                    ON A.CTKEY = E.CTKEY
                    AND A.TOLCKEY = E.LCKEY
                    LEFT OUTER JOIN TWORK_MST_ZN F
                    ON E.CTKEY = F.CTKEY
                    AND E.ZNKEY = F.ZNKEY
                    LEFT OUTER JOIN TWORK_MST_AR G
                    ON E.CTKEY = G.CTKEY
                    AND E.ARKEY = G.ARKEY
                    AND E.ZNKEY = G.ZNKEY
                    INNER JOIN TWORK_MST_CT H
                    ON A.CTKEY = H.CTKEY
                    INNER JOIN TWORK_MST_IC I
                    ON A.CTKEY = I.CTKEY
                    AND A.OWKEY = I.OWKEY
                    AND A.ICKEY = I.ICKEY
                )
                WHERE 1=1
                <if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
                    AND #{SEARCH_CONDITION}
                </if>
                AND ( IVHSTYPECD IN ('130', '140'))
            )
            GROUP BY CTKEY,
                    OWKEY,
                    ICKEYA
        ) D
        ON A.OWKEY = D.OWKEY
            AND B.OWKEY = D.OWKEY
            AND C.OWKEY = D.OWKEY
            AND A.CTKEY = D.CTKEY
            AND B.CTKEY = D.CTKEY
            AND C.CTKEY = D.CTKEY
            AND A.ICKEYA = D.ICKEYA
            AND B.ICKEYA = D.ICKEYA
            AND C.ICKEYA = D.ICKEYA
            INNER JOIN TWORK_MST_IC E -- 자
            ON COALESCE(COALESCE(COALESCE(A.OWKEY, B.OWKEY), C.OWKEY), D.OWKEY) = E.OWKEY
            AND COALESCE(COALESCE(COALESCE(A.CTKEY, B.CTKEY), C.CTKEY), D.CTKEY) = E.CTKEY
            AND COALESCE(COALESCE(COALESCE(A.ICKEYA, B.ICKEYA), C.ICKEYA), D.ICKEYA) = E.ICKEY
            LEFT JOIN TWORK_MST_ASRT F
            ON COALESCE(COALESCE(COALESCE(A.OWKEY, B.OWKEY), C.OWKEY), D.OWKEY) = F.OWKEY
            AND COALESCE(COALESCE(COALESCE(A.CTKEY, B.CTKEY), C.CTKEY), D.CTKEY) = F.CTKEY
            AND COALESCE(COALESCE(COALESCE(A.ICKEYA, B.ICKEYA), C.ICKEYA), D.ICKEYA) = F.ASRTDTICKEY
            AND E.ICKEY = F.ASRTDTICKEY
            LEFT JOIN TWORK_MST_IC G
            ON G.CTKEY = F.CTKEY
            AND G.OWKEY = F.OWKEY
            AND G.ICKEY = F.ASRTMASICKEY
            INNER JOIN TWORK_MST_CTG CTG1
            ON COALESCE(COALESCE(COALESCE(A.CTKEY, B.CTKEY), C.CTKEY), D.CTKEY) = CTG1.CTKEY
            AND COALESCE(COALESCE(COALESCE(A.OWKEY, B.OWKEY), C.OWKEY), D.OWKEY) = CTG1.OWKEY
            AND E.CTGKEY = CTG1.CTGKEY
            AND CTG1.CTGLV = '3'
            INNER JOIN TWORK_MST_CTG CTG2
            ON COALESCE(COALESCE(COALESCE(A.CTKEY, B.CTKEY), C.CTKEY), D.CTKEY) = CTG2.CTKEY
            AND COALESCE(COALESCE(COALESCE(A.OWKEY, B.OWKEY), C.OWKEY), D.OWKEY) = CTG2.OWKEY
            AND CTG1.UPRCTGKEY = CTG2.CTGKEY
            AND CTG2.CTGLV = '2'
            INNER JOIN TWORK_MST_CTG CTG3
            ON COALESCE(COALESCE(COALESCE(A.CTKEY, B.CTKEY), C.CTKEY), D.CTKEY) = CTG3.CTKEY
            AND COALESCE(COALESCE(COALESCE(A.OWKEY, B.OWKEY), C.OWKEY), D.OWKEY) = CTG3.OWKEY
            AND CTG2.UPRCTGKEY = CTG3.CTGKEY
            AND CTG3.CTGLV = '1'
            INNER JOIN TWORK_MST_AC F
            ON E.ACKEY = F.ACKEY
        )
        WHERE 1=1
        <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ctkey)">
            AND CTKEY = #{ctkey}
        </if>
        <if test="@com.kns.framework.util.StringUtil@isNotEmpty(wrkStartDate)">
            AND TASKDATE = #{wrkStartDate} || '000000'
        </if>
        <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ickeyArr)">
            AND (ICKEYM IN (#{ickeyArr}) OR ICKEYA IN (#{ickeyArr}))
        </if>
    </sql>

    <select id="selectinXObIcXMonthStatusCount" resultType="java.lang.Integer">
        /* wms-report-selectinXObIcXMonthStatusList-sql-oracle.xml - selectinXObIcXMonthStatusCount */
        SELECT COUNT(1)
        FROM (
            <include refid="selectinXObIcXMonthStatusSql"/>
        )
    </select>

    <select id="selectinXObIcXMonthStatusList" resultType="camelMap">
        <include refid="sql_pagingTop"/>
            SELECT *
            /* wms-report-selectinXObIcXMonthStatusList-sql-oracle.xml - selectinXObIcXMonthStatusList */
            FROM (
                <include refid="selectinXObIcXMonthStatusSql"/>
            )
        <include refid="sql_pagingBottom"/>
    </select>

    <sql id="selectinXObIcXMonthStatusSql">
        SELECT
            COALESCE(A.OWKEY, B.OWKEY) OWKEY,
            COALESCE(A.CTKEY, B.CTKEY) CTKEY,
            COALESCE(A.ICKEYM, B.ICKEYM) ICKEYM,
            COALESCE(A.ICNMM, B.ICNMM) ICNMM,
            COALESCE(A.ICKEYA, B.ICKEYA) ICKEYA,
            CNFRMQTYDM01, CNFRMQTYMV01, CNFRMQTYET01, QTYUP01, IBSUM01, OBDMQTY01, OBMVQTY01, OBETQTY01, QTYDOWN01, OBSUM01, SUM01,
            CNFRMQTYDM02, CNFRMQTYMV02, CNFRMQTYET02, QTYUP02, IBSUM02, OBDMQTY02, OBMVQTY02, OBETQTY02, QTYDOWN02, OBSUM02, SUM02,
            CNFRMQTYDM03, CNFRMQTYMV03, CNFRMQTYET03, QTYUP03, IBSUM03, OBDMQTY03, OBMVQTY03, OBETQTY03, QTYDOWN03, OBSUM03, SUM03,
            CNFRMQTYDM04, CNFRMQTYMV04, CNFRMQTYET04, QTYUP04, IBSUM04, OBDMQTY04, OBMVQTY04, OBETQTY04, QTYDOWN04, OBSUM04, SUM04,
            CNFRMQTYDM05, CNFRMQTYMV05, CNFRMQTYET05, QTYUP05, IBSUM05, OBDMQTY05, OBMVQTY05, OBETQTY05, QTYDOWN05, OBSUM05, SUM05,
            CNFRMQTYDM06, CNFRMQTYMV06, CNFRMQTYET06, QTYUP06, IBSUM06, OBDMQTY06, OBMVQTY06, OBETQTY06, QTYDOWN06, OBSUM06, SUM06,
            CNFRMQTYDM07, CNFRMQTYMV07, CNFRMQTYET07, QTYUP07, IBSUM07, OBDMQTY07, OBMVQTY07, OBETQTY07, QTYDOWN07, OBSUM07, SUM07,
            CNFRMQTYDM08, CNFRMQTYMV08, CNFRMQTYET08, QTYUP08, IBSUM08, OBDMQTY08, OBMVQTY08, OBETQTY08, QTYDOWN08, OBSUM08, SUM08,
            CNFRMQTYDM09, CNFRMQTYMV09, CNFRMQTYET09, QTYUP09, IBSUM09, OBDMQTY09, OBMVQTY09, OBETQTY09, QTYDOWN09, OBSUM09, SUM09,
            CNFRMQTYDM10, CNFRMQTYMV10, CNFRMQTYET10, QTYUP10, IBSUM10, OBDMQTY10, OBMVQTY10, OBETQTY10, QTYDOWN10, OBSUM10, SUM10,
            CNFRMQTYDM11, CNFRMQTYMV11, CNFRMQTYET11, QTYUP11, IBSUM11, OBDMQTY11, OBMVQTY11, OBETQTY11, QTYDOWN11, OBSUM11, SUM11,
            CNFRMQTYDM12, CNFRMQTYMV12, CNFRMQTYET12, QTYUP12, IBSUM12, OBDMQTY12, OBMVQTY12, OBETQTY12, QTYDOWN12, OBSUM12, SUM12,
            CNFRMQTYDM13, CNFRMQTYMV13, CNFRMQTYET13, QTYUP13, IBSUM13, OBDMQTY13, OBMVQTY13, OBETQTY13, QTYDOWN13, OBSUM13, SUM13,
            CNFRMQTYDM14, CNFRMQTYMV14, CNFRMQTYET14, QTYUP14, IBSUM14, OBDMQTY14, OBMVQTY14, OBETQTY14, QTYDOWN14, OBSUM14, SUM14,
            CNFRMQTYDM15, CNFRMQTYMV15, CNFRMQTYET15, QTYUP15, IBSUM15, OBDMQTY15, OBMVQTY15, OBETQTY15, QTYDOWN15, OBSUM15, SUM15,
            CNFRMQTYDM16, CNFRMQTYMV16, CNFRMQTYET16, QTYUP16, IBSUM16, OBDMQTY16, OBMVQTY16, OBETQTY16, QTYDOWN16, OBSUM16, SUM16,
            CNFRMQTYDM17, CNFRMQTYMV17, CNFRMQTYET17, QTYUP17, IBSUM17, OBDMQTY17, OBMVQTY17, OBETQTY17, QTYDOWN17, OBSUM17, SUM17,
            CNFRMQTYDM18, CNFRMQTYMV18, CNFRMQTYET18, QTYUP18, IBSUM18, OBDMQTY18, OBMVQTY18, OBETQTY18, QTYDOWN18, OBSUM18, SUM18,
            CNFRMQTYDM19, CNFRMQTYMV19, CNFRMQTYET19, QTYUP19, IBSUM19, OBDMQTY19, OBMVQTY19, OBETQTY19, QTYDOWN19, OBSUM19, SUM19,
            CNFRMQTYDM20, CNFRMQTYMV20, CNFRMQTYET20, QTYUP20, IBSUM20, OBDMQTY20, OBMVQTY20, OBETQTY20, QTYDOWN20, OBSUM20, SUM20,
            CNFRMQTYDM21, CNFRMQTYMV21, CNFRMQTYET21, QTYUP21, IBSUM21, OBDMQTY21, OBMVQTY21, OBETQTY21, QTYDOWN21, OBSUM21, SUM21,
            CNFRMQTYDM22, CNFRMQTYMV22, CNFRMQTYET22, QTYUP22, IBSUM22, OBDMQTY22, OBMVQTY22, OBETQTY22, QTYDOWN22, OBSUM22, SUM22,
            CNFRMQTYDM23, CNFRMQTYMV23, CNFRMQTYET23, QTYUP23, IBSUM23, OBDMQTY23, OBMVQTY23, OBETQTY23, QTYDOWN23, OBSUM23, SUM23,
            CNFRMQTYDM24, CNFRMQTYMV24, CNFRMQTYET24, QTYUP24, IBSUM24, OBDMQTY24, OBMVQTY24, OBETQTY24, QTYDOWN24, OBSUM24, SUM24,
            CNFRMQTYDM25, CNFRMQTYMV25, CNFRMQTYET25, QTYUP25, IBSUM25, OBDMQTY25, OBMVQTY25, OBETQTY25, QTYDOWN25, OBSUM25, SUM25,
            CNFRMQTYDM26, CNFRMQTYMV26, CNFRMQTYET26, QTYUP26, IBSUM26, OBDMQTY26, OBMVQTY26, OBETQTY26, QTYDOWN26, OBSUM26, SUM26,
            CNFRMQTYDM27, CNFRMQTYMV27, CNFRMQTYET27, QTYUP27, IBSUM27, OBDMQTY27, OBMVQTY27, OBETQTY27, QTYDOWN27, OBSUM27, SUM27,
            CNFRMQTYDM28, CNFRMQTYMV28, CNFRMQTYET28, QTYUP28, IBSUM28, OBDMQTY28, OBMVQTY28, OBETQTY28, QTYDOWN28, OBSUM28, SUM28,
            CNFRMQTYDM29, CNFRMQTYMV29, CNFRMQTYET29, QTYUP29, IBSUM29, OBDMQTY29, OBMVQTY29, OBETQTY29, QTYDOWN29, OBSUM29, SUM29,
            CNFRMQTYDM30, CNFRMQTYMV30, CNFRMQTYET30, QTYUP30, IBSUM30, OBDMQTY30, OBMVQTY30, OBETQTY30, QTYDOWN30, OBSUM30, SUM30,
            CNFRMQTYDM31, CNFRMQTYMV31, CNFRMQTYET31, QTYUP31, IBSUM31, OBDMQTY31, OBMVQTY31, OBETQTY31, QTYDOWN31, OBSUM31, SUM31,
            CNFRMQTYDM, CNFRMQTYMV, CNFRMQTYET, QTYUP, IBSUM, OBDMQTY, OBMVQTY, OBETQTY, QTYDOWN, OBSUM,
            SUMCUR AS CURIV,
            SUMCUR-SUMTOT AS BFYMIV,
            SUMYM AS DIFFIV
        FROM
        (
            SELECT
                OWKEY,
