    <!-- ==================== 8. 로봇포장 ==================== -->
    <sql id="sql_robotPacking">
        <![CDATA[
        WITH WAV_RATIO AS (
            SELECT RW.CTKEY,
                   RW.OWKEY,
                   RW.WAHDKEY,
                   TO_DATE(RW.WAHDDAY, 'YYYYMMDDHH24MISS') AS WAHDDAY,
                   WH.WARND,
                   RI.ICKEY,
                   RI.QTY,
                   RI.OBHDKEY,
                   TO_DATE(RO.WKPRCSDATE, 'YYYYMMDDHH24MISS') AS WKPRCSDATE,
                   CASE WHEN RI.EMPNOBRCD IS NOT NULL THEN 'AD'||RI.EMPNOBRCD ELSE RI.EMPNOBRCD END AS URKEY,
                   MU.DEPTNM,
                   MU.URNM
              FROM TWIF_ROBDAS_PAKCOMPL_WA RW
              JOIN TWIF_ROBDAS_PAKCOMPL_ORDER RO
                ON RW.WASEQ = RO.WASEQ
               AND RW.CTKEY = RO.CTKEY
               AND RW.OWKEY = RO.OWKEY
               AND RW.WAHDKEY = RO.WAHDKEY
              JOIN TWIF_ROBDAS_PAKCOMPL_IC RI
                ON RO.WASEQ = RI.WASEQ
               AND RO.ORDERSEQ = RI.ORDERSEQ
               AND RO.CTKEY = RI.CTKEY
               AND RO.OWKEY = RI.OWKEY
               AND RO.WAHDKEY = RI.WAHDKEY
               AND RO.OBHDKEY = RI.OBHDKEY
              LEFT JOIN TWORK_INFO_WA_HD WH
                ON RW.CTKEY = WH.CTKEY
               AND RW.OWKEY = WH.OWKEY
               AND RW.WAHDKEY = WH.WAHDKEY
              LEFT JOIN TADMIN_MST_UR MU
                ON CASE WHEN RI.EMPNOBRCD IS NOT NULL THEN 'AD'||RI.EMPNOBRCD ELSE RI.EMPNOBRCD END = MU.URKEY
             WHERE RW.WAHDDAY IS NOT NULL
               AND RI.EMPNOBRCD IS NOT NULL
        ]]>
        <if test="fromDate != null and fromDate != ''">
            AND RW.WAHDDAY >= REPLACE(#{fromDate}, '-', '') || '000000'
        </if>
        <if test="toDate != null and toDate != ''">
            AND RW.WAHDDAY &lt;= REPLACE(#{toDate}, '-', '') || '235959'
        </if>
        <if test="urnm != null and urnm != ''">
            AND MU.URNM LIKE '%' || #{urnm} || '%'
        </if>
        <if test="deptnm != null and deptnm != ''">
            AND MU.DEPTNM LIKE '%' || #{deptnm} || '%'
        </if>
        <if test="ctkey != null and ctkey != ''">
            AND RW.CTKEY = #{ctkey}
        </if>
        <if test="owkey != null and owkey != ''">
            AND RW.OWKEY = #{owkey}
        </if>
        <if test="warnd != null and warnd != ''">
            AND WH.WARND = #{warnd}
        </if>
        <![CDATA[
        )
        SELECT
            TO_CHAR(WAHDDAY, 'YYYY-MM-DD')                AS wahdday,
            WARND                                         AS warnd,
            DEPTNM                                        AS deptnm,
            URKEY                                         AS urkey,
            URNM                                          AS urnm,
            COUNT(DISTINCT ICKEY)                         AS worksku,
            SUM(QTY)                                      AS workea,
            COUNT(DISTINCT OBHDKEY)                       AS packcnt,
            TO_CHAR(MIN(WKPRCSDATE), 'YYYY-MM-DD HH24:MI') AS starttime,
            TO_CHAR(MAX(WKPRCSDATE), 'YYYY-MM-DD HH24:MI') AS endtime,
            CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1 THEN 1 ELSE 0 END AS excltime,
            CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                 THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                 ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
            END AS worktime,
            TRUNC(COUNT(DISTINCT ICKEY)
                  / NULLIF(CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                                THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                                ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
                           END, 0), 1) AS kpisku,
            TRUNC(SUM(QTY)
                  / NULLIF(CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                                THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                                ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
                           END, 0), 1) AS kpiea,
            TRUNC(COUNT(DISTINCT OBHDKEY)
                  / NULLIF(CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                                THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                                ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
                           END, 0), 1) AS kpipack
        FROM WAV_RATIO
        GROUP BY WAHDDAY, WARND, DEPTNM, URKEY, URNM
        ORDER BY WAHDDAY, WARND, URKEY
        ]]>
    </sql>

