<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.daiso.wms.report.mapper.ObOrderWorkerProdStatusMapper">

    <sql id="sql_pagingTop">
        #{GRIDPAGING_ROWNUMTYPE_TOP}
    </sql>

    <sql id="sql_pagingBottom">
        #{GRIDPAGING_ROWNUMTYPE_BOTTOM}
    </sql>

    <!-- ==================== 1. 피킹-경량랙 ==================== -->
    <sql id="sql_pickingLight">
        <![CDATA[
        WITH WAVE_AVG AS (
            SELECT WH.CTKEY,
                   WH.OWKEY,
                   WH.WAHDKEY,
                   SUM(PD.CNFRMQTY) / NULLIF(COUNT(DISTINCT WD.OBHDKEY), 0) AS AVG_QTY_PER_DETAIL
              FROM TWORK_INFO_WA_HD WH
              JOIN TWORK_INFO_WA_DT WD
                ON WH.CTKEY = WD.CTKEY
               AND WH.OWKEY = WD.OWKEY
               AND WH.WAHDKEY = WD.WAHDKEY
              JOIN TWORK_INFO_OB_HD OH
                ON WD.CTKEY = OH.CTKEY
               AND WD.OWKEY = OH.OWKEY
               AND WD.OBHDKEY = OH.OBHDKEY
              JOIN TWORK_INFO_PI_HD PH
                ON OH.CTKEY = PH.CTKEY
               AND OH.OWKEY = PH.OWKEY
               AND OH.PIHDKEY = PH.PIHDKEY
              JOIN TWORK_INFO_PI_DT PD
                ON PH.CTKEY = PD.CTKEY
               AND PH.OWKEY = PD.OWKEY
               AND PH.PIHDKEY = PD.PIHDKEY
             GROUP BY WH.CTKEY, WH.OWKEY, WH.WAHDKEY
        ),
        WAV_RATIO AS (
            SELECT PD.CTKEY,
                   PD.OWKEY,
                   PD.PIHDKEY,
                   PD.PKCNFRMURKEY,
                   TO_DATE(PD.PKCNFRMDATE, 'YYYYMMDDHH24MISS') AS PKCNFRM_DTM,
                   PD.ICKEY,
                   PD.CELLKEY,
                   PD.CNFRMQTY,
                   WH.WAHDDAY,
                   WH.WARND,
                   MU.DEPTNM,
                   MU.URNM,
                   PD.CNFRMQTY / NULLIF(WA.AVG_QTY_PER_DETAIL, 0) AS WAV_CNT
              FROM TWORK_INFO_PI_HD PH
              JOIN TWORK_INFO_PI_DT PD
                ON PH.CTKEY = PD.CTKEY
               AND PH.OWKEY = PD.OWKEY
               AND PH.PIHDKEY = PD.PIHDKEY
              LEFT JOIN TWORK_INFO_WA_HD WH
                ON PH.CTKEY = WH.CTKEY
               AND PH.OWKEY = WH.OWKEY
               AND PH.WAHDKEY = WH.WAHDKEY
              LEFT JOIN WAVE_AVG WA
                ON WH.CTKEY = WA.CTKEY
               AND WH.OWKEY = WA.OWKEY
               AND WH.WAHDKEY = WA.WAHDKEY
              LEFT JOIN TADMIN_MST_UR MU
                ON PD.PKCNFRMURKEY = MU.URKEY
             WHERE WH.WAHDDAY IS NOT NULL
               AND SUBSTR(PD.LCKEY, 0, 1) = 'H'
               AND PD.PKCNFRMURKEY IS NOT NULL
        ]]>
        <if test="fromDate != null and fromDate != ''">
            AND WH.WAHDDAY >= REPLACE(#{fromDate}, '-', '') || '000000'
        </if>
        <if test="toDate != null and toDate != ''">
            AND WH.WAHDDAY &lt;= REPLACE(#{toDate}, '-', '') || '235959'
        </if>
        <if test="urnm != null and urnm != ''">
            AND MU.URNM LIKE '%' || #{urnm} || '%'
        </if>
        <if test="deptnm != null and deptnm != ''">
            AND MU.DEPTNM LIKE '%' || #{deptnm} || '%'
        </if>
        <if test="ctkey != null and ctkey != ''">
            AND WH.CTKEY = #{ctkey}
        </if>
        <if test="owkey != null and owkey != ''">
            AND WH.OWKEY = #{owkey}
        </if>
        <if test="warnd != null and warnd != ''">
            AND WH.WARND = #{warnd}
        </if>
        <![CDATA[
        )
        SELECT
            SUBSTR(X.WAHDDAY, 1, 4) || '-' || SUBSTR(X.WAHDDAY, 5, 2) || '-' || SUBSTR(X.WAHDDAY, 7, 2) AS wahdday,
            X.WARND                                     AS warnd,
            X.DEPTNM                                    AS deptnm,
            X.PKCNFRMURKEY                              AS urkey,
            X.URNM                                      AS urnm,
            X.WORK_CELL                                 AS workcell,
            X.WORK_SKU                                  AS worksku,
            X.WORK_EA                                   AS workea,
            X.WORK_CNT                                  AS workcnt,
            TO_CHAR(X.START_TIME, 'YYYY-MM-DD HH24:MI') AS starttime,
            TO_CHAR(X.END_TIME, 'YYYY-MM-DD HH24:MI')   AS endtime,
            CASE WHEN X.RAW_TIME >= 1 THEN 1 ELSE 0 END AS excltime,
            X.WORK_TIME                                 AS worktime,
            TRUNC(X.WORK_CELL/NULLIF(X.WORK_TIME,0),1)  AS kpicell,
            TRUNC(X.WORK_SKU/NULLIF(X.WORK_TIME,0),1)   AS kpisku,
            TRUNC(X.WORK_EA/NULLIF(X.WORK_TIME,0),1)    AS kpiea,
            TRUNC(X.WORK_CNT/NULLIF(X.WORK_TIME,0),1)   AS kpicnt
        FROM (
            SELECT
                WAHDDAY,
                WARND,
                DEPTNM,
                PKCNFRMURKEY,
                URNM,
                COUNT(DISTINCT CELLKEY)          AS WORK_CELL,
                COUNT(DISTINCT ICKEY)            AS WORK_SKU,
                SUM(CNFRMQTY)                    AS WORK_EA,
                TRUNC(SUM(WAV_CNT),2)            AS WORK_CNT,
                MIN(PKCNFRM_DTM)                 AS START_TIME,
                MAX(PKCNFRM_DTM)                 AS END_TIME,
                (MAX(PKCNFRM_DTM) - MIN(PKCNFRM_DTM)) * 24 AS RAW_TIME,
                CASE WHEN (MAX(PKCNFRM_DTM) - MIN(PKCNFRM_DTM)) * 24 >= 1
                     THEN TRUNC((MAX(PKCNFRM_DTM) - MIN(PKCNFRM_DTM)) * 24 - 1::INTEGER, 2)
                     ELSE TRUNC((MAX(PKCNFRM_DTM) - MIN(PKCNFRM_DTM)) * 24, 2)
                END AS WORK_TIME
            FROM WAV_RATIO
            GROUP BY WAHDDAY, WARND, DEPTNM, PKCNFRMURKEY, URNM
        ) X
        ORDER BY X.WAHDDAY, X.WARND, X.PKCNFRMURKEY
        ]]>
    </sql>

    <select id="selectPickingLightCount" parameterType="map" resultType="int">
        SELECT COUNT(1) FROM (
            <include refid="sql_pickingLight"/>
        ) CNT
    </select>

    <select id="selectPickingLightList" parameterType="map" resultType="camelMap">
        <include refid="sql_pagingTop"/>
        SELECT * FROM (
            <include refid="sql_pickingLight"/>
        ) DATA
        <include refid="sql_pagingBottom"/>
    </select>

    <!-- ==================== 2. 피킹-PLT랙 ==================== -->
    <sql id="sql_pickingPlt">
        <![CDATA[
        WITH WAVE_AVG AS (
            SELECT WH.CTKEY,
                   WH.OWKEY,
                   WH.WAHDKEY,
                   SUM(PD.CNFRMQTY) / NULLIF(COUNT(DISTINCT WD.OBHDKEY), 0) AS AVG_QTY_PER_DETAIL
              FROM TWORK_INFO_WA_HD WH
              JOIN TWORK_INFO_WA_DT WD
                ON WH.CTKEY = WD.CTKEY
               AND WH.OWKEY = WD.OWKEY
               AND WH.WAHDKEY = WD.WAHDKEY
              JOIN TWORK_INFO_OB_HD OH
                ON WD.CTKEY = OH.CTKEY
               AND WD.OWKEY = OH.OWKEY
               AND WD.OBHDKEY = OH.OBHDKEY
              JOIN TWORK_INFO_PI_HD PH
                ON OH.CTKEY = PH.CTKEY
               AND OH.OWKEY = PH.OWKEY
               AND OH.PIHDKEY = PH.PIHDKEY
              JOIN TWORK_INFO_PI_DT PD
                ON PH.CTKEY = PD.CTKEY
               AND PH.OWKEY = PD.OWKEY
               AND PH.PIHDKEY = PD.PIHDKEY
             GROUP BY WH.CTKEY, WH.OWKEY, WH.WAHDKEY
        ),
        WAV_RATIO AS (
            SELECT PD.CTKEY,
                   PD.OWKEY,
                   PD.PIHDKEY,
                   PD.PKCNFRMURKEY,
                   TO_DATE(PD.PKCNFRMDATE, 'YYYYMMDDHH24MISS') AS PKCNFRM_DTM,
                   PD.ICKEY,
                   PD.CELLKEY,
                   PD.CNFRMQTY,
                   WH.WAHDDAY,
                   WH.WARND,
                   MU.DEPTNM,
                   MU.URNM,
                   PD.CNFRMQTY / NULLIF(WA.AVG_QTY_PER_DETAIL, 0) AS WAV_CNT
              FROM TWORK_INFO_PI_HD PH
              JOIN TWORK_INFO_PI_DT PD
                ON PH.CTKEY = PD.CTKEY
               AND PH.OWKEY = PD.OWKEY
               AND PH.PIHDKEY = PD.PIHDKEY
              LEFT JOIN TWORK_INFO_WA_HD WH
                ON PH.CTKEY = WH.CTKEY
               AND PH.OWKEY = WH.OWKEY
               AND PH.WAHDKEY = WH.WAHDKEY
              LEFT JOIN WAVE_AVG WA
                ON WH.CTKEY = WA.CTKEY
               AND WH.OWKEY = WA.OWKEY
               AND WH.WAHDKEY = WA.WAHDKEY
              LEFT JOIN TADMIN_MST_UR MU
                ON PD.PKCNFRMURKEY = MU.URKEY
             WHERE WH.WAHDDAY IS NOT NULL
               AND SUBSTR(PD.LCKEY, 0, 1) = 'P'
               AND PD.PKCNFRMURKEY IS NOT NULL
        ]]>
        <if test="fromDate != null and fromDate != ''">
            AND WH.WAHDDAY >= REPLACE(#{fromDate}, '-', '') || '000000'
        </if>
        <if test="toDate != null and toDate != ''">
            AND WH.WAHDDAY &lt;= REPLACE(#{toDate}, '-', '') || '235959'
        </if>
        <if test="urnm != null and urnm != ''">
            AND MU.URNM LIKE '%' || #{urnm} || '%'
        </if>
        <if test="deptnm != null and deptnm != ''">
            AND MU.DEPTNM LIKE '%' || #{deptnm} || '%'
        </if>
        <if test="ctkey != null and ctkey != ''">
            AND WH.CTKEY = #{ctkey}
        </if>
        <if test="owkey != null and owkey != ''">
            AND WH.OWKEY = #{owkey}
        </if>
        <if test="warnd != null and warnd != ''">
            AND WH.WARND = #{warnd}
        </if>
        <![CDATA[
        )
        SELECT
            SUBSTR(X.WAHDDAY, 1, 4) || '-' || SUBSTR(X.WAHDDAY, 5, 2) || '-' || SUBSTR(X.WAHDDAY, 7, 2) AS wahdday,
            X.WARND                                     AS warnd,
            X.DEPTNM                                    AS deptnm,
            X.PKCNFRMURKEY                              AS urkey,
            X.URNM                                      AS urnm,
            X.WORK_CELL                                 AS workcell,
            X.WORK_SKU                                  AS worksku,
            X.WORK_EA                                   AS workea,
            X.WORK_CNT                                  AS workcnt,
            TO_CHAR(X.START_TIME, 'YYYY-MM-DD HH24:MI') AS starttime,
            TO_CHAR(X.END_TIME, 'YYYY-MM-DD HH24:MI')   AS endtime,
            CASE WHEN X.RAW_TIME >= 1 THEN 1 ELSE 0 END AS excltime,
            X.WORK_TIME                                 AS worktime,
            TRUNC(X.WORK_CELL/NULLIF(X.WORK_TIME,0),1)  AS kpicell,
            TRUNC(X.WORK_SKU/NULLIF(X.WORK_TIME,0),1)   AS kpisku,
            TRUNC(X.WORK_EA/NULLIF(X.WORK_TIME,0),1)    AS kpiea,
            TRUNC(X.WORK_CNT/NULLIF(X.WORK_TIME,0),1)   AS kpicnt
        FROM (
            SELECT
                WAHDDAY,
                WARND,
                DEPTNM,
                PKCNFRMURKEY,
                URNM,
                COUNT(DISTINCT CELLKEY)          AS WORK_CELL,
                COUNT(DISTINCT ICKEY)            AS WORK_SKU,
                SUM(CNFRMQTY)                    AS WORK_EA,
                TRUNC(SUM(WAV_CNT),2)            AS WORK_CNT,
                MIN(PKCNFRM_DTM)                 AS START_TIME,
                MAX(PKCNFRM_DTM)                 AS END_TIME,
                (MAX(PKCNFRM_DTM) - MIN(PKCNFRM_DTM)) * 24 AS RAW_TIME,
                CASE WHEN (MAX(PKCNFRM_DTM) - MIN(PKCNFRM_DTM)) * 24 >= 1
                     THEN TRUNC((MAX(PKCNFRM_DTM) - MIN(PKCNFRM_DTM)) * 24 - 1::INTEGER, 2)
                     ELSE TRUNC((MAX(PKCNFRM_DTM) - MIN(PKCNFRM_DTM)) * 24, 2)
                END AS WORK_TIME
            FROM WAV_RATIO
            GROUP BY WAHDDAY, WARND, DEPTNM, PKCNFRMURKEY, URNM
        ) X
        ORDER BY X.WAHDDAY, X.WARND, X.PKCNFRMURKEY
        ]]>
    </sql>

    <select id="selectPickingPltCount" parameterType="map" resultType="int">
        SELECT COUNT(1) FROM (
            <include refid="sql_pickingPlt"/>
        ) CNT
    </select>

    <select id="selectPickingPltList" parameterType="map" resultType="camelMap">
        <include refid="sql_pagingTop"/>
        SELECT * FROM (
            <include refid="sql_pickingPlt"/>
        ) DATA
        <include refid="sql_pagingBottom"/>
    </select>

    <!-- ==================== 3. 중분류 ==================== -->
    <sql id="sql_midClass">
        <![CDATA[
        WITH WAVE_AVG AS (
            SELECT DW.CTKEY,
                   DW.OWKEY,
                   DW.WAHDKEY,
                   DW.DASDIV,
                   SUM(DI.QTY) / NULLIF(COUNT(DISTINCT DI.OBHDKEY), 0) AS AVG_QTY_PER_DETAIL
              FROM TWIF_DAS_PRCSRSLT_WA DW
              JOIN TWIF_DAS_PRCSRSLT_ORDER DO
                ON DW.WASEQ = DO.WASEQ
               AND DW.CTKEY = DO.CTKEY
               AND DW.OWKEY = DO.OWKEY
               AND DW.WAHDKEY = DO.WAHDKEY
              JOIN TWIF_DAS_PRCSRSLT_IC DI
                ON DO.WASEQ = DI.WASEQ
               AND DO.ORDERSEQ = DI.ORDERSEQ
               AND DO.CTKEY = DI.CTKEY
               AND DO.OWKEY = DI.OWKEY
               AND DO.WAHDKEY = DI.WAHDKEY
               AND DO.OBHDKEY = DI.OBHDKEY
             GROUP BY DW.CTKEY, DW.OWKEY, DW.WAHDKEY, DW.DASDIV
        ),
        WAV_RATIO AS (
            SELECT DW.CTKEY,
                   DW.OWKEY,
                   DW.WAHDKEY,
                   DW.DASDIV,
                   WH.WARND,
                   TO_DATE(DO.WKPRCSDATE, 'YYYYMMDDHH24MISS') AS WKPRCSDATE,
                   DI.ICKEY,
                   DO.DASCELLBRCD,
                   DI.QTY,
                   TO_DATE(DW.IFREQDT, 'YYYYMMDDHH24MISS') AS IFREQDT,
                   CASE WHEN DI.EMPNOBRCD IS NOT NULL THEN 'AD'||DI.EMPNOBRCD ELSE DI.EMPNOBRCD END AS URKEY,
                   MU.DEPTNM,
                   MU.URNM,
                   DI.QTY / NULLIF(WV.AVG_QTY_PER_DETAIL, 0) AS WAV_CNT
              FROM TWIF_DAS_PRCSRSLT_WA DW
              JOIN TWIF_DAS_PRCSRSLT_ORDER DO
                ON DW.WASEQ = DO.WASEQ
               AND DW.CTKEY = DO.CTKEY
               AND DW.OWKEY = DO.OWKEY
               AND DW.WAHDKEY = DO.WAHDKEY
              JOIN TWIF_DAS_PRCSRSLT_IC DI
                ON DO.WASEQ = DI.WASEQ
               AND DO.ORDERSEQ = DI.ORDERSEQ
               AND DO.CTKEY = DI.CTKEY
               AND DO.OWKEY = DI.OWKEY
               AND DO.WAHDKEY = DI.WAHDKEY
               AND DO.OBHDKEY = DI.OBHDKEY
              LEFT JOIN WAVE_AVG WV
                ON DI.CTKEY = WV.CTKEY
               AND DI.OWKEY = WV.OWKEY
               AND DI.WAHDKEY = WV.WAHDKEY
              LEFT JOIN TWORK_INFO_WA_HD WH
                ON DW.CTKEY = WH.CTKEY
               AND DW.OWKEY = WH.OWKEY
               AND DW.WAHDKEY = WH.WAHDKEY
              LEFT JOIN TADMIN_MST_UR MU
                ON CASE WHEN DI.EMPNOBRCD IS NOT NULL THEN 'AD'||DI.EMPNOBRCD ELSE DI.EMPNOBRCD END = MU.URKEY
             WHERE DW.DASDIV = 2
               AND DI.EMPNOBRCD IS NOT NULL
        ]]>
        <if test="fromDate != null and fromDate != ''">
            AND DW.IFREQDT >= REPLACE(#{fromDate}, '-', '') || '000000'
        </if>
        <if test="toDate != null and toDate != ''">
            AND DW.IFREQDT &lt;= REPLACE(#{toDate}, '-', '') || '235959'
        </if>
        <if test="urnm != null and urnm != ''">
            AND MU.URNM LIKE '%' || #{urnm} || '%'
        </if>
        <if test="deptnm != null and deptnm != ''">
            AND MU.DEPTNM LIKE '%' || #{deptnm} || '%'
        </if>
        <if test="ctkey != null and ctkey != ''">
            AND DW.CTKEY = #{ctkey}
        </if>
        <if test="owkey != null and owkey != ''">
            AND DW.OWKEY = #{owkey}
        </if>
        <if test="warnd != null and warnd != ''">
            AND WH.WARND = #{warnd}
        </if>
        <![CDATA[
        )
        SELECT
            TO_CHAR(IFREQDT, 'YYYY-MM-DD') AS wahdday,
            WARND                          AS warnd,
            DEPTNM                         AS deptnm,
            URKEY                          AS urkey,
            URNM                           AS urnm,
            COUNT(DISTINCT ICKEY)          AS worksku,
            SUM(QTY)                       AS workea,
            TRUNC(SUM(WAV_CNT), 2)         AS workcnt,
            TO_CHAR(MIN(WKPRCSDATE), 'YYYY-MM-DD HH24:MI') AS starttime,
            TO_CHAR(MAX(WKPRCSDATE), 'YYYY-MM-DD HH24:MI') AS endtime,
            CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1 THEN 1 ELSE 0 END AS excltime,
            CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                 THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                 ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
            END AS worktime,
            TRUNC(COUNT(DISTINCT ICKEY)
                  / NULLIF(CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                                THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                                ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
                           END, 0), 1) AS kpisku,
            TRUNC(SUM(QTY)
                  / NULLIF(CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                                THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                                ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
                           END, 0), 1) AS kpiea,
            TRUNC(TRUNC(SUM(WAV_CNT), 2)
                  / NULLIF(CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                                THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                                ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
                           END, 0), 1) AS kpicnt
        FROM WAV_RATIO
        GROUP BY IFREQDT, WARND, DEPTNM, URKEY, URNM
        ORDER BY IFREQDT, WARND, URKEY
        ]]>
    </sql>

    <select id="selectMidClassCount" parameterType="map" resultType="int">
        SELECT COUNT(1) FROM (
            <include refid="sql_midClass"/>
        ) CNT
    </select>

    <select id="selectMidClassList" parameterType="map" resultType="camelMap">
        <include refid="sql_pagingTop"/>
        SELECT * FROM (
            <include refid="sql_midClass"/>
        ) DATA
        <include refid="sql_pagingBottom"/>
    </select>

    <!-- ==================== 4. 소분류 ==================== -->
    <sql id="sql_smallClass">
        <![CDATA[
        WITH WAVE_AVG AS (
            SELECT DW.CTKEY,
                   DW.OWKEY,
                   DW.WAHDKEY,
                   DW.DASDIV,
                   SUM(DI.QTY) / NULLIF(COUNT(DISTINCT DI.OBHDKEY), 0) AS AVG_QTY_PER_DETAIL
              FROM TWIF_DAS_PRCSRSLT_WA DW
              JOIN TWIF_DAS_PRCSRSLT_ORDER DO
                ON DW.WASEQ = DO.WASEQ
               AND DW.CTKEY = DO.CTKEY
               AND DW.OWKEY = DO.OWKEY
               AND DW.WAHDKEY = DO.WAHDKEY
              JOIN TWIF_DAS_PRCSRSLT_IC DI
                ON DO.WASEQ = DI.WASEQ
               AND DO.ORDERSEQ = DI.ORDERSEQ
               AND DO.CTKEY = DI.CTKEY
               AND DO.OWKEY = DI.OWKEY
               AND DO.WAHDKEY = DI.WAHDKEY
               AND DO.OBHDKEY = DI.OBHDKEY
             GROUP BY DW.CTKEY, DW.OWKEY, DW.WAHDKEY, DW.DASDIV
        ),
        WAV_RATIO AS (
            SELECT DW.CTKEY,
                   DW.OWKEY,
                   DW.WAHDKEY,
                   DW.DASDIV,
                   WH.WARND,
                   TO_DATE(DO.WKPRCSDATE, 'YYYYMMDDHH24MISS') AS WKPRCSDATE,
                   DI.ICKEY,
                   DO.DASCELLBRCD,
                   DI.QTY,
                   TO_DATE(DW.IFREQDT, 'YYYYMMDDHH24MISS') AS IFREQDT,
                   CASE WHEN DI.EMPNOBRCD IS NOT NULL THEN 'AD'||DI.EMPNOBRCD ELSE DI.EMPNOBRCD END AS URKEY,
                   MU.DEPTNM,
                   MU.URNM,
                   DI.QTY / NULLIF(WV.AVG_QTY_PER_DETAIL, 0) AS WAV_CNT
              FROM TWIF_DAS_PRCSRSLT_WA DW
              JOIN TWIF_DAS_PRCSRSLT_ORDER DO
                ON DW.WASEQ = DO.WASEQ
               AND DW.CTKEY = DO.CTKEY
               AND DW.OWKEY = DO.OWKEY
               AND DW.WAHDKEY = DO.WAHDKEY
              JOIN TWIF_DAS_PRCSRSLT_IC DI
                ON DO.WASEQ = DI.WASEQ
               AND DO.ORDERSEQ = DI.ORDERSEQ
               AND DO.CTKEY = DI.CTKEY
               AND DO.OWKEY = DI.OWKEY
               AND DO.WAHDKEY = DI.WAHDKEY
               AND DO.OBHDKEY = DI.OBHDKEY
              LEFT JOIN WAVE_AVG WV
                ON DI.CTKEY = WV.CTKEY
               AND DI.OWKEY = WV.OWKEY
               AND DI.WAHDKEY = WV.WAHDKEY
              LEFT JOIN TWORK_INFO_WA_HD WH
                ON DW.CTKEY = WH.CTKEY
               AND DW.OWKEY = WH.OWKEY
               AND DW.WAHDKEY = WH.WAHDKEY
              LEFT JOIN TADMIN_MST_UR MU
                ON CASE WHEN DI.EMPNOBRCD IS NOT NULL THEN 'AD'||DI.EMPNOBRCD ELSE DI.EMPNOBRCD END = MU.URKEY
             WHERE DW.DASDIV = 3
               AND DI.EMPNOBRCD IS NOT NULL
        ]]>
        <if test="fromDate != null and fromDate != ''">
            AND DW.IFREQDT >= REPLACE(#{fromDate}, '-', '') || '000000'
        </if>
        <if test="toDate != null and toDate != ''">
            AND DW.IFREQDT &lt;= REPLACE(#{toDate}, '-', '') || '235959'
        </if>
        <if test="urnm != null and urnm != ''">
            AND MU.URNM LIKE '%' || #{urnm} || '%'
        </if>
        <if test="deptnm != null and deptnm != ''">
            AND MU.DEPTNM LIKE '%' || #{deptnm} || '%'
        </if>
        <if test="ctkey != null and ctkey != ''">
            AND DW.CTKEY = #{ctkey}
        </if>
        <if test="owkey != null and owkey != ''">
            AND DW.OWKEY = #{owkey}
        </if>
        <if test="warnd != null and warnd != ''">
            AND WH.WARND = #{warnd}
        </if>
        <![CDATA[
        )
        SELECT
            TO_CHAR(IFREQDT, 'YYYY-MM-DD') AS wahdday,
            WARND                          AS warnd,
            DEPTNM                         AS deptnm,
            URKEY                          AS urkey,
            URNM                           AS urnm,
            COUNT(DISTINCT ICKEY)          AS worksku,
            SUM(QTY)                       AS workea,
            TRUNC(SUM(WAV_CNT), 2)         AS workcnt,
            TO_CHAR(MIN(WKPRCSDATE), 'YYYY-MM-DD HH24:MI') AS starttime,
            TO_CHAR(MAX(WKPRCSDATE), 'YYYY-MM-DD HH24:MI') AS endtime,
            CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1 THEN 1 ELSE 0 END AS excltime,
            CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                 THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                 ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
            END AS worktime,
            TRUNC(COUNT(DISTINCT ICKEY)
                  / NULLIF(CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                                THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                                ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
                           END, 0), 1) AS kpisku,
            TRUNC(SUM(QTY)
                  / NULLIF(CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                                THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                                ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
                           END, 0), 1) AS kpiea,
            TRUNC(TRUNC(SUM(WAV_CNT), 2)
                  / NULLIF(CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                                THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                                ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
                           END, 0), 1) AS kpicnt
        FROM WAV_RATIO
        GROUP BY IFREQDT, WARND, DEPTNM, URKEY, URNM
        ORDER BY IFREQDT, WARND, URKEY
        ]]>
    </sql>

