    </select>

    <!-- ==================== 5. 포장 ==================== -->
    <sql id="sql_packing">
        <![CDATA[
        WITH WAV_RATIO AS (
            SELECT WH.CTKEY,
                   WH.OWKEY,
                   WH.WAHDKEY,
                   TO_DATE(WH.WAHDDAY, 'YYYYMMDDHH24MISS') AS WAHDDAY,
                   WH.WARND,
                   OD.ICKEY,
                   OD.PAKQTY,
                   OD.OBHDKEY,
                   TO_DATE(OD.OBCNFRMDATE, 'YYYYMMDDHH24MISS') AS OBCNFRMDATE,
                   OD.OBCONFIRMURKEY AS URKEY,
                   MU.DEPTNM,
                   MU.URNM
              FROM TWORK_INFO_WA_HD WH
              JOIN TWORK_INFO_WA_DT WD
                ON WH.CTKEY = WD.CTKEY
               AND WH.OWKEY = WD.OWKEY
               AND WH.WAHDKEY = WD.WAHDKEY
              JOIN TWORK_INFO_OB_HD OH
                ON WD.CTKEY = OH.CTKEY
               AND WD.OWKEY = OH.OWKEY
               AND WD.WAHDKEY = OH.WAHDKEY
               AND WD.OBHDKEY = OH.OBHDKEY
              JOIN TWORK_INFO_OB_DT OD
                ON OH.CTKEY = OD.CTKEY
               AND OH.OWKEY = OD.OWKEY
               AND OH.OBHDKEY = OD.OBHDKEY
              LEFT JOIN TADMIN_MST_UR MU
                ON OD.OBCONFIRMURKEY = MU.URKEY
             WHERE WH.WAHDDAY IS NOT NULL
               AND OD.OBCONFIRMURKEY IS NOT NULL
        ]]>
        <if test="fromDate != null and fromDate != ''">
            AND WH.WAHDDAY >= REPLACE(#{fromDate}, '-', '') || '000000'
        </if>
        <if test="toDate != null and toDate != ''">
            AND WH.WAHDDAY &lt;= REPLACE(#{toDate}, '-', '') || '235959'
        </if>
        <if test="urnm != null and urnm != ''">
            AND MU.URNM LIKE '%' || #{urnm} || '%'
        </if>
        <if test="deptnm != null and deptnm != ''">
            AND MU.DEPTNM LIKE '%' || #{deptnm} || '%'
        </if>
        <if test="ctkey != null and ctkey != ''">
            AND WH.CTKEY = #{ctkey}
        </if>
        <if test="owkey != null and owkey != ''">
            AND WH.OWKEY = #{owkey}
        </if>
        <if test="warnd != null and warnd != ''">
            AND WH.WARND = #{warnd}
        </if>
        <![CDATA[
        )
        SELECT
            TO_CHAR(WAHDDAY, 'YYYY-MM-DD')              AS wahdday,
            WARND                                       AS warnd,
            DEPTNM                                      AS deptnm,
            URKEY                                       AS urkey,
            URNM                                        AS urnm,
            COUNT(DISTINCT ICKEY)                       AS worksku,
            SUM(PAKQTY)                                 AS workea,
            COUNT(DISTINCT OBHDKEY)                     AS packcnt,
            TO_CHAR(MIN(OBCNFRMDATE), 'YYYY-MM-DD HH24:MI') AS starttime,
            TO_CHAR(MAX(OBCNFRMDATE), 'YYYY-MM-DD HH24:MI') AS endtime,
            CASE WHEN (MAX(OBCNFRMDATE) - MIN(OBCNFRMDATE)) * 24 >= 1 THEN 1 ELSE 0 END AS excltime,
            CASE WHEN (MAX(OBCNFRMDATE) - MIN(OBCNFRMDATE)) * 24 >= 1
                 THEN TRUNC((MAX(OBCNFRMDATE) - MIN(OBCNFRMDATE)) * 24 - 1::INTEGER, 2)
                 ELSE TRUNC((MAX(OBCNFRMDATE) - MIN(OBCNFRMDATE)) * 24, 2)
            END AS worktime,
            TRUNC(COUNT(DISTINCT ICKEY)
                  / NULLIF(CASE WHEN (MAX(OBCNFRMDATE) - MIN(OBCNFRMDATE)) * 24 >= 1
                                THEN TRUNC((MAX(OBCNFRMDATE) - MIN(OBCNFRMDATE)) * 24 - 1::INTEGER, 2)
                                ELSE TRUNC((MAX(OBCNFRMDATE) - MIN(OBCNFRMDATE)) * 24, 2)
                           END, 0), 1) AS kpisku,
            TRUNC(SUM(PAKQTY)
                  / NULLIF(CASE WHEN (MAX(OBCNFRMDATE) - MIN(OBCNFRMDATE)) * 24 >= 1
                                THEN TRUNC((MAX(OBCNFRMDATE) - MIN(OBCNFRMDATE)) * 24 - 1::INTEGER, 2)
                                ELSE TRUNC((MAX(OBCNFRMDATE) - MIN(OBCNFRMDATE)) * 24, 2)
                           END, 0), 1) AS kpiea,
            TRUNC(COUNT(DISTINCT OBHDKEY)
                  / NULLIF(CASE WHEN (MAX(OBCNFRMDATE) - MIN(OBCNFRMDATE)) * 24 >= 1
                                THEN TRUNC((MAX(OBCNFRMDATE) - MIN(OBCNFRMDATE)) * 24 - 1::INTEGER, 2)
                                ELSE TRUNC((MAX(OBCNFRMDATE) - MIN(OBCNFRMDATE)) * 24, 2)
                           END, 0), 1) AS kpipack
        FROM WAV_RATIO
        GROUP BY WAHDDAY, WARND, DEPTNM, URKEY, URNM
        ORDER BY WAHDDAY, WARND, URKEY
        ]]>
    </sql>

