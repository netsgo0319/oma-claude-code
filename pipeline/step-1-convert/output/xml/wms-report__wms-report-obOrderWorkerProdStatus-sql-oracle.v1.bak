    <!-- ==================== 6. 로봇투입 ==================== -->
    <sql id="sql_robotInput">
        <![CDATA[
        WITH WAVE_AVG AS (
            SELECT PI.CTKEY,
                   PI.OWKEY,
                   PI.WAHDKEY,
                   SUM(PI.QTY) / NULLIF(COUNT(DISTINCT PI.OBHDKEY), 0) AS AVG_QTY_PER_DETAIL
              FROM TWIF_ROBDAS_PRCSRSLT_WA PW
              JOIN TWIF_ROBDAS_PRCSRSLT_ORDER PO
                ON PW.WASEQ = PO.WASEQ
               AND PW.CTKEY = PO.CTKEY
               AND PW.OWKEY = PO.OWKEY
               AND PW.WAHDKEY = PO.WAHDKEY
              JOIN TWIF_ROBDAS_PRCSRSLT_IC PI
                ON PO.WASEQ = PI.WASEQ
               AND PO.ORDERSEQ = PI.ORDERSEQ
               AND PO.CTKEY = PI.CTKEY
               AND PO.OWKEY = PI.OWKEY
               AND PO.WAHDKEY = PI.WAHDKEY
               AND PO.OBHDKEY = PI.OBHDKEY
             GROUP BY PI.CTKEY, PI.OWKEY, PI.WAHDKEY
        ),
        WAV_RATIO AS (
            SELECT PI.CTKEY,
                   PI.OWKEY,
                   PI.WAHDKEY,
                   TO_DATE(PW.WAHDDAY, 'YYYYMMDDHH24MISS') AS WAHDDAY,
                   WH.WARND,
                   PI.ICKEY,
                   PI.QTY,
                   PI.OBHDKEY,
                   TO_DATE(PO.WKPRCSDATE, 'YYYYMMDDHH24MISS') AS WKPRCSDATE,
                   CASE WHEN PI.EMPNOBRCD IS NOT NULL THEN 'AD'||PI.EMPNOBRCD ELSE PI.EMPNOBRCD END AS URKEY,
                   MU.DEPTNM,
                   MU.URNM,
                   PI.QTY/NULLIF(WV.AVG_QTY_PER_DETAIL,0) AS WAV_CNT
              FROM TWIF_ROBDAS_PRCSRSLT_WA PW
              JOIN TWIF_ROBDAS_PRCSRSLT_ORDER PO
                ON PW.WASEQ = PO.WASEQ
               AND PW.CTKEY = PO.CTKEY
               AND PW.OWKEY = PO.OWKEY
               AND PW.WAHDKEY = PO.WAHDKEY
              JOIN TWIF_ROBDAS_PRCSRSLT_IC PI
                ON PO.WASEQ = PI.WASEQ
               AND PO.ORDERSEQ = PI.ORDERSEQ
               AND PO.CTKEY = PI.CTKEY
               AND PO.OWKEY = PI.OWKEY
               AND PO.WAHDKEY = PI.WAHDKEY
               AND PO.OBHDKEY = PI.OBHDKEY
              LEFT JOIN WAVE_AVG WV
                ON PI.CTKEY = WV.CTKEY
               AND PI.OWKEY = WV.OWKEY
               AND PI.WAHDKEY = WV.WAHDKEY
              LEFT JOIN TWORK_INFO_WA_HD WH
                ON PW.CTKEY = WH.CTKEY
               AND PW.OWKEY = WH.OWKEY
               AND PW.WAHDKEY = WH.WAHDKEY
              LEFT JOIN TADMIN_MST_UR MU
                ON CASE WHEN PI.EMPNOBRCD IS NOT NULL THEN 'AD'||PI.EMPNOBRCD ELSE PI.EMPNOBRCD END = MU.URKEY
             WHERE PW.WAHDDAY IS NOT NULL
               AND PI.EMPNOBRCD IS NOT NULL
        ]]>
        <if test="fromDate != null and fromDate != ''">
            AND PW.WAHDDAY >= REPLACE(#{fromDate}, '-', '') || '000000'
        </if>
        <if test="toDate != null and toDate != ''">
            AND PW.WAHDDAY &lt;= REPLACE(#{toDate}, '-', '') || '235959'
        </if>
        <if test="urnm != null and urnm != ''">
            AND MU.URNM LIKE '%' || #{urnm} || '%'
        </if>
        <if test="deptnm != null and deptnm != ''">
            AND MU.DEPTNM LIKE '%' || #{deptnm} || '%'
        </if>
        <if test="ctkey != null and ctkey != ''">
            AND PW.CTKEY = #{ctkey}
        </if>
        <if test="owkey != null and owkey != ''">
            AND PW.OWKEY = #{owkey}
        </if>
        <if test="warnd != null and warnd != ''">
            AND WH.WARND = #{warnd}
        </if>
        <![CDATA[
        )
        SELECT
            TO_CHAR(WAHDDAY, 'YYYY-MM-DD')                  AS wahdday,
            WARND                                           AS warnd,
            DEPTNM                                          AS deptnm,
            URKEY                                           AS urkey,
            URNM                                            AS urnm,
            COUNT(DISTINCT ICKEY)                           AS worksku,
            SUM(QTY)                                        AS workpcs,
            COUNT(DISTINCT OBHDKEY)                         AS inputcnt,
            TRUNC(SUM(WAV_CNT), 2)                          AS workcnt,
            TO_CHAR(MIN(WKPRCSDATE), 'YYYY-MM-DD HH24:MI')  AS starttime,
            TO_CHAR(MAX(WKPRCSDATE), 'YYYY-MM-DD HH24:MI')  AS endtime,
            CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1 THEN 1 ELSE 0 END AS excltime,
            CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                 THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                 ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
            END AS worktime,
            TRUNC(COUNT(DISTINCT ICKEY)
                  / NULLIF(CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                                THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                                ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
                           END, 0), 1) AS kpisku,
            TRUNC(SUM(QTY)
                  / NULLIF(CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                                THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                                ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
                           END, 0), 1) AS kpipcs,
            TRUNC(COUNT(DISTINCT OBHDKEY)
                  / NULLIF(CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                                THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                                ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
                           END, 0), 1) AS kpiinput,
            TRUNC(TRUNC(SUM(WAV_CNT), 2)
                  / NULLIF(CASE WHEN (MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 >= 1
                                THEN TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24 - 1::INTEGER, 2)
                                ELSE TRUNC((MAX(WKPRCSDATE) - MIN(WKPRCSDATE)) * 24, 2)
                           END, 0), 1) AS kpicnt
        FROM WAV_RATIO
        GROUP BY WAHDDAY, WARND, DEPTNM, URKEY, URNM
        ORDER BY WAHDDAY, WARND, URKEY
        ]]>
    </sql>

