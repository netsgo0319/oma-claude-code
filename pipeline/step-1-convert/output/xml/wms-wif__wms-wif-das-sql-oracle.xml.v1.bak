<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
	
<mapper namespace="com.daiso.wms.wif.mapper.DasIfMapper">

	<sql id="sql_pagingTop">
		#{GRIDPAGING_ROWNUMTYPE_TOP}
	</sql>

	<sql id="sql_pagingBottom">
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</sql>

	<select id="selectDasClassifPlanWaveCount" resultType="java.lang.Integer">
		/* wms-wif-das-sql-oracle.xml - selectDasClassifPlanWaveCount 분류계획 Wave 정보(WEB) Count 조회 */
		SELECT COUNT(1)
		  FROM (
				SELECT  WA.WASEQ, WA.CTKEY, WA.OWKEY, WA.WAHDKEY, WA.WAHDDAY, WA.DASEQTYPE, WA.WKDATE, WA.ORD, WA.IFID
					   ,WA.IFREQDT, WA.IFPRCSDATE, WA.INSERTURKEY, WA.INSERTDATE, WA.UPDATEURKEY, WA.UPDATEDATE
				  FROM TWIF_DAS_CLASSIFPLAN_WA WA
				 WHERE 1 = 1
				   AND EXISTS (
					   SELECT 1
						 FROM TWIF_DAS_CLASSIFPLAN_ORDER ORD
					    INNER JOIN TWIF_DAS_CLASSIFPLAN_IC IC
					       ON ORD.WASEQ 	= IC.WASEQ
					      AND ORD.ORDERSEQ 	= IC.ORDERSEQ
					    WHERE WA.WASEQ 		= ORD.WASEQ
						<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)">
						   AND  #{SEARCH_CONDITION}
						</if>
				   )
				   AND WA.IFPRCSDATE IS NOT NULL
				)
	</select>

	<select id="selectDasClassifPlanWaveList" resultType="camelMap">
		<include refid="sql_pagingTop"/>

		/* wms-wif-das-sql-oracle.xml - selectDasClassifPlanWaveList 분류계획 Wave 정보(WEB) 조회 */
		SELECT  '0' AS CHK
			   ,WA.WASEQ
			   ,WA.CTKEY
			   ,CT.CTNM
			   ,WA.OWKEY
			   ,OW.OWNM
			   ,WA.WAHDKEY
			   ,WA.WAHDDAY
			   ,WA.DASEQTYPE
			   ,CDDT2.CTCDDTNM AS DASEQTYPENM
			   ,WA.WKDATE
			   ,WA.WASNDEMP
			   ,WA.IFCD
			   ,EQIF.IFNM
			   ,WA.ORD
			   ,WA.WIFIFID
			   ,WA.IFID
			   ,WA.IFREQDT
			   ,WA.IFPRCSDATE
			   ,WA.IFTYPE
			   ,CDDT.CTCDDTNM AS IFTYPENM
			   ,WA.IFSRCMODULE
			   ,WA.IFTGTMODULE
			   ,WA.IFSTATUS
			   ,CDDT1.CTCDDTNM AS IFSTATUSNM
			   ,WA.IFERRCD
			   ,WA.IFERRMSG
			   ,WA.INSERTURKEY
			   ,WA.INSERTDATE
			   ,WA.UPDATEURKEY
			   ,WA.UPDATEDATE
			   ,WA.IFRETRYYN
			   ,WA.IFRETRYIFID
		  FROM TWIF_DAS_CLASSIFPLAN_WA WA
		  LEFT OUTER JOIN TWORK_MST_CT CT
		    ON WA.CTKEY  		= CT.CTKEY
		  LEFT OUTER JOIN TWORK_MST_OW OW
		    ON WA.OWKEY 		= OW.OWKEY
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT
		    ON WA.CTKEY  		= CDDT.CTKEY
		   AND WA.IFTYPE 		= CDDT.CTCDDTKEY
		   AND CDDT.CTCDHDKEY 	= 'IFTYPE'
		   AND CDDT.LAKEY		= #{lakey}
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT1
		    ON WA.CTKEY  		= CDDT1.CTKEY
		   AND CDDT1.CTCDHDKEY 	= 'IFSTATUS'
		   AND WA.IFSTATUS 		= CDDT1.CTCDDTKEY
		   AND CDDT1.LAKEY		= #{lakey}
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT2
		    ON WA.CTKEY  		= CDDT2.CTKEY
		   AND CDDT2.CTCDHDKEY 	= 'FACTYPE'
		   AND WA.DASEQTYPE		= CDDT2.CTCDDTKEY
		   AND CDDT2.LAKEY		= #{lakey}
		  LEFT OUTER JOIN TWIF_CMM_EQIF_MGMT EQIF
			ON WA.CTKEY 		= EQIF.CTKEY
		   AND WA.OWKEY 		= EQIF.OWKEY
		   AND WA.IFCD 			= EQIF.IFCD
		 WHERE 1 = 1
		   AND EXISTS (
			   SELECT 1
		         FROM TWIF_DAS_CLASSIFPLAN_ORDER ORD
				INNER JOIN TWIF_DAS_CLASSIFPLAN_IC IC
				   ON ORD.WASEQ 	= IC.WASEQ
				  AND ORD.ORDERSEQ 	= IC.ORDERSEQ
			    WHERE ORD.WASEQ 	= WA.WASEQ
				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)">
				   AND  #{SEARCH_CONDITION}
				</if>
		   )
		   AND WA.IFPRCSDATE IS NOT NULL
		 ORDER BY WA.WASEQ DESC
		<include refid="sql_pagingBottom"/>
	</select>

	<select id="selectDasClassifPlanOrderCount" resultType="java.lang.Integer">
		/* wms-wif-das-sql-oracle.xml - selectDasClassifPlanOrderCount 분류계획 Order 정보(WEB) Count 조회 */
		SELECT COUNT(1)
		  FROM TWIF_DAS_CLASSIFPLAN_ORDER
		 WHERE WASEQ = #{waseq}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(OBHDKEY)">
		   AND OBHDKEY = #{OBHDKEY}
		</if>
	</select>

	<select id="selectDasClassifPlanOrderList" resultType="camelMap">
		/* wms-wif-das-sql-oracle.xml - selectDasClassifPlanOrderList 분류계획 Order 정보(WEB) 조회 */
		SELECT
				WASEQ
				,ORDERSEQ
				,CTKEY
				,OWKEY
				,WAHDKEY
				,OBHDKEY
				,DASCELLBRCD
				,MIDGRP
				,PCKGBOXSIZE
				,DFSHPICEXISTYN
				,WBLNO
				,DPRTSPOTTMNLNM
				,DPRTSPOTTMNLCD
				,DESTSPOTTMNLNM
				,DESTSPOTTMNLCD
				,POSTOFICCD
				,POSTOFICNM
				,RGONTYPE
				,HUBCD
				,MDLCD
				,DLVYEMPTYPECD
				,DLVYEMPCD
				,DLVYEMPNM
				,PAY
				,MEMO
				,pkg_crypto$decrypt(RCVPRSNADDR, #{encKey}) 	AS RCVPRSNADDR
				,pkg_crypto$decrypt(RCVPRSNADDR1, #{encKey}) 	AS RCVPRSNADDR1
				,pkg_crypto$decrypt(RCVPRSNADDRABBR, #{encKey}) AS RCVPRSNADDRABBR
				,pkg_crypto$decrypt(RCVPRSNNM, #{encKey}) 		AS RCVPRSNNM
				,pkg_crypto$decrypt(RCVPRSNTEL, #{encKey}) 		AS RCVPRSNTEL
				,pkg_crypto$decrypt(RCVPRSNHP, #{encKey}) 		AS RCVPRSNHP
				,SENDPRSNADDR
				,SENDPRSNNM
				,SENDPRSNTEL
				,SENDPRSNHP
				,WEIGHT
				,ORD
				,INSERTDATE
				,INSERTURKEY
				,UPDATEDATE
				,UPDATEURKEY
		  FROM TWIF_DAS_CLASSIFPLAN_ORDER
		 WHERE WASEQ = #{waseq}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(OBHDKEY)">
		   AND OBHDKEY = #{OBHDKEY}
		</if>
		 ORDER BY ORD
	</select>

	<select id="selectDasClassifPlanItemCount" resultType="java.lang.Integer">
		/* wms-wif-das-sql-oracle.xml - selectDasClassifPlanItemCount 분류계획 Item 정보(WEB) Count 조회 */
		SELECT COUNT(1)
		  FROM TWIF_DAS_CLASSIFPLAN_IC
		 WHERE WASEQ 	= #{waseq}
		   AND ORDERSEQ = #{orderseq}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ICKEY)">
		   AND ICKEY = #{ICKEY}
		</if>
		 ORDER BY ORD
	</select>

	<select id="selectDasClassifPlanItemList" resultType="camelMap">
		/* wms-wif-das-sql-oracle.xml - selectDasClassifPlanItemList 분류계획 Item 정보(WEB) 조회 */
		SELECT
				WASEQ
				,ORDERSEQ
				,ITEMSEQ
				,CTKEY
				,OWKEY
				,WAHDKEY
				,OBHDKEY
				,ICKEY
				,ICNM
				,ICBRCD
				,ICBRCD2
				,ORDQTY
				,LCKEY
				,DFSHPICYN
				,ORD
				,INSERTDATE
				,INSERTURKEY
				,UPDATEDATE
				,UPDATEURKEY
		  FROM TWIF_DAS_CLASSIFPLAN_IC
		 WHERE WASEQ = #{waseq}
		   AND ORDERSEQ = #{orderseq}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ICKEY)">
		   AND ICKEY = #{ICKEY}
		</if>
		 ORDER BY ORD
	</select>

	<select id="selectDasClassifToteMappingWaveCount" resultType="java.lang.Integer">
		/* wms-wif-das-sql-oracle.xml - selectDasClassifToteMappingWaveCount 분류Tote 매핑 Count (WEB) 조회 */
		SELECT COUNT(1)
		  FROM (
				SELECT  '0' AS CHK
						, WA.WASEQ
						, WA.CTKEY
						, WA.OWKEY
						, WA.WAHDKEY
						, WA.IFCD
						, WA.IFID
						, WA.IFREQDT
						, WA.IFTYPE
						, WA.IFSRCMODULE
						, WA.IFTGTMODULE
						, WA.IFSTATUS
						, WA.IFERRCD
						, WA.IFERRMSG
						, WA.IFPRCSDATE
						, WA.INSERTDATE
						, WA.INSERTURKEY
						, WA.UPDATEDATE
						, WA.UPDATEURKEY
				  FROM TWIF_DAS_CLASSIFTOTE_MAPP_WA WA
				 WHERE 1 = 1
				   AND EXISTS (
					   SELECT 1
						 FROM TWIF_DAS_CLASSIFTOTE_MAPP_ORDER ORD
						WHERE ORD.WASEQ = WA.WASEQ
						<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)">
						   AND  #{SEARCH_CONDITION}
						</if>
				   )
				   AND WA.IFPRCSDATE IS NOT NULL
			   ) AA
	</select>

	<select id="selectDasClassifToteMappingWaveList" resultType="camelMap">
		<include refid="sql_pagingTop"/>
		/* wms-wif-das-sql-oracle.xml - selectDasClassifToteMappingWaveList 분류Tote 매핑 리스트 (WEB) 조회 */
		SELECT  '0' AS CHK
				, WA.WASEQ
				, WA.CTKEY
				, CT.CTNM
				, WA.OWKEY
				, OW.OWNM
				, WA.WAHDKEY
				, WA.IFCD
				, EQIF.IFNM AS IFCDNM
				, WA.WIFIFID
				, WA.IFID
				, WA.IFREQDT
				, WA.IFTYPE
				, CDDT.CTCDDTNM AS IFTYPENM
				, WA.IFSRCMODULE
				, WA.IFTGTMODULE
				, WA.IFSTATUS
				, CDDT1.CTCDDTNM AS IFSTATUSNM
				, WA.IFERRCD
				, WA.IFERRMSG
				, WA.IFPRCSDATE
				, WA.INSERTDATE
				, WA.INSERTURKEY
				, WA.UPDATEDATE
				, WA.UPDATEURKEY
				, WA.IFRETRYYN
				, WA.IFRETRYIFID
		  FROM TWIF_DAS_CLASSIFTOTE_MAPP_WA WA
		  LEFT OUTER JOIN TWORK_MST_CT CT
			ON WA.CTKEY  		= CT.CTKEY
		  LEFT OUTER JOIN TWORK_MST_OW OW
			ON WA.OWKEY 		= OW.OWKEY
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT
			ON WA.CTKEY  		= CDDT.CTKEY
		   AND WA.IFTYPE 		= CDDT.CTCDDTKEY
		   AND CDDT.CTCDHDKEY 	= 'IFTYPE'
		   AND CDDT.LAKEY		= #{lakey}
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT1
			ON WA.CTKEY  		= CDDT1.CTKEY
		   AND CDDT1.CTCDHDKEY 	= 'IFSTATUS'
		   AND WA.IFSTATUS 		= CDDT1.CTCDDTKEY
		   AND CDDT1.LAKEY		= #{lakey}
		  LEFT OUTER JOIN TWIF_CMM_EQIF_MGMT EQIF
			ON WA.CTKEY 		= EQIF.CTKEY
		   AND WA.OWKEY 		= EQIF.OWKEY
		   AND WA.IFCD 			= EQIF.IFCD
		 WHERE 1 = 1
		   AND EXISTS (
			   SELECT 1
				 FROM TWIF_DAS_CLASSIFTOTE_MAPP_ORDER ORD
				WHERE WA.WASEQ 	= ORD.WASEQ
				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)">
				   AND  #{SEARCH_CONDITION}
				</if>
		   )
		   AND WA.IFPRCSDATE IS NOT NULL
		 ORDER BY WA.WASEQ DESC
		<include refid="sql_pagingBottom"/>
	</select>

	<select id="selectDasClassifToteMappingOrderCount" resultType="java.lang.Integer">
		/* wms-wif-das-sql-oracle.xml - selectDasClassifToteMappingOrderCount 분류Tote 매핑 ORDER COUNT (WEB) 조회 */
		SELECT
				COUNT(1)
		  FROM TWIF_DAS_CLASSIFTOTE_MAPP_ORDER ORD
		 WHERE 1 = 1
		   AND WASEQ = #{waseq}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(OBHDKEY)">
		   AND OBHDKEY = #{OBHDKEY}
		</if>
	</select>

	<select id="selectDasClassifToteMappingOrderList" resultType="camelMap">
		/* wms-wif-das-sql-oracle.xml - selectDasClassifToteMappingOrderCount 분류Tote 매핑 ORDER LIST (WEB) 조회 */
		SELECT
				WASEQ
				, ORD.ORDERSEQ
				, ORD.CTKEY
				, ORD.OWKEY
				, ORD.WAHDKEY
				, ORD.OBHDKEY
				, ORD.DASCELLBRCD
				, ORD.CLASSIFTOTEBRCD
				, ORD.EMPNOBRCD
				, ORD.FINGERSCANNERID
				, ORD.WKPRCSDATE
				, ORD.ORD
				, ORD.INSERTDATE
				, ORD.INSERTURKEY
				, ORD.UPDATEDATE
				, ORD.UPDATEURKEY
		  FROM TWIF_DAS_CLASSIFTOTE_MAPP_ORDER ORD
		 WHERE 1 = 1
		   AND WASEQ = #{waseq}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(OBHDKEY)">
		   AND OBHDKEY = #{OBHDKEY}
		</if>
		 ORDER BY ORD
	</select>

	<select id="selectDasClassifResultWaveCount" resultType="java.lang.Integer">
		/* wms-wif-das-sql-oracle.xml - selectDasClassifResultWaveCount 분류실적 WAVE COUNT (WEB) 조회 */
		SELECT COUNT(1)
		  FROM (
				SELECT
						WA.WASEQ
						, WA.CTKEY
						, WA.OWKEY
						, WA.WAHDKEY
						, WA.DASDIV
						, WA.IFCD
						, WA.WIFIFID
						, WA.IFID
						, WA.IFREQDT
						, WA.IFTYPE
						, WA.IFSRCMODULE
						, WA.IFTGTMODULE
						, WA.IFSTATUS
						, WA.IFERRCD
						, WA.IFERRMSG
						, WA.IFPRCSDATE
						, WA.ORD
						, WA.INSERTDATE
						, WA.INSERTURKEY
						, WA.UPDATEDATE
						, WA.UPDATEURKEY
				  FROM TWIF_DAS_PRCSRSLT_WA WA
				 WHERE 1 = 1
				   AND EXISTS (
					   SELECT 1
						 FROM TWIF_DAS_PRCSRSLT_ORDER ORD
						INNER JOIN TWIF_DAS_PRCSRSLT_IC IC
						   ON ORD.WASEQ 	= IC.WASEQ
				   		  AND ORD.ORDERSEQ 	= IC.ORDERSEQ
					    WHERE ORD.WASEQ 	= WA.WASEQ
						<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)">
					      AND  #{SEARCH_CONDITION}
						</if>
				   )
				   AND WA.IFPRCSDATE IS NOT NULL
				) AA
	</select>

	<select id="selectDasClassifResultWaveList" resultType="camelMap">
		<include refid="sql_pagingTop"/>
		/* wms-wif-das-sql-oracle.xml - selectDasClassifResultWaveList 분류실적 WAVE LIST (WEB) 조회 */
		SELECT  '0' AS CHK
				, WA.WASEQ
				, WA.CTKEY
				, CT.CTNM
				, WA.OWKEY
				, OW.OWNM
				, WA.WAHDKEY
				, WA.DASDIV
				, CDDT2.CTCDDTNM AS DASDIVNM
				, WA.IFCD
				, EQIF.IFNM
				, WA.WIFIFID
				, WA.IFID
				, WA.IFREQDT
				, WA.IFTYPE
				, CDDT.CTCDDTNM AS IFTYPENM
				, WA.IFSRCMODULE
				, WA.IFTGTMODULE
				, WA.IFSTATUS
				, CDDT1.CTCDDTNM AS IFSTATUSNM
				, WA.IFERRCD
				, WA.IFERRMSG
				, WA.IFPRCSDATE
				, WA.ORD
				, WA.INSERTDATE
				, WA.INSERTURKEY
				, WA.UPDATEDATE
				, WA.UPDATEURKEY
				, WA.IFRETRYYN
				, WA.IFRETRYIFID
		  FROM TWIF_DAS_PRCSRSLT_WA WA
		 INNER JOIN TWORK_MST_CT CT
			ON WA.CTKEY  		= CT.CTKEY
		 INNER JOIN TWORK_MST_OW OW
			ON WA.OWKEY 		= OW.OWKEY
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT
			ON WA.CTKEY  		= CDDT.CTKEY
		   AND WA.IFTYPE 		= CDDT.CTCDDTKEY
		   AND CDDT.CTCDHDKEY 	= 'IFTYPE'
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT1
			ON WA.CTKEY  		= CDDT1.CTKEY
		   AND CDDT1.CTCDHDKEY 	= 'IFSTATUS'
		   AND WA.IFSTATUS 		= CDDT1.CTCDDTKEY
		   AND CDDT1.LAKEY		= #{lakey}
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT2
			ON WA.CTKEY  		= CDDT2.CTKEY
		   AND WA.DASDIV		= CDDT2.CTCDDTKEY
		   AND CDDT2.CTCDHDKEY 	= 'DASDIV'
		   AND CDDT2.LAKEY		= #{lakey}
		  LEFT OUTER JOIN TWIF_CMM_EQIF_MGMT EQIF
			ON WA.CTKEY 		= EQIF.CTKEY
		   AND WA.OWKEY 		= EQIF.OWKEY
		   AND WA.IFCD 			= EQIF.IFCD
		 WHERE 1 = 1
		   AND EXISTS (
			   SELECT 1
				 FROM TWIF_DAS_PRCSRSLT_ORDER ORD
				INNER JOIN TWIF_DAS_PRCSRSLT_IC IC
				   ON ORD.WASEQ 	= IC.WASEQ
				  AND ORD.ORDERSEQ 	= IC.ORDERSEQ
				WHERE ORD.WASEQ 	= WA.WASEQ
				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)">
				   AND  #{SEARCH_CONDITION}
				</if>
		   )
		   AND WA.IFPRCSDATE IS NOT NULL
		 ORDER BY WA.WASEQ DESC
		<include refid="sql_pagingBottom"/>
	</select>

	<select id="selectDasClassifResultOrderCount" resultType="java.lang.Integer">
		/* wms-wif-das-sql-oracle.xml - selectDasClassifResultOrderCount 분류실적 ORDER COUNT (WEB) 조회 */
		SELECT COUNT(1)
		  FROM (
				SELECT
						WASEQ
						, ORDERSEQ
						, CTKEY
						, OWKEY
						, WAHDKEY
						, OBHDKEY
						, DASCELLBRCD
						, WKPRCSDATE
						, ORD
						, INSERTDATE
						, INSERTURKEY
						, UPDATEDATE
						, UPDATEURKEY
				  FROM TWIF_DAS_PRCSRSLT_ORDER ORD
				 WHERE ORD.WASEQ = #{waseq}
				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(OBHDKEY)">
				   AND OBHDKEY = #{OBHDKEY}
				</if>
				) AA
	</select>

	<select id="selectDasClassifResultOrderList" resultType="camelMap">
		/* wms-wif-das-sql-oracle.xml - selectDasClassifResultOrderList 분류실적 ORDER LIST (WEB) 조회 */
		SELECT
				WASEQ
				, ORDERSEQ
				, CTKEY
				, OWKEY
				, WAHDKEY
				, OBHDKEY
				, DASCELLBRCD
				, WKPRCSDATE
				, ORD
				, INSERTDATE
				, INSERTURKEY
				, UPDATEDATE
				, UPDATEURKEY
		  FROM TWIF_DAS_PRCSRSLT_ORDER ORD
		 WHERE ORD.WASEQ = #{waseq}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(OBHDKEY)">
		   AND OBHDKEY = #{OBHDKEY}
		</if>
		 ORDER BY ORD ASC
	</select>

	<select id="selectDasClassifResultItemCount" resultType="java.lang.Integer">
		/* wms-wif-das-sql-oracle.xml - selectDasClassifResultItemCount 분류실적 ITEM COUNT (WEB) 조회 */
		SELECT COUNT(1)
		  FROM (
				SELECT
						WASEQ
						, ORDERSEQ
						, ITEMSEQ
						, CTKEY
						, OWKEY
						, WAHDKEY
						, OBHDKEY
						, ICKEY
						, ICNM
						, ICBRCD
						, ICBRCD2
						, QTY
						, EMPNOBRCD
						, ORD
						, INSERTDATE
						, INSERTURKEY
						, UPDATEDATE
						, UPDATEURKEY
				  FROM TWIF_DAS_PRCSRSLT_IC IC
				 WHERE IC.WASEQ 	= #{waseq}
				   AND IC.ORDERSEQ 	= #{orderseq}
				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ICKEY)">
				   AND ICKEY = #{ICKEY}
				</if>
				) AA
	</select>

	<select id="selectDasClassifResultItemList" resultType="camelMap">
		/* wms-wif-das-sql-oracle.xml - selectDasClassifResultItemList 분류실적 ITEM LIST (WEB) 조회 */
		SELECT
				WASEQ
				, ORDERSEQ
				, ITEMSEQ
				, CTKEY
				, OWKEY
				, WAHDKEY
				, OBHDKEY
				, ICKEY
				, ICNM
				, ICBRCD
				, ICBRCD2
				, QTY
				, EMPNOBRCD
				, FINGERSCANNERID
				, WKPRCSDATE1
				, ORD
				, INSERTDATE
				, INSERTURKEY
				, UPDATEDATE
				, UPDATEURKEY
		  FROM TWIF_DAS_PRCSRSLT_IC IC
		 WHERE IC.WASEQ 	= #{waseq}
		   AND IC.ORDERSEQ 	= #{orderseq}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ICKEY)">
		   AND ICKEY = #{ICKEY}
		</if>
		 ORDER BY IC.ORD ASC
	</select>

	<select id="selectDasClassifToteCloseWaveCount" resultType="java.lang.Integer">
		/* wms-wif-das-sql-oracle.xml - selectDasClassifToteCloseWaveCount 분류토트 마감 WAVE COUNT (WEB) 조회 */
		SELECT COUNT(1)
		  FROM (
				SELECT
						WA.WASEQ
						, WA.CTKEY
						, WA.OWKEY
						, WA.OWKEY
						, WA.WAHDKEY
						, WA.IFCD
						, WA.WIFIFID
						, WA.IFID
						, WA.IFREQDT
						, WA.IFTYPE
						, WA.IFSRCMODULE
						, WA.IFTGTMODULE
						, WA.IFSTATUS
						, WA.IFERRCD
						, WA.IFERRMSG
						, WA.IFPRCSDATE
						, WA.ORD
						, WA.INSERTDATE
						, WA.INSERTURKEY
						, WA.UPDATEDATE
						, WA.UPDATEURKEY
				  FROM TWIF_DAS_CLASSIFTOTE_CLOS_WA WA
				 WHERE 1 = 1
				   AND EXISTS (
					   SELECT 1
						 FROM TWIF_DAS_CLASSIFTOTE_CLOS_ORDER ORD
						INNER JOIN TWIF_DAS_CLASSIFTOTE_CLOS_IC IC
						   ON ORD.WASEQ 	= IC.WASEQ
						  AND ORD.ORDERSEQ 	= IC.ORDERSEQ
						WHERE ORD.WASEQ 	= WA.WASEQ
						<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)">
						   AND  #{SEARCH_CONDITION}
						</if>
				   )
				) AA
	</select>

	<select id="selectDasClassifToteCloseWaveList" resultType="camelMap">
		<include refid="sql_pagingTop"/>
		/* wms-wif-das-sql-oracle.xml - selectDasClassifToteCloseWaveList 분류토트 마감 WAVE LIST (WEB) 조회 */
		SELECT  '0' AS CHK
				, WA.WASEQ
				, WA.CTKEY
				, CT.CTNM
				, WA.OWKEY
				, WA.WAHDKEY
				, WA.IFCD
				, EQIF.IFNM
				, WA.WIFIFID
				, WA.IFID
				, WA.IFREQDT
				, WA.IFTYPE
				, CDDT.CTCDDTNM AS IFTYPENM
				, WA.IFSRCMODULE
				, WA.IFTGTMODULE
				, WA.IFSTATUS
				, CDDT1.CTCDDTNM AS IFSTATUSNM
				, WA.IFERRCD
				, WA.IFERRMSG
				, WA.IFPRCSDATE
				, WA.ORD
				, WA.INSERTDATE
				, WA.INSERTURKEY
				, WA.UPDATEDATE
				, WA.UPDATEURKEY
				, WA.IFRETRYYN
				, WA.IFRETRYIFID
		  FROM TWIF_DAS_CLASSIFTOTE_CLOS_WA WA
		 INNER JOIN TWORK_MST_CT CT
			ON WA.CTKEY  		= CT.CTKEY
		 INNER JOIN TWORK_MST_OW OW
			ON WA.OWKEY 		= OW.OWKEY
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT
			ON WA.CTKEY  		= CDDT.CTKEY
		   AND WA.IFTYPE 		= CDDT.CTCDDTKEY
		   AND CDDT.CTCDHDKEY 	= 'IFTYPE'
		   AND CDDT.LAKEY		= #{lakey}
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT1
			ON WA.CTKEY  		= CDDT1.CTKEY
		   AND CDDT1.CTCDHDKEY 	= 'IFSTATUS'
		   AND WA.IFSTATUS 		= CDDT1.CTCDDTKEY
		   AND CDDT1.LAKEY		= #{lakey}
		  LEFT OUTER JOIN TWIF_CMM_EQIF_MGMT EQIF
			ON WA.CTKEY 		= EQIF.CTKEY
		   AND WA.OWKEY 		= EQIF.OWKEY
		   AND WA.IFCD 			= EQIF.IFCD
		 WHERE 1 = 1
		   AND EXISTS (
			   SELECT 1
				 FROM TWIF_DAS_CLASSIFTOTE_CLOS_ORDER ORD
				INNER JOIN TWIF_DAS_CLASSIFTOTE_CLOS_IC IC
				   ON ORD.WASEQ 	= IC.WASEQ
				  AND ORD.ORDERSEQ 	= IC.ORDERSEQ
				WHERE ORD.WASEQ 	= WA.WASEQ
				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)">
				   AND  #{SEARCH_CONDITION}
				</if>
		   )
		 ORDER BY WA.WASEQ DESC
