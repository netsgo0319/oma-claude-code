				, CTKEY
				, OWKEY
				, WAHDKEY
				, SMLSTN
				, ORD
				, INSERTDATE
				, INSERTURKEY
				, UPDATEDATE
				, UPDATEURKEY
		  FROM TWIF_DAS_MIDLOC_DSN_SMLSTN
		 WHERE WASEQ = #{waseq}
		 ORDER BY ORD ASC
	</select>

	<select id="selectDasMidLocCount" resultType="java.lang.Integer">
		/* wms-wif-das-sql-oracle.xml - selectDasMidLocCount DAS 중분류 셀 바코드 COUNT (WEB) 조회 */
		SELECT COUNT(1)
		  FROM TWIF_DAS_MIDLOC_DSN_MIDCELL
		 WHERE WASEQ 	= #{waseq}
		   AND SMLSTNSEQ = #{smlstnseq}
	</select>

	<select id="selectDasMidLocList" resultType="camelMap">
		/* wms-wif-das-sql-oracle.xml - selectDasMidLocList DAS 중분류 셀 바코드 COUNT (WEB) 조회 */
		SELECT
				WASEQ
				, SMLSTNSEQ
				, MIDCELLSEQ
				, CTKEY
				, OWKEY
				, WAHDKEY
				, SMLSTN
				, MIDCELLBRCD
				, ORD
				, INSERTDATE
				, INSERTURKEY
				, UPDATEDATE
				, UPDATEURKEY
		  FROM TWIF_DAS_MIDLOC_DSN_MIDCELL MID
		 WHERE 1 = 1
		   AND MID.WASEQ = #{waseq}
		   AND MID.SMLSTNSEQ = #{smlstnseq}
		 ORDER BY ORD
	</select>

	<select id="selectClassifPlanWave" resultType="camelMap">
		SELECT
				WASEQ
				, CTKEY
				, OWKEY
				, WAHDKEY
				, WAHDDAY
				, DASEQTYPE
				, WKDATE
				, WASNDEMP
				, IFID
		 FROM TWIF_DAS_CLASSIFPLAN_WA
		WHERE CTKEY 	= #{ctkey}
		  AND OWKEY 	= #{owkey}
		  AND IFID 		= #{ifid}
		  AND IFPRCSDATE IS NOT NULL
 		ORDER BY ORD
	</select>

	<select id="selectClassifPlanOrder" resultType="camelMap">
		SELECT
				WASEQ
				, ORDERSEQ
				, CTKEY
				, OWKEY
				, WAHDKEY
				, OBHDKEY
				, DASCELLBRCD
				, MIDGRP
				, PCKGBOXSIZE
				, DFSHPICEXISTYN
				, WBLNO
				, DPRTSPOTTMNLNM
				, DPRTSPOTTMNLCD
				, DESTSPOTTMNLNM
				, DESTSPOTTMNLCD
				, POSTOFICCD
				, POSTOFICNM
				, RGONTYPE
				, HUBCD
				, MDLCD
				, DLVYEMPTYPECD
				, DLVYEMPCD
				, DLVYEMPNM
				, PAY
				, MEMO
				, RCVPRSNADDR
				, RCVPRSNADDR1
				, RCVPRSNADDRABBR
				, RCVPRSNNM
				, RCVPRSNTEL
				, RCVPRSNHP
				, SENDPRSNADDR
				, SENDPRSNNM
				, SENDPRSNTEL
				, SENDPRSNHP
				, WEIGHT
		  FROM TWIF_DAS_CLASSIFPLAN_ORDER
		 WHERE WASEQ = #{waseq}
 		 ORDER BY ORD
	</select>

	<select id="selectClassifPlanItem" resultType="camelMap">
		SELECT
				WASEQ
				, ORDERSEQ
				, ITEMSEQ
				, CTKEY
				, OWKEY
				, WAHDKEY
				, OBHDKEY
				, ICKEY
				, ICNM
				, ICBRCD
				, ICBRCD2
				, ORDQTY
				, LCKEY
				, DFSHPICYN
		  FROM TWIF_DAS_CLASSIFPLAN_IC
		 WHERE WASEQ 	= #{waseq}
		   AND ORDERSEQ = #{orderseq}
		 ORDER BY ORD
	</select>

</mapper>