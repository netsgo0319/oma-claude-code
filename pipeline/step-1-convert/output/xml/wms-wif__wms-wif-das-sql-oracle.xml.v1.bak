	<select id="selectRobDasPackCompleteWaveCount" resultType="java.lang.Integer">
		/* wms-wif-das-sql-oracle.xml - selectRobDasPackCompleteWaveCount ROBOT DAS 포장완료 WAVE COUNT (WEB) 조회 */
		SELECT COUNT(1)
		  FROM (
				SELECT
						'0' AS CHK
						, WA.WASEQ
						, WA.CTKEY
						, WA.OWKEY
						, WA.WAHDKEY
						, WA.WAHDDAY
						, WA.IFCD
						, WA.WIFIFID
						, WA.IFID
						, WA.IFREQDT
						, WA.IFTYPE
						, WA.IFSRCMODULE
						, WA.IFTGTMODULE
						, WA.IFSTATUS
						, WA.IFERRCD
						, WA.IFERRMSG
						, WA.IFPRCSDATE
						, WA.ORD
						, WA.INSERTDATE
						, WA.INSERTURKEY
						, WA.UPDATEDATE
						, WA.UPDATEURKEY
				  FROM TWIF_ROBDAS_PAKCOMPL_WA WA
				 WHERE 1 = 1
				   AND EXISTS (
					   SELECT 1
						 FROM TWIF_ROBDAS_PAKCOMPL_ORDER ORD
						INNER JOIN TWIF_ROBDAS_PAKCOMPL_IC IC
						   ON ORD.WASEQ 	= IC.WASEQ
						  AND ORD.ORDERSEQ 	= IC.ORDERSEQ
						WHERE WA.WASEQ 		= ORD.WASEQ
						<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)">
						   AND  #{SEARCH_CONDITION}
						</if>
				   )
				) AA
	</select>

	<select id="selectRobDasPackCompleteWaveList" resultType="camelMap">
		<include refid="sql_pagingTop"/>
		/* wms-wif-das-sql-oracle.xml - selectRobDasPackCompleteWaveList ROBOT DAS 포장완료 WAVE List (WEB) 조회 */
		SELECT
				'0' AS CHK
				, WA.WASEQ
				, WA.CTKEY
				, CT.CTNM
				, WA.OWKEY
				, OW.OWNM
				, WA.WAHDKEY
				, WA.WAHDDAY
				, WA.IFCD
				, WA.WIFIFID
				, WA.IFID
				, WA.IFREQDT
				, WA.IFTYPE
				, CDDT.CTCDDTNM AS IFTYPENM
				, WA.IFSRCMODULE
				, WA.IFTGTMODULE
				, WA.IFSTATUS
				, CDDT1.CTCDDTNM AS IFSTATUSNM
				, WA.IFERRCD
				, WA.IFERRMSG
				, WA.IFPRCSDATE
				, WA.ORD
				, WA.INSERTDATE
				, WA.INSERTURKEY
				, WA.UPDATEDATE
				, WA.UPDATEURKEY
				, WA.IFRETRYYN
				, WA.IFRETRYIFID
		  FROM TWIF_ROBDAS_PAKCOMPL_WA WA
		  LEFT OUTER JOIN TWORK_MST_CT CT
			ON WA.CTKEY  		= CT.CTKEY
		  LEFT OUTER JOIN TWORK_MST_OW OW
			ON WA.OWKEY 		= OW.OWKEY
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT
			ON WA.CTKEY  		= CDDT.CTKEY
		   AND WA.IFTYPE 		= CDDT.CTCDDTKEY
		   AND CDDT.CTCDHDKEY 	= 'IFTYPE'
		   AND CDDT.LAKEY		= #{lakey}
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT1
			ON WA.CTKEY  		= CDDT1.CTKEY
		   AND CDDT1.CTCDHDKEY 	= 'IFSTATUS'
		   AND WA.IFSTATUS 		= CDDT1.CTCDDTKEY
		   AND CDDT1.LAKEY		= #{lakey}
		 WHERE 1 = 1
		   AND EXISTS (
			   SELECT 1
				 FROM TWIF_ROBDAS_PAKCOMPL_ORDER ORD
				INNER JOIN TWIF_ROBDAS_PAKCOMPL_IC IC
				   ON ORD.WASEQ 	= IC.WASEQ
				  AND ORD.ORDERSEQ 	= IC.ORDERSEQ
				WHERE WA.WASEQ 		= ORD.WASEQ
				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)">
				   AND  #{SEARCH_CONDITION}
				</if>
		   )
		 ORDER BY WA.WASEQ DESC
		<include refid="sql_pagingBottom"/>
	</select>

	<select id="selectRobDasPackCompleteOrderCount" resultType="java.lang.Integer">
		/* wms-wif-das-sql-oracle.xml - selectRobDasPackCompleteOrderCount ROBOT DAS 포장완료 ORDER COUNT (WEB) 조회 */
		SELECT COUNT(1)
		  FROM TWIF_ROBDAS_PAKCOMPL_ORDER
		 WHERE WASEQ = #{waseq}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(OBHDKEY)">
		   AND OBHDKEY = #{OBHDKEY}
		</if>
	</select>

	<select id="selectRobDasPackCompleteOrderList" resultType="camelMap">
		/* wms-wif-das-sql-oracle.xml - selectRobDasPackCompleteOrderList ROBOT DAS 포장완료 ORDER LIST (WEB) 조회 */
		SELECT
				WASEQ
				, ORDERSEQ
				, CTKEY
				, OWKEY
				, WAHDKEY
				, OBHDKEY
				, WBLNO
				, BOXSIZE
				, WKPRCSDATE
				, ORD
				, INSERTDATE
				, INSERTURKEY
				, UPDATEDATE
				, UPDATEURKEY
		  FROM TWIF_ROBDAS_PAKCOMPL_ORDER
		 WHERE WASEQ = #{waseq}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(OBHDKEY)">
		   AND OBHDKEY = #{OBHDKEY}
		</if>
		 ORDER BY ORD ASC
	</select>

	<select id="selectRobDasPackCompleteItemCount" resultType="java.lang.Integer">
		/* wms-wif-das-sql-oracle.xml - selectRobDasPackCompleteItemCount ROBOT DAS 포장완료 ITEM COUNT (WEB) 조회 */
		SELECT COUNT(1)
		  FROM TWIF_ROBDAS_PAKCOMPL_IC
		 WHERE WASEQ 	= #{waseq}
		   AND ORDERSEQ = #{orderseq}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ICKEY)">
		   AND ICKEY = #{ICKEY}
		</if>
	</select>

	<select id="selectRobDasPackCompleteItemList" resultType="camelMap">
		/* wms-wif-das-sql-oracle.xml - selectRobDasPackCompleteItemList ROBOT DAS 포장완료 ITEM LIST (WEB) 조회 */
		SELECT
				IC.WASEQ
				, IC.ORDERSEQ
				, IC.ITEMSEQ
				, IC.CTKEY
				, IC.OWKEY
				, IC.WAHDKEY
				, IC.OBHDKEY
				, IC.ICKEY
				, ICMST.ICNM
				, IC.ICBRCD
				, IC.ICBRCD2
				, IC.QTY
				, IC.EMPNOBRCD
				, IC.ORD
				, IC.INSERTDATE
				, IC.INSERTURKEY
				, IC.UPDATEDATE
				, IC.UPDATEURKEY
		  FROM TWIF_ROBDAS_PAKCOMPL_IC IC
		  LEFT OUTER JOIN TWORK_MST_IC ICMST
		    ON IC.CTKEY = ICMST.CTKEY
		   AND IC.OWKEY = ICMST.OWKEY
		   AND IC.ICKEY = ICMST.ICKEY
		   AND ICMST.DELYN = 'N'
		 WHERE WASEQ 	= #{waseq}
		   AND ORDERSEQ = #{orderseq}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ICKEY)">
		   AND IC.ICKEY = #{ICKEY}
		</if>
		 ORDER BY ORD ASC
	</select>

	<select id="selectDasMidLocWaveCount" resultType="java.lang.Integer">
		/* wms-wif-das-sql-oracle.xml - selectDasMidLocWaveCount DAS 중분류 로케이션 지정 WAVE List (WEB) 조회 */
		SELECT COUNT(1)
		  FROM (
				SELECT
						WA.WASEQ
						, WA.CTKEY
						, WA.OWKEY
						, WA.WAHDKEY
						, WA.WAHDDAY
						, WA.DASEQTYPE
						, WA.IFCD
						, WA.WIFIFID
						, WA.IFID
						, WA.IFREQDT
						, WA.IFTYPE
						, WA.IFSRCMODULE
						, WA.IFTGTMODULE
						, WA.IFSTATUS
						, WA.IFERRCD
						, WA.IFERRMSG
						, WA.IFPRCSDATE
						, WA.ORD
						, WA.INSERTDATE
						, WA.INSERTURKEY
						, WA.UPDATEDATE
						, WA.UPDATEURKEY
				  FROM TWIF_DAS_MIDLOC_DSN_WA WA
				 WHERE 1 = 1
				   AND EXISTS (
					   SELECT 1
						 FROM TWIF_DAS_MIDLOC_DSN_SMLSTN SML
						INNER JOIN TWIF_DAS_MIDLOC_DSN_MIDCELL MID
						   ON SML.WASEQ = MID.WASEQ
				   		  AND SML.SMLSTNSEQ = MID.SMLSTNSEQ
						WHERE SML.WASEQ = WA.WASEQ
						<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)">
						   AND  #{SEARCH_CONDITION}
						</if>
				   )
			   ) AA
	</select>

	<select id="selectDasMidLocWaveList" resultType="camelMap">
		<include refid="sql_pagingTop"/>
		/* wms-wif-das-sql-oracle.xml - selectDasMidLocWaveList DAS 중분류 로케이션 지정 WAVE List (WEB) 조회 */
		SELECT
				'0' AS CHK
				, WA.WASEQ
				, WA.CTKEY
				, CT.CTNM
				, WA.OWKEY
				, OW.OWNM
				, WA.WAHDKEY
				, WA.WAHDDAY
				, WA.DASEQTYPE
				, CDDT2.CTCDDTNM AS DASEQTYPENM
				, WA.IFCD
				, WA.WIFIFID
				, WA.IFID
				, WA.IFREQDT
				, WA.IFTYPE
				, CDDT.CTCDDTNM AS IFTYPENM
				, WA.IFSRCMODULE
				, WA.IFTGTMODULE
				, WA.IFSTATUS
				, CDDT1.CTCDDTNM AS IFSTATUSNM
				, WA.IFERRCD
				, WA.IFERRMSG
				, WA.IFPRCSDATE
				, WA.ORD
				, WA.INSERTDATE
				, WA.INSERTURKEY
				, WA.UPDATEDATE
				, WA.UPDATEURKEY
				, WA.IFRETRYYN
				, WA.IFRETRYIFID
		  FROM TWIF_DAS_MIDLOC_DSN_WA WA
		  LEFT OUTER JOIN TWORK_MST_CT CT
			ON WA.CTKEY  		= CT.CTKEY
		  LEFT OUTER JOIN TWORK_MST_OW OW
			ON WA.OWKEY 		= OW.OWKEY
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT
			ON WA.CTKEY  		= CDDT.CTKEY
		   AND WA.IFTYPE 		= CDDT.CTCDDTKEY
		   AND CDDT.CTCDHDKEY 	= 'IFTYPE'
		   AND CDDT.LAKEY		= #{lakey}
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT1
			ON WA.CTKEY  		= CDDT1.CTKEY
		   AND CDDT1.CTCDHDKEY 	= 'IFSTATUS'
		   AND WA.IFSTATUS 		= CDDT1.CTCDDTKEY
		   AND CDDT1.LAKEY		= #{lakey}
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT2
			ON WA.CTKEY  		= CDDT2.CTKEY
		   AND CDDT2.CTCDHDKEY 	= 'FACTYPE'
		   AND WA.DASEQTYPE		= CDDT2.CTCDDTKEY
		   AND CDDT2.LAKEY		= #{lakey}
 		 WHERE 1 = 1
		   AND EXISTS (
			   SELECT 1
				 FROM TWIF_DAS_MIDLOC_DSN_SMLSTN SML
				INNER JOIN TWIF_DAS_MIDLOC_DSN_MIDCELL MID
				   ON SML.WASEQ = MID.WASEQ
				  AND SML.SMLSTNSEQ = MID.SMLSTNSEQ
				WHERE SML.WASEQ = WA.WASEQ
				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)">
				   AND  #{SEARCH_CONDITION}
				</if>
		   )
		 ORDER BY WA.WASEQ DESC
		<include refid="sql_pagingBottom"/>
	</select>

	<select id="selectDasSmlStnCount" resultType="java.lang.Integer">
		/* wms-wif-das-sql-oracle.xml - selectDasSmlStnCount DAS 소분류 스테이션 COUNT (WEB) 조회 */
		SELECT COUNT(1)
