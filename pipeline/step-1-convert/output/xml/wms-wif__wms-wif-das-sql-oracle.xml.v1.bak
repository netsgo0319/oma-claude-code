		</if>
	</select>

	<select id="selectRobDasBoxAddReqItemList" resultType="camelMap">
		/* wms-wif-das-sql-oracle.xml - selectRobDasBoxAddReqItemList ROBOT DAS 박스추가 요청 ITEM List (WEB) 조회 */
		SELECT
