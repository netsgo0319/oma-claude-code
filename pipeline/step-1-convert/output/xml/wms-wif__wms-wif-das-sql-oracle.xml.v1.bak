				, WA.INSERTDATE
				, WA.INSERTURKEY
				, WA.UPDATEDATE
				, WA.UPDATEURKEY
				, WA.IFRETRYYN
				, WA.IFRETRYIFID
		  FROM TWIF_ROBDAS_BOXADD_WA WA
		  LEFT OUTER JOIN TWORK_MST_CT CT
			ON WA.CTKEY  		= CT.CTKEY
		  LEFT OUTER JOIN TWORK_MST_OW OW
			ON WA.OWKEY 		= OW.OWKEY
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT
			ON WA.CTKEY  		= CDDT.CTKEY
		   AND WA.IFTYPE 		= CDDT.CTCDDTKEY
		   AND CDDT.CTCDHDKEY 	= 'IFTYPE'
		   AND CDDT.LAKEY		= #{lakey}
		  LEFT OUTER JOIN TWORK_MST_CTCD_DT CDDT1
			ON WA.CTKEY  		= CDDT1.CTKEY
		   AND CDDT1.CTCDHDKEY 	= 'IFSTATUS'
		   AND WA.IFSTATUS 		= CDDT1.CTCDDTKEY
		   AND CDDT1.LAKEY		= #{lakey}
		  LEFT OUTER JOIN TWIF_CMM_EQIF_MGMT EQIF
			ON WA.CTKEY 		= EQIF.CTKEY
		   AND WA.OWKEY 		= EQIF.OWKEY
		   AND WA.IFCD 			= EQIF.IFCD
		 WHERE 1 = 1
		   AND EXISTS ( 
			   SELECT 1
				 FROM TWIF_ROBDAS_BOXADD_ORDER ORD
				 LEFT OUTER JOIN TWIF_ROBDAS_BOXADD_IC IC
				   ON ORD.WASEQ 	= IC.WASEQ
				  AND ORD.ORDERSEQ 	= IC.ORDERSEQ
				WHERE WA.WASEQ 		= ORD.WASEQ
				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)">
				   AND  #{SEARCH_CONDITION}
				</if>
		   )
		 ORDER BY WA.WASEQ DESC
		<include refid="sql_pagingBottom"/>
	</select>

	<select id="selectRobDasBoxAddReqOrderCount" resultType="java.lang.Integer">
		/* wms-wif-das-sql-oracle.xml - selectRobDasBoxAddReqOrderCount ROBOT DAS 박스추가 요청 ORDER COUNT (WEB) 조회 */
		SELECT COUNT(1)
		  FROM TWIF_ROBDAS_BOXADD_ORDER
		 WHERE WASEQ = #{waseq}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(OBHDKEY)">
		   AND OBHDKEY = #{OBHDKEY}
		</if>
	</select>

	<select id="selectRobDasBoxAddReqOrderList" resultType="camelMap">
		/* wms-wif-das-sql-oracle.xml - selectRobDasBoxAddReqOrderList ROBOT DAS 박스추가 요청 ORDER List (WEB) 조회 */
		SELECT
				WASEQ
				, ORDERSEQ
				, CTKEY
				, OWKEY
				, WAHDKEY
				, OBHDKEY
				, WBLNO
				, BFOBHDKEY
				, BFWBLNO
				, PCKGBOXSIZE
				, WKPRCSDATE
				, BFPCKGBOXSIZE
				, ORD
				, INSERTDATE
				, INSERTURKEY
				, UPDATEDATE
				, UPDATEURKEY
		  FROM TWIF_ROBDAS_BOXADD_ORDER
		 WHERE WASEQ = #{waseq}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(OBHDKEY)">
		   AND OBHDKEY = #{OBHDKEY}
		</if>
		 ORDER BY ORD ASC
	</select>

	<select id="selectRobDasBoxAddReqItemCount" resultType="java.lang.Integer">
