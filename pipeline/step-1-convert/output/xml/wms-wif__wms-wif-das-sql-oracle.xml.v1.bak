				, ORDERSEQ
				, ITEMSEQ
				, CTKEY
				, OWKEY
				, WAHDKEY
				, OBHDKEY
				, ICKEY
				, ICNM
				, ICBRCD
				, ICBRCD2
				, QTY
				, EMPNOBRCD
				, ORD
				, INSERTDATE
				, INSERTURKEY
				, UPDATEDATE
				, UPDATEURKEY
		  FROM TWIF_ROBDAS_BOXADD_IC
		 WHERE WASEQ 	= #{waseq}
