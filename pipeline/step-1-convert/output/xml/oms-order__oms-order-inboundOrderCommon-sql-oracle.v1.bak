    <select id="selectInboundOrderDtGroupList" resultType="com.daiso.oms.ordercommon.vo.ServiceOrderProcVO$ServiceOrderItemsVO">
        /* oms-order-inboundOrderCommon-sql-oracle.xml - selectInboundOrderDtGroupList */
        SELECT B.OWKEY
             , B.SOHDKEY
             , B.SODTKEY
             , B.ICKEY
             , B.OLNICKEY
             , B.ICUTKEY
             , B.UOM
             , B.INITQTY
             , B.EXPCTQTY
             , B.CNFRMQTY
             , B.SNDQTY
             , B.DLVYEXPCTDAY
             , B.ORDERISTDAY
             , B.OBAMT
             , B.TTWEIGHT
             , B.WEIGHTUNIT
             , B.VOL
             , B.VOLUNIT
             , B.LOGGRPCD
             , B.CMT
             , B.PRDCTLOT
             , B.PRDCTDAY
             , B.WKSTATUS
             , B.RFRNCKEY
             , B.RFRNCDTKEY
             , B.ORGORDERKEY
             , B.ORGORDERDTKEY
             , B.CNFRMYN
             , B.CNLYN
             , B.NISCMT
             , B.RICMT
             , B.COHDKEY
             , B.CODTKEY
             , B.ORDERERRCD
             , B.ORDERERRCMT
             , B.ICGRKEY
             , B.ICGRTYPE
             , B.SPEC
             , B.DLVYCNTRUNIT
             , B.MALBOXQTY
             , B.MALPCSQTY
             , B.NISQTY
             , B.NISYN
             , B.INSERTDATE
             , B.INSERTURKEY
             , B.UPDATEDATE
             , B.UPDATEURKEY
        FROM TORDER_INFO_SO_HD A
        INNER JOIN TORDER_INFO_SO_DT B
                ON A.OWKEY = B.OWKEY
               AND A.SOHDKEY = B.SOHDKEY
        WHERE A.RFRNCKEY = #{uploadkey}
    </select>

    <select id="selectTOrderMstOwOrderTypeList" resultType="camelMap">
		/* oms-inboundOrderCommon-sql-oracle.xml - selectTOrderMstOwOrderTypeList */
		SELECT A.EXTORDERTYPECD AS FIELD1
			,  B.EXTORDERTYPENM AS FIELD2
			,  A.ORDERTYPECD || ' : '|| C.ORDERTYPENM AS FIELD3
			,  A.ORDERTYPECD AS FIELD4
			,  A.OWKEY AS FIELD5
			,  C.ORDERTYPENM AS FIELD6
            ,  C.WMSYN AS FIELD7
            ,  C.WMSIBTYPE AS FIELD8
		FROM TORDER_INFO_ORTYPE_MAPPING A
			INNER JOIN TORDER_MST_EXTERN B
				    ON A.OWKEY = B.OWKEY
				   AND A.EXTORDERTYPECD = B.EXTORDERTYPECD
			INNER JOIN TORDER_MST_ORTYPE C
					ON A.OWKEY = C.OWKEY
				   AND A.ORDERTYPECD = C.ORDERTYPECD
		WHERE A.DELYN = 'N'
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
			AND A.OWKEY = #{owkey}
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ibyn)">
			AND C.IBYN = #{ibyn}
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(obyn)">
			AND C.OBYN = #{obyn}
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(orderat)">
			AND C.ORDERAT = #{orderat}
		</if>
		ORDER BY A.EXTORDERTYPECD, LPAD(A.ORDERTYPECD::TEXT, 20, '0')
	</select>
	
	<select id="selectAsrtrepkeyYn" resultType="camelMap">
		/* oms-inboundOrderCommon-sql-oracle.xml - selectAsrtrepkeyYn */
		SELECT CASE
		         WHEN (SELECT COUNT(*) 
		               FROM TORDER_MST_IC_ORG X 
		               WHERE X.ICKEY = #{ickey}) > 0 
		           THEN 'Y'
		         WHEN (SELECT COUNT(*) 
		               FROM TORDER_MST_ASRT Y 
		               WHERE Y.ASRTKEY = #{ickey}) > 0 
		           THEN 'N'
		         ELSE ''
		       END AS ASRTREPKEYYN
		      , #{ickey} AS ICKEY
	</select>


    <select id="selectOrderTypeMappingList" resultType="camelMap">
        /* oms-order-inboundOrderCommon-sql-oracle.xml - selectOrderTypeMappingList */
        SELECT A.OWKEY
             , A.EXTORDERTYPECD
             , A.ORDERTYPECD
        FROM TORDER_INFO_ORTYPE_MAPPING A
        WHERE A.DELYN = 'N'
    </select>

    <select id="selectOrderTypeReasonList" resultType="camelMap">
        /* oms-order-inboundOrderCommon-sql-oracle.xml - selectOrderTypeReasonList */
        SELECT A.OWKEY
             , A.ORDERTYPECD
             , B.ORDERRSNCD
             , B.ORDERRSNNM
        FROM TORDER_MST_ORTYPE A
             INNER JOIN TORDER_MST_ORTYPEREASON B
                     ON A.OWKEY = B.OWKEY
                    AND A.ORDERTYPECD = B.ORDERTYPECD
                    AND B.DELYN ='N'
        WHERE A.DELYN = 'N'
        <if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
			AND A.OWKEY = #{owkey}
		</if>
    </select>
    
    <select id="selectInboundReturnOrderHeaderCount" resultType="java.lang.Integer">
        /* oms-order-inboundOrderCommon-sql-oracle.xml - selectInboundReturnOrderHeaderCount */
        SELECT COUNT(1)
		FROM
		(
		SELECT 1
		FROM TORDER_INFO_SO_HD A
		INNER JOIN TORDER_INFO_SO_DT SD
		ON A.OWKEY = SD.OWKEY
		AND A.SOHDKEY = SD.SOHDKEY
		INNER JOIN TORDER_MST_IC MI
		ON SD.OWKEY = MI.OWKEY
		AND SD.ICKEY = MI.ICKEY
		INNER JOIN TORDER_MST_OW MO
		ON A.OWKEY = MO.OWKEY
		INNER JOIN TORDER_MST_CT MC
		ON A.CTKEY = MC.CTKEY
		LEFT OUTER JOIN TORDER_INFO_HOLD IH
		ON A.OWKEY = A.OWKEY
		AND SD.COHDKEY = IH.COHDKEY
		AND SD.CODTKEY = IH.CODTKEY
		AND A.CLAIMNO = IH.CLAIMNO
		LEFT OUTER JOIN
            (
             SELECT T.SOHDKEY
                  , T.OWKEY
                  , T.DLVRYCORP
                  , COUNT(T.WBLNO) AS WBLCNT
                  , CASE WHEN COUNT(1) > 1 THEN MIN(T.WBLNO)||' 외 '||(COUNT(1)-1)||'건' 
				        ELSE MIN(T.WBLNO)
				   END AS WBLNO
             FROM (
                 SELECT X.OWKEY
                      , X.SOHDKEY AS SOHDKEY /*S/O번호*/
                      , X.DLVRYCORP
                      , X.WBLNO
                 FROM TORDER_INFO_SO_WBLNO X
                 WHERE X.OWKEY = 'DAISO'
                 GROUP BY X.SOHDKEY, X.OWKEY, X.WBLNO, X.DLVRYCORP
             	) T GROUP BY T.SOHDKEY, T.OWKEY, T.DLVRYCORP
             ) SW
        ON A.OWKEY = SW.OWKEY AND A.SOHDKEY = SW.SOHDKEY
		LEFT OUTER JOIN TORDER_INFO_SO_HD ESO
		ON  A.ORGORDERKEY = ESO.ORGORDERKEY
		AND A.CLAIMNO = ESO.CLAIMNO
		AND ESO.EXTORDERTYPECD = 'DA10'
		LEFT OUTER JOIN
            (
             SELECT T.SOHDKEY
                  , T.OWKEY
                  , T.DLVRYCORP
                  , COUNT(T.WBLNO) AS WBLCNT
                  , CASE WHEN COUNT(1) > 1 THEN MIN(T.WBLNO)||' 외 '||(COUNT(1)-1)||'건' 
				        ELSE MIN(T.WBLNO)
				   END AS WBLNO
             FROM (
                 SELECT X.OWKEY
                      , X.SOHDKEY AS SOHDKEY /*S/O번호*/
                      , X.DLVRYCORP
                      , X.WBLNO
                 FROM TORDER_INFO_SO_WBLNO X
                 WHERE X.OWKEY = #{owkey}
                 GROUP BY X.SOHDKEY, X.OWKEY, X.WBLNO, X.DLVRYCORP
             	) T GROUP BY T.SOHDKEY, T.OWKEY, T.DLVRYCORP
             ) ESW
        ON A.OWKEY = ESW.OWKEY AND A.SOHDKEY = ESW.SOHDKEY
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
		WHERE #{SEARCH_CONDITION}
			<if test='@com.kns.framework.util.StringUtil@isNotEmpty(isCancel) and "Y".equals(isCancel)'>
			    AND  A.WKSTATUS != #{cancelYn}
			</if>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ortype)" >
				AND  A.ORDERTYPECD IN
			     <foreach item="ortype" index="index" collection="ortype"    open="(" separator="," close=")">
		           #{ortype}
		  		 </foreach>
	        </if>
	        <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ickey)" >
	        	AND SD.ICKEY IN
			    <foreach item="ickey" index="index" collection="ickey"  open="(" separator="," close=")">
			           #{ickey}
                </foreach>
	        </if>
	        <if test="@com.kns.framework.util.StringUtil@isNotEmpty(isDlvrycorp)" >
	        	AND SW.DLVRYCORP = #{isDlvrycorp}
	        </if>
	        <if test="@com.kns.framework.util.StringUtil@isNotEmpty(isRiwblno)" >
	        	AND SW.WBLNO = #{isRiwblno}
	        </if>
	        <if test="@com.kns.framework.util.StringUtil@isNotEmpty(isExwblno)" >
	        	AND (
		        	SELECT MIN(Y.WBLNO)
			     	FROM TORDER_INFO_SO_HD X
			     	INNER JOIN TORDER_INFO_SO_WBLNO Y
			     	ON X.OWKEY = A.OWKEY
			     	AND X.ORGORDERKEY = A.ORGORDERKEY
			     	AND X.OWKEY = Y.OWKEY
			     	AND X.SOHDKEY = Y.SOHDKEY
			     	WHERE 1 = 1
			     	AND X.ORDERTYPECD = '100'
			     	) = #{isExwblno}
	        </if>
		</if>
		GROUP BY A.OWKEY
		     , A.CTKEY
		     , A.ORDERISTDAY
		     , A.CNFRMDAY
		     , A.ORGORDERKEY
		     , A.CLAIMNO
		     , A.RIRSNCD
		     , A.WKSTATUS
		     , A.COHDKEY
		     , A.SOHDKEY
		     , MC.CTNM
		     , A.CMT
		     , A.OWKEY
		     , MO.OWNM
		     , A.SOHDKEY
		     , A.ORDERTYPECD
		     , SW.DLVRYCORP
		     , SW.WBLNO
		     , ESW.WBLNO
		     )
    </select>

    <select id="selectInboundReturnOrderHeaderList" resultType="camelMap">
        /* oms-order-inboundOrderCommon-sql-oracle.xml - selectInboundReturnOrderHeaderList */
        #{GRIDPAGING_ROWNUMTYPE_TOP}
            SELECT '0' AS CHK
		     , A.OWKEY
		     , MO.OWNM
		     , A.SOHDKEY
		     , A.ORDERTYPECD
		     , A.CTKEY
		     , MC.CTNM
		     , A.ORDERISTDAY
		     , A.CNFRMDAY
		     , A.ORGORDERKEY
		     , A.CLAIMNO
		     , CASE WHEN A.RIRSNCD in ('80', '81') THEN 'Y' ELSE 'N' END AS NOTRTNDIV -- CD_00399(80/81)
		     , A.RIRSNCD
		     , A.WKSTATUS
		     , SW.DLVRYCORP
		     , CASE WHEN COUNT(IH.COHDKEY) > 0 THEN 'Y' ELSE 'N' END AS HOLDYN
		     , SW.WBLNO
		     , COUNT(DISTINCT SD.ICKEY) AS ORDSKU
		     , SUM(SD.EXPCTQTY) AS ORDEA
		     , SUM(SD.EXPCTQTY * MI.SLPRC) AS ORDSLPRC
		     , (CASE WHEN A.CNFRMDAY IS NOT NULL THEN COUNT(DISTINCT SD.ICKEY) ELSE 0 END) AS CNFSKU
		     , (CASE WHEN A.CNFRMDAY IS NOT NULL THEN SUM(SD.EXPCTQTY) ELSE 0 END) AS CNFEA
		     , (CASE WHEN A.CNFRMDAY IS NOT NULL THEN SUM(SD.EXPCTQTY * MI.SLPRC) ELSE 0 END) AS CNFSLPRC
		     , ESW.WBLNO AS EXCWBLNNO
		     , A.CMT
		     , A.EXTORDERTYPECD
		     , CH.IFID
		     , A.INSERTDATE
		     , A.INSERTURKEY
		     , A.UPDATEDATE
		     , A.UPDATEURKEY
		FROM TORDER_INFO_SO_HD A
		INNER JOIN TORDER_INFO_CO_HD CH
		ON A.OWKEY = CH.OWKEY
		AND A.COHDKEY = CH.COHDKEY
		INNER JOIN TORDER_INFO_SO_DT SD
		ON A.OWKEY = SD.OWKEY
		AND A.SOHDKEY = SD.SOHDKEY
		INNER JOIN TORDER_MST_IC MI
		ON SD.OWKEY = MI.OWKEY
		AND SD.ICKEY = MI.ICKEY
		INNER JOIN TORDER_MST_OW MO
		ON A.OWKEY = MO.OWKEY
		INNER JOIN TORDER_MST_CT MC
		ON A.CTKEY = MC.CTKEY
		LEFT OUTER JOIN TORDER_INFO_HOLD IH
		ON A.OWKEY = A.OWKEY
		AND SD.COHDKEY = IH.COHDKEY
		AND SD.CODTKEY = IH.CODTKEY
		AND A.CLAIMNO = IH.CLAIMNO
		LEFT OUTER JOIN
        (
         SELECT T.SOHDKEY
              , T.OWKEY
              , T.DLVRYCORP
              , COUNT(T.WBLNO) AS WBLCNT
              , CASE WHEN COUNT(1) > 1 THEN MIN(T.WBLNO)||' 외 '||(COUNT(1)-1)||'건' 
			        ELSE MIN(T.WBLNO)
			   END AS WBLNO
         FROM (
             SELECT X.OWKEY
                  , X.SOHDKEY AS SOHDKEY /*S/O번호*/
                  , X.DLVRYCORP
                  , X.WBLNO
             FROM TORDER_INFO_SO_WBLNO X
             WHERE X.OWKEY = 'DAISO'
             GROUP BY X.SOHDKEY, X.OWKEY, X.WBLNO, X.DLVRYCORP
         	) T GROUP BY T.SOHDKEY, T.OWKEY, T.DLVRYCORP
         ) SW
        ON A.OWKEY = SW.OWKEY AND A.SOHDKEY = SW.SOHDKEY
		LEFT OUTER JOIN TORDER_INFO_SO_HD ESO
		ON  A.ORGORDERKEY = ESO.ORGORDERKEY
		AND A.CLAIMNO = ESO.CLAIMNO
		AND ESO.EXTORDERTYPECD = 'DA10'
		LEFT OUTER JOIN
        (
         SELECT T.SOHDKEY
              , T.OWKEY
              , T.DLVRYCORP
              , COUNT(T.WBLNO) AS WBLCNT
              , CASE WHEN COUNT(1) > 1 THEN MIN(T.WBLNO)||' 외 '||(COUNT(1)-1)||'건' 
			        ELSE MIN(T.WBLNO)
			   END AS WBLNO
         FROM (
             SELECT X.OWKEY
                  , X.SOHDKEY AS SOHDKEY /*S/O번호*/
                  , X.DLVRYCORP
                  , X.WBLNO
             FROM TORDER_INFO_SO_WBLNO X
             WHERE X.OWKEY = #{owkey}
             GROUP BY X.SOHDKEY, X.OWKEY, X.WBLNO, X.DLVRYCORP
         	) T GROUP BY T.SOHDKEY, T.OWKEY, T.DLVRYCORP
         ) ESW
        ON A.OWKEY = ESW.OWKEY AND A.SOHDKEY = ESW.SOHDKEY
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
		WHERE #{SEARCH_CONDITION}
			<if test='@com.kns.framework.util.StringUtil@isNotEmpty(isCancel) and "Y".equals(isCancel)'>
			    AND  A.WKSTATUS != #{cancelYn}
			</if>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ortype)" >
				AND  A.ORDERTYPECD IN
			     <foreach item="ortype" index="index" collection="ortype"    open="(" separator="," close=")">
		           #{ortype}
		  		 </foreach>
	        </if>
	        <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ickey)" >
	        	AND SD.ICKEY IN
			    <foreach item="ickey" index="index" collection="ickey"  open="(" separator="," close=")">
			           #{ickey}
                </foreach>
	        </if>
	         <if test="@com.kns.framework.util.StringUtil@isNotEmpty(isDlvrycorp)" >
	        	AND SW.DLVRYCORP = #{isDlvrycorp}
	        </if>
	        <if test="@com.kns.framework.util.StringUtil@isNotEmpty(isRiwblno)" >
	        	AND SW.WBLNO = #{isRiwblno}
	        </if>
	        <if test="@com.kns.framework.util.StringUtil@isNotEmpty(isExwblno)" >
	        	AND (
		        	SELECT MIN(Y.WBLNO)
			     	FROM TORDER_INFO_SO_HD X
			     	INNER JOIN TORDER_INFO_SO_WBLNO Y
			     	ON X.OWKEY = A.OWKEY
			     	AND X.ORGORDERKEY = A.ORGORDERKEY
			     	AND X.OWKEY = Y.OWKEY
			     	AND X.SOHDKEY = Y.SOHDKEY
			     	WHERE 1 = 1
			     	AND X.ORDERTYPECD = '100'
			     	) = #{isExwblno}
	        </if>
		</if>
		GROUP BY A.OWKEY
		     , A.CTKEY
		     , A.ORDERISTDAY
		     , A.CNFRMDAY
		     , A.ORGORDERKEY
		     , A.CLAIMNO
		     , A.RIRSNCD
		     , A.WKSTATUS
		     , A.COHDKEY
		     , A.SOHDKEY
		     , MC.CTNM
		     , A.CMT
		     , A.OWKEY
		     , MO.OWNM
		     , A.SOHDKEY
		     , A.ORDERTYPECD
		     , SW.DLVRYCORP
		     , SW.WBLNO
		     , ESW.WBLNO
		     , A.EXTORDERTYPECD
		     , CH.IFID
		     , A.INSERTDATE
		     , A.INSERTURKEY
		     , A.UPDATEDATE
		     , A.UPDATEURKEY
			#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
    </select>

    <select id="selectInboundReturnOrderDetailList" resultType="camelMap">
         /* oms-order-inboundOrderCommon-sql-oracle.xml - selectInboundReturnOrderDetailList */
        SELECT '0' AS CHK
		     , MC.CTNM
		     , A.ORDERISTDAY
		     , A.CNFRMDAY
		     , A.ORGORDERKEY
		     , A.CLAIMNO
		     , CASE WHEN A.RIRSNCD in ('80', '81') THEN 'Y' ELSE 'N' END AS NOTRTNDIV -- CD_00399(80/81)
		     , A.RIRSNCD
		     , A.WKSTATUS
		     , SW.DLVRYCORP
	         , SW.WBLNO 
	         , SW.WBLCNT
			 , IC.ICKEY
			 , IC.ICNM
			 , COALESCE(ASRT.ASRTKEY, IC.ICKEY) AS ASRTKEY
			 , COALESCE(ASRT.ASRTNM, IC.ICNM) AS ASRTNM	
		     , SD.EXPCTQTY
		     , SD.CNFRMQTY
		     , GREATEST(COALESCE(SD.EXPCTQTY - SD.CNFRMQTY, 0), 0) AS IMPSQTY
		     , SD.CNFRMQTY AS IBQTY
		     , WP.NORMALQTY AS NORMALQTY
		     , WP.DMGQTY AS DMGQTY
		     , WP.DFCQTY AS DFCQTY
		     , WP.DONAQTY AS DONAQTY
		     , WP.FOODDMGQTY AS FOODDMGQTY
             , WP.MISOBQTY AS MISOBQTY
		     , CASE WHEN IH.HOLDRSNCD IS NOT NULL THEN 'Y' ELSE 'N' END AS HOLDYN
		     , IH.HOLDRSNCD
		     , IH.HOLDPRCSDTCONT
		     , A.CMT
		     , (SELECT COUNT(*) FROM TORDER_INFO_IMG X WHERE X.OWKEY = A.OWKEY AND X.COHDKEY = SD.COHDKEY) AS IMGCNT
		     , A.INSERTDATE
		     , A.INSERTURKEY
		     , A.UPDATEDATE
		     , A.UPDATEURKEY
             , A.OWKEY
		     , MO.OWNM
		     , A.SOHDKEY
		     , SD.COHDKEY
		     , SD.CODTKEY
		     , A.ORDERTYPECD
		     , A.CTKEY
		FROM TORDER_INFO_SO_HD A
		INNER JOIN TORDER_INFO_SO_DT SD
		ON A.OWKEY = SD.OWKEY
		AND A.SOHDKEY = SD.SOHDKEY
		INNER JOIN TORDER_MST_IC IC
		        ON A.OWKEY = IC.OWKEY
		       AND SD.ICKEY = IC.ICKEY
		       AND IC.DELYN = 'N'
		LEFT JOIN TORDER_MST_ASRT ASRT
		       ON A.OWKEY = ASRT.OWKEY
		      AND SD.OLNICKEY = ASRT.ASRTKEY
		LEFT JOIN TORDER_MST_IC REP
			   ON ASRT.OWKEY = REP.OWKEY
			  AND ASRT.ASRTREPKEY = REP.ICKEY
		INNER JOIN TORDER_MST_OW MO
		ON A.OWKEY = MO.OWKEY
		INNER JOIN TORDER_MST_CT MC
		ON A.CTKEY = MC.CTKEY
		LEFT OUTER JOIN TORDER_INFO_HOLD IH
		ON A.OWKEY = IH.OWKEY
		AND A.COHDKEY = IH.COHDKEY
		AND A.CLAIMNO = IH.CLAIMNO
		AND SD.CODTKEY = IH.CODTKEY
		LEFT OUTER JOIN
        (
         SELECT T.SOHDKEY
              , T.OWKEY
              , T.DLVRYCORP
              , COUNT(T.WBLNO) AS WBLCNT
              , CASE WHEN COUNT(1) > 1 THEN MIN(T.WBLNO)||' 외 '||(COUNT(1)-1)||'건' 
			        ELSE MIN(T.WBLNO)
			   END AS WBLNO
         FROM (
             SELECT X.OWKEY
                  , X.SOHDKEY AS SOHDKEY
                  , X.DLVRYCORP
                  , X.WBLNO
             FROM TORDER_INFO_SO_WBLNO X
             WHERE X.OWKEY = #{owkey}
             GROUP BY X.SOHDKEY, X.OWKEY, X.WBLNO, X.DLVRYCORP
         	) T GROUP BY T.SOHDKEY, T.OWKEY, T.DLVRYCORP
         ) SW
        ON A.OWKEY = SW.OWKEY AND A.SOHDKEY = SW.SOHDKEY
        LEFT OUTER JOIN
        (
         SELECT T.SOHDKEY
              , T.SOdtkey
              , T.OWKEY
              , T.NORMALQTY
              , T.DMGQTY
              , T.DFCQTY
              , T.DONAQTY
              , T.FOODDMGQTY
              , T.MISOBQTY
         FROM (
             SELECT X.OWKEY
                  , X.SOHDKEY AS SOHDKEY
                  , X.SODTKEY AS SODTKEY
                  , COALESCE(SUM(X.NORMALQTY), 0) AS NORMALQTY
                  , COALESCE(SUM(X.DMGQTY), 0) AS DMGQTY
                  , COALESCE(SUM(X.DFCQTY), 0) AS DFCQTY
                  , COALESCE(SUM(X.DONAQTY), 0) AS DONAQTY
                  , COALESCE(SUM(X.FOODDMGQTY), 0) AS FOODDMGQTY
                  , COALESCE(SUM(X.MISOBQTY), 0) AS MISOBQTY
             FROM TORDER_INFO_WMS_PERFORMANCE X
             WHERE X.OWKEY = #{owkey}
             GROUP BY X.SOHDKEY, X.SODTKEY, X.OWKEY
         	) T
--         	GROUP BY T.SOHDKEY, T.OWKEY
         ) WP
        ON SD.OWKEY = WP.OWKEY 
        AND SD.SOHDKEY = WP.SOHDKEY
        AND SD.SODTKEY = WP.SODTKEY
        WHERE A.SOHDKEY = #{sohdkey}
          AND A.OWKEY = #{owkey}
    </select>
    
    <select id="selectInboundOrderEtcHeaderCount" resultType="java.lang.Integer">
        /* oms-order-inboundOrder-sql-oracle.xml - selectInboundOrderEtcHeaderCount */
        SELECT  COUNT(0)
        FROM TORDER_INFO_SO_HD A
            LEFT JOIN TORDER_INFO_CO_HD B
               	     ON A.OWKEY = B.OWKEY
               	    AND A.COHDKEY = B.COHDKEY
            INNER JOIN
	                (
	                 SELECT T.SOHDKEY
	                      , T.OWKEY
	                      , COUNT(T.ICKEY)    AS SKU
	                      , SUM(T.EXPCTQTY)   AS EXPCTQTY
	                      , SUM(T.SLPRC)      AS SLPRC
                          , SUM(T.CNFRMYN)    AS CNFRMSKU
	                      , SUM(T.CNFRMQTY)   AS CNFRMQTY
	                      , SUM(T.CNFRMSLPRC) AS CNFRMSLPRC
	                 FROM (
		                 SELECT X.OWKEY
 		                      , X.SOHDKEY AS SOHDKEY /*S/O번호*/
		                      , X.ICKEY
		                      , MAX(I.SLPRC) * SUM(X.EXPCTQTY) AS  SLPRC
		                      , SUM(X.EXPCTQTY) AS EXPCTQTY
                              , CASE WHEN SUM(CNFRMQTY) > 0 THEN 1 ELSE 0 END CNFRMYN
		                      , SUM(CNFRMQTY) AS CNFRMQTY
		                      , MAX(I.SLPRC) * SUM(CNFRMQTY) AS CNFRMSLPRC
		                 FROM TORDER_INFO_SO_DT X
		                 INNER JOIN TORDER_MST_IC I
		                         ON X.OWKEY = I.OWKEY
		                        AND X.ICKEY = I.ICKEY
		                 WHERE X.OWKEY = #{owkey}
                         <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ickey)" >
                             AND X.ICKEY IN
                            <foreach item="ickey" index="index" collection="ickey"    open="(" separator="," close=")">
                               #{ickey}
                            </foreach>
                         </if>
		                 GROUP BY X.SOHDKEY, X.OWKEY, X.ICKEY
	                 	) T GROUP BY T.SOHDKEY, T.OWKEY
	                 ) C
                ON A.OWKEY = C.OWKEY AND A.SOHDKEY = C.SOHDKEY
            LEFT JOIN
	                (
	                 SELECT T.REQORDERNO
	                      , T.OWKEY
	                      , COUNT(T.ICKEY) AS REQORDERSKU
	                      , SUM(T.CNFRMREQORDERQTY) AS CNFRMREQORDERQTY
	                      , SUM(T.SLPRC) AS REQORDERSLPRC
	                 FROM (
		                 SELECT X.OWKEY
                              , X.REQORDERNO AS REQORDERNO
		                      , X.ICKEY
		                      , MAX(I.SLPRC) * SUM(X.CNFRMREQORDERQTY) AS SLPRC
		                      , SUM(X.CNFRMREQORDERQTY) AS CNFRMREQORDERQTY
		                 FROM TORDER_INFO_REQORDER X
 		                 INNER JOIN TORDER_MST_IC I
		                         ON X.OWKEY = I.OWKEY
		                        AND X.ICKEY = I.ICKEY
		                 WHERE X.OWKEY = #{owkey}
                         <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ickey)" >
                             AND X.ICKEY IN
                            <foreach item="ickey" index="index" collection="ickey"    open="(" separator="," close=")">
                               #{ickey}
                            </foreach>
                         </if>
		                 GROUP BY X.REQORDERNO, X.OWKEY, X.ICKEY
	                 	) T GROUP BY T.REQORDERNO, T.OWKEY
	                 ) D
                ON A.OWKEY = D.OWKEY 
                AND (A.RFRNCKEY = D.REQORDERNO OR A.ORGORDERKEY = D.REQORDERNO)
            LEFT OUTER JOIN TORDER_MST_CT E ON A.FROMTOCTKEY = E.CTKEY
            LEFT OUTER JOIN TORDER_MST_CT F ON A.CTKEY = F.CTKEY
            LEFT OUTER JOIN TORDER_MST_AC G ON A.OWKEY = G.OWKEY  AND A.ACKEY = G.ACKEY
            INNER JOIN TORDER_MST_ORTYPE H ON A.OWKEY = H.OWKEY AND A.ORDERTYPECD = H.ORDERTYPECD
            WHERE H.IBYN = 'Y'
                AND H.ORDERAT = #{orderat}
            <if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
                AND #{SEARCH_CONDITION}
                <if test='@com.kns.framework.util.StringUtil@isNotEmpty(isCancel) and "Y".equals(isCancel)'>
                    AND  A.WKSTATUS != #{cancelYn}
                </if>
                <if test='@com.kns.framework.util.StringUtil@isNotEmpty(ibcloseyn)'>
                    AND  CASE WHEN A.WKSTATUS = '20' THEN 'Y' ELSE 'N' END = #{ibcloseyn}
                </if>
                <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ortype)" >
                    AND  A.ORDERTYPECD IN
                    <foreach item="ortype" index="index" collection="ortype"    open="(" separator="," close=")">
                        #{ortype}
                    </foreach>
                </if>
            </if>
    </select>

    <select id="selectInboundOrderEtcHeaderList" resultType="camelMap">
        /* oms-order-inboundOrder-sql-oracle.xml - selectInboundOrderEtcHeaderList */
        #{GRIDPAGING_ROWNUMTYPE_TOP}
            SELECT  '0' AS CHK
                   , A.OWKEY
                   , A.ORDERTYPECD                                                  /* 입고유형 */
                   , H.ORDERTYPENM                                                  /* 입고유형명 */
                   , A.ORDERISTDAY                                                  /* 지시일자 */
                   , A.DLVYEXPCTDAY                                                 /* 입고예정일자 */
                   , A.FROMTOCTKEY                                                  /* 출고센터*/
                   , E.CTNM AS OBCTNM                                               /* 출고센터명*/
                   , A.ACKEY                                                        /* 출고처*/
                   , G.ACNM
                   , A.CTKEY                                                        /* 입고센터*/
                   , F.CTNM  AS IBCTNM                                              /* 입고센터명*/
                   , A.SOHDKEY                                                      /* 입고예정번호(SO)*/
                   , A.COHDKEY                                                      /* 고객주문번호(CO)*/
                   , A.WKSTATUS                                                     /* 주문상태*/
                   , (SELECT ORDERCOMDTNM FROM TORDER_MST_ORCD_DT DT WHERE DT.ORDERCOMHDKEY = 'SOSTATUS' AND DT.ORDERCOMDTKEY = A.WKSTATUS AND DT.LAKEY = 'KOR') AS WKSTATUSNM
                   , COALESCE(A.ORGORDERKEY, A.RFRNCKEY) AS ORGORDERKEY					/* 발주번호*/
                   , A.SHMISTNO                                                     /* 출하지시번호*/
                   , COALESCE(C.SKU, 0)              AS EXPCTSKU
                   , COALESCE(C.EXPCTQTY, 0)         AS EXPCTQTY
                   , COALESCE(C.SLPRC, 0)            AS EXPCTSLPRC
                   , COALESCE(D.REQORDERSKU, 0)      AS REQORDERSKU
                   , COALESCE(D.CNFRMREQORDERQTY, 0) AS CNFRMREQORDERQTY
                   , COALESCE(D.REQORDERSLPRC, 0)    AS REQORDERSLPRC
                   , COALESCE(C.CNFRMSKU, 0)         AS CNFRMSKU
                   , COALESCE(C.CNFRMQTY, 0)         AS CNFRMQTY
                   , COALESCE(C.CNFRMSLPRC, 0)       AS CNFRMSLPRC
                   , A.CMT                                                          /* 비고*/
                   , B.ERPSNDFAILYN                                                 /* ERP확정여부*/
                   , CASE WHEN A.WKSTATUS = '20' THEN 'Y' ELSE 'N' END AS IBCLOSEYN /* 입고마감여부*/
                   , A.ORDERERRCD                                                   /* 주문오류 코드*/
                   , A.ORDERERRCMT                                                  /* 주문오류 비고*/
                   , A.INSERTDATE
                   , A.INSERTURKEY
                   , A.UPDATEDATE
                   , A.UPDATEURKEY
            FROM TORDER_INFO_SO_HD A
            LEFT JOIN TORDER_INFO_CO_HD B
               	     ON A.OWKEY = B.OWKEY
               	    AND A.COHDKEY = B.COHDKEY
            INNER JOIN
	                (
	                 SELECT T.SOHDKEY
	                      , T.OWKEY
	                      , COUNT(T.ICKEY)    AS SKU
	                      , SUM(T.EXPCTQTY)   AS EXPCTQTY
	                      , SUM(T.SLPRC)      AS SLPRC
                          , SUM(T.CNFRMYN)    AS CNFRMSKU
	                      , SUM(T.CNFRMQTY)   AS CNFRMQTY
	                      , SUM(T.CNFRMSLPRC) AS CNFRMSLPRC
	                 FROM (
		                 SELECT X.OWKEY
 		                      , X.SOHDKEY AS SOHDKEY /*S/O번호*/
		                      , X.ICKEY
		                      , MAX(I.SLPRC) * SUM(X.EXPCTQTY) AS  SLPRC
		                      , SUM(X.EXPCTQTY) AS EXPCTQTY
                              , CASE WHEN SUM(CNFRMQTY) > 0 THEN 1 ELSE 0 END CNFRMYN
		                      , SUM(CNFRMQTY) AS CNFRMQTY
		                      , MAX(I.SLPRC) * SUM(CNFRMQTY) AS CNFRMSLPRC
		                 FROM TORDER_INFO_SO_DT X
		                 INNER JOIN TORDER_MST_IC I
		                         ON X.OWKEY = I.OWKEY
		                        AND X.ICKEY = I.ICKEY
		                 WHERE X.OWKEY = #{owkey}
                         <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ickey)" >
                             AND X.ICKEY IN
                            <foreach item="ickey" index="index" collection="ickey"    open="(" separator="," close=")">
                               #{ickey}
                            </foreach>
                         </if>
		                 GROUP BY X.SOHDKEY, X.OWKEY, X.ICKEY
	                 	) T GROUP BY T.SOHDKEY, T.OWKEY
	                 ) C
                ON A.OWKEY = C.OWKEY AND A.SOHDKEY = C.SOHDKEY
            LEFT JOIN
	                (
	                 SELECT T.REQORDERNO
	                      , T.OWKEY
	                      , COUNT(T.ICKEY) AS REQORDERSKU
	                      , SUM(T.CNFRMREQORDERQTY) AS CNFRMREQORDERQTY
	                      , SUM(T.SLPRC) AS REQORDERSLPRC
	                 FROM (
		                 SELECT X.OWKEY
                              , X.REQORDERNO AS REQORDERNO
		                      , X.ICKEY
		                      , MAX(I.SLPRC) * SUM(X.CNFRMREQORDERQTY) AS SLPRC
		                      , SUM(X.CNFRMREQORDERQTY) AS CNFRMREQORDERQTY
		                 FROM TORDER_INFO_REQORDER X
 		                 INNER JOIN TORDER_MST_IC I
		                         ON X.OWKEY = I.OWKEY
		                        AND X.ICKEY = I.ICKEY
		                 WHERE X.OWKEY = #{owkey}
                         <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ickey)" >
                             AND X.ICKEY IN
                            <foreach item="ickey" index="index" collection="ickey"    open="(" separator="," close=")">
                               #{ickey}
                            </foreach>
                         </if>
		                 GROUP BY X.REQORDERNO, X.OWKEY, X.ICKEY
	                 	) T GROUP BY T.REQORDERNO, T.OWKEY
	                 ) D
                ON A.OWKEY = D.OWKEY 
                AND (A.RFRNCKEY = D.REQORDERNO OR A.ORGORDERKEY = D.REQORDERNO)
            LEFT OUTER JOIN TORDER_MST_CT E ON A.FROMTOCTKEY = E.CTKEY
            LEFT OUTER JOIN TORDER_MST_CT F ON A.CTKEY = F.CTKEY
            LEFT OUTER JOIN TORDER_MST_AC G ON A.OWKEY = G.OWKEY  AND A.ACKEY = G.ACKEY
            INNER JOIN TORDER_MST_ORTYPE H ON A.OWKEY = H.OWKEY AND A.ORDERTYPECD = H.ORDERTYPECD
            WHERE H.IBYN = 'Y'
              AND H.ORDERAT = #{orderat}
            <if test="@com.kns.framework.util.StringUtil@isNotEmpty(SEARCH_CONDITION)" >
                AND #{SEARCH_CONDITION}
                <if test='@com.kns.framework.util.StringUtil@isNotEmpty(isCancel) and "Y".equals(isCancel)'>
                    AND  A.WKSTATUS != #{cancelYn}
                </if>
                <if test='@com.kns.framework.util.StringUtil@isNotEmpty(ibcloseyn)'>
                    AND  CASE WHEN A.WKSTATUS = '20' THEN 'Y' ELSE 'N' END = #{ibcloseyn}
                </if>
                <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ortype)" >
                    AND  A.ORDERTYPECD IN
                    <foreach item="ortype" index="index" collection="ortype"    open="(" separator="," close=")">
                        #{ortype}
                    </foreach>
                </if>
            </if>
        #{GRIDPAGING_ROWNUMTYPE_BOTTOM}
    </select>

    <select id="selectInboundOrderEtcDetailList" resultType="camelMap">
        /* oms-order-inboundOrder-sql-oracle.xml - selectInboundOrderEtcDetailList */
        SELECT  '0' AS CHK
                 , A.OWKEY
                 , A.ORDERTYPECD                                                   /* 입고유형 */
                 , H.ORDERTYPENM                                                   /* 입고유형명 */
                 , A.ORDERISTDAY                                                   /* 지시일자 */
                 , A.DLVYEXPCTDAY                                                  /* 입고예정일자 */
                 , A.FROMTOCTKEY                                                   /* 출고센터*/
                 , E.CTNM AS OBCTNM                                                /* 출고센터명*/
                 , A.ACKEY AS STOREKEY                                             /* 출고처*/
                 , G.ACNM  AS STORENM                                              /* 출고처명*/
                 , A.CTKEY                                                         /* 입고센터*/
                 , F.CTNM AS IBCTNM                                                /* 입고센터명*/
                 , A.SOHDKEY                                                       /* 입고예정번호(SO)*/
                 , C.SODTKEY                                                       /* 상세번호*/
                 , A.WKSTATUS                                                      /* 주문상태*/
                 , (SELECT ORDERCOMDTNM FROM TORDER_MST_ORCD_DT DT WHERE DT.ORDERCOMHDKEY = 'SOSTATUS' AND DT.ORDERCOMDTKEY = A.WKSTATUS AND DT.LAKEY = 'KOR') AS WKSTATUSNM
                 , COALESCE(A.ORGORDERKEY, A.RFRNCKEY) AS ORGORDERKEY				   /* 발주번호*/
                 , A.SHMISTNO                                                      /* 출하지시번호*/
                 , IC.ACKEY                                                        /* 공급사*/
                 , J.ACNM                                                          /* 공급사명*/
                 , IC.ICKEY
			     , IC.ICNM
				 , COALESCE(ASRT.ASRTKEY, IC.ICKEY) AS ASRTKEY
				 , COALESCE(ASRT.ASRTNM, IC.ICNM) AS ASRTNM
                 , IC.ASRTYN                                                       /* 아소트여부*/
                 , K.LV1CTGNM                                                      /* 대*/
                 , K.LV2CTGNM                                                      /* 중*/
                 , K.LV3CTGNM                                                      /* 소*/
                 , COALESCE(C.EXPCTQTY, 0)                               AS EXPCTQTY
                 , COALESCE(C.EXPCTQTY * IC.SLPRC, 0)                    AS EXPCTSLPRC
                 , COALESCE(C.CNFRMQTY, 0)                               AS CNFRMQTY
                 , COALESCE(C.CNFRMQTY * IC.SLPRC, 0)                    AS CNFRMSLPRC
                 , COALESCE(D.CNFRMREQORDERQTY, 0)                       AS CNFRMREQORDERQTY
                 , COALESCE(D.CNFRMREQORDERQTY * IC.SLPRC, 0)            AS REQORDERSLPRC
				 , CASE WHEN A.CLAIMNO IS NULL THEN 'Y' ELSE 'N' END AS CLAIMYN
                 , A.CLAIMNO                                                       /* 클레임사유코드*/
                 , C.RICMT                                                         /* 상세사유*/
                 , C.ORDERERRCD                                                    /* 주문오류 코드*/
                 , C.ORDERERRCMT                                                   /* 주문오류 비고*/
                 , C.INSERTDATE
                 , C.INSERTURKEY
                 , C.UPDATEDATE
                 , C.UPDATEURKEY
        FROM TORDER_INFO_SO_HD A
        LEFT JOIN TORDER_INFO_CO_HD B
                ON A.OWKEY = B.OWKEY
               AND A.COHDKEY = B.COHDKEY
        LEFT JOIN TORDER_INFO_SO_DT C
                ON A.OWKEY = C.OWKEY
               AND A.SOHDKEY = C.SOHDKEY
        LEFT JOIN TORDER_INFO_REQORDER D
               ON A.OWKEY = D.OWKEY
              AND (A.RFRNCKEY = D.REQORDERNO OR A.ORGORDERKEY = D.REQORDERNO)
              AND C.ICKEY = D.ICKEY 
        LEFT OUTER JOIN TORDER_MST_CT E ON A.FROMTOCTKEY = E.CTKEY
        LEFT OUTER JOIN TORDER_MST_CT F ON A.CTKEY = F.CTKEY
        LEFT OUTER JOIN TORDER_MST_AC G ON A.OWKEY = G.OWKEY  AND A.ACKEY = G.ACKEY
        INNER JOIN TORDER_MST_ORTYPE H ON A.OWKEY = H.OWKEY AND A.ORDERTYPECD = H.ORDERTYPECD
        INNER JOIN TORDER_MST_IC IC
		        ON A.OWKEY = IC.OWKEY
		       AND C.ICKEY = IC.ICKEY
		LEFT JOIN TORDER_MST_ASRT ASRT
		       ON A.OWKEY = ASRT.OWKEY
		      AND C.OLNICKEY = ASRT.ASRTKEY
		LEFT JOIN TORDER_MST_IC REP
			   ON ASRT.OWKEY = REP.OWKEY
			  AND ASRT.ASRTREPKEY = REP.ICKEY
        LEFT OUTER JOIN TORDER_MST_AC J ON IC.OWKEY = J.OWKEY  AND IC.ACKEY = J.ACKEY
        LEFT JOIN (
                    (SELECT A.OWKEY
                         , A.CTGKEY AS LV1CTGKEY
                         , A.CTGNM  AS LV1CTGNM
                         , B.CTGKEY AS LV2CTGKEY
                         , B.CTGNM  AS LV2CTGNM
                         , C.CTGKEY AS LV3CTGKEY
                         , C.CTGNM  AS LV3CTGNM
                    FROM TORDER_MST_CTG A
                    INNER JOIN TORDER_MST_CTG B
                    ON A.OWKEY = B.OWKEY
                    AND A.CTGKEY  = B.UPPERCTGKEY
                    AND A.CTGLV + 1 = B.CTGLV
                    INNER JOIN TORDER_MST_CTG C
                    ON B.OWKEY = C.OWKEY
                    AND B.CTGKEY  = C.UPPERCTGKEY
                    AND B.CTGLV + 1 = C.CTGLV
                    )
                  ) K
             ON A.OWKEY = K.OWKEY AND IC.CTGKEY = K.LV3CTGKEY
        WHERE A.OWKEY = #{owkey}
          AND A.SOHDKEY = #{sohdkey}
    </select>


</mapper>