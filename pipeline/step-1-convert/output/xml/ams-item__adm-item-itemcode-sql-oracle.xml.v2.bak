	<insert id="insertTAdminMstIcxctExcel">
		/* adm-item-itemcode-sql-oracle.xml - insertTAdminMstIcxctExcel */
		INSERT INTO TADMIN_MST_ICXCT (
			  OWKEY
			, ICKEY
			, CTKEY
			, LOGGRPCD
			, NEWYN
			, ACKEY
			, ORDTYPE
			, ICGRPKEY
			, DELYN
			, INSERTDATE
			, INSERTURKEY
			, UPDATEDATE
			, UPDATEURKEY
		)
		SELECT #{owkey} AS OWKEY
			 , A.ICKEY
			 , C.CTKEY
			 , A.LOGGRPCD
			 , 'Y' AS NEWYN
			 , A.ACKEY
		     , '0' AS ORDTYPE
			 , A.ICGRPKEY
			 , 'N' AS DELYN
			 , A.INSERTDATE
			 , A.INSERTURKEY
			 , A.UPDATEDATE
			 , A.UPDATEURKEY
		FROM (   SELECT UPLDKEY
					  , ICKEY
					  , MIN(UPLDSEQ) AS UPLDSEQ
				 FROM TADMIN_UPLOAD_IC
				 WHERE UPLDKEY = #{upldkey}
				   AND DELYN = 'N'
				 GROUP BY UPLDKEY, ICKEY ) B
				 INNER JOIN TADMIN_UPLOAD_IC A
						 ON A.UPLDKEY = B.UPLDKEY
						AND A.UPLDSEQ = B.UPLDSEQ
						AND A.ICKEY 	= B.ICKEY
			 INNER JOIN TADMIN_MST_ICGRXCT C
