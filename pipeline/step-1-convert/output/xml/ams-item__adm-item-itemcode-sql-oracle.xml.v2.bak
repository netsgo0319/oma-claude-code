	<insert id="insertTTMstIcxctExcel">
		/* adm-item-itemcode-sql-oracle.xml - insertTTMstIcxctExcel */
		INSERT INTO TT_MST_ICXCT (
			  OWKEY
			, ICKEY
			, CTKEY
			, LOGGRPCD
			, VOLTYPE
			, NEWYN
			, ORDTYPE
			, ICGRKEY
			, DCKEY
			, DELYN
			, INSERTDATE
			, INSERTURKEY
			, UPDATEDATE
			, UPDATEURKEY
		)
		SELECT #{owkey} AS OWKEY
			 , A.ICKEY
			 , C.CTKEY
			 , A.LOGGRPCD
			 , '0' AS VOLTYPE
			 , 'Y' AS NEWYN
			 , '0' AS ORDTYPE
			 , A.ICGRPKEY
			 , '1' AS DCKEY
			 , 'N' AS DELYN
			 , A.INSERTDATE    /*입력일자*/
			 , A.INSERTURKEY    /*입력사용자*/
			 , A.UPDATEDATE    /*수정일자*/
			 , A.UPDATEURKEY    /*수정사용자*/
		FROM (   SELECT UPLDKEY
					  , ICKEY
					  , MIN(UPLDSEQ) AS UPLDSEQ
				 FROM TADMIN_UPLOAD_IC
				 WHERE UPLDKEY = #{upldkey}
				   AND DELYN = 'N'
				 GROUP BY UPLDKEY, ICKEY ) B
				 INNER JOIN TADMIN_UPLOAD_IC A
						 ON A.UPLDKEY = B.UPLDKEY
						AND A.UPLDSEQ = B.UPLDSEQ
						AND A.ICKEY 	= B.ICKEY
			 INNER JOIN TADMIN_MST_ICGRXCT C
					 ON C.OWKEY = #{owkey}
					AND C.ICGRPKEY = A.ICGRPKEY
					AND C.ICGRPTYPE = 'CATEGORY'
		WHERE A.UPLDKEY = #{upldkey}
		  AND A.DELYN = 'N'
		  AND A.ERRCD IS NULL
	</insert>

	<insert id="insertTAdminMstCtxAcXIcxctExcel">
		/* adm-item-itemcode-sql-oracle.xml - insertTAdminMstCtxAcXIcxctExcel */
		INSERT INTO TADMIN_MST_CTXACXIC (
		  	  OWKEY
			, CTKEY
			, ICKEY
			, ACKEY
			, CP
			, PODDLNTIME
			, POICUTTYPE
			, SMPOMLP
			, ASNAUTOYN
			, POHDTYPE
			, CTPOYN
			, POSTOPYN
			, DELYN
			, IBTIME
			, HOLD
			, INSERTDATE
			, INSERTURKEY
			, UPDATEDATE
			, UPDATEURKEY )
		SELECT #{owkey}
			 , C.CTKEY
			 , A.ICKEY
			 , A.ACKEY
			 ,  0
			 ,  '140000'
			 ,  'EA'
			 ,  '1'
			 ,  'N'
			 ,  '140'
			 ,  'N'
			 ,  'N'
			 ,  'N'
			 ,  '110000'
			 ,  'N'
			 , A.INSERTDATE    /*입력일자*/
			 , A.INSERTURKEY    /*입력사용자*/
			 , A.UPDATEDATE    /*수정일자*/
			 , A.UPDATEURKEY    /*수정사용자*/
		FROM (	 SELECT T.UPLDKEY
		              , T.UPLDSEQ
		              , CASE WHEN T.ACKEY IS NULL THEN 'Y' ELSE 'N' END AS SAVEYN
				   FROM (   SELECT UPLDKEY
								 , ICKEY
								 , MIN(UPLDSEQ) AS UPLDSEQ
							FROM TADMIN_UPLOAD_IC
							WHERE UPLDKEY = #{upldkey}
							  AND DELYN = 'N'
							GROUP BY UPLDKEY, ICKEY ) B
							INNER JOIN TADMIN_UPLOAD_IC T
									ON T.UPLDKEY = B.UPLDKEY
								   AND T.UPLDSEQ = B.UPLDSEQ
								   AND T.ICKEY 	   = B.ICKEY
				 WHERE T.UPLDKEY = #{upldkey}
				   AND T.DELYN = 'N'
				   AND T.ERRCD IS NULL ) B
			INNER JOIN TADMIN_UPLOAD_IC A
					ON B.UPLDKEY = A.UPLDKEY
				   AND B.UPLDSEQ = A.UPLDSEQ
			INNER JOIN TADMIN_MST_ICGRXCT C
					ON C.OWKEY = #{owkey}
				   AND C.ICGRPKEY = A.ICGRPKEY
				   AND C.ICGRPTYPE = 'CATEGORY'
		WHERE A.UPLDKEY = #{upldkey}
		  AND B.SAVEYN = 'N'
	</insert>

	<insert id="insertTAdminMstIcutxtypexct">
		/* adm-item-itemcode-sql-oracle.xml - insertTAdminMstIcutxtypexct */
		INSERT INTO TADMIN_MST_ICUTXTYPEXCT (
			  OWKEY    /*화주 코드*/
			, ICUNITKEY    /*물품 단위 코드*/
			, ICUNITTYPE    /*물품 단위 유형*/
			, CTKEY    /*센터 코드*/
			, INSERTDATE    /*입력 일시*/
			, INSERTURKEY    /*입력 사용자 ID*/
			, UPDATEDATE    /*수정 일시*/
			, UPDATEURKEY    /*수정 사용자 ID*/
		)
		SELECT #{owkey} AS OWKEY
			 , A.ICUNITKEY    /*물품 단위 코드*/
			 , A.ICUNITTYPE    /*물품 단위 유형*/
			 , B.CTKEY    /*센터 코드*/
			 , A.INSERTDATE    /*입력 일시*/
			 , A.INSERTURKEY    /*입력 사용자 ID*/
			 , A.UPDATEDATE    /*수정 일시*/
			 , A.UPDATEURKEY    /*수정 사용자 ID*/
		FROM TADMIN_UPLOAD_IC A
			 INNER JOIN TADMIN_MST_ICGRXCT B
					 ON B.OWKEY = #{owkey}
					AND B.ICGRPKEY = A.ICGRPKEY
					AND B.ICGRPTYPE = 'CATEGORY'
		WHERE A.UPLDKEY = #{upldkey}
		  AND A.DELYN = 'N'
		  AND A.ERRCD IS NULL
	</insert>
</mapper>	