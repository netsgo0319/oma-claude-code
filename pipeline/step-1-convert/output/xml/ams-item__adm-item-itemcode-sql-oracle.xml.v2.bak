	<insert id="insertTAdminMstIcutTypeExcel">
		/* adm-item-itemcode-sql-oracle.xml - insertTAdminMstIcutTypeExcel */
		INSERT INTO TADMIN_MST_ICUTXTYPE (
			  OWKEY
			, ICUNITKEY
			, ICUNITTYPE
			, ICUNITORDER
			, ICUNITQTY
			, LENGTH
			, WIDTH
			, HEIGHT
			, SIZEUNIT
			, WEIGHT
			, WEIGHTUNIT
			, VOL
			, VOLUNIT
			, INSERTDATE
			, INSERTURKEY
			, UPDATEDATE
			, UPDATEURKEY )
		SELECT #{owkey} AS OWKEY
			 , A.ICUNITKEY
			 , A.ICUNITTYPE
			 , A.ICUNITORDER
			 , A.ICUNITQTY
			 , A.LENGTH
			 , A.WIDTH
			 , A.HEIGHT
			 , 'MM' AS SIZEUNIT
			 , TRUNC(A.WEIGHT, 3) * 1000 AS WEIGHT
			 , 'G' AS WEIGHTUNIT
			 , TRUNC(A.VOL, 3) AS VOL
			 , 'MM3' AS VOLUNIT
			 , A.INSERTDATE
			 , A.INSERTURKEY
			 , A.UPDATEDATE
			 , A.UPDATEURKEY
		FROM TADMIN_UPLOAD_IC A
		WHERE A.UPLDKEY = #{upldkey}
		  AND A.DELYN = 'N'
		  AND A.ERRCD IS NULL
	</insert>

