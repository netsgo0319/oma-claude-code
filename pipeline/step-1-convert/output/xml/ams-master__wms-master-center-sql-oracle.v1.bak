<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
	
<mapper namespace="com.daiso.ams.master.mapper.CenterWmsMapper">

	<insert id="insertTWorkMstCt" >
		/* wms-master-center-sql-oracle.xml - insertTWorkMstCt */
		MERGE INTO TWORK_MST_CT A
		USING DUAL
		ON( CTKEY = #{ctkey})
		WHEN MATCHED THEN
			UPDATE 
			SET
					 CTTYPE = #{cttype}
					,CTNAME = #{ctname}
					,ZIPCODE	 = #{zipcode}
                    ,ADDRESS1	 = #{address1}
                    ,TEL	 	 = #{tel}
                    ,REGNO 		 = #{regno}
                    ,REPORTCTNAME = #{reportctname}
					,CLOSDATE = #{closdate}
			        ,UPDATEDATE = #{sysdate}
			        ,UPDATEURKEY = #{surkey}
		WHEN NOT MATCHED THEN
			INSERT (
			        CTKEY
			        ,CTTYPECD
			        ,CTNAME
			        ,COUNTRYCODE
			        ,ZIPCODE
			        ,ADDRESS1
                    ,TEL
                    ,REGNO
                    ,REPORTCTNAME
			        ,INSERTDATE
			        ,INSERTURKEY
			        ,UPDATEDATE
			        ,UPDATEURKEY
			        ,CLOSDATE
			    ) VALUES (
					#{ctkey}
					,#{cttype}
					,#{ctname}
					,#{lakey}
					,#{zipcode}
					,#{address1}
					,#{tel}
					,#{regno}
					,#{reportctname}
					,#{sysdate}
					,#{surkey}
					,#{sysdate}
					,#{surkey}
					,#{closdate}
				)
	</insert>
	
	<update id="updateTWorkMstCt">
		/* wms-master-center-sql-oracle.xml - updateTWorkMstCt */
		MERGE INTO TWORK_MST_CT A
		USING DUAL
		ON( CTKEY = #{ctkey})
		WHEN MATCHED THEN
			UPDATE 
			SET
					 CTTYPE = #{cttype}
					,CTNAME = #{ctname}
					,ADDRID	 = #{addrid}
					,ZIPCODE	 = #{zipcode}
                    ,ADDRESS1	 = #{address1}
                    ,ADDRESS2	 = #{address2}
                    ,TEL	 	 = #{tel}
                    ,REGNO 		 = #{regno}
                    ,REPORTCTNAME = #{reportctname}
					,CLOSDATE = #{closdate}
			        ,UPDATEDATE = #{sysdate}
			        ,UPDATEURKEY = #{surkey}
					,DELYN = #{delyn}
		WHEN NOT MATCHED THEN
			INSERT (
			        CTKEY
			        ,CTTYPE
			        ,CTNAME
			        ,COUNTRYCODE
			        ,ADDRID	
			        ,ZIPCODE
			        ,ADDRESS1
					,ADDRESS2
                    ,TEL
                    ,REGNO
                    ,REPORTCTNAME
			        ,INSERTDATE
			        ,INSERTURKEY
			        ,UPDATEDATE
			        ,UPDATEURKEY
			        ,CLOSDATE
			    ) VALUES (
					#{ctkey}
					,#{cttype}
					,#{ctname}
					,#{lakey}
					,#{addrid}
					,#{zipcode}
					,#{address1}
					,#{address2}
					,#{tel}
					,#{regno}
					,#{reportctname}
					,#{sysdate}
					,#{surkey}
					,#{sysdate}
					,#{surkey}
					,#{closdate}
				)
	</update>
	
	<delete id="deleteTWorkMstCt">
		/* wms-master-center-sql-oracle.xml - deleteTWorkMstCt */
			UPDATE	TWORK_MST_CT
			SET     CLOSDATE		= #{updatedate , typeHandler=GmtDateTimeTypeHandler }
			WHERE	CTKEY=#{ctkey}
	</delete>
	
</mapper>	