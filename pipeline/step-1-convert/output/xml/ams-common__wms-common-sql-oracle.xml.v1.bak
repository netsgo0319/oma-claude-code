	</select>	

	<resultMap id="selectMyMenuSetupMap" type="java.util.HashMap">
		<result property="mekey" column="MEKEY" />
		<result property="mename" column="MENAME" />
		<result property="meorder" column="MEORDER" />
		<result property="eqtype" column="EQTYPE" />
		<result property="uskey" column="USKEY" />
		<result property="uppermekey" column="UPPERMEKEY" />
		<result property="uppermename" column="UPPERMENAME" />
		<result property="isseparator" column="ISSEPARATOR" />
		<result property="isleaf" column="ISLEAF" />		
		<result property="leaf" column="LEAF" />
		<result property="comments" column="COMMENTS" />
		<result property="melvl" column="MELVL" />
		<result property="checked" column="CHECKED" javaType="boolean"/>
		
	</resultMap>
	<select id="selectMyMenuGrouping" fetchSize="1000" resultMap="selectMyMenuSetupMap">
		/* Converted from: CONNECT BY PRIOR MEKEY=UPPERMEKEY START WITH UPPERMEKEY='0' + LEVEL */
		WITH RECURSIVE mymenu_tree AS (
			SELECT URKEY, MEKEY, MENAME, MEORDER, EQTYPE, USKEY, UPPERMEKEY, ISSEPARATOR, ISLEAF, COMMENTS, 1 AS depth
			FROM TWORK_MST_URDFME WHERE UPPERMEKEY = '0' AND URKEY = #{surkey}
			UNION ALL
			SELECT m.URKEY, m.MEKEY, m.MENAME, m.MEORDER, m.EQTYPE, m.USKEY, m.UPPERMEKEY, m.ISSEPARATOR, m.ISLEAF, m.COMMENTS, t.depth + 1
			FROM TWORK_MST_URDFME m INNER JOIN mymenu_tree t ON m.UPPERMEKEY = t.MEKEY WHERE m.URKEY = #{surkey}
		)
		SELECT URKEY, MEKEY, MENAME, MEORDER, EQTYPE, USKEY, UPPERMEKEY, ISSEPARATOR, ISLEAF, COMMENTS
			  , depth - 1 AS MELVL
		FROM mymenu_tree
		ORDER BY UPPERMEKEY, MEORDER

	</select>

	<select id="selectMyMenuGroupingWithLevel" fetchSize="1000" resultMap="selectMyMenuSetupMap">
		/* Converted from: CONNECT BY PRIOR MEKEY=UPPERMEKEY START WITH UPPERMEKEY='0' + LEVEL */
		WITH RECURSIVE mymenu_tree2 AS (
			SELECT URKEY, MEKEY, MENAME, MEORDER, EQTYPE, USKEY, UPPERMEKEY, ISSEPARATOR, ISLEAF, COMMENTS, 1 AS depth
			FROM TWORK_MST_URDFME WHERE UPPERMEKEY = '0' AND URKEY = #{surkey}
			UNION ALL
			SELECT m.URKEY, m.MEKEY, m.MENAME, m.MEORDER, m.EQTYPE, m.USKEY, m.UPPERMEKEY, m.ISSEPARATOR, m.ISLEAF, m.COMMENTS, t.depth + 1
			FROM TWORK_MST_URDFME m INNER JOIN mymenu_tree2 t ON m.UPPERMEKEY = t.MEKEY WHERE m.URKEY = #{surkey}
		)
		SELECT URKEY, MEKEY, MENAME, MEORDER, EQTYPE, USKEY, UPPERMEKEY, ISSEPARATOR, ISLEAF, COMMENTS
			  , depth - 1 AS MELVL
		FROM mymenu_tree2
		ORDER BY UPPERMEKEY, MEORDER

	</select>
	
	
