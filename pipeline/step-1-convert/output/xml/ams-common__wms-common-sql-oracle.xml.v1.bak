	</select>

	
	<select id="selectTWorkMstToLcBonCount" resultType="java.lang.Integer">	
		
		SELECT COUNT(*) FROM
	   (
		SELECT LCKEY 
		FROM TWORK_MST_AR A
		INNER JOIN TWORK_MST_LC B
				ON A.CTKEY = B.CTKEY
			   AND A.ARKEY = B.ARKEY
		 WHERE  A.CTKEY = #{ctkey}
 			AND A.WRHOUS_SE = 'GNRL'
 			AND A.BONDTYPE = '2'		
 			AND B.LCKEY NOT LIKE 'PICK%'
		  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
		  	AND (B.LCKEY LIKE '%' || #{value} || '%' OR B.LCTYPE LIKE '%' || #{value} || '%' OR B.LCHOLDTYPE  LIKE '%' || #{value} || '%')
		  </if>
		 UNION ALL
		 SELECT LCKEY
		 FROM TWORK_MST_LC
		 WHERE LCKEY IN ('STAGE_A','STAGE_B','STAGE_C')
		   AND CTKEY = #{ctkey} 
		  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
		   AND (LCKEY LIKE '%' || #{value} || '%' OR LCTYPE LIKE '%' || #{value} || '%' OR LCHOLDTYPE  LIKE '%' || #{value} || '%')
		  </if>
		 )
	</select>
	
	<select id="selectTWorkMstToLcBon" resultMap="selectCommonCode">
		<if test="type != 'combo'">
			#{GRIDPAGING_ROWNUMTYPE_TOP}
		</if>			SELECT B.* 
						  FROM(
								SELECT
									   B.LCKEY AS FIELD1 
								      ,B.LCTYPE AS FIELD2
								      ,B.LCHOLDTYPE AS FIELD3
								  FROM TWORK_MST_AR A
								  INNER JOIN TWORK_MST_LC B
								  		  ON A.CTKEY = B.CTKEY
										 AND A.ARKEY = B.ARKEY
								WHERE  A.CTKEY = #{ctkey}
						 			AND A.WRHOUS_SE = 'GNRL'
						 			AND A.BONDTYPE = '2'	
						 			AND B.LCKEY NOT LIKE 'PICK%'
									<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
									AND (B.LCKEY LIKE '%' || #{value} || '%' OR B.LCTYPE LIKE '%' || #{value} || '%' OR B.LCHOLDTYPE  LIKE '%' || #{value} || '%')
									</if>
									  
								 UNION ALL
								 
 								 SELECT LCKEY
								       ,LCTYPE
								       ,LCHOLDTYPE
								 FROM  TWORK_MST_LC
								 WHERE LCKEY IN ('STAGE_A','STAGE_B','STAGE_C')
								   AND CTKEY = #{ctkey}
								   <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
								   AND (LCKEY LIKE '%' || #{value} || '%' OR LCTYPE LIKE '%' || #{value} || '%' OR LCHOLDTYPE  LIKE '%' || #{value} || '%')
								   </if>
								)B
							<choose>
								<when test='sortValue !=null and sortValue != ""'>	
									<if test='sortValue == "DESC" and colName !=null'>
									ORDER BY #{colName} DESC
									</if>
									<if test='sortValue == "ASC" and colName !=null'>
									ORDER BY #{colName} ASC
									</if>	
								</when>	
								<otherwise>
									ORDER BY FIELD1 ASC
								</otherwise>
							</choose>
								
			<if test="type != 'combo'">
				#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	    	</if>
	</select>
	
