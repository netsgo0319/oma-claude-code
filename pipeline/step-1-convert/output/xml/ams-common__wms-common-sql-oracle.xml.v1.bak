	<select id="selectFactorUnit" resultMap="selectCommonCode">
		SELECT
		     CTCD_DTKEY  AS FIELD1
		   , CTCD_DTNAME AS FIELD2
		   , COMMENTS    AS FIELD3
		FROM
		    TWORK_MST_CTCD_DT
		WHERE LAKEY = #{lakey} 
	  	  AND CTCD_HDKEY = #{ctcd_hdkey} 
 		  AND CTKEY = #{ctkey} 
		ORDER BY CTCD_DTORDER							
	</select>

	<select id="selectTworkMstLegend" resultMap="selectCommonCode">
		SELECT LGHDKEY AS FIELD1
			 ,LGHDNAME AS FIELD2
		FROM TWORK_MST_LEGEND_HD
		WHERE CTKEY = #{ctkey}
	</select>

	<select id="selectTworkMstLegendCount" resultType="java.lang.Integer">
		SELECT COUNT(1)
		FROM TWORK_MST_LEGEND_HD
		WHERE CTKEY = #{ctkey}
	</select>
</mapper>	