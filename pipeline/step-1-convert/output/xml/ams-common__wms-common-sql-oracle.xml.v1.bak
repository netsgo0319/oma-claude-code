	<resultMap id="selectCommonMobCode" type="java.util.HashMap">
		<result property="field1" column="FIELD1" />
		<result property="field2" column="FIELD2" typeHandler="WmsCodeDescTypeHandler"/>
		<result property="field3" column="FIELD3" typeHandler="WmsCodeDescTypeHandler"/>
		<result property="field4" column="FIELD4" />
		<result property="field5" column="FIELD5" />
		<result property="field6" column="FIELD6" typeHandler="WmsCodeDescTypeHandler"/>
	</resultMap>
	
	<select id="selectTWorkMstLcMob" resultMap="selectCommonMobCode">
    	#{GRIDPAGING_ROWNUMTYPE_TOP}
			SELECT	B.* 
				  FROM(
						SELECT LCKEY AS FIELD1, 
                               CTKEY || ';' || 'LCTYPE' || ';' || LCTYPE AS FIELD2,
                               CTKEY || ';' || 'LCHOLDTYPE' || ';' || LCHOLDTYPE AS FIELD3,
                               ERPSTLC AS FIELD4,
                               ARKEY AS FIELD5,
						  FROM TWORK_MST_LC
						 WHERE CTKEY = #{ctkey}
						  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
			  				AND (LCKEY LIKE '%' || #{value} || '%' OR LCTYPE LIKE '%' || #{value} || '%' OR LCHOLDTYPE LIKE '%' || #{value} || '%' OR ARKEY LIKE '%' || #{value} || '%')
						 </if>      
                       		)B
		 		<choose>
					<when test='sortValue !=null and sortValue != ""'>	
						<if test='sortValue == "DESC" and colName !=null'>
						ORDER BY #{colName} DESC
						</if>
						<if test='sortValue == "ASC" and colName !=null'>
						ORDER BY #{colName} ASC
						</if>	
					</when>	
					<otherwise>
						ORDER BY FIELD1 ASC
					</otherwise>
				</choose>
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>

	<select id="selectTWorkMstErpLoc" resultMap="selectCommonCode">
		#{GRIDPAGING_ROWNUMTYPE_TOP}
		SELECT 	*
		  FROM	(
			SELECT	LCKEY AS FIELD1 ,
	                        CTKEY || ';' || 'LCTYPE' || ';' || LCTYPE AS FIELD2,
                                CTKEY || ';' || 'LCHOLDTYPE' || ';' || LCHOLDTYPE AS FIELD3,
                                ERPSTLC AS FIELD4,
                                ARKEY AS FIELD5,
			  FROM 	TWORK_MST_LC 
			 WHERE 
			       	CTKEY = #{ctkey}
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
				<choose>
			        <when test='opval !=null and opval.equals("eq")'>
			            AND LCKEY = #{value}
			        </when>
		        	<otherwise>
					   AND 	(LCKEY LIKE '%' || #{value} || '%' OR LCTYPE LIKE '%' || #{value} || '%' OR LCHOLDTYPE LIKE '%' || #{value} || '%' 
							OR ARKEY LIKE '%' || #{value} || '%' 
							OR ERPSTLC LIKE '%' || #{value} || '%'
							)
			   		</otherwise>
			   	</choose>
			</if>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(arkey)" >
			   AND ARKEY = #{arkey}       
			</if>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(erpstlc)" >
			   AND ERPSTLC = #{erpstlc}       
			</if>
        )
		<choose>
			<when test='sortValue !=null and sortValue != ""'>	
				<if test='sortValue == "DESC" and colName !=null'>
				ORDER BY #{colName} DESC
				</if>
				<if test='sortValue == "ASC" and colName !=null'>
				ORDER BY #{colName} ASC
				</if>	
			</when>	
			<otherwise>
				ORDER BY FIELD1 ASC
			</otherwise>
		</choose>
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>	
	
	
	
