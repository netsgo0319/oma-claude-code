	<select id="selectTWorkMstToLcMoveBon" resultMap="selectCommonCode">
		<if test="type != 'combo'">
			#{GRIDPAGING_ROWNUMTYPE_TOP}
		</if>			
				SELECT * 
				  FROM(
				        SELECT
				               B.LCKEY AS FIELD1
				              ,B.LCTYPE AS FIELD2
				              ,B.LCHOLDTYPE AS FIELD3
				              ,B.CTKEY ||';'|| 'LCTYPE' ||';'|| B.LCTYPE AS FIELD2_DESC
				              ,B.CTKEY ||';'|| 'LCHOLDTYPE' ||';'|| B.LCHOLDTYPE AS FIELD3_DESC
				          FROM TWORK_MST_AR A
				          INNER JOIN TWORK_MST_LC B
				          		  ON A.CTKEY = B.CTKEY
								 AND A.ARKEY = B.ARKEY
						WHERE  A.CTKEY = #{ctkey}
				           AND A.WRHOUS_SE = 'GNRL'
				           AND A.BONDTYPE = '2'
				           AND B.LCKEY NOT LIKE 'PICK%'
				          <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
				           AND (B.LCKEY LIKE '%' || #{value} || '%' OR B.LCTYPE LIKE '%' || #{value} || '%' OR B.LCHOLDTYPE  LIKE '%' || #{value} || '%')
				          </if>
				         UNION ALL
