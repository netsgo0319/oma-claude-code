       </if>
       
	</select>

   <sql id="selectTWorkMstCtXStCommonCdRefSql">
        SELECT   STKEY AS FIELD1
                 ,STNAME AS FIELD2             
          FROM  TWORK_MST_CTXST 
         WHERE   CTKEY = #{sctkey}
           AND   STKEY != #{sstkey}           
         <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
            <choose>
                <when test='opval !=null and opval.equals("eq")'>
                    AND STKEY = #{value}
                </when>
                <otherwise>
                    AND (STKEY LIKE '%' || #{value} || '%' OR STNAME LIKE '%' || #{value}
                    || '%')
                </otherwise>
            </choose>
        </if>
    </sql>
    
