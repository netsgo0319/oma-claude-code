	<select id="selcetTWorkMstIcsb" resultMap="selectCommonCode">
		#{GRIDPAGING_ROWNUMTYPE_TOP}

					SELECT	B.* 
					  FROM(	
						
							SELECT 
									 SBKEY AS FIELD1
									,ICKEY AS FIELD2
									,OWKEY AS FIELD3
									,ICUTTYPE AS FIELD4
					                ,#{ctkey} ||';'|| 'ICUTTYPE' ||';'|| ICUTTYPE AS FIELD4_DESC
						  	  FROM TWORK_MST_ICSB
						  	 WHERE 
							 	   CTKEY = #{ctkey}
					           AND CLOSDATE >= #{sysdate}
							<if test="OWKEY_AUTH_LIST != null and OWKEY_AUTH_LIST.size > 0" >
							  AND OWKEY IN 
								<foreach item="OWKEY_AUTH_LIST" index="index" collection="OWKEY_AUTH_LIST"
									open="(" separator="," close=")">
									#{OWKEY_AUTH_LIST}
								</foreach>
							</if>
							<if test="LOGGRPCD_SELECTION_VALUE != null and LOGGRPCD_SELECTION_VALUE != ''" >
								AND LOGGRPCD IN 
								<foreach item="LOGGRPCD_SELECTION_VALUE" index="loggrpcdIdx" collection="LOGGRPCD_SELECTION_VALUE" open="(" separator="," close=")">
									#{LOGGRPCD_SELECTION_VALUE}
								</foreach>
							</if>
							  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
								  AND (
									  OWKEY LIKE '%' || #{value} || '%' 
									  OR ICKEY LIKE '%' || #{value} || '%' 
									  OR SBKEY LIKE '%' || #{value} || '%' 
									  OR ICUTTYPE LIKE '%' || #{value} || '%' 
								  )
							 </if>
	 				 )B
			 		<choose>
						<when test='sortValue !=null and sortValue != ""'>	
							<if test='sortValue == "DESC" and colName !=null'>
							ORDER BY #{colName} DESC
							</if>
							<if test='sortValue == "ASC" and colName !=null'>
							ORDER BY #{colName} ASC
							</if>	
						</when>	
						<otherwise>
							ORDER BY FIELD1 ASC
						</otherwise>
					</choose>
                        
			#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>

