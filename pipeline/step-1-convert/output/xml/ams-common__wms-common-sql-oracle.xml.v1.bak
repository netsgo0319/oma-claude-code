	<select id="selectTWorkInfoReqCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
		  FROM TWORK_INFO_REQ_HD
		 WHERE CTKEY = #{ctkey}
		<if test="OWKEY_AUTH_LIST != null and OWKEY_AUTH_LIST.size > 0" >
			 AND OWKEY IN 
			<foreach item="OWKEY_AUTH_LIST" index="index" collection="OWKEY_AUTH_LIST"
				open="(" separator="," close=")">
				#{OWKEY_AUTH_LIST}
			</foreach>
		</if>				    	
		  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
				AND (
					A.REQHDKEY LIKE '%' || #{value} || '%' 
			   	 OR A.OWKEY LIKE '%' || #{value} || '%'
				 OR A.ACKEY LIKE '%' || #{value} || '%'
				 OR B.ACNAME LIKE '%' || #{value} || '%'
				 OR A.STORE_KEY LIKE '%' || #{value} || '%'
				 OR C.STORE_NAME LIKE '%' || #{value} || '%'
				)
		 </if>
		 
	</select>
	
	<select id="selectTWorkInfoReqHd" resultMap="selectCommonCode">
	
			#{GRIDPAGING_ROWNUMTYPE_TOP}
          
						SELECT B.* 
							FROM(
								SELECT  A.REQHDKEY  AS FIELD1 
								       ,A.OWKEY AS FIELD2
									   ,A.REQUESTDATE  AS FIELD3 
									   ,A.REQHDTYPE AS FIELD4
									   ,#{ctkey} ||';'||'REQHDTYPE'||';'||A.REQHDTYPE AS FIELD4_DESC
									   ,A.ACKEY AS FIELD5
									   ,B.ACNAME AS FIELD6
									   ,A.STORE_KEY AS FIELD7
									   ,C.STORE_NAME AS FIELD8
								 FROM TWORK_INFO_REQ_HD A
								 LEFT OUTER JOIN TWORK_MST_AC B
											  ON A.CTKEY = B.CTKEY
											 AND A.OWKEY = B.OWKEY
											 AND A.ACKEY = B.ACKEY
											 AND A.DCKEY = B.DCKEY
								 LEFT OUTER JOIN TWORK_MST_STORE C
								 			  ON A.CTKEY = C.CTKEY
											 AND A.OWKEY = C.OWKEY
											 AND A.STORE_KEY = C.STORE_KEY
											 AND A.DCKEY = C.DCKEY
								 WHERE A.CTKEY = #{ctkey}
									<if test="OWKEY_AUTH_LIST != null and OWKEY_AUTH_LIST.size > 0" >
										 AND A.OWKEY IN 
										<foreach item="OWKEY_AUTH_LIST" index="index" collection="OWKEY_AUTH_LIST"
											open="(" separator="," close=")">
											#{OWKEY_AUTH_LIST}
										</foreach>
									</if>				    	
								  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
										AND (
											A.REQHDKEY LIKE '%' || #{value} || '%' 
				                     	 OR A.OWKEY LIKE '%' || #{value} || '%'
				                     	 OR A.ACKEY LIKE '%' || #{value} || '%'
				                     	 OR B.ACNAME LIKE '%' || #{value} || '%'
				                     	 OR A.STORE_KEY LIKE '%' || #{value} || '%'
				                     	 OR C.STORE_NAME LIKE '%' || #{value} || '%'
										)
								 </if>
      							)B
								<choose>
									<when test='sortValue !=null and sortValue != ""'>	
										<if test='sortValue == "DESC" and colName !=null'>
										ORDER BY #{colName} DESC
										</if>
										<if test='sortValue == "ASC" and colName !=null'>
										ORDER BY #{colName} ASC
										</if>	
									</when>	
									<otherwise>
										ORDER BY FIELD1 DESC , FIELD2 ASC
									</otherwise>
								</choose>
		
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>	
	

	<select id="selectPutawayLocationCount" resultType="java.lang.Integer" >
			SELECT COUNT(1)
			  FROM (
						SELECT FIELD1
						      ,FIELD2
						      ,FIELD2_DESC
						      ,CASE WHEN SUBSTR(FIELD3,2) = 'SAME' THEN '동일 재고 존재'
						            WHEN SUBSTR(FIELD3,2) = 'EMPTY' THEN '재고 없음' 
						            ELSE SUBSTR(FIELD3,2)
						        END  AS FIELD3
						      ,FIELD4
						      ,#{ctkey} ||';'|| ''|| ';'|| COALESCE(B.ARNAME, FIELD4) AS FIELD4_DESC
						      ,COALESCE(FIELD5, 0) AS FIELD5
						  FROM (
									SELECT A.LCKEY   AS FIELD1
									      ,A.LCTYPE  AS FIELD2
										  ,A.CTKEY ||';'|| 'LCTYPE' || ';' || A.LCTYPE AS FIELD2_DESC
									      ,B.STATUS  AS FIELD3
									      ,A.LCSEQ AS LCSEQ
									      ,A.ARKEY AS FIELD4
									      ,B.STATUS  AS STATUS
									      ,B.TTQTY AS FIELD5
									  FROM TWORK_MST_LC A
									  LEFT OUTER JOIN (
											SELECT B.TO_LCKEY AS LCKEY
											    ,'1' AS STATUS
											    ,B.CTKEY
											    ,COALESCE((
		                                                SELECT SUM(TTQTY)
		                                                  FROM TWORK_INFO_IVATXLCXULC A 
		                                                 WHERE A.CTKEY =  B.CTKEY
		                                                   AND A.OWKEY = B.OWKEY
		                                                   AND A.ICKEY = B.ICKEY
		                                                   AND A.LCKEY = B.TO_LCKEY
	                                         	 ), 0) AS TTQTY
											 FROM TWORK_MST_IC B
											WHERE B.CTKEY = #{ctkey}
											    AND B.OWKEY = #{owkey}
											    AND B.ICKEY = #{ickey}
											UNION ALL
												SELECT LCKEY 
												      ,'3SAME' AS STATUS
												      , CTKEY
												      ,SUM(TTQTY) AS TTQTY
												  FROM TWORK_INFO_IVATXLCXULC
												 WHERE
												       CTKEY = #{ctkey}
												   AND OWKEY = #{owkey}
												   AND ICKEY = #{ickey}
												   AND TTQTY > 0 
												   AND LCKEY NOT IN (
												        SELECT COALESCE(TO_LCKEY, ' ')
												         FROM TWORK_MST_IC
												        WHERE CTKEY = #{ctkey}
												            AND OWKEY = #{owkey}
												            AND ICKEY = #{ickey}                           
												        )   
												GROUP BY LCKEY , CTKEY										
											UNION ALL
											SELECT LCKEY
											      ,'2EMPTY' AS STATUS
											      , CTKEY
											      ,0 AS TTQTY  
											  FROM (
											         SELECT B.LCKEY 
											               ,B.CTKEY 
											               ,SUM(A.TTQTY) AS TTQTY
											           FROM TWORK_INFO_IVATXLCXULC A 
											           RIGHT OUTER JOIN TWORK_MST_LC B
											           				 ON A.CTKEY = B.CTKEY
																	AND A.LCKEY = B.LCKEY
											          WHERE
											                B.CTKEY = #{ctkey}
											          GROUP BY B.LCKEY 
											                  ,B.CTKEY                  
											        )
											 WHERE
											       (TTQTY = 0 OR TTQTY IS NULL)
											       AND LCKEY NOT IN (
											            SELECT COALESCE(TO_LCKEY, ' ')
											             FROM TWORK_MST_IC
											            WHERE CTKEY = #{ctkey}
											                AND OWKEY = #{owkey}
											                AND ICKEY = #{ickey}                            
											            )										
											UNION ALL
		                                    SELECT B.LCKEY,
		                                           B.CTKEY,
		                                          '4' AS STAUS,
		                                           COALESCE(SUM (A.TTQTY), 0) AS TTQTY
		                                    FROM TWORK_INFO_IVATXLCXULC A
		                                    RIGHT OUTER JOIN TWORK_MST_LC B
		                                    			  ON A.CTKEY = B.CTKEY
														 AND A.LCKEY = B.LCKEY
		                                   WHERE 
		                                         B.CTKEY = #{ctkey}
											     AND B.LCKEY NOT IN (
												            SELECT COALESCE(TO_LCKEY, ' ') AS LCKEY
												             FROM TWORK_MST_IC
												            WHERE CTKEY = #{ctkey}
												                AND OWKEY = #{owkey}
												                AND ICKEY = #{ickey}
												            UNION ALL
												            SELECT LCKEY
												              FROM (
												                     SELECT B.LCKEY 
												                           ,B.CTKEY 
												                           ,SUM(A.TTQTY) AS TTQTY
												                       FROM TWORK_INFO_IVATXLCXULC A 
												                       RIGHT OUTER JOIN TWORK_MST_LC B
												                       				 ON A.CTKEY = B.CTKEY
																					AND A.LCKEY = B.LCKEY
												                      WHERE
												                            B.CTKEY = #{ctkey}
												                      GROUP BY B.LCKEY 
												                              ,B.CTKEY                  
												                    )
												             WHERE
												                   (TTQTY = 0 OR TTQTY IS NULL)
												            UNION ALL
												            SELECT LCKEY 
												              FROM TWORK_INFO_IVATXLCXULC
												             WHERE
												                   CTKEY = #{ctkey}
												               AND OWKEY = #{owkey}
												               AND ICKEY = #{ickey}
												               AND TTQTY > 0     
												    	)
											  GROUP BY B.LCKEY, B.CTKEY
									     ) B ON A.CTKEY = B.CTKEY
											AND A.LCKEY = B.LCKEY
									WHERE A.CTKEY = #{ctkey}
									  <if test="lcholdtype != 'NOTHING' ">
									  AND A.LCHOLDTYPE = '10'
									  </if>
									  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
										AND (
											   A.LCKEY LIKE '%' || #{value} || '%' 
											OR A.LCTYPE LIKE '%' || #{value} || '%'
											OR B.STATUS LIKE '%' || #{value} || '%'
										)
									  </if>
							     
						  		) A
						  INNER JOIN TWORK_MST_AR B
						  		  ON A.FIELD4 = B.ARKEY
						 WHERE B.CTKEY = #{ctkey}
					 		<choose>
								<when test='arkey !=null'>
									<if test="arkey2 != null">
										AND ARKEY IN (#{arkey} , #{arkey2})
									</if>
									<if test="arkey2 == null">
										AND ARKEY = #{arkey}
									</if>
								</when>	
							</choose>
						  AND (B.OWKEY = #{owkey} OR B.OWKEY IS NULL)
			  )
	</select>
	
	<select id="selectPutawayLocation" resultMap="selectCommonCode">
			<if test="device != 'MOBILE'">
				#{GRIDPAGING_ROWNUMTYPE_TOP}
			</if>
					SELECT FIELD1
					      ,FIELD2
					      ,FIELD2_DESC
					      ,CASE WHEN SUBSTR(FIELD3,2) = 'SAME' THEN '동일 재고 존재'
					            WHEN SUBSTR(FIELD3,2) = 'EMPTY' THEN '재고 없음' 
					            ELSE SUBSTR(FIELD3,2)
					        END  AS FIELD3
					      ,FIELD4
					      ,#{ctkey} ||';'|| ''|| ';'|| COALESCE(B.ARNAME, FIELD4) AS FIELD4_DESC
					      ,COALESCE(FIELD5, 0) AS FIELD5
					  FROM (
								SELECT A.LCKEY   AS FIELD1
								      ,A.LCTYPE  AS FIELD2
									  ,A.CTKEY ||';'|| 'LCTYPE' || ';' || A.LCTYPE AS FIELD2_DESC
								      ,B.STATUS  AS FIELD3
								      ,A.LCSEQ AS LCSEQ
								      ,A.ARKEY AS FIELD4
								      ,B.STATUS  AS STATUS
								      ,B.TTQTY AS FIELD5
								  FROM TWORK_MST_LC A
								  LEFT OUTER JOIN (
										SELECT B.TO_LCKEY AS LCKEY
										    ,'1' AS STATUS
										    ,B.CTKEY
										    ,COALESCE((
	                                                SELECT SUM(TTQTY)
	                                                  FROM TWORK_INFO_IVATXLCXULC A 
	                                                 WHERE A.CTKEY =  B.CTKEY
	                                                   AND A.OWKEY = B.OWKEY
	                                                   AND A.ICKEY = B.ICKEY
	                                                   AND A.LCKEY = B.TO_LCKEY
                                         	 ), 0) AS TTQTY
										 FROM TWORK_MST_IC B
										WHERE B.CTKEY = #{ctkey}
										    AND B.OWKEY = #{owkey}
										    AND B.ICKEY = #{ickey}
										UNION ALL
											SELECT LCKEY 
											      ,'3SAME' AS STATUS
											      , CTKEY
											      ,SUM(TTQTY) AS TTQTY
											  FROM TWORK_INFO_IVATXLCXULC
											 WHERE
											       CTKEY = #{ctkey}
											   AND OWKEY = #{owkey}
											   AND ICKEY = #{ickey}
											   AND TTQTY > 0 
											   AND LCKEY NOT IN (
											        SELECT COALESCE(TO_LCKEY, ' ')
											         FROM TWORK_MST_IC
											        WHERE CTKEY = #{ctkey}
											            AND OWKEY = #{owkey}
											            AND ICKEY = #{ickey}                           
											        )   
											GROUP BY LCKEY , CTKEY										
										UNION ALL
										SELECT LCKEY
										      ,'2EMPTY' AS STATUS
										      , CTKEY
										      ,0 AS TTQTY  
										  FROM (
										         SELECT B.LCKEY 
										               ,B.CTKEY 
										               ,SUM(A.TTQTY) AS TTQTY
										           FROM TWORK_INFO_IVATXLCXULC A 
										           RIGHT OUTER JOIN TWORK_MST_LC B
										           				ON A.CTKEY = B.CTKEY
										           			   AND A.LCKEY = B.LCKEY
										          WHERE
										                B.CTKEY = #{ctkey}
										          GROUP BY B.LCKEY 
										                  ,B.CTKEY                  
										        )
										 WHERE
										       (TTQTY = 0 OR TTQTY IS NULL)
										       AND LCKEY NOT IN (
										            SELECT COALESCE(TO_LCKEY, ' ')
										             FROM TWORK_MST_IC
										            WHERE CTKEY = #{ctkey}
										                AND OWKEY = #{owkey}
										                AND ICKEY = #{ickey}                            
										            )										
										UNION ALL
	                                    SELECT B.LCKEY,
	                                           B.CTKEY,
	                                          '4' AS STAUS,
	                                           COALESCE(SUM (A.TTQTY), 0) AS TTQTY
	                                    FROM TWORK_INFO_IVATXLCXULC A
	                                    RIGHT OUTER JOIN TWORK_MST_LC B
	                                    			  ON A.CTKEY = B.CTKEY
	                                    			 AND A.LCKEY = B.LCKEY
	                                   WHERE 
	                                         B.CTKEY = #{ctkey}
										     AND B.LCKEY NOT IN (
											            SELECT COALESCE(TO_LCKEY, ' ') AS LCKEY
											             FROM TWORK_MST_IC
											            WHERE CTKEY = #{ctkey}
											                AND OWKEY = #{owkey}
											                AND ICKEY = #{ickey}
											            UNION ALL
											            SELECT LCKEY
											              FROM (
											                     SELECT B.LCKEY 
											                           ,B.CTKEY 
											                           ,SUM(A.TTQTY) AS TTQTY
											                       FROM TWORK_INFO_IVATXLCXULC A 
											                       RIGHT OUTER JOIN TWORK_MST_LC B
											                       				 ON A.CTKEY = B.CTKEY
											                       				AND A.LCKEY = B.LCKEY
											                      WHERE
											                            B.CTKEY = #{ctkey}
											                      GROUP BY B.LCKEY 
											                              ,B.CTKEY                  
											                    )
											             WHERE
											                   (TTQTY = 0 OR TTQTY IS NULL)
											            UNION ALL
											            SELECT LCKEY 
											              FROM TWORK_INFO_IVATXLCXULC
											             WHERE
											                   CTKEY = #{ctkey}
											               AND OWKEY = #{owkey}
											               AND ICKEY = #{ickey}
											               AND TTQTY > 0     
											    	)
										  GROUP BY B.LCKEY, B.CTKEY
								     ) B ON A.CTKEY = B.CTKEY
										AND A.LCKEY = B.LCKEY
								WHERE A.CTKEY = #{ctkey}
								  <if test="lcholdtype != 'NOTHING' ">
								  AND A.LCHOLDTYPE = '10'
								  </if>
								  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
									AND (
										   A.LCKEY LIKE '%' || #{value} || '%' 
										OR A.LCTYPE LIKE '%' || #{value} || '%'
										OR B.STATUS LIKE '%' || #{value} || '%'
									)
								  </if>
						     
					  		) A
					      ,TWORK_MST_AR B
					 WHERE 
					 	  A.FIELD4 = B.ARKEY
				 		<choose>
							<when test='arkey !=null'>
								<if test="arkey2 != null">
									AND ARKEY IN (#{arkey} , #{arkey2})
								</if>
								<if test="arkey2 == null">
									AND ARKEY = #{arkey}
								</if>
							</when>	
						</choose>
					  AND B.CTKEY = #{ctkey}
					  AND (B.OWKEY = #{owkey} OR B.OWKEY IS NULL)
				 		<choose>
							<when test='sortValue !=null and sortValue != ""'>	
								<if test='sortValue == "DESC" and colName !=null'>
								ORDER BY #{colName} DESC
								</if>
								<if test='sortValue == "ASC" and colName !=null'>
								ORDER BY #{colName} ASC
								</if>	
							</when>	
							<otherwise>
								ORDER BY STATUS, LCSEQ ASC
							</otherwise>
						</choose>

			<if test="device != 'MOBILE'">
				#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
			</if>
	</select>		
	
	
	<!-- Equipment -->
	<select id="selectTWorkMstEqCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
		  FROM TWORK_MST_EQ
		 WHERE 
		       CLOSDATE >= #{sysdate}
		  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
		 		AND (EQKEY LIKE '%' || #{value} || '%')
		 	</if>
		 	<if test="ctkey != null">
	 			AND CTKEY = #{ctkey}
	 		</if>
	</select>
	
	<select id="selectTWorkMstEq" resultMap="selectCommonCode">
		#{GRIDPAGING_ROWNUMTYPE_TOP}
					
						 SELECT B.* 
						   FROM(	
								SELECT EQKEY AS FIELD1
								      ,EQTYPE AS FIELD2
								      ,#{ctkey} ||';'|| 'EQTYPE' ||';'|| EQTYPE AS FIELD2_DESC					      
								  FROM TWORK_MST_EQ
								 WHERE 
								       CLOSDATE >= #{sysdate}
								  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
								 		AND (EQKEY LIKE '%' || #{value} || '%')
								 	</if>
								 	<if test="ctkey != null">
							 			AND CTKEY = #{ctkey}
							 		</if>
						  	)B
							<choose>
								<when test='sortValue !=null and sortValue != ""'>	
									<if test='sortValue == "DESC" and colName !=null'>
									ORDER BY #{colName} DESC
									</if>
									<if test='sortValue == "ASC" and colName !=null'>
									ORDER BY #{colName} ASC
									</if>	
								</when>	
								<otherwise>
									ORDER BY FIELD1 ASC
								</otherwise>
							</choose>
		
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>


	<!-- WAYBILLNO -->
	<select id="selectWaybillnoCount" resultType="java.lang.Integer" >
     	SELECT COUNT(1) 
          FROM (
		      SELECT 
				     C.WAYBILLNO AS FIRSTWAYBILLNO
			        ,A.UDF1
			        ,A.OWKEY
			        ,A.WAYBILLNO
			        ,A.ULCKEY		      
				FROM TWORK_INFO_ULCXWB A
				INNER JOIN TWORK_INFO_OBXULC B
				   		ON A.ULCKEY = B.ULCKEY
					   AND A.CTKEY = B.CTKEY
					   AND A.OWKEY = B.OWKEY
				INNER JOIN TWORK_INFO_OB_HD C
						ON A.CTKEY = C.CTKEY
					   AND A.OWKEY = C.OWKEY
					   AND B.OBHDKEY = C.OBHDKEY
				WHERE A.CTKEY = #{ctkey}
				<if test="OWKEY_AUTH_LIST != null and OWKEY_AUTH_LIST.size > 0" >
					 AND A.OWKEY IN 
					<foreach item="OWKEY_AUTH_LIST" index="index" collection="OWKEY_AUTH_LIST"
						open="(" separator="," close=")">
						#{OWKEY_AUTH_LIST}
					</foreach>
				</if>				    	
               ) A 
		  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
		 		WHERE (FIRSTWAYBILLNO LIKE '%' || #{value} || '%' 
		 		OR UDF1 LIKE '%' || #{value} || '%'
		 		OR OWKEY LIKE '%' || #{value} || '%'
		 		OR WAYBILLNO LIKE '%' || #{value} || '%'
		 		OR ULCKEY LIKE '%' || #{value} || '%'
		 		)
		 	</if>
	</select>
	
	<select id="selectWaybillno" resultMap="selectCommonCode">
		#{GRIDPAGING_ROWNUMTYPE_TOP}
		
                  		SELECT B.* 
						  FROM(                  	
			                  	SELECT 
										 A.FIRSTWAYBILLNO AS FIELD1
										,A.UDF1           AS FIELD2
										,A.OWKEY          AS FIELD3
										,A.WAYBILLNO      AS FIELD4
										,A.ULCKEY         AS FIELD5
										,A.INSERTDATE     AS FIELD6
										,A.INSERTURKEY    AS FIELD7                  	
			                  	  FROM (
										SELECT C.WAYBILLNO FIRSTWAYBILLNO
										      ,A.UDF1
										      ,A.OWKEY
										      ,A.WAYBILLNO
										      ,A.ULCKEY
										      ,A.INSERTDATE
										      ,A.INSERTURKEY 
										FROM TWORK_INFO_ULCXWB A
										INNER JOIN TWORK_INFO_OBXULC B
										    	ON A.CTKEY = B.CTKEY
											   AND A.OWKEY = B.OWKEY
											   AND A.ULCKEY = B.ULCKEY
										INNER JOIN TWORK_INFO_OB_HD C
												ON A.CTKEY = C.CTKEY
											   AND A.OWKEY = C.OWKEY
											   AND B.OBHDKEY = C.OBHDKEY
										WHERE A.CTKEY = #{ctkey}
											<if test="OWKEY_AUTH_LIST != null and OWKEY_AUTH_LIST.size > 0" >
												 AND A.OWKEY IN 
												<foreach item="OWKEY_AUTH_LIST" index="index" collection="OWKEY_AUTH_LIST"
													open="(" separator="," close=")">
													#{OWKEY_AUTH_LIST}
												</foreach>
											</if>				    	
										  
			                  	  		) A 
								  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
								 		WHERE (FIRSTWAYBILLNO LIKE '%' || #{value} || '%' 
								 		OR UDF1 LIKE '%' || #{value} || '%'
								 		OR OWKEY LIKE '%' || #{value} || '%'
								 		OR WAYBILLNO LIKE '%' || #{value} || '%'
								 		OR ULCKEY LIKE '%' || #{value} || '%'
								 		)
								 	</if>
					 		)B
							<choose>
								<when test='sortValue !=null and sortValue != ""'>	
									<if test='sortValue == "DESC" and colName !=null'>
									ORDER BY #{colName} DESC
									</if>
									<if test='sortValue == "ASC" and colName !=null'>
									ORDER BY #{colName} ASC
									</if>	
								</when>	
								<otherwise>
									ORDER BY FIELD1 ASC
								</otherwise>
							</choose>
					 	
			#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>
	
	<select id="selectTworkInfoPoHdCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
		  FROM TWORK_INFO_PO_HD
		 WHERE CTKEY = #{ctkey}			    	
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
		   AND (
				POHDKEY LIKE '%' || #{value} || '%' 
				OR POHDDATE LIKE '%' || #{value} || '%'
				OR ACKEY LIKE '%' || #{value} || '%'
				OR ACNAME LIKE '%' || #{value} || '%'
		   )
		</if>
		 
	</select>
	
	<select id="selectTworkInfoPoHd" resultMap="selectCommonCode">
	
		#{GRIDPAGING_ROWNUMTYPE_TOP}

            	SELECT POHDKEY  AS FIELD1 
					   ,POHDDATE  AS FIELD2 
					   ,DELIVERYDATE AS FIELD3
					   ,OWKEY AS FIELD4
					   ,ACKEY   AS FIELD5 
					   ,ACNAME  AS FIELD6 
				  FROM TWORK_INFO_PO_HD
			     WHERE CTKEY = #{ctkey}			
			    <if test="type == 'inboundorder' " >
				   AND WKSTATUS != '90'  
				</if> 	    	
				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
				   AND (
						POHDKEY LIKE '%' || #{value} || '%' 
						OR POHDDATE LIKE '%' || #{value} || '%'
						OR ACKEY LIKE '%' || #{value} || '%'
						OR ACNAME LIKE '%' || #{value} || '%'
				   )
				</if>
				<choose>
					<when test='sortValue !=null and sortValue != ""'>	
						<if test='sortValue == "DESC" and colName !=null'>
						ORDER BY #{colName} DESC
						</if>
						<if test='sortValue == "ASC" and colName !=null'>
						ORDER BY #{colName} ASC
						</if>	
					</when>	
					<otherwise>
						ORDER BY FIELD1 ASC
					</otherwise>
				</choose> 
				
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
										 
	</select>	

	<resultMap id="staticManagerMap" type="java.util.HashMap" >
		<result property="ctkey" 		column="CTKEY" />
		<result property="ctcd_hdkey" 	column="CTCD_HDKEY" />
		<result property="ctcd_dtkey" 	column="CTCD_DTKEY" />
		<result property="ctcd_dtorder"	column="CTCD_DTORDER" />
		<result property="ctcd_dtname"	column="CTCD_DTNAME" />
		<result property="lakey" 		column="LAKEY" />
	</resultMap>
	
	<select id="selectTWorkMstCtcdDtList" resultMap="staticManagerMap">
		<![CDATA[
		SELECT CTKEY, CTCD_HDKEY, CTCD_DTKEY, CTCD_DTNAME, LAKEY
		  FROM TWORK_MST_CTCD_DT 
		 ]]>    		
	</select>	
	
	<resultMap id="selectTWorkMstCtcdDtCtkeyListMap" type="java.util.HashMap" >
		<result property="hdkey" 	column="CTCD_HDKEY" />
		<result property="field1" 	column="CTCD_DTKEY" />
		<result property="field2"	column="CTCD_DTNAME" />
	</resultMap>

	<select id="selectTWorkMstCtcdDtCtkeyList" fetchSize="1000" resultMap="selectTWorkMstCtcdDtCtkeyListMap">
		SELECT CTCD_HDKEY
		      ,CTCD_DTKEY
		      ,CTCD_DTNAME
		 FROM TWORK_MST_CTCD_DT
		WHERE
			  CTKEY = #{ctkey}
	      AND LAKEY = #{lakey}
     ORDER BY CTCD_HDKEY , CTCD_DTORDER	      
	</select>

	<resultMap id="selectEquipmentListMap" type="java.util.HashMap">
		<result property="eqkey" column="EQKEY" />
		<result property="prtype" column="PRTYPE" />
		<result property="eqtype" column="EQTYPE" />
		<result property="eqname" column="EQNAME" />
		<result property="dlcompany" column="DLCOMPANY" />
		<result property="ipaddress" column="IPADDRESS" />
	</resultMap>
	
	<select id="selectEquipmentList" resultMap="selectEquipmentListMap">
        SELECT EQKEY 
              ,PRTYPE 
              ,EQTYPE 
              ,EQNAME 
              ,IPADDRESS
          FROM TWORK_MST_EQ
        WHERE
              CTKEY = #{ctkey}	
	</select>
	
	
	<select id="selectTWorkMstStgCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
		  FROM TWORK_MST_STG
		<where>
		  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
				<choose>
			        <when test='opval !=null and opval.equals("eq")'>
			            AND STGKEY = #{value}
			        </when>
		        	<otherwise>
			   			AND (STGDESC LIKE '%' || #{value} || '%')
			   		</otherwise>
			   	</choose>
		 	</if>
		 	<if test="stgkey != null and stgkey != ''">
	 			AND STGKEY = #{stgkey}
	 		</if>
			<if test="stgtype != null and stgtype != ''">
				AND STGTYPE = #{stgtype}
			</if>
	 	</where>
	</select>
	
	<select id="selectTWorkMstStg" resultMap="selectCommonCode">
	
			#{GRIDPAGING_ROWNUMTYPE_TOP}
	
			
						 SELECT B.* 
						   FROM(	
								SELECT STGKEY AS FIELD1
								      ,STGDESC AS FIELD2		      
								  FROM TWORK_MST_STG
								<where>
							  		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
									<choose>
								        <when test='opval !=null and opval.equals("eq")'>
								            AND STGKEY = #{value}
								        </when>
							        	<otherwise>
								   			AND (STGDESC LIKE '%' || #{value} || '%')
								   		</otherwise>
								   	</choose>
							 		</if>
							 		<if test="stgkey != null and stgkey != ''">
										AND STGKEY = #{stgkey}
									</if>
									<if test="stgtype != null and stgtype != ''">
										AND STGTYPE = #{stgtype}
									</if>
								</where>
						  	)B
							<choose>
								<when test='sortValue !=null and sortValue != ""'>	
									<if test='sortValue == "DESC" and colName !=null'>
									ORDER BY #{colName} DESC
									</if>
									<if test='sortValue == "ASC" and colName !=null'>
									ORDER BY #{colName} ASC
									</if>	
								</when>	
								<otherwise>
									ORDER BY FIELD1 ASC
								</otherwise>
							</choose>

			#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
                           
	</select>

