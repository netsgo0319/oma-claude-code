	<select id="selectTWorkMstIcgrCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
	  	  FROM TWORK_MST_ICGR
		  <where>
		  		CTKEY = #{ctkey}
			   <if test="OWKEY_SELECTION_VALUE != null and OWKEY_SELECTION_VALUE != ''" >
				  AND OWKEY IN 
					<foreach item="OWKEY_SELECTION_VALUE" index="index" collection="OWKEY_SELECTION_VALUE" open="(" separator="," close=")">
						#{OWKEY_SELECTION_VALUE}
					</foreach>
			   </if>			
			<if test="OWKEY_AUTH_LIST != null and OWKEY_AUTH_LIST.size > 0" >
			  AND OWKEY IN 
				<foreach item="OWKEY_AUTH_LIST" index="index" collection="OWKEY_AUTH_LIST"
					open="(" separator="," close=")">
					#{OWKEY_AUTH_LIST}
				</foreach>
			</if>
            AND CLOSDATE >= #{sysdate}
			  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
					<choose>
				        <when test='opval !=null and opval.equals("eq")'>
				            AND ICGRKEY = #{value}
				        </when>
			        	<otherwise>
				   			AND (ICGRKEY LIKE '%' || #{value} || '%' OR ICGRNAME LIKE '%' || #{value} || '%')
				   		</otherwise>
				   	</choose>
				</if>
		  </where>
	</select>	

	<select id="selectTWorkMstIcgr" resultMap="selectCommonCode">
			#{GRIDPAGING_ROWNUMTYPE_TOP}
        
                    SELECT	B.* 
					  FROM(                    
		                    SELECT ICGRKEY AS FIELD1
		                          ,ICGRNAME AS FIELD2 
		                          ,ICGRTYPE AS FIELD3
								  ,'ICGRTYPE' || ';' || ICGRTYPE AS FIELD3_DESC
								  ,OWKEY AS FIELD4
		                        FROM TWORK_MST_ICGR					
							  <where>
							  		CTKEY = #{ctkey}
							   <if test="OWKEY_SELECTION_VALUE != null and OWKEY_SELECTION_VALUE != ''" >
								  AND OWKEY IN 
									<foreach item="OWKEY_SELECTION_VALUE" index="index" collection="OWKEY_SELECTION_VALUE" open="(" separator="," close=")">
										#{OWKEY_SELECTION_VALUE}
									</foreach>
							   </if>							  		
								<if test="OWKEY_AUTH_LIST != null and OWKEY_AUTH_LIST.size > 0" >
								  AND OWKEY IN 
									<foreach item="OWKEY_AUTH_LIST" index="index" collection="OWKEY_AUTH_LIST"
										open="(" separator="," close=")">
										#{OWKEY_AUTH_LIST}
									</foreach>
								</if>
					            AND CLOSDATE >= #{sysdate}
								  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
										<choose>
									        <when test='opval !=null and opval.equals("eq")'>
									            AND ICGRKEY = #{value}
									        </when>
								        	<otherwise>
									   			AND (ICGRKEY LIKE '%' || #{value} || '%' OR ICGRNAME LIKE '%' || #{value} || '%')
									   		</otherwise>
									   	</choose>
									</if>
							  </where>
					  		)B
							<choose>
								<when test='sortValue !=null and sortValue != ""'>	
									<if test='sortValue == "DESC" and colName !=null'>
									ORDER BY #{colName} DESC
									</if>
									<if test='sortValue == "ASC" and colName !=null'>
									ORDER BY #{colName} ASC
									</if>	
								</when>	
								<otherwise>
									ORDER BY FIELD1 ASC
								</otherwise>
							</choose>
							
			#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>

	<select id="selectTWorkMstIcutCount" resultType="java.lang.Integer">
		SELECT COUNT(1)
	  	  FROM TWORK_MST_ICUT A
	  	  INNER JOIN TWORK_MST_ICUTXTYPE B
	  	  		  ON A.CTKEY = B.CTKEY
				 AND A.OWKEY = B.OWKEY
				 AND A.ICUTKEY = B.ICUTKEY
		 WHERE 
		       A.CTKEY = #{ctkey}
		   AND A.CLOSDATE >= #{sysdate}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)" >
		   AND A.OWKEY = #{owkey}
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
		   AND (A.ICUTKEY LIKE '%' || #{value} || '%' OR A.CLOSDATE LIKE '%' || #{value} || '%')
		</if>
	</select>

	<select id="selectTWorkMstIcut" resultMap="selectCommonCode">
    	#{GRIDPAGING_ROWNUMTYPE_TOP}
    	
			SELECT B.* 
	   		  FROM (
				SELECT A.ICUTKEY AS FIELD1
					   ,B.ICUTTYPE AS FIELD2
					   ,A.CTKEY ||  ';' ||'ICUTTYPE' || ';' || B.ICUTTYPE AS FIELD2_DESC
					   ,B.ICUTQTY AS FIELD3
					   ,A.OWKEY AS FIELD4
			  	  FROM TWORK_MST_ICUT A
			      INNER JOIN TWORK_MST_ICUTXTYPE B
			  	  		  ON A.CTKEY = B.CTKEY
						 AND A.ICUTKEY = B.ICUTKEY
						 AND A.OWKEY = B.OWKEY
				WHERE
			       	   A.CTKEY = #{ctkey}
			       AND A.CLOSDATE >= #{sysdate}
			  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)" >
			       AND A.OWKEY = #{owkey}
			    </if>
			    <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
				   AND (A.ICUTKEY LIKE '%' || #{value} || '%' OR A.CLOSDATE LIKE '%' || #{value} || '%')
			    </if>
			)B
			<choose>
				<when test='sortValue !=null and sortValue != ""'>	
					<if test='sortValue == "DESC" and colName !=null'>
					ORDER BY #{colName} DESC
					</if>
					<if test='sortValue == "ASC" and colName !=null'>
					ORDER BY #{colName} ASC
					</if>	
				</when>	
				<otherwise>
					ORDER BY FIELD1 ASC
				</otherwise>
			</choose>       
			
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>
 
	<select id="selectTWorkMstIcCount" resultType="java.lang.Integer" >
		SELECT  COUNT(1)
		  FROM  TWORK_MST_IC
		 WHERE
		 	    CTKEY = #{ctkey}
		   AND  CLOSDATE >= #{sysdate}
		   AND  DELYN = 'N'
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)" >
		   AND  OWKEY = #{owkey}
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ackey)" >
		   AND  ACKEY = #{ackey}
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(loggrpcd)" >
		   AND  LOGGRPCD = #{loggrpcd}
		</if>
		<if test="OWKEY_SELECTION_VALUE != null and OWKEY_SELECTION_VALUE != ''" >
		   AND 	OWKEY IN 
			<foreach item="OWKEY_SELECTION_VALUE" index="index" collection="OWKEY_SELECTION_VALUE" open="(" separator="," close=")">
				#{OWKEY_SELECTION_VALUE}
			</foreach>
		</if>
		<if test="OWKEY_AUTH_LIST != null and OWKEY_AUTH_LIST.size > 0" >
		   AND 	OWKEY IN 
			<foreach item="OWKEY_AUTH_LIST" index="index" collection="OWKEY_AUTH_LIST" open="(" separator="," close=")">
				#{OWKEY_AUTH_LIST}
			</foreach>
		</if>	
		<if test="LOGGRPCD_SELECTION_VALUE != null and LOGGRPCD_SELECTION_VALUE != ''" >
		   AND  LOGGRPCD IN 
			<foreach item="LOGGRPCD_SELECTION_VALUE" index="loggrpcdIdx" collection="LOGGRPCD_SELECTION_VALUE" open="(" separator="," close=")">
				#{LOGGRPCD_SELECTION_VALUE}
			</foreach>
		</if>		   
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
			<choose>
		        <when test='opval !=null and opval.equals("eq")'>
		            AND ICKEY = #{value}
		        </when>
	        	<otherwise>
		   			AND  (ICKEY LIKE '%' || #{value} || '%' OR ICNAME LIKE '%' || #{value} || '%' OR OWKEY LIKE '%' || #{value} || '%')
		   		</otherwise>
		   	</choose>
		</if>
	</select>
	
	<select id="selectTWorkMstIc" resultMap="selectCommonCode">
	<if test="type != 'combo'">
	#{GRIDPAGING_ROWNUMTYPE_TOP}
	</if>			
		SELECT	* 
		  FROM	(
			 SELECT  A.ICKEY AS FIELD1
					 ,(A.ICNAME || ' [' || (
									SELECT CTCD_DTNAME
									  FROM TWORK_MST_CTCD_DT 
									 WHERE 
									       CTCD_HDKEY = 'ORDTYPE'
									   AND LAKEY = 'KOR'
									   AND CTKEY = #{ctkey}
									   AND CTCD_DTKEY = A.ORDTYPE					
					) || ']' ) 	AS FIELD2 		
					,A.OWKEY 		AS FIELD3
					,A.ICUTKEY 	AS FIELD4
					,A.UOM 		AS FIELD5
					,COALESCE(A.COSTPRICE, 0) 	AS FIELD6
					,COALESCE(A.SALEPRICE, 0) 	AS FIELD7
					,A.LOGGRPCD 	AS FIELD8
					,A.SPEC	 	AS FIELD9
					,A.ICGRKEY    AS FIELD10
					,A.CTKEY ||';'|| 'ICUTTYPE' ||';'|| A.UOM AS FIELD5_DESC
					,A.CTKEY ||';'|| 'LOGGRPCD' ||';'|| A.LOGGRPCD AS FIELD8_DESC
					,(SELECT ICGRNAME FROM TWORK_MST_ICGR WHERE CTKEY = #{ctkey} AND OWKEY = A.OWKEY AND ICGRKEY = A.ICGRKEY AND ICGRTYPE = A.ICGRTYPE) AS FIELD11
			  FROM 	TWORK_MST_IC A
			 WHERE
					CTKEY = #{ctkey}
			   AND 	CLOSDATE >= #{sysdate}
			   AND 	DELYN = 'N'
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)" >
			   AND 	OWKEY = #{owkey}
			</if>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ackey)" >
			   AND  ACKEY = #{ackey}
			</if>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(loggrpcd)" >
		   	   AND  LOGGRPCD = #{loggrpcd}
		    </if>
			<if test="OWKEY_SELECTION_VALUE != null and OWKEY_SELECTION_VALUE != ''" >
			   AND 	OWKEY IN 
				<foreach item="OWKEY_SELECTION_VALUE" index="index" collection="OWKEY_SELECTION_VALUE" open="(" separator="," close=")">
					#{OWKEY_SELECTION_VALUE}
				</foreach>
			</if>
			<if test="OWKEY_AUTH_LIST != null and OWKEY_AUTH_LIST.size > 0" >
			   AND 	OWKEY IN 
				<foreach item="OWKEY_AUTH_LIST" index="index" collection="OWKEY_AUTH_LIST"
					open="(" separator="," close=")">
					#{OWKEY_AUTH_LIST}
				</foreach>
			</if>
			<if test="LOGGRPCD_SELECTION_VALUE != null and LOGGRPCD_SELECTION_VALUE != ''" >
			   AND 	LOGGRPCD IN 
				<foreach item="LOGGRPCD_SELECTION_VALUE" index="loggrpcdIdx" collection="LOGGRPCD_SELECTION_VALUE" open="(" separator="," close=")">
					#{LOGGRPCD_SELECTION_VALUE}
				</foreach>
			</if>
			<if test="ickey != null ">
			   AND 	ICKEY = #{ickey}
			</if>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
				<choose>
			        <when test='opval !=null and opval.equals("eq")'>
			            AND ICKEY = #{value}
			        </when>
		        	<otherwise>
			   			AND	(ICKEY LIKE '%' || #{value} || '%' OR ICNAME LIKE '%' || #{value} || '%' OR OWKEY LIKE '%' || #{value} || '%')
			   		</otherwise>
			   	</choose>
			</if>     
		)
		<choose>
			<when test='sortValue !=null and sortValue != ""'>	
				<if test='sortValue == "DESC" and colName !=null'>
				ORDER BY #{colName} DESC
				</if>
				<if test='sortValue == "ASC" and colName !=null'>
				ORDER BY #{colName} ASC
				</if>	
			</when>	
			<otherwise>
				ORDER BY FIELD1 ASC
			</otherwise>
		</choose>
	<if test="type != 'combo'">
	#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</if>						  
	</select>
	
