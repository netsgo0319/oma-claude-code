	<select id="selectTWorkMstAcForRepCount" resultType="java.lang.Integer" >
		SELECT  COUNT(1)
		FROM  ( 
				      SELECT B.* 
		  FROM (
			SELECT  B.ACKEY AS FIELD1 
			       ,B.ACNAME AS FIELD2
			       ,B.ACTYPE AS FIELD3
			       ,#{ctkey} || ';' || 'ACTYPE' || ';' || B.ACTYPE AS FIELD3_DESC
			 FROM  ( 
				      SELECT REP_ACKEY AS ACKEY
				      		,OWKEY 
				      		,CTKEY 
		                FROM TWORK_MST_AC
		            GROUP BY REP_ACKEY
		            		,OWKEY
		            		,CTKEY
	               ) A
	         INNER JOIN  TWORK_MST_AC B
			 		 ON A.CTKEY = B.CTKEY
					AND A.OWKEY = B.OWKEY
					AND A.ACKEY = B.ACKEY
        	 WHERE A.CTKEY = #{ctkey}
			   AND DELYN = 'N' 
			   AND CLOSDATE >= #{sysdate}
			 <if test="owkey != null">
			   AND A.OWKEY = #{owkey}
		  	</if> 
			<if test="OWKEY_SELECTION_VALUE != null and OWKEY_SELECTION_VALUE != ''" >
			   AND A.OWKEY IN 
				<foreach item="OWKEY_SELECTION_VALUE" index="index" collection="OWKEY_SELECTION_VALUE" open="(" separator="," close=")">
					#{OWKEY_SELECTION_VALUE}
				</foreach>
			</if>		  	
		  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
			  	AND (B.ACKEY LIKE '%' || #{value} || '%' OR B.ACNAME LIKE '%' || #{value} || '%')
			</if>
			)B
		)
	</select>
	
	<select id="selectTworkMstAcForRep" resultMap="selectCommonCode">
    <if test="type != 'combo'">
	#{GRIDPAGING_ROWNUMTYPE_TOP}
    </if>
		SELECT B.* 
		  FROM (
			SELECT  B.ACKEY AS FIELD1 
			       ,B.ACNAME AS FIELD2
			       ,B.ACTYPE AS FIELD3
			       ,#{ctkey} || ';' || 'ACTYPE' || ';' || B.ACTYPE AS FIELD3_DESC
			 FROM  ( 
				      SELECT REP_ACKEY AS ACKEY
				      		,OWKEY  
				      		,CTKEY
		                FROM TWORK_MST_AC
		            GROUP BY REP_ACKEY
		            		,OWKEY
		            		,CTKEY
	               ) A
	          INNER JOIN TWORK_MST_AC B
			 		  ON A.CTKEY = B.CTKEY
					 AND A.OWKEY = B.OWKEY
					 AND A.ACKEY = B.ACKEY
        	 WHERE  A.CTKEY = #{ctkey}
			   AND CLOSDATE >= #{sysdate}
			   AND DELYN = 'N'
			 <if test="owkey != null">
			   AND A.OWKEY = #{owkey}
		  	</if> 
			<if test="OWKEY_SELECTION_VALUE != null and OWKEY_SELECTION_VALUE != ''" >
			   AND A.OWKEY IN 
				<foreach item="OWKEY_SELECTION_VALUE" index="index" collection="OWKEY_SELECTION_VALUE" open="(" separator="," close=")">
					#{OWKEY_SELECTION_VALUE}
				</foreach>
			</if>		  	
		  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
			  	AND (B.ACKEY LIKE '%' || #{value} || '%' OR B.ACNAME LIKE '%' || #{value} || '%')
			</if>
		)B
	     <choose>
			<when test='sortValue !=null and sortValue != ""'>	
				<if test='sortValue == "DESC" and colName !=null'>
				ORDER BY #{colName} DESC
				</if>
				<if test='sortValue == "ASC" and colName !=null'>
				ORDER BY #{colName} ASC
				</if>	
			</when>	
			<otherwise>
				ORDER BY FIELD1 ASC
			</otherwise>
		</choose>
    <if test="type != 'combo'">            
	#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
    </if>				 
	</select>
	
	
	<select id="selectTWorkMstToLcCount" resultType="java.lang.Integer">	
		SELECT COUNT(1) 
		  FROM TWORK_MST_AR A
		  INNER JOIN TWORK_MST_LC B
		  		  ON A.CTKEY = B.CTKEY
				 AND A.ARKEY = B.ARKEY
		 WHERE    A.WRHOUS_SE = 'GNRL'
 			  AND A.BONDTYPE = '1'
 			  AND B.LCKEY NOT LIKE 'PICK%'		 	  
		      AND A.CTKEY = #{ctkey}
		  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
		  	AND (B.LCKEY LIKE '%' || #{value} || '%' OR B.LCTYPE LIKE '%' || #{value} || '%' OR B.LCHOLDTYPE  LIKE '%' || #{value} || '%')
		  </if>
	</select>
	
