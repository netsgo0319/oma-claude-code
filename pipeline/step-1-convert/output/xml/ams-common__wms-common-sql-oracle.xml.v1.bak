		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(lcstortype)" >
		   AND LCSTORTYPE = #{lcstortype}       
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(autoflag)">
			<choose>
				<when test="autoflag == 'auto'">
				AND LCSTORTYPE IN ('40', '50')
				</when>
				<otherwise>
				AND LCSTORTYPE NOT IN ('40', '50')
				</otherwise>
			</choose>
		</if>
	</select>
	
	<select id="selectTWorkMstLc" resultMap="selectCommonCode">
		#{GRIDPAGING_ROWNUMTYPE_TOP}
		SELECT 	*
		  FROM	(
			SELECT	A.LCKEY AS FIELD1 
			     	,A.LCTYPE AS FIELD2
			     	,A.LCHOLDTYPE AS FIELD3
			     	,A.ERPSTLC AS FIELD4
			     	,A.ARKEY AS FIELD5
			     	,B.EMPTYLOCATION_YN AS FIELD6
			     	,A.CTKEY ||';'|| 'LCTYPE' ||';'|| A.LCTYPE AS FIELD2_DESC
			     	,A.CTKEY ||';'|| 'LCHOLDTYPE' ||';'|| A.LCHOLDTYPE AS FIELD3_DESC
			     	,A.CTKEY || ';' || 'ERPSTLC' ||';'|| A.ERPSTLC AS FIELD4_DESC	
			     	,A.CTKEY || ';' || 'YESORNO' ||';'|| B.EMPTYLOCATION_YN AS FIELD6_DESC
			  FROM 	TWORK_MST_LC A
			  INNER JOIN (
		                SELECT
		                    A.CTKEY,
		                    A.LCKEY,
		                    CASE WHEN SUM(COALESCE(B.TTQTY, 0)) > 0 THEN 'N'
		                        ELSE 'Y'
		                    END AS EMPTYLOCATION_YN
		                FROM
		                    TWORK_MST_LC A
		                LEFT OUTER JOIN TWORK_INFO_IVATXLCXULC B
		                			 ON A.CTKEY = B.CTKEY
									AND   A.LCKEY = B.LCKEY
		                WHERE A.CTKEY = #{ctkey}
		                GROUP BY
		                    A.CTKEY,
		                    A.LCKEY
		             ) B ON A.CTKEY = B.CTKEY
			  			AND A.LCKEY = B.LCKEY
			 WHERE 
			       	A.CTKEY = #{ctkey}
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
				<choose>
			        <when test='opval !=null and opval.equals("eq")'>
			            AND A.LCKEY = #{value}
			        </when>
		        	<otherwise>
					   AND 	(A.LCKEY LIKE '%' || #{value} || '%' OR A.LCTYPE LIKE '%' || #{value} || '%' OR A.LCHOLDTYPE LIKE '%' || #{value} || '%' 
							OR A.ARKEY LIKE '%' || #{value} || '%' 
							OR A.ERPSTLC LIKE '%' || #{value} || '%'
							)
			   		</otherwise>
			   	</choose>
			</if>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(arkey)" >
			   AND A.ARKEY = #{arkey}       
			</if>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(erpstlc)" >
			   AND A.ERPSTLC = #{erpstlc}       
			</if>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(lcstortype)" >
		   		AND A.LCSTORTYPE = #{lcstortype}       
			</if>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(autoflag)">
				<choose>
					<when test="autoflag == 'auto'">
					AND A.LCSTORTYPE IN ('40', '50')
					</when>
					<otherwise>
					AND A.LCSTORTYPE NOT IN ('40', '50')
					</otherwise>
				</choose>
			</if>
        )
		<choose>
			<when test='sortValue !=null and sortValue != ""'>	
				<if test='sortValue == "DESC" and colName !=null'>
				ORDER BY #{colName} DESC
				</if>
				<if test='sortValue == "ASC" and colName !=null'>
				ORDER BY #{colName} ASC
				</if>	
			</when>	
			<otherwise>
				ORDER BY FIELD1 ASC
			</otherwise>
		</choose>
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>

