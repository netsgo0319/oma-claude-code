	<select id="selectIcXIcuttypeXQtyCount" resultType="java.lang.Integer" >
		SELECT 	/* hint: ORDERED */
				COUNT(1)
		  FROM 	TWORK_MST_IC A
		  INNER JOIN TWORK_MST_ICUT B
		      	  ON A.CTKEY = B.CTKEY
				 AND A.OWKEY = B.OWKEY
				 AND A.ICUTKEY = B.ICUTKEY
		  INNER JOIN TWORK_MST_ICUTXTYPE C
				  ON B.CTKEY = C.CTKEY
				 AND B.OWKEY = C.OWKEY
				 AND B.ICUTKEY = C.ICUTKEY
		 WHERE 
				A.CTKEY = #{ctkey}
		 <if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)" >
		   AND 	A.OWKEY = #{owkey}
		 </if>
		 <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ackey)" >
			   AND 	A.ACKEY = #{ackey}
			 </if>
		   <if test="OWKEY_SELECTION_VALUE != null and OWKEY_SELECTION_VALUE != ''" >
			  AND A.OWKEY IN 
				<foreach item="OWKEY_SELECTION_VALUE" index="index" collection="OWKEY_SELECTION_VALUE" open="(" separator="," close=")">
					#{OWKEY_SELECTION_VALUE}
				</foreach>
		   </if>
			<if test="LOGGRPCD_SELECTION_VALUE != null and LOGGRPCD_SELECTION_VALUE != ''" >
				AND A.LOGGRPCD IN 
				<foreach item="LOGGRPCD_SELECTION_VALUE" index="loggrpcdIdx" collection="LOGGRPCD_SELECTION_VALUE" open="(" separator="," close=")">
					#{LOGGRPCD_SELECTION_VALUE}
				</foreach>
			</if>		   
			<if test="OWKEY_AUTH_LIST != null and OWKEY_AUTH_LIST.size > 0" >
				AND A.OWKEY IN 
				<foreach item="OWKEY_AUTH_LIST" index="index" collection="OWKEY_AUTH_LIST" open="(" separator="," close=")">
					#{OWKEY_AUTH_LIST}
				</foreach>
			</if>				    	
		 <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
		   AND 	(
			A.ICKEY LIKE '%' || #{value} || '%' 
			OR A.ICNAME  LIKE '%'|| #{value} || '%'
			OR C.ICUTKEY  LIKE '%'|| #{value} || '%'
			OR C.ICUTTYPE   LIKE '%'|| #{value} || '%'
			OR C.ICUTQTY  LIKE '%'|| #{value} || '%'
			OR A.LOGGRPCD  LIKE '%'|| #{value} || '%'
			OR A.OWKEY  LIKE '%'|| #{value} || '%'
		   )
		 </if>
	</select>
	
	<select id="selectIcXIcuttypeXQty" resultMap="selectCommonCode">		
    #{GRIDPAGING_ROWNUMTYPE_TOP}
		SELECT 	*
		  FROM 	(
			SELECT 	/* hint: ORDERED */
					A.ICKEY AS FIELD1
					,A.ICNAME AS FIELD2
					,C.ICUTKEY AS FIELD3
					,C.ICUTTYPE  AS FIELD4
					,A.CTKEY ||  ';' ||'ICUTTYPE' || ';' || C.ICUTTYPE AS FIELD4_DESC
					,C.ICUTQTY AS FIELD5
					,A.LOGGRPCD  AS FIELD6
					,A.CTKEY ||  ';' ||'LOGGRPCD' || ';' || A.LOGGRPCD AS FIELD6_DESC
					,A.OWKEY    AS FIELD7
					,A.ACKEY    AS FIELD8
					,A.ICGRKEY  AS FIELD9
					,A.ICGRTYPE AS FIELD10
			  FROM 	TWORK_MST_IC A
			  INNER JOIN TWORK_MST_ICUT B
			      	  ON A.CTKEY = B.CTKEY
					 AND A.OWKEY = B.OWKEY
					 AND A.ICUTKEY = B.ICUTKEY
			  INNER JOIN TWORK_MST_ICUTXTYPE C
			  	  	  ON B.CTKEY = C.CTKEY
					 AND B.OWKEY = C.OWKEY
					 AND B.ICUTKEY = C.ICUTKEY
			 WHERE 
					A.CTKEY = #{ctkey}
			 <if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)" >
			   AND 	A.OWKEY = #{owkey}
			 </if>
			 <if test="@com.kns.framework.util.StringUtil@isNotEmpty(ackey)" >
			   AND 	A.ACKEY = #{ackey}
			 </if>
		   <if test="OWKEY_SELECTION_VALUE != null and OWKEY_SELECTION_VALUE != ''" >
			  AND A.OWKEY IN 
				<foreach item="OWKEY_SELECTION_VALUE" index="index" collection="OWKEY_SELECTION_VALUE" open="(" separator="," close=")">
					#{OWKEY_SELECTION_VALUE}
				</foreach>
		   </if>
			<if test="LOGGRPCD_SELECTION_VALUE != null and LOGGRPCD_SELECTION_VALUE != ''" >
				AND A.LOGGRPCD IN 
				<foreach item="LOGGRPCD_SELECTION_VALUE" index="loggrpcdIdx" collection="LOGGRPCD_SELECTION_VALUE" open="(" separator="," close=")">
					#{LOGGRPCD_SELECTION_VALUE}
				</foreach>
			</if>		   
			<if test="OWKEY_AUTH_LIST != null and OWKEY_AUTH_LIST.size > 0" >
				AND A.OWKEY IN 
				<foreach item="OWKEY_AUTH_LIST" index="index" collection="OWKEY_AUTH_LIST" open="(" separator="," close=")">
					#{OWKEY_AUTH_LIST}
				</foreach>
			</if>				    	
			 <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
			   AND 	(
				A.ICKEY LIKE '%' || #{value} || '%' 
				OR A.ICNAME  LIKE '%'|| #{value} || '%'
				OR C.ICUTKEY  LIKE '%'|| #{value} || '%'
				OR C.ICUTTYPE   LIKE '%'|| #{value} || '%'
				OR C.ICUTQTY  LIKE '%'|| #{value} || '%'
				OR A.LOGGRPCD  LIKE '%'|| #{value} || '%'
				OR A.OWKEY  LIKE '%'|| #{value} || '%'
			   )
			 </if>
		)
		<choose>
			<when test='sortValue !=null and sortValue != ""'>	
				<if test='sortValue == "DESC" and colName !=null'>
				ORDER BY #{colName} DESC
				</if>
				<if test='sortValue == "ASC" and colName !=null'>
				ORDER BY #{colName} ASC
				</if>	
			</when>	
			<otherwise>
				ORDER BY FIELD1 ASC
			</otherwise>
		</choose>						               
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>


	<resultMap id="selectCommonCodeAcxUr" type="java.util.HashMap">
		<result property="field1" column="FIELD1"/>
		<result property="field1_desc" column="FIELD1_DESC" typeHandler="UrMstDescTypeHandler"/>
		<result property="field2" column="FIELD2" />
		<result property="field3" column="FIELD3" />
		<result property="field4" column="FIELD4" />
		<result property="field5" column="FIELD5" />
		<result property="field6" column="FIELD6" />
		<result property="field7" column="FIELD7" />
	</resultMap>

	<sql id="selectTWorkMstAcXUrCommonCdRefSql">
		SELECT 	A.URKEY AS FIELD1
		 		,A.URKEY AS FIELD1_DESC                  
				,A.ACKEY AS FIELD2
				,B.ACNAME AS FIELD3
				,A.ICGRKEY AS FIELD4
				,A.ICGRTYPE AS FIELD5
				,C.ICGRNAME AS FIELD6
          FROM 	TWORK_MST_ACXUR A 
          INNER JOIN TWORK_MST_AC B
             	  ON A.CTKEY = B.CTKEY
				 AND A.ACKEY = B.ACKEY
				 AND A.OWKEY = B.OWKEY
        LEFT OUTER JOIN TWORK_MST_ICGR C
             		 ON A.CTKEY = C.CTKEY
					AND A.OWKEY = C.OWKEY
					AND A.ICGRKEY = C.ICGRKEY
					AND A.ICGRTYPE = C.ICGRTYPE
         INNER JOIN TADMIN_MST_UR D
          		 ON A.URKEY = D.URKEY
         WHERE A.CTKEY = #{ctkey}
		<if test="LOGGRPCD_SELECTION_VALUE != null and LOGGRPCD_SELECTION_VALUE != ''" >
			AND A.LOGGRPCD IN 
			<foreach item="LOGGRPCD_SELECTION_VALUE" index="loggrpcdIdx" collection="LOGGRPCD_SELECTION_VALUE" open="(" separator="," close=")">
				#{LOGGRPCD_SELECTION_VALUE}
			</foreach>
		</if>	   	
	 <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
	   	   AND 	(
			A.URKEY LIKE '%' || #{value} || '%'
		    OR A.ACKEY LIKE '%'|| #{value} || '%'    
			OR B.ACNAME LIKE '%'|| #{value} || '%'
			OR A.ICGRKEY LIKE '%'|| #{value} || '%'
			OR A.ICGRTYPE  LIKE '%'|| #{value} || '%'
			OR C.ICGRNAME  LIKE '%'|| #{value} || '%'
			OR D.URNM  LIKE '%'|| #{value} || '%'
	   		)
	 </if>
	</sql>

	<select id="selectTWorkMstAcXUrCommonCdCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
		  FROM (
			<include refid="selectTWorkMstAcXUrCommonCdRefSql"/>
		  )
	</select>


	<select id="selectTWorkMstAcXUrCommonCd" resultMap="selectCommonCodeAcxUr">
	    #{GRIDPAGING_ROWNUMTYPE_TOP}
	    	SELECT *
	    	  FROM (	
	    	  	<include refid="selectTWorkMstAcXUrCommonCdRefSql"/>
