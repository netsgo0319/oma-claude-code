		<result property="field3" column="FIELD3" />
		<result property="field4" column="FIELD4" />
		<result property="field5" column="FIELD5" />
		<result property="field6" column="FIELD6" />
		<result property="field7" column="FIELD7" />
		<result property="field8" column="FIELD8" />
		<result property="field9" column="FIELD9" />
		<result property="field10" column="FIELD10" />
		<result property="field11" column="FIELD11" />
		<result property="field12" column="FIELD12" />
		<result property="field13" column="FIELD13" />
		<result property="field14" column="FIELD14" />
		<result property="field15" column="FIELD15" />
		<result property="field16" column="FIELD16" />
		<result property="field17" column="FIELD17" />
		<result property="field18" column="FIELD18" />
		<result property="field19" column="FIELD19" />
		<result property="field20" column="FIELD20" />
		<result property="field1_desc" column="FIELD1_DESC" typeHandler="WmsCodeDescTypeHandler"/>
		<result property="field2_desc" column="FIELD2_DESC" typeHandler="WmsCodeDescTypeHandler"/>
		<result property="field3_desc" column="FIELD3_DESC" typeHandler="WmsCodeDescTypeHandler"/>
		<result property="field4_desc" column="FIELD4_DESC" typeHandler="WmsCodeDescTypeHandler"/>
		<result property="field5_desc" column="FIELD5_DESC" typeHandler="WmsCodeDescTypeHandler"/>
		<result property="field6_desc" column="FIELD6_DESC" typeHandler="WmsCodeDescTypeHandler"/>
		<result property="field7_desc" column="FIELD7_DESC" typeHandler="WmsCodeDescTypeHandler"/>
		<result property="field8_desc" column="FIELD8_DESC" typeHandler="WmsCodeDescTypeHandler"/>
		<result property="field9_desc" column="FIELD9_DESC" typeHandler="WmsCodeDescTypeHandler"/>
		<result property="field10_desc" column="FIELD10_DESC" typeHandler="WmsCodeDescTypeHandler"/>
		<result property="field11_desc" column="FIELD11_DESC" typeHandler="WmsCodeDescTypeHandler"/>
		<result property="field12_desc" column="FIELD12_DESC" typeHandler="WmsCodeDescTypeHandler"/>
		<result property="field13_desc" column="FIELD13_DESC" typeHandler="WmsCodeDescTypeHandler"/>
