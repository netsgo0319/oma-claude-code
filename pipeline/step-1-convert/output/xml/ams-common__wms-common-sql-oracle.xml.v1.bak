		SELECT COUNT(1) 
		  FROM TWORK_MST_AR A
		  INNER JOIN TWORK_MST_LC B
		  		  ON A.CTKEY = B.CTKEY
				 AND A.ARKEY = B.ARKEY
		WHERE  A.CTKEY = #{ctkey}
