		  FROM TWORK_MST_AR A
		  INNER JOIN TWORK_MST_LC B
		  		  ON A.CTKEY = B.CTKEY
				 AND A.ARKEY = B.ARKEY
		WHERE A.WRHOUS_SE = 'GNRL'
