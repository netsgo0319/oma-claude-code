	<select id="selectTWorkMstLcCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
		  FROM TWORK_MST_LC
		 WHERE 
		       	CTKEY = #{ctkey}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
			<choose>
		        <when test='opval !=null and opval.equals("eq")'>
		            AND LCKEY = #{value}
		        </when>
	        	<otherwise>
				   AND 	(LCKEY LIKE '%' || #{value} || '%' OR LCTYPE LIKE '%' || #{value} || '%' OR LCHOLDTYPE LIKE '%' || #{value} || '%' 
						OR ARKEY LIKE '%' || #{value} || '%' 
						OR ERPSTLC LIKE '%' || #{value} || '%'
						)
		   		</otherwise>
		   	</choose>
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(arkey)" >
		   AND ARKEY = #{arkey}       
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(erpstlc)" >
