	<resultMap id="selectAppMessageMap" type="java.util.HashMap" >
		<result property="mulaapmsg_hdkey" column="MULAAPMSG_HDKEY" />
		<result property="displaymessage" column="DISPLAYMESSAGE" />
	</resultMap>

	<resultMap id="selectSystemConfigListMap" type="java.util.HashMap" >
		<result property="key" 			column="CTCSKEY" />
		<result property="name" 		column="CTCSNAME" />
		<result property="value1"		column="VALUE1" />
		<result property="value2"		column="VALUE2" />
		<result property="defaultvalue" column="DEFAULTVALUE" />
	</resultMap>

	<select id="selectWmsConfigList" resultMap="selectSystemConfigListMap">
		 SELECT 
		       CTCSKEY 
		      ,CTCSNAME
		      ,VALUE1
		      ,VALUE2
		      ,DEFAULTVALUE 
		   FROM TWORK_SET_CTCS	
		  WHERE
		  		CTKEY = #{ctkey}
	</select>		

	<select id="selectTWorkMstCtcdDtCount" resultType="java.lang.Integer">
		SELECT
				COUNT(1) 
		  FROM TWORK_MST_CTCD_HD A 
		  INNER JOIN TWORK_MST_CTCD_DT B
		  		  ON A.CTKEY = B.CTKEY
		  		 AND A.CTCD_HDKEY = B.CTCD_HDKEY
		 WHERE A.CTKEY = #{ctkey}
		  AND B.LAKEY = #{lakey}
		  AND A.CTCD_HDKEY = #{ctcd_hdkey}
		  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
			<choose>
		        <when test='opval !=null and opval.equals("eq")'>
		            AND B.CTCD_DTKEY = #{value}
		        </when>
	        	<otherwise>
		   			AND (B.CTCD_DTVALUE LIKE '%' || #{value} || '%' OR B.CTCD_DTNAME LIKE '%' || #{value} || '%' OR B.CTCD_DTKEY LIKE '%' || #{value} || '%')
		   		</otherwise>
		   	</choose>
		  </if>
		  
	</select>
	
	<select id="selectTWorkMstCtcdDt" resultMap="selectCommonCode">
					<if test="type != 'combo'">
						#{GRIDPAGING_ROWNUMTYPE_TOP}
				    </if>			
	                      SELECT B.* 
							FROM(
								SELECT 
								     B.CTCD_DTKEY AS FIELD1 
								    ,B.CTCD_DTNAME AS FIELD2 
								    ,B.CTCD_DTVALUE AS FIELD3
								    ,B.COMMENTS AS FIELD4
								    ,B.CTCD_DTORDER AS CTCD_DTORDER      
								  FROM TWORK_MST_CTCD_HD A 
								  INNER JOIN TWORK_MST_CTCD_DT B
								  		  ON A.CTKEY = B.CTKEY
								  		 AND A.CTCD_HDKEY = B.CTCD_HDKEY
								 WHERE A.CTKEY = #{ctkey}
								  AND B.LAKEY = #{lakey}
								  AND A.CTCD_HDKEY = #{ctcd_hdkey}
								  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
									<choose>
								        <when test='opval !=null and opval.equals("eq")'>
								            AND B.CTCD_DTKEY = #{value}
								        </when>
							        	<otherwise>
								   			AND (B.CTCD_DTVALUE LIKE '%' || #{value} || '%' OR B.CTCD_DTNAME LIKE '%' || #{value} || '%' OR B.CTCD_DTKEY LIKE '%' || #{value} || '%')
								   		</otherwise>
								   	</choose>
								  </if>
				      			)B
							<choose>
								<when test='sortValue !=null and sortValue != ""'>	
									<if test='sortValue == "DESC" and colName !=null'>
									ORDER BY #{colName} DESC
									</if>
									<if test='sortValue == "ASC" and colName !=null'>
									ORDER BY #{colName} ASC
									</if>	
								</when>	
								<otherwise>
									ORDER BY CTCD_DTORDER ASC
								</otherwise>
							</choose>				      
				      						  
					<if test="type != 'combo'">
						#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
				    </if>
	</select>
	
	<select id="selectTWorkMstCtcdDtMobileCount" resultType="java.lang.Integer">
		SELECT  COUNT(1) 
		  FROM  TWORK_MST_CTCD_HD A 
		  INNER JOIN TWORK_MST_CTCD_DT B
		  		  ON A.CTKEY = B.CTKEY
		  		 AND A.CTCD_HDKEY = B.CTCD_HDKEY
		 WHERE  A.CTKEY = #{ctkey}
		   AND 	A.CTCD_HDKEY = #{ctcd_hdkey}
		   AND 	B.LAKEY = #{lakey}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
		   AND	(B.CTCD_DTNAME LIKE '%' || #{value} || '%' OR B.CTCD_DTKEY LIKE '%' || #{value} || '%')
		</if>
	</select>
	
	<select id="selectTWorkMstCtcdDtMobile" resultMap="selectCommonCode">
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_TOP} </if>
	    				SELECT	B.* 
						  FROM(						  
								SELECT 
								     B.CTCD_DTKEY AS FIELD1 
								    ,B.CTCD_DTNAME AS FIELD2 
								    ,B.COMMENTS AS FIELD3      
								  FROM TWORK_MST_CTCD_HD A 
								  INNER JOIN TWORK_MST_CTCD_DT B
								  		  ON A.CTKEY = B.CTKEY
		  		 						 AND A.CTCD_HDKEY = B.CTCD_HDKEY
								 WHERE A.CTKEY = #{ctkey}
								  AND A.CTCD_HDKEY = #{ctcd_hdkey}
								  AND B.LAKEY = #{lakey}
								  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
								  	AND (B.CTCD_DTNAME LIKE '%' || #{value} || '%' OR B.CTCD_DTKEY LIKE '%' || #{value} || '%')
								  </if>
								)B
					 		<choose>
								<when test='sortValue !=null and sortValue != ""'>	
									<if test='sortValue == "DESC" and colName !=null'>
									ORDER BY #{colName} DESC
									</if>
									<if test='sortValue == "ASC" and colName !=null'>
									ORDER BY #{colName} ASC
									</if>	
								</when>	
								<otherwise>
									ORDER BY FIELD1 ASC
								</otherwise>
							</choose>
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_BOTTOM} </if>
	</select>
	
	<select id="selectTWorkMstCtcdCstDtCount" resultType="java.lang.Integer">	
		SELECT COUNT(1) 
		  FROM TWORK_MST_CTCD_DT
		 WHERE
		      LAKEY = #{lakey}
		  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
		  	AND (CTCD_HDKEY LIKE '%' || #{value} || '%' OR CTCD_DTVALUE LIKE '%' || #{value} || '%' OR CTCD_DTNAME LIKE '%' || #{value} || '%' OR CTCD_DTKEY LIKE '%' || #{value} || '%')
		  </if>
		  <if test='ctkey != null'>
		  	AND CTKEY = #{ctkey}
		  </if>
		  <if test='ctcd_hdkey != null'>
		  	AND CTCD_HDKEY = #{ctcd_hdkey}
		  </if>
	</select>
	
	<select id="selectTWorkMstCtcdCstDt" resultMap="selectCommonCode">
		<if test="type != 'combo'">
			#{GRIDPAGING_ROWNUMTYPE_TOP}
	    </if>
						SELECT B.* 
						  FROM(	
								SELECT
									CTCD_HDKEY AS FIELD1 
								   ,CTCD_DTKEY AS FIELD2 
								   ,CTCD_DTNAME AS FIELD3 
								   ,CTCD_DTVALUE AS FIELD4      
								  FROM  
								      TWORK_MST_CTCD_DT
								  WHERE
									  LAKEY = #{lakey}
									  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
									  	AND (CTCD_HDKEY LIKE '%' || #{value} || '%' OR CTCD_DTKEY LIKE '%' || #{value} || '%' OR CTCD_DTNAME LIKE '%' || #{value} || '%' OR CTCD_DTVALUE LIKE '%' || #{value} || '%')
									  </if>
									  <if test='ctkey != null'>
									  	AND CTKEY = #{ctkey}
									  </if>
									  <if test='ctcd_hdkey != null'>
									  	AND CTCD_HDKEY = #{ctcd_hdkey}
									  </if>
								)B
								<choose>
									<when test='sortValue !=null and sortValue != ""'>	
										<if test='sortValue == "DESC" and colName !=null'>
										ORDER BY #{colName} DESC
										</if>
										<if test='sortValue == "ASC" and colName !=null'>
										ORDER BY #{colName} ASC
										</if>	
									</when>	
									<otherwise>
										ORDER BY FIELD2 ASC
									</otherwise>
								</choose>
		<if test="type != 'combo'">             
			#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	    </if>
	</select>
	
	<select id="selectTWorkMstAcCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
		  FROM TWORK_MST_AC
		 WHERE
		 	   CTKEY = #{ctkey}
           AND CLOSDATE >= #{sysdate}
           AND DELYN = 'N'		 	   
	  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
			<choose>
		        <when test='opval !=null and opval.equals("eq")'>
		            AND ACKEY = #{value}
		        </when>
	        	<otherwise>
				   AND (ACKEY LIKE '%' || #{value} || '%' 
				    OR ACTYPE LIKE '%' || #{value} || '%'
				    OR ACNAME LIKE '%' || #{value} || '%')
		   		</otherwise>
		   	</choose>
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)" >
		   AND  OWKEY = #{owkey}
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(loggrpcd)" >
		   AND  LOGGRPCD = #{loggrpcd}
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(dckey)" >
		   AND  DCKEY = #{dckey}
		</if>
		<if test="LOGGRPCD_SELECTION_VALUE != null and LOGGRPCD_SELECTION_VALUE != ''" >
			AND LOGGRPCD IN 
			<foreach item="LOGGRPCD_SELECTION_VALUE" index="loggrpcdIdx" collection="LOGGRPCD_SELECTION_VALUE" open="(" separator="," close=")">
				#{LOGGRPCD_SELECTION_VALUE}
			</foreach>
		</if>	   	
	</select>	

	<select id="selectTWorkMstAc" resultMap="selectCommonCode">
	#{GRIDPAGING_ROWNUMTYPE_TOP}
			SELECT B.* 
			  FROM (					
				SELECT ACKEY AS FIELD1
				       ,ACNAME AS FIELD2
				       ,ACTYPE AS FIELD3
				       ,LOGGRPCD AS FIELD4
				       ,DCKEY AS FIELD5
				       ,CTKEY ||';'|| 'ACTYPE' || ';' || ACTYPE AS FIELD3_DESC
				       ,CTKEY ||';'|| 'LOGGRPCD' || ';' || LOGGRPCD  AS FIELD4_DESC
				       ,CTKEY ||';'|| 'DCKEY' || ';' || DCKEY  AS FIELD5_DESC
				  FROM TWORK_MST_AC
				 WHERE 1=1
				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)" >
				   AND CTKEY = #{ctkey}
				</if>
	               AND CLOSDATE >= #{sysdate}
	               AND DELYN = 'N'
				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)" >
				   AND  OWKEY = #{owkey}
				</if>	               			 	   
			  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
					<choose>
				        <when test='opval !=null and opval.equals("eq")'>
				            AND ACKEY = #{value}
				        </when>
			        	<otherwise>
						   AND (ACKEY LIKE '%' || #{value} || '%' 
						    OR ACTYPE LIKE '%' || #{value} || '%'
						    OR ACNAME LIKE '%' || #{value} || '%')
				   		</otherwise>
				   	</choose>
				</if>
				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(loggrpcd)" >
				   AND  LOGGRPCD = #{loggrpcd}
				</if>
				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(dckey)" >
				   AND  DCKEY = #{dckey}
				</if>
				<if test="LOGGRPCD_SELECTION_VALUE != null and LOGGRPCD_SELECTION_VALUE != ''" >
					AND LOGGRPCD IN 
					<foreach item="LOGGRPCD_SELECTION_VALUE" index="loggrpcdIdx" collection="LOGGRPCD_SELECTION_VALUE" open="(" separator="," close=")">
						#{LOGGRPCD_SELECTION_VALUE}
					</foreach>
				</if>	   	
			)B
		<choose>
			<when test='sortValue !=null and sortValue != ""'>	
				<if test='sortValue == "DESC" and colName !=null'>
				ORDER BY #{colName} DESC
				</if>
				<if test='sortValue == "ASC" and colName !=null'>
				ORDER BY #{colName} ASC
				</if>	
			</when>	
			<otherwise>
				ORDER BY FIELD1 ASC
			</otherwise>
		</choose>         
	#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>

	<select id="selectTWorkMstOwCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
		  FROM TWORK_MST_OW
		 WHERE DELYN = 'N'
		   AND CLOSDATE >= #{sysdate}
		  <if test="OWKEY_SELECTION_VALUE != null and OWKEY_SELECTION_VALUE != ''" >
		     AND OWKEY IN 
			  <foreach item="OWKEY_SELECTION_VALUE" index="index" collection="OWKEY_SELECTION_VALUE" open="(" separator="," close=")">
			  	#{OWKEY_SELECTION_VALUE}
			  </foreach>
		  </if>					    	
		  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
				<choose>
			        <when test='opval !=null and opval.equals("eq")'>
			            AND OWKEY = #{value}
			        </when>
		        	<otherwise>
			   			AND (OWKEY LIKE '%' || #{value} || '%' OR OWNAME LIKE '%' || #{value} || '%')
			   		</otherwise>
			   	</choose>
			</if>
	</select>	
	
	<select id="selectTWorkMstOw" resultMap="selectCommonCode">
			#{GRIDPAGING_ROWNUMTYPE_TOP}

					SELECT B.* 
					  FROM(
							SELECT OWKEY AS FIELD1 
							     , OWNAME AS FIELD2
							  FROM TWORK_MST_OW
							 WHERE DELYN = 'N'
							   AND CLOSDATE >= #{sysdate}
							  <if test="OWKEY_SELECTION_VALUE != null and OWKEY_SELECTION_VALUE != ''" >
							     AND OWKEY IN 
								  <foreach item="OWKEY_SELECTION_VALUE" index="index" collection="OWKEY_SELECTION_VALUE" open="(" separator="," close=")">
								  	#{OWKEY_SELECTION_VALUE}
								  </foreach>
							  </if>					    	
							  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
									<choose>
								        <when test='opval !=null and opval.equals("eq")'>
								            AND OWKEY = #{value}
								        </when>
							        	<otherwise>
								   			AND (OWKEY LIKE '%' || #{value} || '%' OR OWNAME LIKE '%' || #{value} || '%')
								   		</otherwise>
								   	</choose>
								</if>
	                         		)B
							<choose>
								<when test='sortValue !=null and sortValue != ""'>	
									<if test='sortValue == "DESC" and colName !=null'>
									ORDER BY #{colName} DESC
									</if>
									<if test='sortValue == "ASC" and colName !=null'>
									ORDER BY #{colName} ASC
									</if>	
								</when>	
								<otherwise>
									ORDER BY FIELD1 ASC
								</otherwise>
							</choose>
                           
			#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>
	

	<select id="selectTWorkMstCtCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
	  	  FROM TWORK_MST_CT
	  	 WHERE 
	  	       CLOSDATE >= #{sysdate}
	  	   AND DELYN = 'N'
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
				AND (CTKEY LIKE '%' || #{value} || '%' OR CTKEY LIKE '%' || #{value} || '%')
			</if>
		    <if test="CTKEY_SELECTION_VALUE != null and CTKEY_SELECTION_VALUE != ''" >
		    	AND CTKEY IN 
				<foreach item="CTKEY_SELECTION_VALUE" index="index" collection="CTKEY_SELECTION_VALUE" open="(" separator="," close=")">
					#{CTKEY_SELECTION_VALUE}
				</foreach>
		    </if>			       
	</select>	
	

	<select id="selectTWorkMstCt" resultMap="selectCommonCode">
		#{GRIDPAGING_ROWNUMTYPE_TOP}
  
					SELECT	B.* 
					  FROM(	
		
						SELECT CTKEY AS FIELD1
						      ,CTNAME AS FIELD2
						      ,CTTYPE AS FIELD3
						      ,#{ctkey} ||';'|| 'CTTYPE' ||';'|| CTTYPE AS FIELD3_DESC
					  	  FROM TWORK_MST_CT
					  	 WHERE 
					  	       CLOSDATE >= #{sysdate}
					  	   AND DELYN = 'N' 
							<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
								AND (CTKEY LIKE '%' || #{value} || '%' 
								OR CTKEY LIKE '%' || #{value} || '%'
								OR CTTYPE LIKE '%' || #{value} || '%'
								)
							</if>
						    <if test="CTKEY_SELECTION_VALUE != null and CTKEY_SELECTION_VALUE != ''" >
						    	AND CTKEY IN 
								<foreach item="CTKEY_SELECTION_VALUE" index="index" collection="CTKEY_SELECTION_VALUE" open="(" separator="," close=")">
									#{CTKEY_SELECTION_VALUE}
								</foreach>
						    </if>	
						)B
			 		<choose>
						<when test='sortValue !=null and sortValue != ""'>	
							<if test='sortValue == "DESC" and colName !=null'>
							ORDER BY #{colName} DESC
							</if>
							<if test='sortValue == "ASC" and colName !=null'>
							ORDER BY #{colName} ASC
							</if>	
						</when>	
						<otherwise>
							ORDER BY FIELD1 ASC
						</otherwise>
					</choose> 					  
		
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>

	<select id="selectTWorkMstToCtCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
	  	  FROM TWORK_MST_CT
	  	 WHERE 
	  	       CLOSDATE >= #{sysdate}
	  	   AND DELYN = 'N'
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
				AND (CTKEY LIKE '%' || #{value} || '%' OR CTKEY LIKE '%' || #{value} || '%')
			</if>	       
	</select>	
	

	<select id="selectTWorkMstToCt" resultMap="selectCommonCode">
		#{GRIDPAGING_ROWNUMTYPE_TOP}
  
					SELECT	B.* 
					  FROM(	
		
						SELECT CTKEY AS FIELD1
						      ,CTNAME AS FIELD2
						      ,CTTYPE AS FIELD3
						      ,#{ctkey} ||';'|| 'CTTYPE' ||';'|| CTTYPE AS FIELD3_DESC
					  	  FROM TWORK_MST_CT
					  	 WHERE 
					  	       CLOSDATE >= #{sysdate}
					  	   AND DELYN = 'N' 
							<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
								AND (CTKEY LIKE '%' || #{value} || '%' 
								OR CTKEY LIKE '%' || #{value} || '%'
								OR CTTYPE LIKE '%' || #{value} || '%'
								)
							</if>
						)B
			 		<choose>
						<when test='sortValue !=null and sortValue != ""'>	
