	<sql id="sql_tAdminMstMe">
		FROM TADMIN_MST_ME A
			LEFT OUTER JOIN T_MSG B
						 ON B.MULAAPMSGHDKEY = A.MENM
						AND B.MSGTYPE = 'MENU'
			INNER JOIN TADMIN_MST_URSCR C
					ON C.APKEY = A.APKEY
				   AND C.USKEY = A.USKEY
			LEFT OUTER JOIN TADMIN_MST_ME D
						 ON D.MEKEY = A.UPRMEKEY
		<where>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(apkey)">
				AND A.APKEY = #{apkey}
			</if>
			AND A.DELYN = 'N'
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.MEKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.MEKEY ~ #{value}
						OR
						A.MENM ~ #{value}
						OR
						B.DISPLAYMSG ~ #{value}
						OR
						A.APKEY ~ #{value}
						OR
						A.EQTYPE ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.MEKEY LIKE '%' || #{value} || '%'
						OR
						A.MENM LIKE '%' || #{value} || '%'
						OR
						B.DISPLAYMSG LIKE '%' || #{value} || '%'
						OR
						A.APKEY LIKE '%' || #{value} || '%'
						OR
						A.EQTYPE LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
		/* Converted from: START WITH A.UPRMEKEY='0' CONNECT BY PRIOR A.MEKEY = A.UPRMEKEY ORDER SIBLINGS BY A.MEORDER */
		AND A.MEKEY IN (
			WITH RECURSIVE menu_tree AS (
				SELECT MEKEY, UPRMEKEY FROM TADMIN_MST_ME WHERE UPRMEKEY = '0'
				UNION ALL
				SELECT m.MEKEY, m.UPRMEKEY FROM TADMIN_MST_ME m INNER JOIN menu_tree t ON m.UPRMEKEY = t.MEKEY
			)
			SELECT MEKEY FROM menu_tree
		)
		ORDER BY A.UPRMEKEY, A.MEORDER
	</sql>

