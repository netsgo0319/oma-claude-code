	      INNER JOIN TADMIN_MST_MULAAPMSG_DT B
	      		  ON A.MULAAPMSGHDKEY = B.MULAAPMSGHDKEY
	     WHERE A.CLOSDATE >= #{sysdate}
	       AND B.LAKEY = #{lakey}
	       AND B.MSGTYPE = #{msgtype}
	</select>
	
