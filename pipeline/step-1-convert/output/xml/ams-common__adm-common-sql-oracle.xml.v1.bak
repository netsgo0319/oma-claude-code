						AND A.ICKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.ICKEY ~ #{value}
						OR
						A.ICNM ~ #{value}
						OR
						A.OWKEY ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.ICKEY LIKE '%' || #{value} || '%'
