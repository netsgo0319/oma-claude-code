	<sql id="sql_tAdminMstAcForRep">
		FROM (
		SELECT
		REPACKEY AS ACKEY
		, OWKEY
		FROM TADMIN_MST_AC
		GROUP BY
		REPACKEY
		, OWKEY
		) A
		INNER JOIN TADMIN_MST_AC B
		ON B.ACKEY = A.ACKEY AND B.OWKEY = A.OWKEY
		LEFT OUTER JOIN T_CODE C
		ON C.ADCDHDKEY = 'ACTYPE' AND C.ADCDDTKEY = B.ACTYPE

		<where>
			AND DELYN = 'N'
			AND CLOSDATE <![CDATA[ >= ]]> #{sysdate}

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
				AND A.OWKEY = #{owkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND B.ACKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						B.ACKEY ~ #{value}
						OR
						B.ACNM ~ #{value}
						OR
						C.ADCDDTNM ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						B.ACKEY LIKE '%' || #{value} || '%'
						OR
						B.ACNM LIKE '%' || #{value} || '%'
						OR
						C.ADCDDTNM LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

