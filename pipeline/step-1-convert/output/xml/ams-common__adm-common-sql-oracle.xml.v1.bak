	<resultMap id="GridColumnsMap" type="java.util.HashMap">
  		<result property="updfdtkey" column="UPDFDTKEY" />
		<result property="columnnm" column="COLUMNNM" />
		<result property="columndesc" column="COLUMNDESC" />
		<result property="columntype" column="COLUMNTYPE" />
