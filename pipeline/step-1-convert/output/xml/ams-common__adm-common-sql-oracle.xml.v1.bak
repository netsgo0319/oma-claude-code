	<!-- SELECT ====================================================================== -->

	<select id="selectTAdminMstApCount" resultType="java.lang.Integer">
		/* adm-common-sql-oracle.xml - selectTAdminMstApCount */
		WITH <include refid="sql_tRoleAp"/>
		SELECT
		    COUNT(1)
		<include refid="sql_tAdminMstAp"/>
	</select>

	<select id="selectTAdminMstAp" resultType="camelMap">
		/* adm-common-sql-oracle.xml - selectTAdminMstAp */
		WITH <include refid="sql_tRoleAp"/>
		<include refid="sql_pagingTop"/>
		SELECT
		      A.APKEY AS FIELD1
			, A.APNM AS FIELD2
			, A.APKEY
			, A.APNM
		<include refid="sql_tAdminMstAp"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<select id="selectTAdminMstAdcdCount" resultType="java.lang.Integer">
		/* adm-common-sql-oracle.zxml - selectTAdminMstAdcdCount */
		SELECT
		    COUNT(1)
		<include refid="sql_tAdminMstAdcd"/>
	</select>

	<select id="selectTAdminMstAdcd" resultType="camelMap">
		/* adm-common-sql-oracle.xml - selectTAdminMstAdcd */
		<include refid="sql_pagingTop"/>
		SELECT
			  B.ADCDDTKEY AS FIELD1
			, B.ADCDDTNM AS FIELD2
			, B.ADCDDTVALUE as FIELD3
			, A.ADCDHDKEY AS FIELD4
			, B.ADCDDTORDER AS FIELD5
		<include refid="sql_tAdminMstAdcd"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<select id="selectTAdminMstMulaapmsgCount" resultType="java.lang.Integer">
		/* adm-common-sql-oracle.xml - selectTAdminMstMulaapmsgCount */
		SELECT
		COUNT(1)
		<include refid="sql_tAdminMstMulaapmsg"/>
	</select>

	<select id="selectTAdminMstMulaapmsg" resultType="camelMap">
		/* adm-common-sql-oracle.xml - selectTAdminMstMulaapmsg */
		<include refid="sql_pagingTop"/>
		SELECT
			  B.MULAAPMSGHDKEY AS FIELD1
			, B.DISPLAYMSG AS FIELD2
			, B.LAKEY AS FIELD3
			, B.MSGTYPE AS FIELD4
		<include refid="sql_tAdminMstMulaapmsg"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<select id="selectTAdminMstAcCount" resultType="java.lang.Integer">
