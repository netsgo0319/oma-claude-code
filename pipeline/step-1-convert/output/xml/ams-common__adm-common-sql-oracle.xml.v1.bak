	<select id="selectGridColumns" resultMap="GridColumnsMap">
		SELECT B.UPDFDTKEY
			  ,B.COLUMNNM
			  ,B.COLUMNDESC
			  ,B.COLUMNTYPE
			  ,A.OWKEY
			  ,A.ULTYPE
		  FROM TADMIN_MST_UPDF_HD A
		  INNER JOIN TADMIN_MST_UPDF_DT B
		  		  ON A.UPDFHDKEY = B.UPDFHDKEY
		 WHERE A.APKEY = #{apkey}
		   AND A.ULTYPE = #{ultype}		
		  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
		 	AND A.OWKEY = #{owkey}
		 </if>
		 ORDER BY B.COLUMNORDER,B.UPDFDTKEY
	</select>

	<select id="selectGridCount" resultType="java.lang.Integer">
		SELECT COUNT(1)  
		  FROM TADMIN_MST_UPDF_HD A
		  INNER JOIN TADMIN_MST_UPDF_DT B
		  		  ON A.UPDFHDKEY = B.UPDFHDKEY
		 WHERE A.APKEY = #{apkey}
		   AND A.ULTYPE = #{ultype}		
		  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
		 	AND A.OWKEY = #{owkey}
		 </if>
	</select>	

	<select id="selectEncTargetMstUR" resultType="camelMap">
		SELECT URKEY, CP, EMAIL
		  FROM TADMIN_MST_UR
		 WHERE EMAIL IS NOT NULL
	</select>

	<update id="updateEncTargetMstUR">
		UPDATE TADMIN_MST_UR
		   SET CP = #{cp}
		     , EMAIL = #{email}
		 WHERE URKEY = #{urkey}
	</update>

	<select id="selectEncTargetDriver" resultType="camelMap">
		SELECT DRVNO, MOBILENO
	      FROM TT_DRVR_T
		 WHERE MOBILENO IS NOT NULL
	</select>

	<update id="updateEncTargetDriver">
        UPDATE TT_DRVR_T
           SET MOBILENO = #{mobileno}
         WHERE DRVNO = #{drvno}
	</update>

	<sql id="sql_tAdminMstAdcdUnion">
		<where>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND T.FIELD1 = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						T.FIELD1 ~ #{value}
						OR
						T.FIELD2 ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						T.FIELD1 LIKE '%' || #{value} || '%'
						OR
						T.FIELD2 LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<select id="selectTAdminMstAdcdUnionCount" resultType="java.lang.Integer">
		/* adm-common-sql-oracle.xml - selectTAdminMstAdcdUnionCount */
		SELECT COUNT(1)
		FROM (
		    SELECT B.ADCDDTKEY AS FIELD1
				 , B.ADCDDTNM AS FIELD2
			FROM TADMIN_MST_ADCD_HD A
				INNER JOIN TADMIN_MST_ADCD_DT B
						ON B.ADCDHDKEY = A.ADCDHDKEY
			WHERE  A.DELYN = 'N'
			  AND B.DELYN = 'N'
			  AND A.ADCDHDKEY = 'CTGLEVEL'
			  AND B.LAKEY = 'KOR'
			  AND A.ADCDHDKEY = 'CTGLEVEL'
		    UNION ALL
		    SELECT B.ADCDDTKEY AS FIELD1
				 , B.ADCDDTNM AS FIELD2
			FROM TADMIN_MST_ADCD_HD A
				INNER JOIN TADMIN_MST_ADCD_DT B
						ON B.ADCDHDKEY = A.ADCDHDKEY
			WHERE  A.DELYN = 'N'
			  AND B.DELYN = 'N'
			  AND A.ADCDHDKEY = 'CTGLEVELTOP'
			  AND B.LAKEY = 'KOR' ) T
		<include refid="sql_tAdminMstAdcdUnion"/>
	</select>

	<select id="selectTAdminMstAdcdUnion" resultType="camelMap">
		/* adm-common-sql-oracle.xml - selectTAdminMstAdcdUnion */
		<include refid="sql_pagingTop"/>
		SELECT T.FIELD1
			 , T.FIELD2
			 , T.FIELD3
			 , T.FIELD4
			 , T.FIELD5
		FROM   (SELECT B.ADCDDTKEY AS FIELD1
			 	     , B.ADCDDTNM AS FIELD2
			 	     , B.ADCDDTVALUE AS FIELD3
			 	     , A.ADCDHDKEY AS FIELD4
			 	     , B.ADCDDTORDER AS FIELD5
				FROM TADMIN_MST_ADCD_HD A
					INNER JOIN TADMIN_MST_ADCD_DT B
							ON B.ADCDHDKEY = A.ADCDHDKEY
				WHERE A.DELYN = 'N'
				  AND B.DELYN = 'N'
				  AND A.ADCDHDKEY = 'CTGLEVEL'
				  AND B.LAKEY = 'KOR'
				UNION ALL
				SELECT B.ADCDDTKEY AS FIELD1
					 , B.ADCDDTNM AS FIELD2
					 , B.ADCDDTVALUE AS FIELD3
					 , A.ADCDHDKEY AS FIELD4
					 , B.ADCDDTORDER AS FIELD5
				FROM TADMIN_MST_ADCD_HD A
					INNER JOIN TADMIN_MST_ADCD_DT B
							ON B.ADCDHDKEY = A.ADCDHDKEY
				WHERE  A.DELYN = 'N'
				  AND B.DELYN = 'N'
				  AND A.ADCDHDKEY = 'CTGLEVELTOP'
				  AND B.LAKEY = 'KOR' ) T
		<include refid="sql_tAdminMstAdcdUnion"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tAdminMstUrDetail">
		FROM TADMIN_MST_UR A
		INNER JOIN TADMIN_MST_URGR B
				ON A.URGRKEY = B.URGRKEY
		LEFT OUTER JOIN T_CODE C
					 ON C.ADCDHDKEY = 'URTYP'
					AND C.ADCDDTKEY = A.URTYP
		<where>
			AND A.DELYN = 'N'
			AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.URKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.URKEY ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.URKEY LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
			AND EXISTS (SELECT 1
						  FROM TADMIN_MST_URGRXROGT GRRO
				    INNER JOIN TADMIN_MST_RO RO
				  		    ON GRRO.ROKEY = RO.ROKEY
				    INNER JOIN TADMIN_MST_ROXAPGT ROAP
				  		    ON RO.ROKEY = ROAP.ROKEY
				    INNER JOIN TADMIN_MST_ROXMEGT ROME
				  		    ON RO.ROKEY = ROME.ROKEY
						 WHERE GRRO.URGRKEY = B.URGRKEY
						   AND ROAP.APKEY = #{apkey}
						   AND ROME.MEKEY = #{mekey}
					)
		</where>
	</sql>

	<select id="selectTadminMstUrDetailCount" resultType="java.lang.Integer">
		/* adm-common-sql-oracle.xml - selectTadminMstUrDetailCount */
		WITH <include refid="sql_Tcode"/>
		SELECT
		COUNT(1)
		<include refid="sql_tAdminMstUrDetail"/>
	</select>

	<select id="selectTadminMstUrDetail" resultType="camelMap">
		/* adm-common-sql-oracle.xml - selectTadminMstUrDetail */
		WITH <include refid="sql_Tcode"/>
		<include refid="sql_pagingTop"/>
		SELECT
		  A.URKEY AS FIELD1
		, A.URNM AS FIELD2
		, C.ADCDDTKEY
		, C.ADCDDTNM AS FIELD3
		, A.URGRKEY AS FIELD4
		, B.URGRNM AS FIELD5
		<include refid="sql_tAdminMstUrDetail"/>
		<include refid="sql_pagingBottom"/>
	</select>
	
	<insert id="insertTadminInfoUrHs">
		/* adm-common-sql-oracle.xml - insertTadminInfoUrHs */
		INSERT INTO TADMIN_INFO_URHS (
		       ACSDATE
			,  ACSURKEY
			,  ACSIP
			,  ACSUSKEY
			,  SEARCHCOND
			,  PRGRBIZ
			,  INFOTGTCNT
			,  INSERTDATE
			,  INSERTURKEY
			,  UPDATEDATE
			,  UPDATEURKEY
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(cmt)">
				, CMT
			</if>
		) VALUES (
			   #{sysdate}
			,  #{surkey}
			,  #{acsip}
			,  #{menuId}
			,  #{resultParam}
			,  #{method}
			,  #{infotgtcnt}
			,  #{sysdate}
			,  #{surkey}
			,  #{sysdate}
			,  #{surkey}
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(cmt)">
				, #{cmt}
			</if>
		)
	</insert>

	<select id="selectMainNoticeList" resultType="camelMap">
		/* adm-common-sql-oracle.xml - selectMainNoticeList */
		<![CDATA[
		SELECT MSGNO
		           , TITLE
		      	   , INSERTURKEY
		      	   , INSERTDATE
		        FROM TADMIN_INFO_NOTICE
		       WHERE STARTDT <= TO_CHAR(CURRENT_TIMESTAMP, 'YYYYMMDD')
		         AND ENDDT >= TO_CHAR(CURRENT_TIMESTAMP, 'YYYYMMDD')
		       ORDER BY INSERTDATE DESC
LIMIT 4
		]]>
	</select>

	<select id="selectRecruitment" resultType="camelMap">
		/* adm-common-sql-oracle.xml - selectRecruitment */
		/* Converted from: Oracle UNPIVOT + PIVOT to LATERAL VALUES + CASE aggregation */
		WITH BASE AS (
			SELECT
				COALESCE(REC.TOWEEK, 0) AS TO_WEEK,
				COALESCE(REC.TONGT, 0) AS TO_NGT,
				COALESCE(REC.POWEEK, 0) AS PO_WEEK,
				COALESCE(REC.PONGT, 0) AS PO_NGT,
				COALESCE(REC.WORKWEEK, 0) AS WORK_WEEK,
				COALESCE(REC.WORKNGT, 0) AS WORK_NGT,
				COALESCE(REC.ETCWEEK, 0) AS ETC_WEEK,
				COALESCE(REC.ETCNGT, 0) AS ETC_NGT
			FROM (SELECT 1 AS DL) AS DL
			LEFT JOIN TADMIN_INFO_RECRUIT REC
				   ON REC.REQDAY = #{reqDay}
		),
		UNPVT AS (
			SELECT SUBSTR(v.COL, 1, POSITION('_' IN v.COL) - 1) AS COLTYPE
				,  SUBSTR(v.COL, POSITION('_' IN v.COL) + 1)    AS TM
				,  v.VAL
			  FROM BASE b
			  CROSS JOIN LATERAL (
				VALUES
					('TO_WEEK',   b.TO_WEEK),
					('TO_NGT',    b.TO_NGT),
					('PO_WEEK',   b.PO_WEEK),
					('PO_NGT',    b.PO_NGT),
					('WORK_WEEK', b.WORK_WEEK),
					('WORK_NGT',  b.WORK_NGT),
					('ETC_WEEK',  b.ETC_WEEK),
					('ETC_NGT',   b.ETC_NGT)
			  ) AS v(COL, VAL)
		)
		SELECT COLTYPE
			 , SUM(CASE WHEN TM = 'WEEK' THEN VAL END) AS WEEK
			 , SUM(CASE WHEN TM = 'NGT'  THEN VAL END) AS NGT
		  FROM UNPVT
		 GROUP BY COLTYPE
		 ORDER BY CASE COLTYPE
				 WHEN 'TO'   THEN 1
				 WHEN 'PO'   THEN 2
				 WHEN 'WORK' THEN 3
				 WHEN 'ETC'  THEN 4
				 END
	</select>

	<update id="saveRecruitment">
		/* adm-common-sql-oracle.xml - saveRecruitment */
		/* Converted from: MERGE INTO TADMIN_INFO_RECRUIT USING DUAL ON CONFLICT */
		INSERT INTO TADMIN_INFO_RECRUIT (
					  REQDAY
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(TO_WEEK)">
						, TOWEEK
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(TO_NGT)">
						, TONGT
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(PO_WEEK)">
						, POWEEK
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(PO_NGT)">
						, PONGT
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(WORK_WEEK)">
						, WORKWEEK
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(WORK_NGT)">
						, WORKNGT
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ETC_WEEK)">
						, ETCWEEK
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ETC_NGT)">
						, ETCNGT
					</if>
					, INSERTDATE
					, INSERTURKEY
					, UPDATEDATE
					, UPDATEURKEY
				)
				VALUES (
					  #{reqDay}
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(TO_WEEK)">
						, #{TO_WEEK}
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(TO_NGT)">
						, #{TO_NGT}
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(PO_WEEK)">
						, #{PO_WEEK}
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(PO_NGT)">
						, #{PO_NGT}
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(WORK_WEEK)">
						, #{WORK_WEEK}
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(WORK_NGT)">
						, #{WORK_NGT}
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ETC_WEEK)">
						, #{ETC_WEEK}
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ETC_NGT)">
						, #{ETC_NGT}
					</if>
					, #{sysdate}
					, #{surkey}
					, #{sysdate}
					, #{surkey}
				)
		ON CONFLICT (REQDAY) DO UPDATE SET
					  UPDATEURKEY = #{surkey}
					, UPDATEDATE  = #{sysdate}
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(TO_WEEK)">
						, TOWEEK 	 	= #{TO_WEEK}
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(TO_NGT)">
						, TONGT  	 	= #{TO_NGT}
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(PO_WEEK)">
						, POWEEK 	 	= #{PO_WEEK}
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(PO_NGT)">
						, PONGT 	 	= #{PO_NGT}
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(WORK_WEEK)">
						, WORKWEEK 	= #{WORK_WEEK}
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(WORK_NGT)">
						, WORKNGT  	= #{WORK_NGT}
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ETC_WEEK)">
						, ETCWEEK  	= #{ETC_WEEK}
					</if>
					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ETC_NGT)">
						, ETCNGT   	= #{ETC_NGT}
					</if>
	</update>

</mapper>	