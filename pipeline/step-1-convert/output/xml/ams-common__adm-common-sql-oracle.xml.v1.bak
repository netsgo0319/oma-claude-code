    <sql id="sql_ttCarrT">
       FROM    TT_CARR_T
       WHERE   1 = 1
       AND DELYN = 'N'
       <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
           AND (CARRCD LIKE '%' || #{value} || '%' OR CARRNM LIKE '%' || #{value} || '%')
       </if>
   </sql>

    <select id="selectTtCarrTCount" resultType="java.lang.Integer">
        SELECT  COUNT(1)
        <include refid="sql_ttCarrT"/>
    </select>

