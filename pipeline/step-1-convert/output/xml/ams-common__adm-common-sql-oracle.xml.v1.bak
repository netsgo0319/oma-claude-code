		 ]]>    		
	</select>

		
	<select id="selectModuleMenuNexacro" resultMap="selectModuleMenuNexacroMap">
		/* adm-common-sql-oracle.xml  selectModuleMenuNexacro */
		/* Converted from: CONNECT BY PRIOR MEKEY=UPRMEKEY START WITH (inner: DELYN='Y', outer: UPRMEKEY='0') + SYS_CONNECT_BY_PATH + LEVEL */
		WITH RECURSIVE deleted_tree AS (
			SELECT MEKEY, UPRMEKEY FROM TADMIN_MST_ME WHERE DELYN = 'Y'
			UNION ALL
			SELECT m.MEKEY, m.UPRMEKEY FROM TADMIN_MST_ME m INNER JOIN deleted_tree dt ON m.UPRMEKEY = dt.MEKEY
		),
		menu_base AS (
			SELECT A.EQTYPE,A.ISLEAF,A.ISSEPARATOR,A.MEKEY
				,A.MEORDER,A.UPRMEKEY,A.USKEY
				,A.APKEY,A.DELYN
				,B.USPATH,B.NXPATH
				,COALESCE(( SELECT D.DISPLAYMSG
					 FROM TADMIN_MST_MULAAPMSG_HD C
					 INNER JOIN TADMIN_MST_MULAAPMSG_DT D
							 ON C.MULAAPMSGHDKEY = D.MULAAPMSGHDKEY
					WHERE C.CLOSDATE >= #{sysdate}
					  AND D.MSGTYPE = 'MENU'
					  AND D.LAKEY = #{lakey}
					  AND C.MULAAPMSGHDKEY = A.MENM
				  ), A.MENM)AS MENAME
				,COALESCE(( SELECT D.DISPLAYMSG
					 FROM TADMIN_MST_MULAAPMSG_HD C
					 INNER JOIN TADMIN_MST_MULAAPMSG_DT D
							 ON  C.MULAAPMSGHDKEY = D.MULAAPMSGHDKEY
					WHERE C.CLOSDATE >= #{sysdate}
					  AND D.MSGTYPE = 'MENU'
					  AND D.LAKEY = #{lakey}
					  AND C.MULAAPMSGHDKEY = B.USNM
				  ), B.USNM) AS USNAME
				  , B.URINFOYN
				  , B.CMT AS REMARK
			FROM (
				   SELECT A.MENM,A.EQTYPE,A.ISLEAF,A.ISSEPARATOR,A.MEKEY
						 ,A.MEORDER,A.UPRMEKEY,A.USKEY
						 ,A.APKEY,A.DELYN
					 FROM TADMIN_MST_ME A
					WHERE 1=1
					  AND A.DELYN <![CDATA[ <> ]]> 'Y'
					  AND A.MEKEY NOT IN (SELECT MEKEY FROM deleted_tree)
				  ) A
				,TADMIN_MST_URSCR B
				,( SELECT TB3.MEKEY
					 FROM TADMIN_MST_UR TB1
					 INNER JOIN TADMIN_MST_URXROGT TB2
							 ON TB1.URKEY = TB2.URKEY
					 INNER JOIN TADMIN_MST_ROXMEGT TB3
							 ON TB2.ROKEY = TB3.ROKEY
					WHERE TB1.URKEY = #{surkey}
					UNION
				   SELECT TB4.MEKEY
					 FROM TADMIN_MST_UR TB1
					 INNER JOIN TADMIN_MST_URGR TB2
							 ON TB1.URGRKEY = TB2.URGRKEY
					 INNER JOIN TADMIN_MST_URGRXROGT TB3
							 ON TB2.URGRKEY = TB3.URGRKEY
							AND TB1.URGRKEY = TB3.URGRKEY
					 INNER JOIN TADMIN_MST_ROXMEGT TB4
							 ON TB3.ROKEY = TB4.ROKEY
					WHERE TB1.URKEY = #{surkey}
				  ) C
		   WHERE A.USKEY = B.USKEY
			 AND A.APKEY = B.APKEY
			 AND A.MEKEY = C.MEKEY
			 AND A.DELYN <![CDATA[ <> ]]> 'Y'
			AND A.APKEY = #{apKey}
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(eqType)">
				AND A.EQTYPE = #{eqType}
			</if>
		),
		menu_tree AS (
			SELECT mb.*, 1 AS MELVL, mb.MENAME::TEXT AS MEPULLPATH
			FROM menu_base mb
			WHERE mb.UPRMEKEY = '0'
			UNION ALL
			SELECT mb.*, mt.MELVL + 1, (mt.MEPULLPATH || '|' || mb.MENAME)::TEXT
			FROM menu_base mb
			INNER JOIN menu_tree mt ON mb.UPRMEKEY = mt.MEKEY
		)
		SELECT EQTYPE,ISLEAF,ISSEPARATOR,MEKEY
			  ,COALESCE(MENAME, MEKEY) AS MENAME, MEPULLPATH
			  ,USNAME,MEORDER,UPRMEKEY,USKEY,USPATH,NXPATH,APKEY,DELYN,MELVL-2 AS MELVL,URINFOYN,REMARK
		FROM menu_tree
		WHERE MELVL-2 > -1
		ORDER BY MELVL, MEORDER

	</select>
	
	<select id="selectModuleMenuByRoleNexacro" resultMap="selectModuleMenuNexacroMap">
		/* adm-common-sql-oracle.xml  selectModuleMenuByRoleNexacro */
		/* Converted from: CONNECT BY PRIOR MEKEY=UPRMEKEY START WITH (inner: DELYN='Y', outer: UPRMEKEY='0') + SYS_CONNECT_BY_PATH + LEVEL */
		WITH RECURSIVE deleted_tree2 AS (
			SELECT MEKEY, UPRMEKEY FROM TADMIN_MST_ME WHERE DELYN = 'Y'
			UNION ALL
			SELECT m.MEKEY, m.UPRMEKEY FROM TADMIN_MST_ME m INNER JOIN deleted_tree2 dt ON m.UPRMEKEY = dt.MEKEY
		),
		menu_base2 AS (
			SELECT A.EQTYPE,A.ISLEAF,A.ISSEPARATOR,A.MEKEY
				,A.MEORDER,A.UPRMEKEY,A.USKEY
				,A.APKEY,A.DELYN
				,B.USPATH,B.NXPATH
				,COALESCE(( SELECT D.DISPLAYMSG
					 FROM TADMIN_MST_MULAAPMSG_HD C
					 INNER JOIN TADMIN_MST_MULAAPMSG_DT D
							 ON C.MULAAPMSGHDKEY = D.MULAAPMSGHDKEY
					WHERE C.CLOSDATE >= #{sysdate}
					  AND D.MSGTYPE = 'MENU'
					  AND D.LAKEY = #{lakey}
					  AND C.MULAAPMSGHDKEY = A.MENM
				  ), A.MENM)AS MENAME
				,COALESCE(( SELECT D.DISPLAYMSG
					 FROM TADMIN_MST_MULAAPMSG_HD C
					 INNER JOIN TADMIN_MST_MULAAPMSG_DT D
							 ON  C.MULAAPMSGHDKEY = D.MULAAPMSGHDKEY
					WHERE C.CLOSDATE >= #{sysdate}
					  AND D.MSGTYPE = 'MENU'
					  AND D.LAKEY = #{lakey}
					  AND C.MULAAPMSGHDKEY = B.USNM
				  ), B.USNM) AS USNAME
				  , B.URINFOYN
				  , B.CMT
			FROM (
				   SELECT A.MENM,A.EQTYPE,A.ISLEAF,A.ISSEPARATOR,A.MEKEY
						 ,A.MEORDER,A.UPRMEKEY,A.USKEY
						 ,A.APKEY,A.DELYN
					 FROM TADMIN_MST_ME A
					WHERE 1=1
					  AND A.DELYN <![CDATA[ <> ]]> 'Y'
					  AND A.MEKEY NOT IN (SELECT MEKEY FROM deleted_tree2)
				  ) A
				,TADMIN_MST_URSCR B
				,( SELECT TB3.MEKEY
					 FROM TADMIN_MST_UR TB1
					 INNER JOIN TADMIN_MST_URXROGT TB2
							 ON TB1.URKEY = TB2.URKEY
					 INNER JOIN TADMIN_MST_ROXMEGT TB3
							 ON TB2.ROKEY = TB3.ROKEY
					WHERE TB1.URKEY = #{surkey}
					UNION
				   SELECT TB4.MEKEY
					 FROM TADMIN_MST_UR TB1
					 INNER JOIN TADMIN_MST_URGR TB2
							 ON TB1.URGRKEY = TB2.URGRKEY
					 INNER JOIN TADMIN_MST_URGRXROGT TB3
							 ON TB2.URGRKEY = TB3.URGRKEY
							AND TB1.URGRKEY = TB3.URGRKEY
					 INNER JOIN TADMIN_MST_ROXMEGT TB4
							 ON TB3.ROKEY = TB4.ROKEY
					WHERE TB1.URKEY = #{surkey}
				  ) C
		   WHERE A.USKEY = B.USKEY
			 AND A.APKEY = B.APKEY
			 AND A.MEKEY = C.MEKEY
			 AND A.DELYN <![CDATA[ <> ]]> 'Y'
		  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(eqType)">
			 AND A.EQTYPE = #{eqType}
		  </if>
		),
		menu_tree2 AS (
			SELECT mb.*, 1 AS MELVL, mb.MENAME::TEXT AS MEPULLPATH
			FROM menu_base2 mb
			WHERE mb.UPRMEKEY = '0'
			UNION ALL
			SELECT mb.*, mt.MELVL + 1, (mt.MEPULLPATH || '|' || mb.MENAME)::TEXT
			FROM menu_base2 mb
			INNER JOIN menu_tree2 mt ON mb.UPRMEKEY = mt.MEKEY
		)
		SELECT EQTYPE,ISLEAF,ISSEPARATOR,MEKEY
			  ,COALESCE(MENAME, MEKEY) AS MENAME, MEPULLPATH
			  ,USNAME,MEORDER,UPRMEKEY,USKEY,USPATH,NXPATH,APKEY,DELYN,MELVL-2 AS MELVL,URINFOYN, CMT
		FROM menu_tree2
		WHERE MELVL-2 > -1
		ORDER BY MELVL, MEORDER
	</select>
	
	<select id="selectUserSearchCondtion" resultType="camelMap">
         SELECT
				 C.USSCHDKEY
               , C.DBFIELDNM
               ,C.DEFAULTOPERATOR
               ,C.DEFAULTVALUE
               ,C.INPUTRESTRICT
               ,C.SEARCHID
               ,C.USSCDTKEY
               ,C.USSCDTTYPE
               ,C.USSCLABEL
               ,C.USSCORDER
               ,C.ISMANDATORY
               ,A.USKEY 
               ,C.SINGLEOPERATORYN
               ,C.GMTAPPLYCHK
               ,C.DATEFORMAT
               ,C.USSCACTIVE
               ,C.FRDATEVALUE
               ,C.TODATEVALUE
               ,C.SINGLEPOPYN
         	   , A.APKEY
         	, D.MEKEY
          FROM TADMIN_MST_URSCR A
          INNER JOIN TADMIN_MST_USSC_DT C
             	  ON <choose>
						<when test="tabIdx == 'tab2'">
							A.USSCHDKEY2 = C.USSCHDKEY
						</when>
						<otherwise>
							A.USSCHDKEY = C.USSCHDKEY
						</otherwise>
					</choose>
           INNER JOIN TADMIN_MST_USSC_HD B
				   ON B.USSCHDKEY = C.USSCHDKEY
           INNER JOIN TADMIN_MST_ME D
				   ON A.APKEY = D.APKEY
				  AND A.USKEY = D.USKEY
         WHERE D.DELYN = 'N'
	      <if test="@com.kns.framework.util.StringUtil@isNotEmpty(eqtype)">
           AND D.EQTYPE = #{eqtype}
          </if>
      ORDER BY C.USSCORDER ASC
		   
	</select>
		

