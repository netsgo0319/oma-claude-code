	<select id="selectAmsCommonCode" resultType="camelMap">
		/* adm-common-sql-oracle.xml - selectAmsCommonCode */
		SELECT
		      B.ADCDHDKEY AS HDKEY
			, B.ADCDDTKEY AS FIELD1
			, B.ADCDDTNM AS FIELD2
		FROM
		    TADMIN_MST_ADCD_HD A
		INNER JOIN TADMIN_MST_ADCD_DT B
			ON B.ADCDHDKEY = A.ADCDHDKEY
		WHERE A.DELYN = 'N'
		AND B.DELYN = 'N'
		AND B.LAKEY = #{slakey}
		ORDER BY
		      A.ADCDHDKEY ASC
			, B.ADCDDTORDER ASC
	</select>

	<select id="selectOmsCommonCode" fetchSize="1000" resultType="camelMap">
		/* adm-common-sql-oracle.xml - selectOmsCommonCode */
		<include refid="sql_tRoleOw"/>
		SELECT B.COMHDKEY AS HDKEY
			 , B.COMDTKEY AS FIELD1
			 , B.COMDTNM AS FIELD2
			 , B.COMHDKEY
			 , B.COMDTKEY
			 , B.COMDTNM
			 , B.VAL
			 , B.OWKEY
		  FROM TORDER_MST_COM_HD A
		 INNER JOIN TORDER_MST_COM_DT B
				 ON A.OWKEY = B.OWKEY
				AND B.COMHDKEY = A.COMHDKEY
		 WHERE EXISTS (
				SELECT 1 FROM T_ROLE_OW WHERE OWKEY = A.OWKEY
			)
		   AND A.DELYN = 'N'
		   AND B.DELYN = 'N'
		   AND B.LAKEY = #{slakey}
		 ORDER BY
		 		A.COMHDKEY
			  , B.COMDTKEY
	</select>

	<select id="selectOrderCode" resultType="camelMap">
		/* adm-common-sql-oracle.xml - selectOrderCode */
		SELECT
		      B.ORDERCOMHDKEY AS HDKEY
			, B.ORDERCOMDTKEY AS FIELD1
			, B.ORDERCOMDTNM AS FIELD2
		FROM TORDER_MST_ORCD_HD A
		INNER JOIN TORDER_MST_ORCD_DT B
			ON B.ORDERCOMHDKEY = A.ORDERCOMHDKEY
		WHERE A.DELYN = 'N'
		AND B.DELYN = 'N'
		AND B.LAKEY = #{slakey}
		ORDER BY
		      A.ORDERCOMHDKEY
			, B.ORDERCOMDTKEY
	</select>

	<select id="selectWmsCommonCode" fetchSize="1000" resultType="camelMap">
		/* adm-common-sql-oracle.xml - selectWmsCommonCode */
		WITH <include refid="sql_tRoleCt"/>
		SELECT
		      B.CTCDHDKEY AS HDKEY
			, B.CTCDDTKEY AS FIELD1
			, B.CTCDDTNM AS FIELD2
			, A.CTKEY
			, B.CTCDHDKEY
			, B.CTCDDTKEY
			, B.CTCDDTNM
			, B.CTCDDTORD
			, B.CTCDDTVAL
			, B.CMT
		FROM TWORK_MST_CTCD_HD A
		INNER JOIN TWORK_MST_CTCD_DT B
			ON B.CTKEY = A.CTKEY AND B.CTCDHDKEY = A.CTCDHDKEY
		WHERE EXISTS (
			SELECT 1 FROM T_ROLE_CT WHERE CTKEY = A.CTKEY
		)
		AND A.DELYN = 'N'
		AND B.DELYN = 'N'
		AND B.LAKEY = #{slakey}
		ORDER BY
		      A.CTCDHDKEY
			, B.CTCDDTORD
	</select>

	<select id="selectTmsCommonCode" resultType="camelMap">
		/* adm-common-sql-oracle.xml - selectTmsCommonCode */
		SELECT B.TMCD_HDKEY AS HDKEY
			 , B.TMCD_DTKEY AS FIELD1
			 , B.TMCD_DTNAME AS FIELD2
		FROM TT_MST_TMCD_HD A
				 INNER JOIN TT_MST_TMCD_DT B
							ON B.TMCD_HDKEY = A.TMCD_HDKEY
		WHERE A.DELYN = 'N'
		  AND B.DELYN = 'N'
		  AND B.LAKEY = #{slakey}
		ORDER BY A.TMCD_HDKEY
			   , B.TMCD_DTORDER
	</select>

	<select id="selectBookmarkMenuCount" resultType="java.lang.Integer">
		/* adm-common-sql-oracle.xml - selectBookmarkMenuCount */
		SELECT
			COUNT(1)
		FROM TADMIN_MST_URBM
		WHERE URKEY = #{surkey}
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(apkey)">
				AND APKEY = #{apkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(mekey)">
				AND MEKEY = #{mekey}
			</if>
	</select>

	<select id="selectBookmarkMenu" resultType="camelMap">
		/* adm-common-sql-oracle.xml - selectBookmarkMenu */
		WITH <include refid="sql_Tmsg"/>
		, <include refid="sql_tRoleAp"/>

		/* Converted from: CONNECT BY PRIOR MEKEY = APKEY START WITH APKEY IS NULL */
		WITH RECURSIVE bm_base AS (
			SELECT
				  '' AS APKEY
				, A.APKEY AS MEKEY
				, A.APNM AS MENAME
				, A.APORDER
			FROM TADMIN_MST_AP A
			WHERE EXISTS (
				SELECT 1 FROM T_ROLE_AP WHERE APKEY = A.APKEY
			)
			AND A.ISOFFLINE = 'N'

			UNION

			SELECT
				  B.APKEY
				, A.MEKEY
				, D.DISPLAYMSG AS MENAME
				, 0 AS APORDER
			FROM TADMIN_MST_URBM A
			INNER JOIN TADMIN_MST_AP B
				ON B.APKEY = A.APKEY
			INNER JOIN TADMIN_MST_ME C
				ON C.MEKEY = A.MEKEY
			LEFT OUTER JOIN T_MSG D
				ON D.MSGTYPE = 'MENU' AND D.MULAAPMSGHDKEY = C.MENM
			WHERE B.ISOFFLINE = 'N'
			AND A.URKEY = #{surkey}
			AND C.DELYN = 'N'
		),
		bm_tree AS (
			SELECT APKEY, MEKEY, MENAME, APORDER, 1 AS LVL
			FROM bm_base
			WHERE APKEY IS NULL OR APKEY = ''
			UNION ALL
			SELECT b.APKEY, b.MEKEY, b.MENAME, b.APORDER, t.LVL + 1
			FROM bm_base b
			INNER JOIN bm_tree t ON b.APKEY = t.MEKEY
		),
		bm_leaf AS (
			SELECT bt.*,
				CASE WHEN NOT EXISTS (
					SELECT 1 FROM bm_base b2 WHERE b2.APKEY = bt.MEKEY
				) THEN 1 ELSE 0 END AS LEAF
			FROM bm_tree bt
		)
		SELECT *
		FROM bm_leaf
		WHERE NOT((APKEY IS NULL OR APKEY = '') AND LEAF=1)
		ORDER BY LVL, APORDER
	</select>

	<insert id="insertBookmarkMenu">
		/* adm-common-sql-oracle.xml - insertBookmarkMenu */
		INSERT INTO TADMIN_MST_URBM (
			  URKEY
			, APKEY
			, MEKEY
			, BKORDER
			, INSERTDATE
			, INSERTURKEY
			, UPDATEDATE
			, UPDATEURKEY
		) VALUES (
			  #{surkey}
			, #{apkey}
			, #{mekey}
			, (SELECT COALESCE(MAX(BKORDER), 1) FROM TADMIN_MST_URBM WHERE URKEY = #{surkey})
			, #{sysdate}
			, #{surkey}
			, #{sysdate}
			, #{surkey}
		)
	</insert>

	<delete id="deleteBookmarkMenu">
		/* adm-common-sql-oracle.xml - deleteBookmarkMenu */
		DELETE
		FROM TADMIN_MST_URBM

		<where>
			AND URKEY = #{surkey}
			AND APKEY = #{apkey}
			AND MEKEY = #{mekey}
		</where>
	</delete>

	<select id="selectBatchManageCount" resultType="java.lang.Integer">
		SELECT COUNT(1)
		  FROM BATCH_MANAGE
		 WHERE BATEXECYN = 'Y'
	</select>

	<select id="selectBatchManage" resultType="camelMap">
		SELECT BATID AS FIELD1
			,  BATNM AS FIELD2
		FROM BATCH_MANAGE
		WHERE BATEXECYN = 'Y'
	</select>













































