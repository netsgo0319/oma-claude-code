<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
	
<mapper namespace="com.daiso.ams.common.mapper.CommonMapper">

	<!-- SQL ====================================================================== -->

	<sql id="sql_pagingTop">
		<if test='@com.kns.framework.util.StringUtil@isNotEmpty(pagingYn) and "Y".equals(pagingYn) and type != "combo"'>
			#{GRIDPAGING_ROWNUMTYPE_TOP}
			SELECT B.* FROM (
		</if>
	</sql>

	<sql id="sql_pagingBottom">
		<choose>
			<when test='@com.kns.framework.util.StringUtil@isNotEmpty(pagingYn) and "Y".equals(pagingYn) and type != "combo"'>
				) B
				#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
			</when>
		</choose>
	</sql>

	<sql id="sql_sort">
		<choose>
			<when test='@com.kns.framework.util.StringUtil@isNotEmpty(sortValue) and @com.kns.framework.util.StringUtil@isNotEmpty(colName)'>
				ORDER BY
				#{colName} #{sortValue}
			</when>
			<otherwise>
				ORDER BY
				FIELD1 ASC
			</otherwise>
		</choose>
	</sql>

	<sql id="sql_Tmsg">
		T_MSG AS (
			SELECT
				  A.MULAAPMSGHDKEY
				, B.MSGTYPE
				, B.DISPLAYMSG
			FROM
				TADMIN_MST_MULAAPMSG_HD A
			INNER JOIN
				TADMIN_MST_MULAAPMSG_DT B ON B.MULAAPMSGHDKEY = A.MULAAPMSGHDKEY
			<where>
				AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}

				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(lakey)">
					AND LAKEY = #{lakey}
				</if>
			</where>
		)
	</sql>

	<sql id="sql_Tcode">
		T_CODE AS (
			SELECT
				  A.ADCDHDKEY
				, B.ADCDDTKEY
				, B.ADCDDTNM
			FROM TADMIN_MST_ADCD_HD A
			INNER JOIN TADMIN_MST_ADCD_DT B
				ON B.ADCDHDKEY = A.ADCDHDKEY

			<where>
				AND A.DELYN = 'N'
				AND B.DELYN = 'N'

				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(lakey)">
					AND B.LAKEY = #{lakey}
				</if>
			</where>
		)
	</sql>

	<sql id="sql_tRoleAp">
		T_ROLE AS (
			SELECT
				D.ROKEY
			FROM TADMIN_MST_UR A
			INNER JOIN TADMIN_MST_URGR B
					ON B.URGRKEY = A.URGRKEY
			INNER JOIN TADMIN_MST_URGRXROGT C
					ON C.URGRKEY = B.URGRKEY
			INNER JOIN TADMIN_MST_RO D
					ON D.ROKEY = C.ROKEY
			WHERE
				A.URKEY = #{surkey}
		), T_ROLE_AP AS (
			SELECT
				DISTINCT
				APKEY
			FROM TADMIN_MST_ROXAPGT A
			WHERE EXISTS (
				SELECT 1 FROM T_ROLE WHERE ROKEY = A.ROKEY
			)
		)
	</sql>

	<sql id="sql_tRoleCt">
		T_ROLE AS (
			SELECT
				D.ROKEY
			FROM TADMIN_MST_UR A
					 INNER JOIN TADMIN_MST_URGR B
								ON B.URGRKEY = A.URGRKEY
					 INNER JOIN TADMIN_MST_URGRXROGT C
								ON C.URGRKEY = B.URGRKEY
					 INNER JOIN TADMIN_MST_RO D
								ON D.ROKEY = C.ROKEY
			 WHERE A.DELYN = 'N'
			   AND A.URKEY = #{surkey}
		), T_ROLE_CT AS (
			SELECT DISTINCT
				   B.CTKEY
			  FROM
				   TADMIN_MST_ROXCTGT A
			  INNER JOIN  TADMIN_MST_CT B
			  		  ON A.CTKEY = B.CTKEY
			 WHERE B.DELYN = 'N'
			   AND EXISTS (
					SELECT 1 FROM T_ROLE WHERE ROKEY = A.ROKEY
				   )
		)
	</sql>

	<sql id="sql_tRoleOw">
		WITH T_ROLE AS (
			SELECT D.ROKEY
			  FROM TADMIN_MST_UR A
			 INNER JOIN TADMIN_MST_URGR B
				ON B.URGRKEY = A.URGRKEY
			 INNER JOIN TADMIN_MST_URGRXROGT C
				ON C.URGRKEY = B.URGRKEY
			 INNER JOIN TADMIN_MST_RO D
				ON D.ROKEY = C.ROKEY
			 WHERE A.DELYN = 'N'
			   AND A.URKEY = #{surkey}
		), T_ROLE_OW AS (
			SELECT DISTINCT
				   A.OWKEY
			  FROM TADMIN_MST_ROXOWGT A
			  INNER JOIN  TADMIN_MST_CT B
			     	  ON A.CTKEY = B.CTKEY
			  INNER JOIN  TADMIN_MST_OW C
			  		  ON A.OWKEY = C.OWKEY
			 WHERE B.DELYN = 'N'
			   AND C.DELYN = 'N'
			   AND EXISTS (
					SELECT 1 FROM T_ROLE WHERE ROKEY = A.ROKEY
				   )
		)
	</sql>

	<sql id="sql_tRoleCtOw">
		WITH T_ROLE AS (
			SELECT
				D.ROKEY
			FROM TADMIN_MST_UR A
			 INNER JOIN TADMIN_MST_URGR B
						ON B.URGRKEY = A.URGRKEY
			 INNER JOIN TADMIN_MST_URGRXROGT C
						ON C.URGRKEY = B.URGRKEY
			 INNER JOIN TADMIN_MST_RO D
						ON D.ROKEY = C.ROKEY
			WHERE
				A.URKEY = #{surkey}
		), T_ROLE_CT AS (
			SELECT
				DISTINCT
				CTKEY
			FROM TADMIN_MST_ROXCTGT A
			WHERE  EXISTS (
				SELECT 1 FROM T_ROLE WHERE ROKEY = A.ROKEY
			)
		), T_ROLE_CT_OW AS (
			SELECT
				DISTINCT
				OWKEY
			FROM TADMIN_MST_CTXOW A
			WHERE EXISTS (
				SELECT 1 FROM T_ROLE_CT WHERE CTKEY = A.CTKEY
			)
		), T_ROLE_OW AS (
			SELECT DISTINCT
				 A.CTKEY
				,A.OWKEY
			FROM TADMIN_MST_ROXOWGT A
			INNER JOIN TADMIN_MST_CT B
			    	ON A.CTKEY = B.CTKEY
			INNER JOIN TADMIN_MST_OW C
					ON A.OWKEY = C.OWKEY
			WHERE B.DELYN = 'N'
			  AND C.DELYN = 'N'
			  AND EXISTS (
				SELECT 1 FROM T_ROLE WHERE ROKEY = A.ROKEY
			)
			  AND EXISTS (
				SELECT 1 FROM T_ROLE_CT_OW WHERE OWKEY = A.OWKEY
			)
		)
	</sql>

	<sql id="sql_tRoleAc">
		WITH T_ROLE AS (
			SELECT
				D.ROKEY
			FROM TADMIN_MST_UR A
					 INNER JOIN TADMIN_MST_URGR B
								ON B.URGRKEY = A.URGRKEY
					 INNER JOIN TADMIN_MST_URGRXROGT C
								ON C.URGRKEY = B.URGRKEY
					 INNER JOIN TADMIN_MST_RO D
								ON D.ROKEY = C.ROKEY
			WHERE
				A.URKEY = #{surkey}
		), T_ROLE_CT AS (
			SELECT
				DISTINCT
				CTKEY
			FROM TADMIN_MST_ROXCTGT A
			WHERE EXISTS (
				SELECT 1 FROM T_ROLE WHERE ROKEY = A.ROKEY
			)
		), T_ROLE_CT_AC AS (
			SELECT
				DISTINCT
				ACKEY
			FROM TADMIN_MST_ACXCT A
			WHERE EXISTS (
				SELECT 1 FROM T_ROLE_CT WHERE CTKEY = A.CTKEY
			)
		)
	</sql>

	<sql id="sql_tGrpRoleCt">
		T_ROLE AS (
			SELECT B.ROKEY
			  FROM TADMIN_MST_URGRXROGT A
			 INNER JOIN TADMIN_MST_RO B
				ON B.ROKEY = A.ROKEY
			 WHERE A.URGRKEY = #{urgrkey}
		), T_ROLE_CT AS (
			SELECT DISTINCT
			B.CTKEY
			FROM TADMIN_MST_ROXCTGT A
			INNER JOIN TADMIN_MST_CT B
					ON A.CTKEY = B.CTKEY
			WHERE B.DELYN = 'N'
			  AND EXISTS (
					SELECT 1 FROM T_ROLE WHERE ROKEY = A.ROKEY
				)
		)
	</sql>

	<sql id="sql_tGrpRoleOw">
		WITH T_ROLE AS (
			SELECT B.ROKEY
			FROM TADMIN_MST_URGRXROGT A
					 INNER JOIN TADMIN_MST_RO B
								ON B.ROKEY = A.ROKEY
			WHERE A.URGRKEY = #{urgrkey}
		), T_ROLE_OW AS (
			SELECT DISTINCT
				A.OWKEY
			FROM TADMIN_MST_ROXOWGT A
			INNER JOIN TADMIN_MST_CT B
			    	ON A.CTKEY = B.CTKEY
			INNER JOIN TADMIN_MST_OW C
					ON A.OWKEY = C.OWKEY
			WHERE B.DELYN = 'N'
			  AND C.DELYN = 'N'
			  AND EXISTS (
				SELECT 1 FROM T_ROLE WHERE ROKEY = A.ROKEY
			  )

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ctkey)">
			   AND A.CTKEY = #{ctkey}
			</if>
		)
	</sql>

	<sql id="sql_tAdminMstAp">
		FROM TADMIN_MST_AP A
		<where>
			AND EXISTS (
				SELECT 1 FROM T_ROLE_AP WHERE APKEY = A.APKEY
            )
			AND A.ISOFFLINE = 'N'
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.APKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.APKEY ~ #{value}
						OR
						A.APNM ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.APKEY LIKE '%' || #{value} || '%'
						OR
						A.APNM LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<sql id="sql_tAdminMstAdcd">
		FROM TADMIN_MST_ADCD_HD A
		INNER JOIN TADMIN_MST_ADCD_DT B
		ON B.ADCDHDKEY = A.ADCDHDKEY
		<where>
			AND A.DELYN = 'N'
			AND B.DELYN = 'N'
			AND A.ADCDHDKEY = #{adcd_hdkey}
			AND B.LAKEY = #{lakey}
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND B.ADCDDTKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						B.ADCDDTKEY ~ #{value}
						OR
						B.ADCDDTNM ~ #{value}
						OR
						B.ADCDDTVALUE ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						B.ADCDDTKEY LIKE '%' || #{value} || '%'
						OR
						B.ADCDDTNM LIKE '%' || #{value} || '%'
						OR
						B.ADCDDTVALUE LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>

		</where>
	</sql>

	<sql id="sql_tAdminMstMulaapmsg">
		FROM TADMIN_MST_MULAAPMSG_HD A
		INNER JOIN TADMIN_MST_MULAAPMSG_DT B
			ON B.MULAAPMSGHDKEY = A.MULAAPMSGHDKEY

		<where>
			AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}
			AND B.LAKEY = #{slakey}

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(msgtype)">
				AND B.MSGTYPE = #{msgtype}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND B.MULAAPMSGHDKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						B.MULAAPMSGHDKEY ~ #{value}
						OR
						B.DISPLAYMSG ~ #{value}
						OR
						B.LAKEY ~ #{value}
						OR
						B.MSGTYPE ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						B.MULAAPMSGHDKEY LIKE '%' || #{value} || '%'
						OR
						B.DISPLAYMSG LIKE '%' || #{value} || '%'
						OR
						B.LAKEY LIKE '%' || #{value} || '%'
						OR
						B.MSGTYPE LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<sql id="sql_tAdminMstAc">
		FROM TADMIN_MST_AC A
		LEFT OUTER JOIN T_CODE B
			ON B.ADCDHDKEY = 'ACTYPE' AND B.ADCDDTKEY = A.ACTYPE

		<where>
			AND EXISTS (
				SELECT 1 FROM T_ROLE_CT_AC WHERE ACKEY = A.ACKEY
			)
			AND A.DELYN = 'N'
			AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
				AND A.OWKEY = #{owkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.ACKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.ACKEY ~ #{value}
						OR
						A.ACNM ~ #{value}
						OR
						B.ADCDDTNM ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.ACKEY LIKE '%' || #{value} || '%'
						OR
						A.ACNM LIKE '%' || #{value} || '%'
						OR
						B.ADCDDTNM LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<sql id="sql_tAdminMstOw">
		FROM TADMIN_MST_OW A

		<where>
			AND EXISTS (
				SELECT 1 FROM T_ROLE_OW WHERE OWKEY = A.OWKEY
			)

			AND A.DELYN = 'N'
			AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.OWKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.OWKEY ~ #{value}
						OR
						A.OWNM ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.OWKEY LIKE '%' || #{value} || '%'
						OR
						A.OWNM LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<sql id="sql_tAdminMstCt">
		FROM TADMIN_MST_CT A
		LEFT OUTER JOIN T_CODE B
			ON B.ADCDHDKEY = 'CTTYPE' AND B.ADCDDTKEY = A.CTTYPE

		<where>
			AND EXISTS (
				SELECT 1 FROM T_ROLE_CT WHERE CTKEY = A.CTKEY
			)
			AND A.DELYN = 'N'
			AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.CTKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.CTKEY ~ #{value}
						OR
						A.CTNM ~ #{value}
						OR
						B.ADCDDTNM ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.CTKEY LIKE '%' || #{value} || '%'
						OR
						A.CTNM LIKE '%' || #{value} || '%'
						OR
						B.ADCDDTNM LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<sql id="sql_tAdminMstUrgr">
		FROM TADMIN_MST_URGR

		<where>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND URGRKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						URGRKEY ~ #{value}
						OR
						URGRNM ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						URGRKEY LIKE '%' || #{value} || '%'
						OR
						URGRNM LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<sql id="sql_tAdminMstUr">
		FROM TADMIN_MST_UR A
		INNER JOIN TADMIN_MST_URGR B
			ON A.URGRKEY = B.URGRKEY

		<where>
			AND A.DELYN = 'N'
			AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.URKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.URKEY ~ #{value}
						OR
						A.URNM ~ #{value}
						)
					</when>
					<otherwise>
						/* 2025.11.17 보안점검 조치로 인하여 like 검색 제외 */
						AND (
						A.URKEY = #{value}
						OR
						A.URNM = #{value}
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<sql id="sql_tAdminMstIcgr">
		FROM TADMIN_MST_ICGR A
		LEFT OUTER JOIN T_CODE B
			ON B.ADCDHDKEY = 'ICGRTYPE' AND B.ADCDDTKEY = A.ICGRPTYPE

		<where>
			AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
				AND A.OWKEY = #{owkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.ICGRPKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.ICGRPKEY ~ #{value}
						OR
						A.ICGRPNM ~ #{value}
						OR
						B.ADCDDTNM ~ #{value}
						OR
						A.OWKEY ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.ICGRPKEY LIKE '%' || #{value} || '%'
						OR
						A.ICGRPNM LIKE '%' || #{value} || '%'
						OR
						B.ADCDDTNM LIKE '%' || #{value} || '%'
						OR
						A.OWKEY LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<sql id="sql_tAdminMstIcut">
		FROM TADMIN_MST_ICUT A
		INNER JOIN TADMIN_MST_ICUTXTYPE B
			ON B.OWKEY = A.OWKEY AND B.ICUNITKEY = A.ICUNITKEY
		LEFT OUTER JOIN T_CODE C
			ON C.ADCDHDKEY = 'ICUTTYPE' AND C.ADCDDTKEY = B.ICUNITTYPE

		<where>
			AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
				AND A.OWKEY = #{owkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.ICUNITKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.ICUNITKEY ~ #{value}
						OR
						C.ADCDDTNM ~ #{value}
						OR
						B.ICUNITQTY ~ #{value}
						OR
						A.OWKEY ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.ICUNITKEY LIKE '%' || #{value} || '%'
						OR
						C.ADCDDTNM LIKE '%' || #{value} || '%'
						OR
						B.ICUNITQTY LIKE '%' || #{value} || '%'
						OR
						A.OWKEY LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<sql id="sql_tAdminMstIc">
		FROM TADMIN_MST_IC A
		LEFT OUTER JOIN T_CODE B
			ON B.ADCDHDKEY = 'ICUTTYPE' AND B.ADCDDTKEY = A.UOM
		LEFT OUTER JOIN T_CODE C
			ON C.ADCDHDKEY = 'LOGGRPCD' AND C.ADCDDTKEY = A.UDF2

		<where>
			AND A.DELYN = 'N'
			AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
				AND OWKEY = #{owkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.ICKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.ICKEY ~ #{value}
						OR
						A.ICNM ~ #{value}
						OR
						A.OWKEY ~ #{value}
						OR
						A.ICUNITKEY ~ #{value}
						OR
						B.ADCDDTNM ~ #{value}
						OR
						C.ADCDDTNM ~ #{value}
						)
					</when>
					<otherwise>
						AND (
