	<resultMap id="selectSystemConfigListMap" type="java.util.HashMap" >
	  <result property="key"    column="TMCSKEY" />
	  <result property="name"   column="TMCSNAME" />
	  <result property="value1"  column="VALUE1" />
	  <result property="value2"  column="VALUE2" />
	  <result property="defaultvalue" column="DEFAULTVALUE" />
	 </resultMap>

	<select id="selectTmsConfigList" resultMap="selectSystemConfigListMap">
		SELECT
			 TMCSKEY
	        ,TMCSNAME
	        ,VALUE1
	        ,VALUE2
	        ,DEFAULTVALUE
	    FROM TT_SET_TMCS
	</select>

	<select id="selectTtMstEqmtTypCdCount" resultType="java.lang.Integer">
		SELECT  COUNT(1)
		FROM    TT_MST_TMCD_HD A
		INNER JOIN TT_MST_TMCD_DT B
				ON A.TMCD_HDKEY = B.TMCD_HDKEY
		WHERE   1 = 1
		        AND A.TMCD_HDKEY = 'EQUIPTYPCD'
		        AND B.LAKEY = #{lakey}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
		        AND (B.TMCD_DTVALUE LIKE '%' || #{value} || '%' OR B.TMCD_DTNAME LIKE '%' || #{value} || '%' OR B.TMCD_DTKEY LIKE '%' || #{value} || '%')
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(type)">
                AND B.TMCD_DTVALUE = #{type}
        </if>
	</select>

	<select id="selectTtMstEqmtTypCd" resultMap="selectCommonCode">
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_TOP} </if>
						SELECT  B.TMCD_DTKEY AS FIELD1
						       ,B.TMCD_DTNAME AS FIELD2
						       ,B.TMCD_DTVALUE as FIELD3
						FROM    TT_MST_TMCD_HD A
						INNER JOIN TT_MST_TMCD_DT B
								ON A.TMCD_HDKEY = B.TMCD_HDKEY
						WHERE   1 = 1
						        AND A.TMCD_HDKEY = 'EQUIPTYPCD'
						        AND B.LAKEY = #{lakey}
						<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
						        AND (B.TMCD_DTVALUE LIKE '%' || #{value} || '%' OR B.TMCD_DTNAME LIKE '%' || #{value} || '%' OR B.TMCD_DTKEY LIKE '%' || #{value} || '%')
						</if>
						<if test="@com.kns.framework.util.StringUtil@isNotEmpty(type)">
                                AND B.TMCD_DTVALUE = #{type}
                        </if>
				        ORDER BY B.TMCD_DTORDER ASC
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_BOTTOM} </if>
	</select>


    <!-- SHPGLOC -->
    <select id="selectTtShpglocTCount" resultType="java.lang.Integer">
        SELECT  COUNT(1)
        FROM    TT_SHPG_LOC_T
        WHERE   1 = 1
                AND DELYN = 'N'
            <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
                AND (SHPGLOCCD LIKE '%' || #{value} || '%' OR SHPGLOCNM LIKE '%' || #{value} || '%')
            </if>
    </select>

    <select id="selectTtShpglocTList" resultMap="selectCommonCode">
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_TOP} </if>
           SELECT  SHPGLOCNM    AS FIELD1
                  ,SHPGLOCCD  AS FIELD2
             FROM TT_SHPG_LOC_T
            WHERE 1 = 1
              AND DELYN = 'N'
               <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
                   AND (SHPGLOCCD LIKE '%' || #{value} || '%' OR SHPGLOCNM LIKE '%' || #{value} || '%')
               </if>
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_BOTTOM} </if>
    </select>

	<resultMap id="selectMyMenuSetupMap" type="java.util.HashMap">
		<result property="mekey" column="MEKEY" />
		<result property="mename" column="MENAME" />
		<result property="meorder" column="MEORDER" />
		<result property="eqtype" column="EQTYPE" />
		<result property="uskey" column="USKEY" />
		<result property="uppermekey" column="UPPERMEKEY" />
		<result property="uppermename" column="UPPERMENAME" />
		<result property="isseparator" column="ISSEPARATOR" />
		<result property="isleaf" column="ISLEAF" />
		<result property="leaf" column="LEAF" />
		<result property="comments" column="COMMENTS" />
		<result property="melvl" column="MELVL" />
		<result property="checked" column="CHECKED" javaType="boolean"/>

	</resultMap>
	<select id="selectMyMenuGrouping" fetchSize="1000" resultMap="selectMyMenuSetupMap">

	 SELECT URKEY
           	  ,MEKEY
           	  ,MENAME
           	  ,MEORDER
           	  ,EQTYPE
           	  ,USKEY
           	  ,UPPERMEKEY
           	  ,ISSEPARATOR
           	  ,ISLEAF
           	  ,COMMENTS
      		  ,LEVEL - 1 AS MELVL
		FROM TT_MST_URDFME
	    WHERE URKEY = #{surkey}
	    CONNECT BY PRIOR MEKEY=UPPERMEKEY
	    START WITH UPPERMEKEY = '0'
	    ORDER SIBLINGS BY UPPERMEKEY, MEORDER



	</select>
	<select id="selectMyMenuGroupingWithLevel" fetchSize="1000" resultMap="selectMyMenuSetupMap">
        SELECT URKEY
           	  ,MEKEY
           	  ,MENAME
           	  ,MEORDER
           	  ,EQTYPE
           	  ,USKEY
           	  ,UPPERMEKEY
           	  ,ISSEPARATOR
           	  ,ISLEAF
           	  ,COMMENTS
      		  ,LEVEL -2 AS MELVL
		  FROM TT_MST_URDFME
	   	 WHERE 1=1
		   AND URKEY= #{surkey}
	CONNECT BY
	     PRIOR MEKEY=UPPERMEKEY
	START WITH UPPERMEKEY = '-1'
	  ORDER SIBLINGS BY UPPERMEKEY, MEORDER
	</select>

	<resultMap id="sselectTtMstUrdfusMap" type="java.util.HashMap">
		<result property="urkey" column="URKEY" />
		<result property="uskey" column="USKEY" />
		<result property="usgridId" column="USGRID_ID" />
		<result property="urdfusInfo" column="URDFUS_INFO"  javaType="java.lang.String" jdbcType="CLOB" typeHandler="org.apache.ibatis.type.ClobTypeHandler"/>
		<result property="urdfusInfoInit" column="URDFUS_INFO_INIT"  javaType="java.lang.String" jdbcType="CLOB" typeHandler="org.apache.ibatis.type.ClobTypeHandler"/>
		<result property="insertdate" column="INSERTDATE"/>
		<result property="inserturkey" column="INSERTURKEY" />
		<result property="updatedate" column="UPDATEDATE"/>
		<result property="updateurkey" column="UPDATEURKEY" />
	</resultMap>
	<select id="selectTtMstUrdfus" resultMap="sselectTtMstUrdfusMap">
		SELECT
				URKEY
				,USKEY
				,USGRID_ID
				,URDFUS_INFO
				,URDFUS_INFO_INIT
				,INSERTDATE
				,INSERTURKEY
				,UPDATEDATE
				,UPDATEURKEY
		FROM	TT_MST_URDFUS
       WHERE	URKEY = #{surkey}
       <if test="uskey != null">
         AND	USKEY = #{uskey}
       </if>
       <if test="usgridId != null">
         AND	USGRID_ID = #{usgridId}
       </if>
	</select>
</mapper>