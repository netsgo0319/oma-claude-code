		<result property="field3_desc" column="FIELD3_DESC" typeHandler="TmsCodeDescTypeHandler"/>
		<result property="field4_desc" column="FIELD4_DESC" typeHandler="TmsCodeDescTypeHandler"/>
		<result property="field5_desc" column="FIELD5_DESC" typeHandler="TmsCodeDescTypeHandler"/>
		<result property="field6_desc" column="FIELD6_DESC" typeHandler="TmsCodeDescTypeHandler"/>
		<result property="field7_desc" column="FIELD7_DESC" typeHandler="TmsCodeDescTypeHandler"/>
		<result property="field8_desc" column="FIELD8_DESC" typeHandler="TmsCodeDescTypeHandler"/>
		<result property="field9_desc" column="FIELD9_DESC" typeHandler="TmsCodeDescTypeHandler"/>
		<result property="field10_desc" column="FIELD10_DESC" typeHandler="TmsCodeDescTypeHandler"/>
		<result property="field11_desc" column="FIELD11_DESC" typeHandler="TmsCodeDescTypeHandler"/>
		<result property="field12_desc" column="FIELD12_DESC" typeHandler="TmsCodeDescTypeHandler"/>
