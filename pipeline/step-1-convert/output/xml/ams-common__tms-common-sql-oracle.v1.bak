	<resultMap id="selectTmMstTmcdDtListMap" type="java.util.HashMap">
		<result property="hdkey" 	column="TMCD_HDKEY" />
		<result property="field1" 	column="TMCD_DTKEY" />
		<result property="field2"	column="TMCD_DTNAME" />
	</resultMap>

	<resultMap id="selectAppMessageMap" type="java.util.HashMap" >
		<result property="mulaapmsg_hdkey" column="MULAAPMSG_HDKEY" />
		<result property="displaymessage" column="DISPLAYMESSAGE" />
	</resultMap>

	<select id="selectTtMstTmcdDtCount" resultType="java.lang.Integer">
		SELECT  COUNT(1)
		FROM    TT_MST_TMCD_HD A
		INNER JOIN TT_MST_TMCD_DT B
				ON A.TMCD_HDKEY = B.TMCD_HDKEY
		WHERE   1 = 1
		        AND A.TMCD_HDKEY = #{adcd_hdkey}
		        AND B.LAKEY = #{lakey}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
		        AND (B.TMCD_DTVALUE LIKE '%' || #{value} || '%' OR B.TMCD_DTNAME LIKE '%' || #{value} || '%' OR B.TMCD_DTKEY LIKE '%' || #{value} || '%')
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(type)">
                AND B.TMCD_DTVALUE = #{type}
        </if>
        <if test="adcd_hdkey=='LOGGRPCD'">
                AND B.TMCD_DTKEY IN (
				        SELECT
				            TRIM(SUBSTR(','
				            || LOGGRPCD
				            || ',',INSTR(','
				            || LOGGRPCD
				            || ',',',',1,LEVEL) + 1, (INSTR(','
				            || LOGGRPCD
				            || ',',',',1,LEVEL + 1) - INSTR(','
				            || LOGGRPCD
				            || ',',',',1,LEVEL) ) - 1) )
				        FROM
				            (
				                SELECT
				                    LOGGRPCD
				                FROM
				                    TADMIN_MST_UR
				                WHERE
				                    URKEY = #{surkey}
				                    AND   RSTCLGST = 'Y'
				                UNION ALL
				                SELECT
				                    TMCD_DTKEY
				                FROM
				                    TT_MST_TMCD_DT
				                WHERE
				                    TMCD_HDKEY = 'LOGGRPCD'
				                    AND   (
				                        SELECT
				                            RSTCLGST
				                        FROM
				                            TADMIN_MST_UR
				                        WHERE
				                            URKEY = #{surkey}
				                    ) = 'N'
				            )
				        CONNECT BY
				            LEVEL <![CDATA[ <= ]]> ( LENGTH(LOGGRPCD) - LENGTH(REPLACE(LOGGRPCD,',','') ) + 1 )
				    )
        </if>
	</select>

	<select id="selectTtMstTmcdDt" resultMap="selectCommonCode">
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_TOP} </if>
		SELECT  B.TMCD_DTKEY AS FIELD1
		       ,B.TMCD_DTNAME AS FIELD2
		       ,B.TMCD_DTVALUE AS FIELD3
		       ,B.COMMENTS AS FIELD4
		FROM    TT_MST_TMCD_HD A
		INNER JOIN TT_MST_TMCD_DT B
				ON A.TMCD_HDKEY = B.TMCD_HDKEY
		WHERE   1 = 1
		        AND A.TMCD_HDKEY = #{adcd_hdkey}
		        AND B.LAKEY = #{lakey}
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
		        AND (B.TMCD_DTVALUE LIKE '%' || #{value} || '%' OR B.TMCD_DTNAME LIKE '%' || #{value} || '%' OR B.TMCD_DTKEY LIKE '%' || #{value} || '%')
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(type)">
		        AND B.TMCD_DTVALUE = #{type}
		</if>
		<if test="adcd_hdkey=='LOGGRPCD'">
                AND B.TMCD_DTKEY IN (
				        SELECT
				            TRIM(SUBSTR(','
				            || LOGGRPCD
				            || ',',INSTR(','
				            || LOGGRPCD
				            || ',',',',1,LEVEL) + 1, (INSTR(','
				            || LOGGRPCD
				            || ',',',',1,LEVEL + 1) - INSTR(','
				            || LOGGRPCD
				            || ',',',',1,LEVEL) ) - 1) )
				        FROM
				            (
				                SELECT
				                    LOGGRPCD
				                FROM
				                    TADMIN_MST_UR
				                WHERE
				                    URKEY = #{surkey}
				                    AND   RSTCLGST = 'Y'
				                UNION ALL
				                SELECT
				                    TMCD_DTKEY
				                FROM
				                    TT_MST_TMCD_DT
				                WHERE
				                    TMCD_HDKEY = 'LOGGRPCD'
				                    AND   (
				                        SELECT
				                            RSTCLGST
				                        FROM
				                            TADMIN_MST_UR
				                        WHERE
				                            URKEY = #{surkey}
				                    ) = 'N'
				            )
				        CONNECT BY
				            LEVEL <![CDATA[ <=  ]]>( LENGTH(LOGGRPCD) - LENGTH(REPLACE(LOGGRPCD,',','') ) + 1 )
				    )
        </if>

		        ORDER BY B.TMCD_DTKEY ASC
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_BOTTOM} </if>
	</select>

	<select id="selectTmMstTmcdDtList" resultMap="selectTmMstTmcdDtListMap">
		SELECT TMCD_HDKEY
		      ,TMCD_DTKEY
		      ,TMCD_DTNAME
		 FROM TT_MST_TMCD_DT
		WHERE LAKEY = #{lakey}
     	ORDER BY TMCD_HDKEY , TMCD_DTORDER
	</select>

	<select id="selectTMMstAcCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
		  FROM TT_MST_AC
		 WHERE
		 	   CLOSDATE >= #{sysdate}
		   AND DELYN = 'N'
		  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
			   AND (ACKEY LIKE '%' || #{value} || '%'
			   OR ACTYPE LIKE '%' || #{value} || '%'
			   OR ACNAME LIKE '%' || #{value} || '%')
			</if>
	</select>

	<select id="selectTMMstAc" resultMap="selectCommonCode">
		#{GRIDPAGING_ROWNUMTYPE_TOP}
			SELECT B.*
			  FROM(
					SELECT ACKEY AS FIELD1
					      ,ACNAME AS FIELD2
					      ,ACTYPE AS FIELD3
					      ,#{ctkey} ||';'|| 'ACTYPE' || ';' || ACTYPE AS FIELD3_DESC
					  FROM TT_MST_AC
					 WHERE
					 	   CLOSDATE >= #{sysdate}
					   AND DELYN = 'N'
					  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
						   AND (ACKEY LIKE '%' || #{value} || '%'
						   OR ACTYPE LIKE '%' || #{value} || '%'
						   OR ACNAME LIKE '%' || #{value} || '%')
						</if>
			    	)B
				<choose>
					<when test='sortValue !=null and sortValue != ""'>
						<if test='sortValue == "DESC" and colName !=null'>
						ORDER BY #{colName} DESC
						</if>
						<if test='sortValue == "ASC" and colName !=null'>
						ORDER BY #{colName} ASC
						</if>
					</when>
					<otherwise>
						ORDER BY FIELD1 ASC
					</otherwise>
				</choose>
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>

	<select id="selectTMMstStoreCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
			FROM TT_MST_STORE
	         WHERE CLOSDATE >= #{sysdate}
	           AND DELYN = 'N'
	           AND STORE_TYPE = '0'
			 <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
		       AND (STORE_KEY LIKE '%' || #{value} || '%' OR STORE_NAME LIKE '%'|| #{value} || '%' )
			 </if>
	</select>

	<select id="selectTMMstStore" resultMap="selectCommonCode">
		#{GRIDPAGING_ROWNUMTYPE_TOP}
				SELECT B.*
				  FROM (
					SELECT STORE_KEY	FIELD1
					      ,STORE_NAME	FIELD2
					FROM TT_MST_STORE
			       WHERE CLOSDATE >= #{sysdate}
			         AND DELYN = 'N'
			         AND STORE_TYPE = '0'
					 <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
				       AND (STORE_KEY LIKE '%' || #{value} || '%' OR STORE_NAME LIKE '%'|| #{value} || '%' )
					 </if>
				)B
				<choose>
					<when test='sortValue !=null and sortValue != ""'>
						<if test='sortValue == "DESC" and colName !=null'>
						ORDER BY #{colName} DESC
						</if>
						<if test='sortValue == "ASC" and colName !=null'>
						ORDER BY #{colName} ASC
						</if>
					</when>
					<otherwise>
						ORDER BY FIELD1 ASC
					</otherwise>
				</choose>
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>

	<select id="selectTTMstOwCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
		  FROM TT_MST_OW
		 WHERE DELYN = 'N'
		   AND CLOSDATE >= #{sysdate}
		  <if test="OWKEY_SELECTION_VALUE != null and OWKEY_SELECTION_VALUE != ''" >
		     AND OWKEY IN
			  <foreach item="OWKEY_SELECTION_VALUE" index="index" collection="OWKEY_SELECTION_VALUE" open="(" separator="," close=")">
			  	#{OWKEY_SELECTION_VALUE}
			  </foreach>
		  </if>
		 <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
		   AND (OWKEY LIKE '%' || #{value} || '%' OR OWNAME LIKE '%' || #{value} || '%')
		 </if>
	</select>

	<select id="selectTTMstOw" resultMap="selectCommonCode">
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_TOP} </if>
						SELECT	B.*
						  FROM(
								SELECT 	OWKEY AS FIELD1
										,OWNAME AS FIELD2
								FROM 	TT_MST_OW
								WHERE   DELYN = 'N'
								  AND   CLOSDATE >= #{sysdate}
								  <if test="OWKEY_SELECTION_VALUE != null and OWKEY_SELECTION_VALUE != ''" >
								     AND OWKEY IN
									  <foreach item="OWKEY_SELECTION_VALUE" index="index" collection="OWKEY_SELECTION_VALUE" open="(" separator="," close=")">
									  	#{OWKEY_SELECTION_VALUE}
									  </foreach>
								  </if>
								<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
									AND (OWKEY LIKE '%' || #{value} || '%' OR OWNAME LIKE '%' || #{value} || '%')
								</if>
					 		)B
				 		<choose>
							<when test='sortValue !=null and sortValue != ""'>
								<if test='sortValue == "DESC" and colName !=null'>
								ORDER BY #{colName} DESC
								</if>
								<if test='sortValue == "ASC" and colName !=null'>
								ORDER BY #{colName} ASC
								</if>
							</when>
							<otherwise>
								ORDER BY FIELD1 ASC
							</otherwise>
						</choose>
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_BOTTOM} </if>
	</select>

	<select id="selectTTMstCtCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
		  FROM TT_MST_CT
		 WHERE
		      CLOSDATE >= #{sysdate}
		    <if test="CTKEY_SELECTION_VALUE != null and CTKEY_SELECTION_VALUE != ''" >
		    	AND CTKEY IN
				<foreach item="CTKEY_SELECTION_VALUE" index="index" collection="CTKEY_SELECTION_VALUE" open="(" separator="," close=")">
					#{CTKEY_SELECTION_VALUE}
				</foreach>
		    </if>
		  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
		  AND (CTKEY LIKE '%' || #{value} || '%' OR CTNAME LIKE '%' || #{value} || '%')
		 </if>
	</select>

	<select id="selectTTMstCt" resultMap="selectCommonCode">
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_TOP} </if>
						SELECT	B.*
						  FROM(

							SELECT 	CTKEY AS FIELD1
									,CTNAME AS FIELD2
									,CTTYPE AS FIELD3
									,'CTTYPE' || ';' || CTTYPE AS FIELD3_DESC
							FROM 	TT_MST_CT
							WHERE	CLOSDATE >= #{sysdate}
						    <if test="CTKEY_SELECTION_VALUE != null and CTKEY_SELECTION_VALUE != ''" >
						    	AND CTKEY IN
								<foreach item="CTKEY_SELECTION_VALUE" index="index" collection="CTKEY_SELECTION_VALUE" open="(" separator="," close=")">
									#{CTKEY_SELECTION_VALUE}
								</foreach>
						    </if>
							<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
								AND (CTKEY LIKE '%' || #{value} || '%' OR CTNAME LIKE '%' || #{value} || '%')
							</if>
						)B
			 		<choose>
						<when test='sortValue !=null and sortValue != ""'>
							<if test='sortValue == "DESC" and colName !=null'>
							ORDER BY #{colName} DESC
							</if>
							<if test='sortValue == "ASC" and colName !=null'>
							ORDER BY #{colName} ASC
							</if>
						</when>
						<otherwise>
							ORDER BY FIELD1 ASC
						</otherwise>
					</choose>
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_BOTTOM} </if>
	</select>

	<select id="selectTTMstIcgrCount" resultType="java.lang.Integer">
		SELECT COUNT(1)
	  	  FROM TT_MST_ICGR
		  <where>
                     CLOSDATE >= #{sysdate}
				<if test="OWKEY_AUTH_LIST != null and OWKEY_AUTH_LIST.size > 0" >
					 AND OWKEY IN
					<foreach item="OWKEY_AUTH_LIST" index="index" collection="OWKEY_AUTH_LIST"
						open="(" separator="," close=")">
						#{OWKEY_AUTH_LIST}
					</foreach>
				</if>
			  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
				 AND (ICGRKEY LIKE '%' || #{value} || '%' OR ICGRNAME LIKE '%' || #{value} || '%')
				</if>
		  </where>

	</select>

	<select id="selectTTMstIcgr" resultMap="selectCommonCode">
		#{GRIDPAGING_ROWNUMTYPE_TOP}
                   SELECT B.*
						FROM(
		                    SELECT ICGRKEY AS FIELD1
		                          ,ICGRNAME AS FIELD2
		                          ,OWKEY AS FIELD3
		                        FROM TT_MST_ICGR
							  <where>
					                 CLOSDATE >= #{sysdate}
									<if test="OWKEY_AUTH_LIST != null and OWKEY_AUTH_LIST.size > 0" >
										 AND OWKEY IN
										<foreach item="OWKEY_AUTH_LIST" index="index" collection="OWKEY_AUTH_LIST"
											open="(" separator="," close=")">
											#{OWKEY_AUTH_LIST}
										</foreach>
									</if>
								  	<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
									 AND (ICGRKEY LIKE '%' || #{value} || '%' OR ICGRNAME LIKE '%' || #{value} || '%')
									</if>
							  </where>
                  				)B
							<choose>
								<when test='sortValue !=null and sortValue != ""'>
									<if test='sortValue == "DESC" and colName !=null'>
									ORDER BY #{colName} DESC
									</if>
									<if test='sortValue == "ASC" and colName !=null'>
									ORDER BY #{colName} ASC
									</if>
								</when>
								<otherwise>
									ORDER BY FIELD1 ASC
								</otherwise>
							</choose>
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>

	<select id="selectTTMstIcsbCount" resultType="java.lang.Integer" >
		SELECT COUNT(1)
		  FROM TT_MST_ICSB
		 WHERE
		       CLOSDATE >= #{sysdate}
		<if test="OWKEY_AUTH_LIST != null and OWKEY_AUTH_LIST.size > 0" >
			 AND OWKEY IN
			<foreach item="OWKEY_AUTH_LIST" index="index" collection="OWKEY_AUTH_LIST"
				open="(" separator="," close=")">
				#{OWKEY_AUTH_LIST}
			</foreach>
		</if>
		  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
		 	AND (ICKEY LIKE '%' || #{value} || '%' OR SBKEY LIKE '%' || #{value} || '%' OR OWKEY LIKE '%' || #{value} || '%' OR ICUTTYPE LIKE '%' || #{value} || '%')
		  </if>
	</select>

	<select id="selectTTMstIcsb" resultMap="selectCommonCode">
		#{GRIDPAGING_ROWNUMTYPE_TOP}

						SELECT B.*
							FROM(
								SELECT  SBKEY AS FIELD1
										,ICKEY AS FIELD2
										,OWKEY AS FIELD3
										,ICUTTYPE AS FIELD4
				                        ,'ICUTTYPE' ||';'|| ICUTTYPE AS FIELD4_DESC
								  FROM TT_MST_ICSB
								 WHERE
								       CLOSDATE >= #{sysdate}
									<if test="OWKEY_AUTH_LIST != null and OWKEY_AUTH_LIST.size > 0" >
										 AND OWKEY IN
										<foreach item="OWKEY_AUTH_LIST" index="index" collection="OWKEY_AUTH_LIST"
											open="(" separator="," close=")">
											#{OWKEY_AUTH_LIST}
										</foreach>
									</if>
								  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
								 	AND (ICKEY LIKE '%' || #{value} || '%' OR SBKEY LIKE '%' || #{value} || '%' OR OWKEY LIKE '%' || #{value} || '%' OR ICUTTYPE LIKE '%' || #{value} || '%')
								  </if>
							 	)B
								<choose>
									<when test='sortValue !=null and sortValue != ""'>
										<if test='sortValue == "DESC" and colName !=null'>
										ORDER BY #{colName} DESC
										</if>
										<if test='sortValue == "ASC" and colName !=null'>
										ORDER BY #{colName} ASC
										</if>
									</when>
									<otherwise>
										ORDER BY FIELD1 ASC
									</otherwise>
								</choose>
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>

    <!-- PLANID -->
    <select id="selectTtPlanTCount" resultType="java.lang.Integer">
        SELECT  COUNT(1)
        FROM    TT_PLAN_T   P
        WHERE   1 = 1
                AND P.DELYN = 'N'
            <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
                AND (P.PLANID LIKE '%' || #{value} || '%' OR P.PLANDESC LIKE '%' || #{value} || '%')
            </if>
            <if test="@com.kns.framework.util.StringUtil@isNotEmpty(urkey)" >
                AND NOT EXISTS (SELECT 1 FROM TT_PLANAUTHO_T PA WHERE P.PLANID = PA.PLANID AND PA.DELYN = 'N' AND PA.URKEY = #{urkey})
            </if>
    </select>

    <select id="selectTtPlanTList" resultMap="selectCommonCode">
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_TOP} </if>
	        SELECT  P.PLANID    AS FIELD1
	               ,P.PLANDESC  AS FIELD2
	        FROM    TT_PLAN_T   P
	        WHERE   1 = 1
	                AND P.DELYN = 'N'
	            <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
	                AND (P.PLANID LIKE '%' || #{value} || '%' OR P.PLANDESC LIKE '%' || #{value} || '%')
	            </if>
	            <if test="@com.kns.framework.util.StringUtil@isNotEmpty(urkey)" >
	       			AND NOT EXISTS (SELECT 1 FROM TT_PLANAUTHO_T PA WHERE P.PLANID = PA.PLANID AND PA.DELYN = 'N' AND PA.URKEY = #{urkey})
	   			</if>
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_BOTTOM} </if>
    </select>

    <!-- CARRCD -->
    <select id="selectTtCarrTCount" resultType="java.lang.Integer">
        SELECT  COUNT(1)
        FROM    TADMIN_MST_CARR
        WHERE   1 = 1
                AND DELYN = 'N'
            <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
                AND (CARRCD LIKE '%' || #{value} || '%' OR CARRNM LIKE '%' || #{value} || '%')
            </if>
    </select>

    <select id="selectTtCarrTList" resultMap="selectCommonCode">
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_TOP} </if>
            SELECT  CARRCD  AS FIELD1
                   ,CARRNM  AS FIELD2
            FROM    TADMIN_MST_CARR
            WHERE   1 = 1
                    <!-- AND DELYN = 'N' --> <!--과거 실적 조회도 모두 조회되도록 하기 위함 -->
                <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
                    AND (CARRCD LIKE '%' || #{value} || '%' OR CARRNM LIKE '%' || #{value} || '%')
                </if>
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_BOTTOM} </if>
    </select>

    <!-- CUSTCD -->
    <select id="selectTtCustTCount" resultType="java.lang.Integer">
        SELECT  COUNT(1)
        FROM    TT_MST_OW
        WHERE   1 = 1
                AND DELYN = 'N'
			  <if test="OWKEY_SELECTION_VALUE != null and OWKEY_SELECTION_VALUE != ''" >
			     AND OWKEY IN
				  <foreach item="OWKEY_SELECTION_VALUE" index="index" collection="OWKEY_SELECTION_VALUE" open="(" separator="," close=")">
				  	#{OWKEY_SELECTION_VALUE}
				  </foreach>
			  </if>
            <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
                AND (OWKEY LIKE '%' || #{value} || '%' OR OWNAME LIKE '%' || #{value} || '%')
            </if>
    </select>

    <select id="selectTtCustTList" resultMap="selectCommonCode">
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_TOP} </if>
            SELECT  OWKEY  AS FIELD1
                   ,OWNAME  AS FIELD2
            FROM    TT_MST_OW
            WHERE   1 = 1
                    AND DELYN = 'N'
				  <if test="OWKEY_SELECTION_VALUE != null and OWKEY_SELECTION_VALUE != ''" >
				     AND OWKEY IN
					  <foreach item="OWKEY_SELECTION_VALUE" index="index" collection="OWKEY_SELECTION_VALUE" open="(" separator="," close=")">
					  	#{OWKEY_SELECTION_VALUE}
					  </foreach>
				  </if>
                <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
                    AND (OWKEY LIKE '%' || #{value} || '%' OR OWNAME LIKE '%' || #{value} || '%')
                </if>
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_BOTTOM} </if>
    </select>

    <!-- SMESTM -->
    <select id="selectTtSmEstmTCount" resultType="java.lang.Integer">
        SELECT
        	COUNT(1)
        FROM
        	TT_SM_ESTM_T
        WHERE   1 = 1
        	AND DELYN = 'N'
            <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
                AND (ESTMDESC LIKE '%' || #{value} || '%')
            </if>
    </select>

    <select id="selectTtSmEstmTList" resultMap="selectCommonCode">
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_TOP} </if>
              SELECT
	              	 ESTMDESC AS FIELD1
	              	,FRMDATE AS FIELD2
	              	,TODATE AS FIELD3
	              	,SMESTMID FIELD4
              FROM
              	TT_SM_ESTM_T
              WHERE   1 = 1
                	AND   DELYN = 'N'
                  <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
		      		AND (ESTMDESC LIKE '%' || #{value} || '%')
		   		</if>
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_BOTTOM} </if>
    </select>

      <!-- SMESTM -->
    <select id="selectTtSmEstmHdCount" resultType="java.lang.Integer">
