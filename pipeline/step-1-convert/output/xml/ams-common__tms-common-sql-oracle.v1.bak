    <!-- ITMGRPCD -->
    <select id="selectTtItmGrpTCount" resultType="java.lang.Integer">
        SELECT  COUNT(1)
        FROM    TT_ITM_GRP_T
        WHERE   1 = 1
                AND DELYN = 'N'
            <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
                AND (ITMGRPCD LIKE '%' || #{value} || '%' OR ITMGRPDESC LIKE '%' || #{value} || '%')
            </if>
            <if test="@com.kns.framework.util.StringUtil@isNotEmpty(mstitmgrpcd)" >
                AND MSTITMGRPCD = #{mstitmgrpcd}
            </if>
            <if test="@com.kns.framework.util.StringUtil@isEmpty(mstitmgrpcd)" >
                AND (MSTITMGRPCD IS NULL OR MSTITMGRPCD = '')
            </if>
    </select>

    <select id="selectTtItmGrpTList" resultMap="selectCommonCode">
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_TOP} </if>
                            SELECT  ITMGRPCD    AS FIELD1
                                   ,ITMGRPDESC  AS FIELD2
                            FROM    TT_ITM_GRP_T
                            WHERE   1 = 1
                                    AND DELYN = 'N'
                                <if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
                                    AND (ITMGRPCD LIKE '%' || #{value} || '%' OR ITMGRPDESC LIKE '%' || #{value} || '%')
                                </if>
                                <if test="@com.kns.framework.util.StringUtil@isNotEmpty(mstitmgrpcd)" >
                                    AND MSTITMGRPCD = #{mstitmgrpcd}
                                </if>
                                <if test="@com.kns.framework.util.StringUtil@isEmpty(mstitmgrpcd)" >
					                AND (MSTITMGRPCD IS NULL OR MSTITMGRPCD = '')
					            </if>
		<if test="type != 'combo'"> #{GRIDPAGING_ROWNUMTYPE_BOTTOM} </if>
    </select>

