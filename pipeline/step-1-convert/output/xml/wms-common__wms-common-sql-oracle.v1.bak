			, A.ACKEY
			, B.ACNAME
			, A.STORE_KEY
			, C.STORE_NAME
		<include refid="selectTWorkInfoReqSql"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstToLc">
		FROM
			  TWORK_MST_AR A
		INNER JOIN TWORK_MST_LC B
				ON A.CTKEY = B.CTKEY
			   AND A.ARKEY = B.ARKEY
		WHERE A.CTKEY = COALESCE(#{ctkey}, #{sctkey})
		AND A.WRHOUS_SE = 'GNRL'
		AND A.BONDTYPE = '1'
		AND B.LCKEY NOT LIKE 'PICK%'

		<if test="ctkeyList != null and ctkeyList.size > 0">
			AND A.CTKEY IN
			<foreach item="ctkey" collection="ctkeyList"
					 open="(" separator="," close=")">
				#{ctkey}
			</foreach>
		</if>

		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
			<choose>
				<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
					AND B.LCKEY = #{value}
				</when>
				<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
					AND (
					B.LCKEY ~ #{value}
					OR
					B.LCTYPE ~ #{value}
					OR
					B.LCHOLDTYPE ~ #{value}
					)
				</when>
				<otherwise>
					AND (
					B.LCKEY LIKE '%' || #{value} || '%'
					OR
					B.LCTYPE LIKE '%' || #{value} || '%'
					OR
					B.LCHOLDTYPE LIKE '%' || #{value} || '%'
					)
				</otherwise>
			</choose>
		</if>
	</sql>

