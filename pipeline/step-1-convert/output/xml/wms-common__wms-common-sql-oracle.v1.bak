						A.SBKEY LIKE '%' || #{value} || '%'
						OR
						A.ICKEY LIKE '%' || #{value} || '%'
						OR
						A.OWKEY LIKE '%' || #{value} || '%'
						OR
						A.ICUTTYPE LIKE '%' || #{value} || '%'
