						A.WAHDKEY LIKE '%' || #{value} || '%'
						OR
						A.WAHDNM LIKE '%' || #{value} || '%'
						OR
						A.OWKEY LIKE '%' || #{value} || '%'
						OR
						A.WAWKSTATUSCD LIKE '%' || #{value} || '%'
						OR
						A.WAHDDAY LIKE '%' || #{value} || '%'
