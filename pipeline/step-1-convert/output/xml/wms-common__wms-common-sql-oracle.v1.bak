<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
	
<mapper namespace="com.daiso.wms.common.mapper.CommonMapper">

	<sql id="sql_pagingTop">
		<if test='@com.kns.framework.util.StringUtil@isNotEmpty(pagingYn) and "Y".equals(pagingYn) and type != "combo"'>
			#{GRIDPAGING_ROWNUMTYPE_TOP}
			SELECT B.* FROM (
		</if>
	</sql>

	<sql id="sql_pagingBottom">
		<choose>
			<when test='@com.kns.framework.util.StringUtil@isNotEmpty(pagingYn) and "Y".equals(pagingYn) and type != "combo"'>
				) B
				<include refid="sql_sort"/>
				#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
			</when>
			<otherwise>
				<include refid="sql_sort"/>
			</otherwise>
		</choose>
	</sql>

	<sql id="sql_sort">
		<choose>
			<otherwise>
				ORDER BY
				FIELD1 ASC
			</otherwise>
		</choose>
	</sql>

	<sql id="sql_Tcode">
		WITH T_CODE AS (
			SELECT
			      B.CTKEY
			    , B.CTCDHDKEY
				, B.CTCDDTKEY
				, B.CTCDDTNM
			FROM TWORK_MST_CTCD_HD A
			INNER JOIN TWORK_MST_CTCD_DT B
				ON B.CTKEY = A.CTKEY AND B.CTCDHDKEY = A.CTCDHDKEY

			<where>
				AND A.DELYN = 'N'
				AND B.DELYN = 'N'

				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(lakey)">
						AND B.LAKEY = #{lakey}
				</if>
			</where>
		)
	</sql>

	<sql id="sql_tWorkMstCtcdDt">
		  FROM  TWORK_MST_CTCD_HD A
		  INNER JOIN  TWORK_MST_CTCD_DT B
		  		  ON A.CTCDHDKEY = B.CTCDHDKEY
				 AND A.CTKEY = B.CTKEY

		<where>
			AND A.CTKEY = COALESCE(#{ctkey}, #{sctkey})
			AND A.CTCDHDKEY = #{ctcdhdkey}
			AND B.LAKEY = #{lakey}

			<if test="ctkeyList != null and ctkeyList.size > 0">
				AND A.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND B.CTCDDTKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						B.CTCDDTKEY ~ #{value}
						OR
						B.CTCDDTNM ~ #{value}
						OR
						B.CTCDDTVAL ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						B.CTCDDTKEY LIKE '%' || #{value} || '%'
						OR
						B.CTCDDTNM LIKE '%' || #{value} || '%'
						OR
						B.CTCDDTVAL LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<select id="selectTWorkMstCtcdDtMobileCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstCtcdDtMobileCount */
		SELECT COUNT(1)
		<include refid="sql_tWorkMstCtcdDt"/>
	</select>

	<select id="selectTWorkMstCtcdDtMobile" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstCtcdDtMobile */
		<include refid="sql_pagingTop"/>
		SELECT B.CTCD_DTKEY AS FIELD1
			 , B.CTCD_DTNAME AS FIELD2
			 , B.COMMENTS AS FIELD3
			 , B.CTCD_DTKEY
			 , B.CTCD_DTNAME
			 , B.COMMENTS
		<include refid="sql_tWorkMstCtcdDt"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<select id="selectTWorkMstCtcdDtCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstCtcdDtCount */
		SELECT COUNT(1)
		<include refid="sql_tWorkMstCtcdDt"/>
	</select>

	<select id="selectTWorkMstCtcdDt" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstCtcdDt */
		<include refid="sql_pagingTop"/>

		SELECT B.CTCDDTKEY AS FIELD1
			 , B.CTCDDTNM AS FIELD2
			 , B.CTCDDTVAL AS FIELD3
			 , B.CMT AS FIELD4
			 , B.CTCDDTKEY
			 , B.CTCDDTNM
			 , B.CTCDDTVAL
			 , B.CMT
			 , B.CTCDDTORD

		<include refid="sql_tWorkMstCtcdDt"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstAc">
		<where>
			AND A.CTKEY = COALESCE(#{ctkey}, #{sctkey})
			<!--AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}-->
			AND A.DELYN = 'N'

			<if test="ctkeyList != null and ctkeyList.size > 0">
				AND A.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<!--<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
				AND A.OWKEY = #{owkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(loggrpcd)">
				AND A.LOGGRPCD = #{loggrpcd}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(dckey)">
				AND A.DCKEY = #{dckey}
			</if>-->

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.ACKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.ACKEY ~ #{value}
						OR
						A.ACNM ~ #{value}
						OR
						A.ACTYPECD ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.ACKEY LIKE '%' || #{value} || '%'
						OR
						A.ACNM LIKE '%' || #{value} || '%'
						OR
						A.ACTYPECD LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<select id="selectTWorkMstAcCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstAcCount */
		SELECT COUNT(1)
		FROM TWORK_MST_AC A
		<include refid="sql_tWorkMstAc"/>
	</select>

	<select id="selectTWorkMstAc" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstAc */
		<include refid="sql_Tcode"/>
		<include refid="sql_pagingTop"/>

		SELECT
		      A.ACKEY AS FIELD1
			, A.ACNM AS FIELD2
			, B.CTCDDTNM AS FIELD3
			, C.CTCDDTNM AS FIELD4
			, D.CTCDDTNM AS FIELD5
		    , A.ACKEY
			, A.ACNM
			, A.ACTYPECD
			, A.LOGGRPCD
			, A.DCKEY
		FROM TWORK_MST_AC A
		LEFT OUTER JOIN T_CODE B
			ON B.CTKEY = A.CTKEY AND B.CTCDHDKEY = 'ACTYPE' AND B.CTCDDTKEY = A.ACTYPECD
		LEFT OUTER JOIN T_CODE C
			ON C.CTKEY = A.CTKEY AND C.CTCDHDKEY = 'LOGGRPCD' AND C.CTCDDTKEY = A.LOGGRPCD
		LEFT OUTER JOIN T_CODE D
			ON D.CTKEY = A.CTKEY AND D.CTCDHDKEY = 'DCKEY' AND D.CTCDDTKEY = A.DCKEY

		<include refid="sql_tWorkMstAc"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstOw">
		/* wms-common-sql-oracle.xml - sql_tWorkMstOw - common 화주 조회 SQL */
		FROM TWORK_MST_OW A

		<where>
			<!--AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}-->
			<choose>
				<when test="owkeyList != null and owkeyList.size > 0">
					AND A.OWKEY IN
					<foreach item="owkey" collection="owkeyList"
							 open="(" separator="," close=")">
						#{owkey}
					</foreach>
				</when>
				<otherwise>
					AND 1 = 2 -- 센터별 화주 권한이 없는경우
				</otherwise>
			</choose>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.OWKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.OWKEY ~ #{value}
						OR
						A.OWNM ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.OWKEY LIKE '%' || #{value} || '%'
						OR
						A.OWNM LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<select id="selectTWorkMstOwCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstOwCount - common 화주 조회 카운트 */
		SELECT COUNT(1)
		<include refid="sql_tWorkMstOw"/>
	</select>

	<select id="selectTWorkMstOw" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstOw - common 화주 조회 */
		<include refid="sql_pagingTop"/>

		SELECT
		      OWKEY AS FIELD1
			, OWNM AS FIELD2
			, OWKEY
			, OWNM

		<include refid="sql_tWorkMstOw"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstCt">
		/* wms-common-sql-oracle.xml - sql_tWorkMstCt - common 센터 조회 SQL */
		<where>
			AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}

			<if test="ctkeyList != null and ctkeyList.size > 0" >
				AND A.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.CTKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.CTKEY ~ #{value}
						OR
						A.CTNM ~ #{value}
						OR
						B.CTCDDTNM ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.CTKEY LIKE '%' || #{value} || '%'
						OR
						A.CTNM LIKE '%' || #{value} || '%'
						OR
						B.CTCDDTNM LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<select id="selectTWorkMstCtCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstCtCount - common 센터 조회 카운트 */
		<include refid="sql_Tcode"/>
		SELECT COUNT(1)
		FROM TWORK_MST_CT A
        LEFT OUTER JOIN T_CODE B
        			 ON B.CTKEY = A.CTKEY
        			AND B.CTCDHDKEY = 'CTTYPE'
        			AND B.CTCDDTKEY = A.CTTYPECD
		<include refid="sql_tWorkMstCt"/>
	</select>

	<select id="selectTWorkMstCt" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstCt - common 센터 조회 */
		<include refid="sql_Tcode"/>
		<include refid="sql_pagingTop"/>

		SELECT
		      A.CTKEY AS FIELD1
			, A.CTNM AS FIELD2
			, B.CTCDDTNM AS FIELD3
			, A.CTKEY
			, A.CTNM
			, A.CTTYPECD
		FROM TWORK_MST_CT A
		LEFT OUTER JOIN T_CODE B
					 ON B.CTKEY = A.CTKEY
					AND B.CTCDHDKEY = 'CTTYPECD'
					AND B.CTCDDTKEY = A.CTTYPECD
		<include refid="sql_tWorkMstCt"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tAdminMstUr">
		FROM TADMIN_MST_UR A
		INNER JOIN TADMIN_MST_URGR B
			ON A.URGRKEY = B.URGRKEY

		<where>
			AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.URKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.URKEY ~ #{value}
						OR
						A.URNM ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.URKEY LIKE '%' || #{value} || '%'
						OR
						A.URNM LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<select id="selectTAdminMstUrCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTAdminMstUrCount */
		SELECT COUNT(1)
		<include refid="sql_tAdminMstUr"/>
	</select>

	<select id="selectTAdminMstUr" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTAdminMstUr */
		<include refid="sql_pagingTop"/>

		SELECT
			  A.URKEY AS FIELD1
			, A.URNM AS FIELD2
			, A.URKEY
			, A.URNM
			, A.URGRKEY
			, B.URGRNM

		<include refid="sql_tAdminMstUr"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstIcgr">
		<where>
			AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}
			AND A.CTKEY = COALESCE(#{ctkey}, #{sctkey})

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
				AND A.OWKEY = #{owkey}
			</if>

			<if test="ctkeyList != null and ctkeyList.size > 0">
				AND A.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="owkeyList != null and owkeyList.size > 0">
				AND A.OWKEY IN
				<foreach item="owkey" collection="owkeyList"
						 open="(" separator="," close=")">
					#{owkey}
				</foreach>
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.ICGRPKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.ICGRPKEY ~ #{value}
						OR
						A.ICGRPNM ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.ICGRPKEY LIKE '%' || #{value} || '%'
						OR
						A.ICGRPNM LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<select id="selectTWorkMstIcgrCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstIcgrCount */
		SELECT COUNT(1)
		FROM TWORK_MST_ICGR A
		<include refid="sql_tWorkMstIcgr"/>
	</select>

	<select id="selectTWorkMstIcgr" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstIcgr */
		<include refid="sql_Tcode"/>
		<include refid="sql_pagingTop"/>

		SELECT
		      A.ICGRPKEY AS FIELD1
			, A.ICGRPNM AS FIELD2
			, B.CTCDDTNM AS FIELD3
			, A.OWKEY AS FIELD4
			, A.ICGRPKEY
			, A.ICGRPNM
			, A.ICGRPTYPECD
			, A.OWKEY
		FROM TWORK_MST_ICGR A
		LEFT OUTER JOIN T_CODE B
			ON B.CTKEY = A.CTKEY AND B.CTCDHDKEY = 'ICGRPTYPECD' AND B.CTCDDTKEY = A.ICGRPTYPECD

		<include refid="sql_tWorkMstIcgr"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstIcut">
		FROM
			TWORK_MST_ICUT A
		INNER JOIN TWORK_MST_ICUTXTYPE B
			ON B.CTKEY = A.CTKEY AND B.OWKEY = A.OWKEY AND B.ICUTKEY = A.ICUTKEY
		LEFT OUTER JOIN T_CODE C
			ON C.CTKEY = B.CTKEY AND C.CTCD_HDKEY = 'ICUTTYPE' AND C.CTCD_DTKEY = B.ICUTTYPE

		<where>
			AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}
			AND A.CTKEY = COALESCE(#{ctkey}, #{sctkey})

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
				AND A.OWKEY = #{owkey}
			</if>

			<if test="ctkeyList != null and ctkeyList.size > 0">
				AND A.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="owkeyList != null and owkeyList.size > 0">
				AND A.OWKEY IN
				<foreach item="owkey" collection="owkeyList"
						 open="(" separator="," close=")">
					#{owkey}
				</foreach>
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.ICUTKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.ICUTKEY ~ #{value}
						OR
						C.CTCD_DTNAME ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.ICUTKEY LIKE '%' || #{value} || '%'
						OR
						C.CTCD_DTNAME LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<select id="selectTWorkMstIcutCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstIcutCount */
		<include refid="sql_Tcode"/>
		SELECT COUNT(1)
		<include refid="sql_tWorkMstIcut"/>
	</select>

	<select id="selectTWorkMstIcut" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstIcut */
		<include refid="sql_Tcode"/>
		<include refid="sql_pagingTop"/>

		SELECT
		      A.ICUTKEY AS FIELD1
			, C.CTCD_DTNAME AS FIELD2
			, B.ICUTQTY AS FIELD3
			, A.OWKEY AS FIELD4
			, A.ICUTKEY
			, B.ICUTTYPE
			, B.ICUTQTY
			, A.OWKEY
		<include refid="sql_tWorkMstIcut"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstIcMob">
		<where>
			AND A.CLOSDATE >= #{sysdate}
			AND A.DELYN = 'N'
			AND A.CTKEY = COALESCE(#{ctkey}, #{sctkey})

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
				AND A.OWKEY = #{owkey}
			</if>

			<if test="ctkeyList != null and ctkeyList.size > 0">
				AND A.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="owkeyList != null and owkeyList.size > 0">
				AND A.OWKEY IN
				<foreach item="owkey" collection="owkeyList"
						 open="(" separator="," close=")">
					#{owkey}
				</foreach>
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ackey)">
				AND A.ACKEY = #{ackey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(loggrpcd)">
				AND A.LOGGRPCD = #{loggrpcd}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.ICKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.ICKEY ~ #{value}
						OR
						A.ICNAME ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.ICKEY LIKE '%' || #{value} || '%'
						OR
						A.ICNAME LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<select id="selectTWorkMstIcMobileCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstIcMobileCount */
		SELECT COUNT(1)
		FROM TWORK_MST_IC A
		<include refid="sql_tWorkMstIcMob"/>
	</select>

	<select id="selectTWorkMstIcMobile" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstIcMobile */
		<include refid="sql_Tcode"/>
		<include refid="sql_pagingTop"/>

		SELECT
			  A.ICKEY AS FIELD1
			, A.ICNAME AS FIELD2
			, A.ICUTKEY AS FIELD3
			, B.CTCD_DTNAME AS FIELD4
			, A.SPEC AS FIELD5
			, C.CTCD_DTNAME AS FIELD6
			, D.CTCD_DTNAME AS FIELD7
		    , A.ICKEY
			, A.ORDTYPE
			, A.ICUTKEY
			, A.UOM
			, A.SPEC
			, A.ICGRKEY
			, A.LOGGRPCD
		FROM  TWORK_MST_IC A
		LEFT OUTER JOIN T_CODE B
			ON B.CTKEY = A.CTKEY AND B.CTCD_HDKEY = 'ICUTTYPE' AND B.CTCD_DTKEY = A.UOM
		LEFT OUTER JOIN T_CODE C
			ON C.CTKEY = A.CTKEY AND C.CTCD_HDKEY = 'ICGRKEY' AND C.CTCD_DTKEY = A.ICGRKEY
		LEFT OUTER JOIN T_CODE D
			ON D.CTKEY = A.CTKEY AND D.CTCD_HDKEY = 'LOGGRPCD' AND D.CTCD_DTKEY = A.LOGGRPCD
		LEFT OUTER JOIN T_CODE E
			ON E.CTKEY = A.CTKEY AND E.CTCD_HDKEY = 'ORDTYPE' AND E.CTCD_DTKEY = A.ORDTYPE

		<include refid="sql_tWorkMstIcMob"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstIc">
		<where>
			AND A.CTKEY = COALESCE(#{ctkey}, #{sctkey})

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
				AND A.OWKEY = #{owkey}
			</if>

