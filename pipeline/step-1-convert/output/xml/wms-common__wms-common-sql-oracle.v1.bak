	<sql id="sql_icxIcuttypeXQty">
		FROM TWORK_MST_IC A
		INNER JOIN TWORK_MST_ICUT B
			ON B.CTKEY = A.CTKEY AND B.OWKEY = A.OWKEY AND B.ICUNITKEY = A.ICUNITKEY
		INNER JOIN TWORK_MST_ICUTXTYPE C
			ON C.CTKEY = B.CTKEY AND C.OWKEY = B.OWKEY AND C.ICUNITKEY = B.ICUNITKEY
		LEFT OUTER JOIN T_CODE D
			ON D.CTKEY = C.CTKEY AND D.CTCDHDKEY = 'ICUNITTYPECD' AND D.CTCDDTKEY = C.ICUNITTYPECD
		LEFT OUTER JOIN T_CODE E
			ON E.CTKEY = A.CTKEY AND E.CTCDHDKEY = 'ICTMPRDIVCD' AND E.CTCDDTKEY = A.ICTMPRDIVCD

		<where>
			AND A.CTKEY = COALESCE(#{ctkey}, #{sctkey})

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
				AND A.OWKEY = #{owkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ackey)">
				AND A.ACKEY = #{ackey}
			</if>

			<if test="ctkeyList != null and ctkeyList.size > 0">
				AND A.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="owkeyList != null and owkeyList.size > 0">
				AND A.OWKEY IN
				<foreach item="owkey" collection="owkeyList"
						 open="(" separator="," close=")">
					#{owkey}
				</foreach>
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.ICKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.ICKEY ~ #{value}
						OR
						A.ICNM ~ #{value}
						OR
						C.ICUNITKEY ~ #{value}
						OR
						C.ICUNITTYPECD ~ #{value}
						OR
						C.ICUNITQTY ~ #{value}
						OR
						A.ICTMPRDIVCD ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.ICKEY LIKE '%' || #{value} || '%'
						OR
						A.ICNM LIKE '%' || #{value} || '%'
						OR
						C.ICUNITKEY LIKE '%' || #{value} || '%'
						OR
						C.ICUNITTYPECD LIKE '%' || #{value} || '%'
						OR
						C.ICUNITQTY LIKE '%' || #{value} || '%'
						OR
						A.ICTMPRDIVCD LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

