	<select id="selectTWorkMstIcCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstIcCount */
		SELECT COUNT(1)
		FROM TWORK_MST_IC A
		<include refid="sql_tWorkMstIc"/>
	</select>

	<select id="selectTWorkMstIc" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstIc */
		WITH T_CODE AS (
			SELECT
			      B.CTKEY
			    , B.CTCDHDKEY
				, B.CTCDDTKEY
				, B.CTCDDTNM
			FROM TWORK_MST_CTCD_HD A
			INNER JOIN TWORK_MST_CTCD_DT B
				ON B.CTKEY = A.CTKEY AND B.CTCDHDKEY = A.CTCDHDKEY
			<where>
				AND A.DELYN = 'N'
				AND B.DELYN = 'N'
				AND B.CTCDHDKEY IN ('ICUNITTYPECD', 'ICGRPKEY', 'ICTMPRDIVCD')
				<if test="@com.kns.framework.util.StringUtil@isNotEmpty(lakey)">
					AND B.LAKEY = #{lakey}
				</if>
			</where>
		)
		<include refid="sql_pagingTop"/>

		SELECT
		      A.ICKEY AS FIELD1
			, A.ICNM AS FIELD2
		    , B.CTCDDTNM AS FIELD3
			, F.ICGRPNM AS FIELD4
			, A.EXPCKYN AS FIELD5
		    , A.EXPCKTYPECD AS FIELD6
		    , A.ICKEY
		    , A.ICNM
			, A.ICUNITKEY
			, B.CTCDDTNM AS ICUNITNM
			, A.ICGRPTYPECD
			, A.ICGRPKEY
			, F.ICGRPNM
			, A.EXPCKYN
			, A.EXPCKTYPECD
		FROM TWORK_MST_IC A
		LEFT OUTER JOIN T_CODE B
			ON B.CTKEY = A.CTKEY AND B.CTCDHDKEY = 'ICUNITTYPECD' AND B.CTCDDTKEY = A.UOM
		LEFT OUTER JOIN T_CODE C
			ON C.CTKEY = A.CTKEY AND C.CTCDHDKEY = 'ICGRPKEY' AND C.CTCDDTKEY = A.ICGRPKEY
		LEFT OUTER JOIN T_CODE D
			ON D.CTKEY = A.CTKEY AND D.CTCDHDKEY = 'ICTMPRDIVCD' AND D.CTCDDTKEY = A.ICTMPRDIVCD
		/*LEFT OUTER JOIN T_CODE E
			ON E.CTKEY = A.CTKEY AND E.CTCDHDKEY = 'ORDTYPE' AND E.CTCDDTKEY = A.ORDTYPE*/
		LEFT OUTER JOIN TWORK_MST_ICGR F
			ON F.CTKEY = A.CTKEY AND F.ICGRPKEY = A.ICGRPKEY AND F.ICGRPTYPECD = A.ICGRPTYPECD

		<include refid="sql_tWorkMstIc"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstIc2">
		<where>
			AND IC.CTKEY = COALESCE(#{ctkey}, #{sctkey})

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
				AND IC.OWKEY = #{owkey}
			</if>

			<if test="ctkeyList != null and ctkeyList.size > 0">
				AND IC.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="owkeyList != null and owkeyList.size > 0">
				AND IC.OWKEY IN
				<foreach item="owkey" collection="owkeyList"
						 open="(" separator="," close=")">
					#{owkey}
				</foreach>
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ackey)">
				AND IC.ACKEY = #{ackey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(loggrpcd)">
				AND IC.LOGGRPCD = #{loggrpcd}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(icgrpkey)">
				AND IC.ICGRPKEY = #{icgrpkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ctgkey)">
				AND IC.CTGKEY = #{ctgkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND IC.ICKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						<if test="valueList != null and valueList.size > 0">
							AND IC.ICKEY IN
							<foreach item="item" collection="valueList" open="(" separator="," close=")">
								#{item}
							</foreach>
						</if>
					</when>
					<otherwise>
						AND (
						IC.ICKEY LIKE '%' || #{value} || '%'
						OR
						IC.ICNM LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>

			AND NOT EXISTS (
				SELECT 1 FROM TWORK_MST_ASRT WHERE CTKEY = IC.CTKEY AND OWKEY = IC.OWKEY AND ASRTDTICKEY = IC.ICKEY
			)
		</where>
	</sql>

	<select id="selectTWorkMstIc2Count" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstIc2Count */
		SELECT COUNT(1)
		  FROM TWORK_MST_IC IC
		  LEFT JOIN TWORK_MST_ICGR IG
			ON IG.CTKEY = IC.CTKEY
		   AND IG.ICGRPKEY = IC.ICGRPKEY
		   AND IG.ICGRPTYPECD = IC.ICGRPTYPECD
		<include refid="sql_tWorkMstIc2"/>
	</select>

	<select id="selectTWorkMstIc2" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstIc2 */
		  WITH T_CODE AS (
				SELECT
					  DT.CTKEY
					, DT.CTCDHDKEY
					, DT.CTCDDTKEY
					, DT.CTCDDTNM
				FROM TWORK_MST_CTCD_HD HD
				INNER JOIN TWORK_MST_CTCD_DT DT
					ON DT.CTKEY = HD.CTKEY AND DT.CTCDHDKEY = HD.CTCDHDKEY

				<where>
					AND HD.DELYN = 'N'
					AND DT.DELYN = 'N'
					AND DT.CTCDHDKEY IN ('ICUNITTYPECD')

					<if test="@com.kns.framework.util.StringUtil@isNotEmpty(lakey)">
							AND DT.LAKEY = #{lakey}
					</if>
				</where>
			 )

		<include refid="sql_pagingTop"/>

		SELECT IC.ICKEY AS FIELD1
			 , IC.ICNM AS FIELD2
			 , CD.CTCDDTNM AS FIELD3
			 , IG.ICGRPNM AS FIELD4
			 , IC.ICKEY
			 , IC.ICNM
			 , IC.ICUNITKEY
			 , CD.CTCDDTNM AS ICUNITNM
			 , IG.ICGRPTYPECD
			 , IG.ICGRPKEY
			 , IG.ICGRPNM
		  FROM TWORK_MST_IC IC
		  LEFT JOIN T_CODE CD
			ON CD.CTKEY = IC.CTKEY
		   AND CD.CTCDHDKEY = 'ICUNITTYPECD'
		   AND CD.CTCDDTKEY = IC.UOM
		  LEFT JOIN TWORK_MST_ICGR IG
			ON IG.CTKEY = IC.CTKEY
		   AND IG.ICGRPKEY = IC.ICGRPKEY
		   AND IG.ICGRPTYPECD = IC.ICGRPTYPECD

		<include refid="sql_tWorkMstIc2"/>

		<include refid="sql_pagingBottom"/>
	</select>

