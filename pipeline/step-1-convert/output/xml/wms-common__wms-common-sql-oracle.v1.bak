			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(icgrpkey)">
				AND A.ICGRPKEY = #{icgrpkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ctgkey)">
				AND A.CTGKEY = #{ctgkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
