		LEFT OUTER JOIN T_CODE C
			ON C.CTKEY = A.CTKEY AND C.CTCD_HDKEY = 'LCTYPE' AND C.CTCD_DTKEY = B.LCTYPE
		LEFT OUTER JOIN T_CODE D
			ON D.CTKEY = A.CTKEY AND D.CTCD_HDKEY = 'LCHOLDTYPE' AND D.CTCD_DTKEY = B.LCHOLDTYPE
