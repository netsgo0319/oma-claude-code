	<sql id="sql_wayBillNo">
		FROM (
		SELECT
		C.WAYBILLNO AS FIRSTWAYBILLNO
		, A.UDF1
		, A.OWKEY
		, A.WAYBILLNO
		, A.ULCKEY
		FROM
		TWORK_INFO_ULCXWB A
		INNER JOIN TWORK_INFO_OBXULC B
				ON A.ULCKEY = B.ULCKEY
			   AND A.CTKEY = B.CTKEY
			   AND A.OWKEY = B.OWKEY
		INNER JOIN TWORK_INFO_OB_HD C
				ON A.CTKEY = C.CTKEY
			   AND A.OWKEY = C.OWKEY
			   AND B.OBHDKEY = C.OBHDKEY
		WHERE A.CTKEY = COALESCE(#{ctkey}, #{sctkey})

		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
			AND A.OWKEY = #{owkey}
		</if>

		<if test="ctkeyList != null and ctkeyList.size > 0">
			AND A.CTKEY IN
			<foreach item="ctkey" collection="ctkeyList"
					 open="(" separator="," close=")">
				#{ctkey}
			</foreach>
		</if>

		<if test="owkeyList != null and owkeyList.size > 0">
			AND A.OWKEY IN
			<foreach item="owkey" collection="owkeyList"
					 open="(" separator="," close=")">
				#{owkey}
			</foreach>
		</if>
		) A

		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
			<choose>
				<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
					AND FIRSTWAYBILLNO = #{value}
				</when>
				<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
					AND (
					FIRSTWAYBILLNO ~ #{value}
					OR
					UDF1 ~ #{value}
					OR
					WAYBILLNO ~ #{value}
					OR
					ULCKEY ~ #{value}
					)
				</when>
				<otherwise>
					AND (
					FIRSTWAYBILLNO LIKE '%' || #{value} || '%'
					OR
					UDF1 LIKE '%' || #{value} || '%'
					OR
					WAYBILLNO LIKE '%' || #{value} || '%'
					OR
					ULCKEY LIKE '%' || #{value} || '%'
					)
				</otherwise>
			</choose>
		</if>
	</sql>

