						OR
						A.DONG ~ #{value}
						OR
						A.FLOOR ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.ARKEY LIKE '%' || #{value} || '%'
						OR
						A.ARNAME LIKE '%' || #{value} || '%'
						OR
						A.DONG LIKE '%' || #{value} || '%'
						OR
						A.FLOOR LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>

		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstLc">
		<where>
			AND A.CTKEY = COALESCE(#{ctkey}, #{sctkey})

			<if test="ctkeyList != null and ctkeyList.size > 0">
				AND A.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(znkey)">
				AND A.ZNKEY = #{znkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(arkey)">
				AND A.ARKEY = #{arkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(lcstorgtypecd)">
				AND A.LCSTORGTYPECD = #{lcstorgtypecd}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(autoflag)">
				<choose>
					<when test="autoflag == 'auto'">
						AND LCSTORGTYPECD IN ('40', '50')
					</when>
					<otherwise>
						AND LCSTORGTYPECD NOT IN ('40', '50')
					</otherwise>
				</choose>
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.LCKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.LCKEY ~ #{value}
						OR
						A.LCTYPECD ~ #{value}
						OR
						A.LCHOLDTYPECD ~ #{value}
						OR
						A.ARKEY ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.LCKEY LIKE '%' || #{value} || '%'
						OR
						A.LCTYPECD LIKE '%' || #{value} || '%'
						OR
						A.LCHOLDTYPECD LIKE '%' || #{value} || '%'
						OR
						A.ARKEY LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<select id="selectTWorkMstLcCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstLcCount */
		SELECT COUNT(1)
		FROM TWORK_MST_LC A
		<include refid="sql_tWorkMstLc"/>
	</select>

	<select id="selectTWorkMstLc" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstLc */
		<include refid="sql_Tcode"/>
		<include refid="sql_pagingTop"/>
		SELECT
		      A.LCKEY AS FIELD1
			, B.CTCDDTNM AS FIELD2
			, C.CTCDDTNM AS FIELD3
			, A.ARKEY AS FIELD4
		    , E.EMPTYLOCATION_YN AS FIELD5
			, A.IVCNTRMGMTYN AS FIELD6
			, A.LCKEY
			, A.LCTYPECD
			, A.LCHOLDTYPECD
			, A.LCSTORGTYPECD
			<!--, A.ERPSTLC-->
			, A.ARKEY
			, E.EMPTYLOCATION_YN
		FROM TWORK_MST_LC A
		LEFT OUTER JOIN T_CODE B
			ON B.CTKEY = A.CTKEY AND B.CTCDHDKEY = 'LCTYPECD' AND B.CTCDDTKEY = A.LCTYPECD
		LEFT OUTER JOIN T_CODE C
			ON C.CTKEY = A.CTKEY AND C.CTCDHDKEY = 'LCHOLDTYPECD' AND C.CTCDDTKEY = A.LCHOLDTYPECD
		<!--LEFT OUTER JOIN T_CODE D
			ON D.CTKEY = A.CTKEY AND D.CTCDHDKEY = 'ERPSTLC' AND D.CTCDDTKEY = A.ERPSTLC-->
		INNER JOIN (SELECT A.CTKEY
				, A.LCKEY
				, CASE WHEN SUM(COALESCE(B.TOTQTY, 0)) > 0 THEN 'N' ELSE 'Y' END AS EMPTYLOCATION_YN
				FROM TWORK_MST_LC A
				LEFT OUTER JOIN TWORK_INFO_IVATXLC B
				ON A.CTKEY = B.CTKEY
				AND A.LCKEY = B.LCKEY
				GROUP BY A.CTKEY, A.LCKEY
				) E ON E.CTKEY = A.CTKEY AND E.LCKEY = A.LCKEY
		<include refid="sql_tWorkMstLc"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<select id="selectTWorkMstErpLoc" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstErpLoc */
		<include refid="sql_Tcode"/>
		<include refid="sql_pagingTop"/>
		SELECT
		      A.LCKEY AS FIELD1
			, B.CTCD_DTNAME AS FIELD2
			, C.CTCD_DTNAME AS FIELD3
			, A.ERPSTLC AS FIELD4
			, A.ARKEY AS FIELD5
		FROM TWORK_MST_LC A
		LEFT OUTER JOIN T_CODE B
			ON B.CTKEY = A.CTKEY AND B.CTCD_HDKEY = 'LCTYPE' AND B.CTCD_DTKEY = A.LCTYPE
		LEFT OUTER JOIN T_CODE C
			ON C.CTKEY = A.CTKEY AND C.CTCD_HDKEY = 'LCHOLDTYPE' AND C.CTCD_DTKEY = A.LCHOLDTYPE
		<include refid="sql_tWorkMstLc"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstLcNonAuto">
		FROM 	TWORK_MST_LC A
		INNER JOIN (
		SELECT
		A.CTKEY,
		A.LCKEY,
		CASE WHEN SUM(COALESCE(B.TTQTY, 0)) > 0 THEN 'N'
		ELSE 'Y'
		END AS EMPTYLOCATION_YN
		FROM
		TWORK_MST_LC A
		LEFT OUTER JOIN TWORK_INFO_IVATXLCXULC B
					 ON A.CTKEY = B.CTKEY
					AND A.LCKEY = B.LCKEY
		WHERE A.CTKEY = COALESCE(#{ctkey}, #{sctkey})
		GROUP BY
		A.CTKEY,
		A.LCKEY
		) B
		ON A.CTKEY = B.CTKEY
		AND A.LCKEY = B.LCKEY
		LEFT OUTER JOIN T_CODE C
		ON C.CTKEY = A.CTKEY
		AND C.CTCD_DTKEY = A.LCTYPE
		AND C.CTCD_HDKEY = 'LCTYPE'
		LEFT OUTER JOIN T_CODE D
		ON D.CTKEY = A.CTKEY
		AND D.CTCD_DTKEY = A.LCHOLDTYPE
		AND D.CTCD_HDKEY = 'LCHOLDTYPE'
		LEFT OUTER JOIN T_CODE E
		ON E.CTKEY = A.CTKEY
		AND E.CTCD_DTKEY = A.ERPSTLC
		AND E.CTCD_HDKEY = 'ERPSTLC'
		LEFT OUTER JOIN T_CODE F
		ON F.CTKEY = B.CTKEY
		AND F.CTCD_DTKEY = B.EMPTYLOCATION_YN
		AND F.CTCD_HDKEY = 'YESORNO'
		WHERE
		A.CTKEY = COALESCE(#{ctkey}, #{sctkey})
		<if test="ctkeyList != null and ctkeyList.size > 0" >
			AND A.CTKEY IN
			<foreach item="ctkey" index="index" collection="ctkeyList"
					 open="(" separator="," close=")">
				#{ctkey}
			</foreach>
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(arkey)" >
			AND A.ARKEY = #{arkey}
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(erpstlc)" >
			AND A.ERPSTLC = #{erpstlc}
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(lcstortype)" >
			AND A.LCSTORTYPE = #{lcstortype}
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
			<choose>
				<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
					AND A.LCKEY = #{value}
				</when>
				<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
					AND (
					A.LCKEY ~ #{value}
					OR
					C.CTCD_DTNAME ~ #{value}
					OR
					D.CTCD_DTNAME ~ #{value}
					OR
					E.CTCD_DTNAME ~ #{value}
					OR
					A.ARKEY ~ #{value}
					OR
					F.CTCD_DTNAME ~ #{value}
					)
				</when>
				<otherwise>
					AND (
					A.LCKEY LIKE '%' || #{value} || '%'
					OR
					C.CTCD_DTNAME LIKE '%' || #{value} || '%'
					OR
					D.CTCD_DTNAME LIKE '%' || #{value} || '%'
					OR
					E.CTCD_DTNAME LIKE '%' || #{value} || '%'
					OR
					A.ARKEY LIKE '%' || #{value} || '%'
					OR
					F.CTCD_DTNAME LIKE '%' || #{value} || '%'
					)
				</otherwise>
			</choose>
		</if>

	</sql>

	<select id="selectTWorkMstLcNonAutoCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstLcNonAutoCount */
		<include refid="sql_Tcode"/>
		SELECT COUNT(1)
