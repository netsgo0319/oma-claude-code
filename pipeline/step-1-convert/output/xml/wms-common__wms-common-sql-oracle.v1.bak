	<sql id="selectTWorkMstAcXUrCommonCdRefSql">
		FROM
			  TWORK_MST_ACXUR A
		INNER JOIN TWORK_MST_AC B
				ON A.CTKEY = B.CTKEY
			   AND A.ACKEY = B.ACKEY
			   AND A.OWKEY = B.OWKEY
		LEFT OUTER JOIN TWORK_MST_ICGR C
					 ON A.CTKEY = C.CTKEY
					AND A.OWKEY = C.OWKEY
					AND A.ICGRKEY = C.ICGRKEY
					AND A.ICGRTYPE = C.ICGRTYPE
		INNER JOIN TADMIN_MST_UR D
				ON A.URKEY = D.URKEY
		WHERE A.CTKEY = COALESCE(#{ctkey}, #{sctkey})

		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
			AND A.OWKEY = #{owkey}
		</if>

		<if test="ctkeyList != null and ctkeyList.size > 0">
			AND A.CTKEY IN
			<foreach item="ctkey" collection="ctkeyList"
					 open="(" separator="," close=")">
				#{ctkey}
			</foreach>
		</if>

		<if test="owkeyList != null and owkeyList.size > 0">
			AND A.OWKEY IN
			<foreach item="owkey" collection="owkeyList"
					 open="(" separator="," close=")">
				#{owkey}
			</foreach>
		</if>

		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
			<choose>
				<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
					AND A.URKEY = #{value}
				</when>
				<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
					AND (
					A.URKEY ~ #{value}
					OR
					A.ACKEY ~ #{value}
					OR
					A.ACNAME ~ #{value}
					OR
					A.ICGRKEY ~ #{value}
					OR
					A.ICGRTYPE ~ #{value}
					OR
					C.ICGRNAME ~ #{value}
					OR
					D.URNM ~ #{value}
					)
				</when>
				<otherwise>
					AND (
					A.URKEY LIKE '%' || #{value} || '%'
					OR
					A.ACKEY LIKE '%' || #{value} || '%'
					OR
					A.ACNAME LIKE '%' || #{value} || '%'
					OR
					A.ICGRKEY LIKE '%' || #{value} || '%'
					OR
					A.ICGRTYPE LIKE '%' || #{value} || '%'
					OR
					C.ICGRNAME LIKE '%' || #{value} || '%'
					OR
					D.URNM LIKE '%' || #{value} || '%'
					)
				</otherwise>
			</choose>
		</if>
