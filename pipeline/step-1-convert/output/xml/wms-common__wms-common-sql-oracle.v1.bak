	<sql id="sql_tWorkInfoIbat">
		FROM TWORK_INFO_IVAT A

		<where>
			AND A.CTKEY = COALESCE(#{ctkey}, #{sctkey})

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
				AND A.OWKEY = #{owkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ickey)">
				AND A.ICKEY = #{ickey}
			</if>

			<if test="ctkeyList != null and ctkeyList.size > 0">
				AND A.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="owkeyList != null and owkeyList.size > 0">
				AND A.OWKEY IN
				<foreach item="owkey" collection="owkeyList"
						 open="(" separator="," close=")">
					#{owkey}
				</foreach>
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.IVATKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.IVATKEY ~ #{value}
						OR
						A.OWKEY ~ #{value}
						OR
						A.ICKEY ~ #{value}
						OR
						A.PRODUCTLOT ~ #{value}
						OR
						A.IVATSTATUS ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.IVATKEY LIKE '%' || #{value} || '%'
						OR
						A.OWKEY LIKE '%' || #{value} || '%'
						OR
						A.ICKEY LIKE '%' || #{value} || '%'
						OR
						A.PRODUCTLOT LIKE '%' || #{value} || '%'
						OR
						A.IVATSTATUS LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<select id="selectTWorkInfoIvatCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkInfoIvatCount */
