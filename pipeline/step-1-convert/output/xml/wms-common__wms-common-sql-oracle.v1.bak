	<select id="selectPutawayLocation" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectPutawayLocation */
		<include refid="sql_pagingTop"/>
		SELECT
		FIELD1
		, FIELD2
		, FIELD2_DESC
		, CASE WHEN SUBSTR(FIELD3,2) = 'SAME' THEN '동일 재고 존재'
		WHEN SUBSTR(FIELD3,2) = 'EMPTY' THEN '재고 없음'
		ELSE SUBSTR(FIELD3,2)
		END  AS FIELD3
		, FIELD4
		, COALESCE(#{ctkey}, #{sctkey}) ||';'|| ''|| ';'|| COALESCE(B.ARNAME, FIELD4) AS FIELD4_DESC
		, COALESCE(FIELD5, 0) AS FIELD5
		<include refid="sql_putawayLocation"/>
		<include refid="sql_pagingBottom"/>
	</select>

