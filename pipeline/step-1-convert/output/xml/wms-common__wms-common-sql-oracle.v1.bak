	<sql id="selectTWorkInfoReqSql">
		FROM TWORK_INFO_REQ_HD A
		LEFT OUTER JOIN TWORK_MST_AC B
			ON A.CTKEY = B.CTKEY AND A.OWKEY = B.OWKEY AND A.ACKEY = B.ACKEY AND A.DCKEY = B.DCKEY
		LEFT OUTER JOIN TWORK_MST_STORE C
			ON A.CTKEY = C.CTKEY AND A.OWKEY = C.OWKEY AND A.STORE_KEY = C.STORE_KEY AND A.DCKEY = C.DCKEY
		LEFT OUTER JOIN T_CODE D
			ON D.CTKEY = A.CTKEY AND D.CTCD_HDKEY = 'REQHDTYPE' AND D.CTCD_DTKEY = A.REQHDTYPE

		<where>
			AND A.CTKEY = COALESCE(#{ctkey}, #{sctkey})

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(owkey)">
				AND A.OWKEY = #{owkey}
			</if>

			<if test="ctkeyList != null and ctkeyList.size > 0">
				AND A.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="owkeyList != null and owkeyList.size > 0">
				AND A.OWKEY IN
				<foreach item="owkey" collection="owkeyList"
						 open="(" separator="," close=")">
					#{owkey}
				</foreach>
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.REQHDKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.REQHDKEY ~ #{value}
						OR
						A.ACKEY ~ #{value}
						OR
						B.ACNAME ~ #{value}
						OR
						A.STORE_KEY ~ #{value}
						OR
						C.STORE_NAME ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.REQHDKEY LIKE '%' || #{value} || '%'
						OR
						A.ACKEY LIKE '%' || #{value} || '%'
						OR
						B.ACNAME LIKE '%' || #{value} || '%'
						OR
						A.STORE_KEY LIKE '%' || #{value} || '%'
						OR
						C.STORE_NAME LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

