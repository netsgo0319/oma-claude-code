		    , D.CTCD_DTNAME AS FIELD4
			, A.ACKEY AS FIELD5
			, B.ACNAME AS FIELD6
			, A.STORE_KEY AS FIELD7
			, C.STORE_NAME AS FIELD8
			, A.REQHDKEY
			, A.OWKEY
