	<sql id="sql_putawayLocation">
		FROM (
		SELECT
		A.LCKEY AS FIELD1
		, A.LCTYPE  AS FIELD2
		, A.CTKEY ||';'|| 'LCTYPE' || ';' || A.LCTYPE AS FIELD2_DESC
		, B.STATUS AS FIELD3
		, A.LCSEQ AS LCSEQ
		, A.ARKEY AS FIELD4
		, B.STATUS AS STATUS
		, B.TTQTY AS FIELD5
		FROM
		TWORK_MST_LC A
		LEFT OUTER JOIN (
			SELECT
			B.TO_LCKEY AS LCKEY
			, '1' AS STATUS
			, B.CTKEY
			, COALESCE((SELECT SUM(TTQTY) FROM TWORK_INFO_IVATXLCXULC A WHERE A.CTKEY =  B.CTKEY AND A.OWKEY = B.OWKEY AND A.ICKEY = B.ICKEY AND A.LCKEY = B.TO_LCKEY), 0) AS TTQTY
			FROM TWORK_MST_IC B
			WHERE B.CTKEY = COALESCE(#{ctkey}, #{sctkey})
			AND B.OWKEY = #{owkey}
			AND B.ICKEY = #{ickey}

			UNION ALL

			SELECT
			LCKEY
			, '3SAME' AS STATUS
			,  CTKEY
			, SUM(TTQTY) AS TTQTY
			FROM TWORK_INFO_IVATXLCXULC
			WHERE CTKEY = COALESCE(#{ctkey}, #{sctkey})
			AND OWKEY = #{owkey}
			AND ICKEY = #{ickey}
			AND TTQTY > 0
			AND LCKEY NOT IN (SELECT COALESCE(TO_LCKEY, ' ') FROM TWORK_MST_IC WHERE CTKEY = COALESCE(#{ctkey}, #{sctkey})AND OWKEY = #{owkey} AND ICKEY = #{ickey})
			GROUP BY
			LCKEY
			, CTKEY

			UNION ALL

			SELECT
			LCKEY
			, '2EMPTY' AS STATUS
			, CTKEY
			, 0 AS TTQTY
			FROM (
			SELECT
			B.LCKEY
			, B.CTKEY
			, SUM(A.TTQTY) AS TTQTY
			FROM
			TWORK_INFO_IVATXLCXULC A
			RIGHT OUTER JOIN TWORK_MST_LC B
						  ON A.CTKEY = B.CTKEY
						 AND A.LCKEY = B.LCKEY
			WHERE B.CTKEY = COALESCE(#{ctkey}, #{sctkey})
			GROUP BY
			B.LCKEY
			, B.CTKEY
			)
			WHERE (TTQTY = 0 OR TTQTY IS NULL)
			AND LCKEY NOT IN (
			SELECT
			COALESCE(TO_LCKEY, ' ')
			FROM TWORK_MST_IC
			WHERE CTKEY = COALESCE(#{ctkey}, #{sctkey})
			AND OWKEY = #{owkey}
			AND ICKEY = #{ickey}
			)

			UNION ALL

			SELECT
			B.LCKEY
			, B.CTKEY
			, '4' AS STAUS
			, COALESCE(SUM (A.TTQTY), 0) AS TTQTY
			FROM
			TWORK_INFO_IVATXLCXULC A
			RIGHT OUTER JOIN TWORK_MST_LC B
						  ON A.CTKEY = B.CTKEY
						 AND A.LCKEY = B.LCKEY
			WHERE B.CTKEY = COALESCE(#{ctkey}, #{sctkey})
			AND B.LCKEY NOT IN (
			SELECT COALESCE(TO_LCKEY, ' ') AS LCKEY
			FROM TWORK_MST_IC
			WHERE CTKEY = COALESCE(#{ctkey}, #{sctkey})
			AND OWKEY = #{owkey}
			AND ICKEY = #{ickey}

			UNION ALL

			SELECT LCKEY
			FROM (
			SELECT
			B.LCKEY
			, B.CTKEY
			, SUM(A.TTQTY) AS TTQTY
			FROM
			TWORK_INFO_IVATXLCXULC A
			RIGHT OUTER JOIN TWORK_MST_LC B
						  ON A.CTKEY = B.CTKEY
						 AND A.LCKEY = B.LCKEY
			WHERE B.CTKEY = COALESCE(#{ctkey}, #{sctkey})
			GROUP BY
			B.LCKEY
			, B.CTKEY
			)
			WHERE (TTQTY = 0 OR TTQTY IS NULL)

			UNION ALL

			SELECT LCKEY
			FROM TWORK_INFO_IVATXLCXULC
			WHERE CTKEY = COALESCE(#{ctkey}, #{sctkey})
			AND OWKEY = #{owkey}
			AND ICKEY = #{ickey}
			AND TTQTY > 0
			)
			GROUP BY B.LCKEY, B.CTKEY
		) B ON A.CTKEY = B.CTKEY
		   AND A.LCKEY = B.LCKEY

		WHERE A.CTKEY = COALESCE(#{ctkey}, #{sctkey})

		<if test="lcholdtype != 'NOTHING'">
			AND A.LCHOLDTYPE = '10'
		</if>

		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
			AND (
			A.LCKEY LIKE '%' || #{value} || '%'
			OR A.LCTYPE LIKE '%' || #{value} || '%'
			OR B.STATUS LIKE '%' || #{value} || '%'
			)
		</if>
		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
			<choose>
				<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
					AND A.LCKEY = #{value}
				</when>
				<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
					AND (
					A.LCKEY ~ #{value}
					OR
					A.LCTYPE ~ #{value}
					OR
					B.STATUS ~ #{value}
					)
				</when>
				<otherwise>
					AND (
					A.LCKEY LIKE '%' || #{value} || '%'
					OR
					A.LCTYPE LIKE '%' || #{value} || '%'
					OR
					B.STATUS LIKE '%' || #{value} || '%'
					)
				</otherwise>
			</choose>
		</if>

		) A
		INNER JOIN TWORK_MST_AR B
				ON A.FIELD4 = B.ARKEY

		<where>
			AND B.CTKEY = COALESCE(#{ctkey}, #{sctkey})
			AND (B.OWKEY = #{owkey} OR B.OWKEY IS NULL)

			<if test="ctkeyList != null and ctkeyList.size > 0">
				AND B.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="owkeyList != null and owkeyList.size > 0">
				AND B.OWKEY IN
				<foreach item="owkey" collection="owkeyList"
						 open="(" separator="," close=")">
					#{owkey}
				</foreach>
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(arkey)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(arkey2)'>
						AND ARKEY IN (#{arkey} , #{arkey2})
					</when>
					<otherwise>
						AND ARKEY = #{arkey}
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<select id="selectPutawayLocationCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectPutawayLocationCount */
