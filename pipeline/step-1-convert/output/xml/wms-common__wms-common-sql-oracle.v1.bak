	<select id="selectTAdminMstOw" resultMap="selectPopupCommonCode">
		<include refid="sql_pagingTop"/>
			SELECT 	OWKEY AS FIELD1
					,OWNM AS FIELD2
					,MASTERUPDATEIMPOS AS FN_GET_MASTER_IMPOS
			FROM 	TADMIN_MST_OW
			WHERE DELYN = 'N'
			  AND CLOSDATE >= #{sysdate}
			<if test="owkeyList != null and owkeyList.size > 0" >
										 AND OWKEY IN 
										<foreach item="owkey" index="index" collection="owkeyList"
											open="(" separator="," close=")">
											#{owkey}
										</foreach>
			</if>
			<if test="OWKEY_SELECTION_VALUE != null and OWKEY_SELECTION_VALUE != ''" >
				AND OWKEY IN
				<foreach item="OWKEY_SELECTION_VALUE" index="index" collection="OWKEY_SELECTION_VALUE" open="(" separator="," close=")">
					#{OWKEY_SELECTION_VALUE}
				</foreach>
			</if>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
				<choose>
					<when test='opval !=null and opval.equals("eq")'>
						AND OWKEY = #{value}
					</when>
					<otherwise>
						AND (OWKEY LIKE '%' || #{value} || '%' OR OWNM LIKE '%' || #{value} || '%')
					</otherwise>
				</choose>
			</if>
		<include refid="sql_pagingBottom"/>
	</select>

	<select id="selectTAdminMstCt" resultMap="selectPopupCommonCode">
		<include refid="sql_pagingTop"/>
			SELECT 	CTKEY AS FIELD1
					,CTNM AS FIELD2
					,CTTYPE AS FIELD3
					,'CTTYPE' || ';' || CTTYPE AS FIELD3_DESC
			FROM 	TADMIN_MST_CT
			WHERE	CLOSDATE >= #{sysdate}
			  AND	DELYN = 'N'
			<if test="ctkeyList != null and ctkeyList.size > 0" >
										 AND A.CTKEY IN 
										<foreach item="ctkey" index="index" collection="ctkeyList"
											open="(" separator="," close=")">
											#{ctkey}
										</foreach>
			</if>
			<if test="CTKEY_SELECTION_VALUE != null and CTKEY_SELECTION_VALUE != ''" >
				AND CTKEY IN
				<foreach item="CTKEY_SELECTION_VALUE" index="index" collection="CTKEY_SELECTION_VALUE" open="(" separator="," close=")">
					#{CTKEY_SELECTION_VALUE}
				</foreach>
			</if>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)" >
				<choose>
					<when test='opval !=null and opval.equals("eq")'>
						AND CTKEY = #{value}
					</when>
					<otherwise>
						AND (CTKEY LIKE '%' || #{value} || '%' OR CTNM LIKE '%' || #{value} || '%')
					</otherwise>
				</choose>
			</if>
		<include refid="sql_pagingBottom"/>
	</select>

	<resultMap id="selectUserInfoMap" type="java.util.HashMap">
		<result property="urkey" column="URKEY" />
		<result property="urnm" column="URNM" />
	</resultMap>

	<select id="selectUserInfoList" fetchSize="1000" resultMap="selectUserInfoMap">
		SELECT URKEY
		       ,URNM
		  FROM TADMIN_MST_UR
	</select>


	<resultMap id="staticManagerMap" type="java.util.HashMap" >
		<result property="ctkey" 		column="CTKEY" />
		<result property="ctcd_hdkey" 	column="CTCD_HDKEY" />
		<result property="ctcd_dtkey" 	column="CTCD_DTKEY" />
		<result property="ctcd_dtorder"	column="CTCD_DTORDER" />
		<result property="ctcd_dtname"	column="CTCD_DTNAME" />
		<result property="lakey" 		column="LAKEY" />
	</resultMap>

	<select id="selectTWorkMstCtcdDtList" fetchSize="1000" resultMap="staticManagerMap">
		<![CDATA[
		SELECT 	CTKEY
			 ,CTCDHDKEY
			 ,CTCDDTKEY
			 ,CTCDDTNM
			 ,LAKEY
		FROM 	TWORK_MST_CTCD_DT
		]]>
	</select>

	<select id="selectCountICxOWxCT" resultType="java.lang.Integer">
		SELECT 	COUNT(1)
		FROM 	TWORK_MST_IC
		WHERE 	CTKEY = COALESCE(#{ctkey}, #{sctkey})
		  AND 	OWKEY = #{owkey}
		  AND		ICKEY = #{ickey}
	</select>

	<select id="selectCountICUTxCT" resultType="java.lang.Integer">
		SELECT 	COUNT(1)
		FROM 	TWORK_MST_ICUT
		WHERE 	CTKEY = COALESCE(#{ctkey}, #{sctkey})
		  AND 	ICUTKEY = #{icutkey}
	</select>

	<select id="getIcomMulLangMsg" resultType="java.lang.String">
		SELECT 	DISPLAYMSG
		FROM 	TADMIN_MST_MULAAPMSG_DT
		WHERE 	MULAAPMSGHDKEY = #{msgcode}
		  AND 	LAKEY = #{lakey}
		GROUP BY DISPLAYMSG
	</select>

	<select id="selectSetscList" resultType="camelMap">
		SELECT CTKEY
		,CTCSKEY
		,CTCSNM
		,VALUE1
		,VALUE2
		,DEFAULTVALUE
		FROM TWORK_SET_CTCS
		<where>
			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ctkey)" >
				CTKEY = COALESCE(#{ctkey}, #{sctkey})
			</if>
		</where>
	</select>

	<select id="selectSetsc" resultType="camelMap">
		SELECT CTKEY
			 ,CTCSKEY
			 ,CTCSNAME
			 ,VALUE1
			 ,VALUE2
			 ,DEFAULTVALUE
		FROM TWORK_SET_CTCS
		WHERE
			CTKEY = COALESCE(#{ctkey}, #{sctkey})
		  AND CTCSKEY = #{ctcskey}
	</select>

	<insert id="saveFileInfo">
		<selectKey keyProperty="filekey" resultType="string" order="BEFORE">
			SELECT nextval('seq_tadmin_mst_file')
		</selectKey>
		/* adm-common-sql-oracle.xml - saveFileInfo */
		INSERT INTO TADMIN_MST_FILE
		(
		FILEKEY
		, FILESEQ
		, APKEY
		, MEKEY
		, FILEPATH
		, FILESIZE
		, FILEEXTS
		, ORIGFILENM
		, SAVEFILENM
		, REM
		, INSERTDATE
		, INSERTURKEY
		, UPDATEDATE
		, UPDATEURKEY
		)
		VALUES
		(
		#{filekey}
		, #{fileseq}
		, #{apkey}
		, #{mekey}
		, #{filepath}
		, #{filesize}
		, #{fileexts}
		, #{origfilenm}
		, #{savefilenm}
		, #{rem}
		, #{sysdate}
		, #{surkey}
		, #{sysdate}
		, #{surkey}
		)
	</insert>

	<sql id="sql_tWorkMstAsrt">
		/* wms-common-sql-oracle.xml - sql_tWorkMstAsrt - common Assort 모상품 조회 SQL */
		SELECT ASRT.CTKEY
			 , ASRT.OWKEY
			 , ASRT.ASRTMASICKEY AS FIELD1
			 , IC.ICNM AS FIELD2
			 , ASRT.ASRTMASICKEY
			 , IC.ICNM AS ASRTMASICNM
		  FROM TWORK_MST_ASRT ASRT
		 INNER JOIN TWORK_MST_IC IC
			ON IC.CTKEY = ASRT.CTKEY
		   AND IC.OWKEY = ASRT.OWKEY
		   AND IC.ICKEY = ASRT.ASRTMASICKEY

		<where>
			<if test="ctkeyList != null and ctkeyList.size > 0">
				AND ASRT.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="owkeyList != null and owkeyList.size > 0">
				AND ASRT.OWKEY IN
				<foreach item="owkey" collection="owkeyList"
						 open="(" separator="," close=")">
					#{owkey}
				</foreach>
			</if>

			AND ASRT.CTKEY = COALESCE(#{ctkey}, #{sctkey})
			AND ASRT.OWKEY = #{owkey}

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND ASRT.ASRTMASICKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						<if test="valueList != null and valueList.size > 0">
							AND ASRT.ASRTMASICKEY IN
							<foreach item="item" collection="valueList" open="(" separator="," close=")">
								#{item}
							</foreach>
						</if>
					</when>
					<otherwise>
						AND (
						ASRT.ASRTMASICKEY LIKE '%' || #{value} || '%'
						OR
						IC.ICNM LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>

		 GROUP BY
		       ASRT.CTKEY
			 , ASRT.OWKEY
			 , ASRT.ASRTMASICKEY
			 , IC.ICNM
	</sql>

	<select id="selectTWorkMstAsrtCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstAsrtCount - common Assort 모상품 카운트 */
		SELECT COUNT(1)
		  FROM (
			<include refid="sql_tWorkMstAsrt"/>
		     )
	</select>

	<select id="selectTWorkMstAsrt" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstAsrt - common Assort 모상품 조회 */
		<include refid="sql_pagingTop"/>
		<include refid="sql_tWorkMstAsrt"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstAsrtDt">
		/* wms-common-sql-oracle.xml - sql_tWorkMstAsrtDt - common Assort 자상품 조회 SQL */
		  FROM TWORK_MST_ASRT ASRT
		 INNER JOIN TWORK_MST_IC IC
			ON IC.CTKEY = ASRT.CTKEY
		   AND IC.OWKEY = ASRT.OWKEY
		   AND IC.ICKEY = ASRT.ASRTDTICKEY

		<where>
			<if test="ctkeyList != null and ctkeyList.size > 0">
				AND ASRT.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="owkeyList != null and owkeyList.size > 0">
				AND ASRT.OWKEY IN
				<foreach item="owkey" collection="owkeyList"
						 open="(" separator="," close=")">
					#{owkey}
				</foreach>
			</if>

			AND ASRT.CTKEY = COALESCE(#{ctkey}, #{sctkey})
			AND ASRT.OWKEY = #{owkey}

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND ASRT.ASRTDTICKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						<if test="valueList != null and valueList.size > 0">
							AND ASRT.ASRTDTICKEY IN
							<foreach item="item" collection="valueList" open="(" separator="," close=")">
								#{item}
							</foreach>
						</if>
					</when>
					<otherwise>
						AND (
						ASRT.ASRTDTICKEY LIKE '%' || #{value} || '%'
						OR
						IC.ICNM LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>

	</sql>

	<select id="selectTWorkMstAsrtDtCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstAsrtDtCount - common Assort 자상품 카운트 */
		SELECT COUNT(1)
		<include refid="sql_tWorkMstAsrtDt"/>
	</select>

	<select id="selectTWorkMstAsrtDt" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstAsrtDt - common Assort 자상품 조회 */
		<include refid="sql_pagingTop"/>

		SELECT ASRT.CTKEY
			 , ASRT.OWKEY
			 , ASRT.ASRTDTICKEY AS FIELD1
			 , IC.ICNM AS FIELD2
			 , ASRT.COLOR AS FIELD3
			 , ASRT.DESIGN AS FIELD4
			 , ASRT.CHRT AS FIELD5
		     , ASRT.ASRTDTICKEY
			 , IC.ICNM AS ASRTDTICNM
			 , ASRT.COLOR
			 , ASRT.DESIGN
			 , ASRT.CHRT
		<include refid="sql_tWorkMstAsrtDt"/>

		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstDlvrycorp">
		/* wms-common-sql-oracle.xml - sql_tWorkMstDlvrycorp - 택배사 정보 SQL */
		  FROM TWORK_MST_DLVRYCORP DC
		 INNER JOIN TWORK_MST_CT CT
			ON CT.CTKEY = DC.CTKEY
		 INNER JOIN TWORK_MST_OW OW
			ON OW.OWKEY = DC.OWKEY

		<where>
			<if test="ctkeyList != null and ctkeyList.size > 0">
				AND DC.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="owkeyList != null and owkeyList.size > 0">
				AND DC.OWKEY IN
				<foreach item="owkey" collection="owkeyList"
						 open="(" separator="," close=")">
					#{owkey}
				</foreach>
			</if>

			   AND DC.CTKEY = COALESCE(#{ctkey}, #{sctkey})
			   AND DC.OWKEY = COALESCE(#{owkey}, #{sowkey})
			   AND DC.DELYN <![CDATA[<>]]> 'Y'
		</where>

	</sql>

	<select id="selectTWorkMstDlvrycorpCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstDlvrycorpCount - 택배사 정보 Count */
		SELECT COUNT(1)
		<include refid="sql_tWorkMstDlvrycorp"/>
	</select>

	<select id="selectTWorkMstDlvrycorp" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstDlvrycorp - 택배사 정보 조회 */
		<include refid="sql_pagingTop"/>

		SELECT DC.DLVRYCORPCD AS FIELD1
			 , DC.DLVRYCORPNM AS FIELD2
		     , DC.DLVRYCORPCD
			 , DC.DLVRYCORPNM
			 , DC.CNTRCTCD
			 , DC.CNTRCTSTATUS
		<include refid="sql_tWorkMstDlvrycorp"/>

		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstDlvrycorpBox">
		/* wms-common-sql-oracle.xml - sql_tWorkMstDlvrycorp - 택배사 박스규격 정보 SQL */
		  FROM TWORK_MST_DLVRYCORP_BOX DCB
		 INNER JOIN TWORK_MST_CT CT
			ON CT.CTKEY = DCB.CTKEY
		 INNER JOIN TWORK_MST_OW OW
			ON OW.OWKEY = DCB.OWKEY

		<where>
			<if test="ctkeyList != null and ctkeyList.size > 0">
				AND DCB.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="owkeyList != null and owkeyList.size > 0">
				AND DCB.OWKEY IN
				<foreach item="owkey" collection="owkeyList"
						 open="(" separator="," close=")">
					#{owkey}
				</foreach>
			</if>

			   AND DCB.CTKEY = COALESCE(#{ctkey}, #{sctkey})
			   AND DCB.OWKEY = COALESCE(#{owkey}, #{sowkey})
			   AND DCB.DELYN <![CDATA[<>]]> 'Y'
		</where>

	</sql>

	<select id="selectTWorkMstDlvrycorpBoxCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstDlvrycorpBoxCount - 택배사 박스규격 마스터 Count */
		SELECT COUNT(1)
		<include refid="sql_tWorkMstDlvrycorpBox"/>
	</select>

	<select id="selectTWorkMstDlvrycorpBox" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstDlvrycorpBox - 택배사 박스규격 마스터 조회 */
		<include refid="sql_pagingTop"/>

		SELECT DCB.BOXTYPECD AS FIELD1
			 , DCB.BOXTYPENM AS FIELD2
		     , DCB.DLVRYCORPCD
			 , DCB.BOXTYPECD
			 , DCB.BOXSPEC
		<include refid="sql_tWorkMstDlvrycorpBox"/>

		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstStnPak">
		/* wms-common-sql-oracle.xml - sql_tWorkMstStnPak - 스테이션 마스터 패킹정보 SQL */
		FROM TWORK_MST_STN STN
	   INNER JOIN TWORK_MST_CT CT
		  ON STN.CTKEY = CT.CTKEY
	   WHERE STN.STNDIVCD = '30' /*30:패킹*/
		 AND STN.USEYN = 'Y'
		 AND STN.CTKEY = COALESCE(#{ctkey}, #{sctkey})
		 AND STN.STNBARCODE = #{value}
	</sql>

	<select id="selectTworkMstStnPakCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTworkMstStnPakCount - 스테이션 마스터 패킹정보 Count */
		SELECT COUNT(1)
		<include refid="sql_tWorkMstStnPak"/>
	</select>

	<select id="selectTworkMstStnPak" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTworkMstStnPak - 스테이션 마스터 패킹정보 조회 */
		<include refid="sql_pagingTop"/>

		SELECT STN.STNBARCODE AS FIELD1
			 , 'STN NO. ' || STN.STNNO AS FIELD2
		<include refid="sql_tWorkMstStnPak"/>

		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstCntr">
		/* wms-common-sql-oracle.xml - sql_tWorkMstCntr - 용기마스터 정보 SQL */
		FROM TWORK_MST_CNTR CNTR
	   INNER JOIN TWORK_MST_CT CT
		  ON CNTR.CTKEY = CT.CTKEY
	   INNER JOIN TWORK_MST_CTCD_DT DIV
	      ON CT.CTKEY = DIV.CTKEY
	     AND CNTR.CNTRDIVCD = DIV.CTCDDTKEY
	     AND DIV.CTCDHDKEY = 'CNTRDIVCD'
	   INNER JOIN TWORK_MST_CTCD_DT WKDIV
	      ON CT.CTKEY = WKDIV.CTKEY
	     AND CNTR.CNTRWKDIVCD = WKDIV.CTCDDTKEY
	     AND WKDIV.CTCDHDKEY = 'CNTRWKDIVCD'
	   WHERE CNTR.CTKEY = COALESCE(#{ctkey}, #{sctkey})
	     AND CNTR.CNTRBARCODE = #{value}
	     AND CNTR.CNTRWKDIVCD IN ('10', '20')
	     AND CNTR.USEYN = 'Y'
	</sql>

	<select id="selectTworkMstCntrCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTworkMstCntrCount - 용기마스터 정보 Count */
		SELECT COUNT(1)
		<include refid="sql_tWorkMstStnPak"/>
	</select>

	<select id="selectTworkMstCntr" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTworkMstCntr - 용기마스터 정보 조회 */
		<include refid="sql_pagingTop"/>

		SELECT CNTR.CNTRBARCODE AS FIELD1
			 , WKDIV.CTCDDTNM || ' ' || DIV.CTCDDTNM AS FIELD2
		<include refid="sql_tWorkMstCntr"/>

		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_obHdKeyWblNo">
		/* wms-common-sql-oracle.xml - sql_obHdKeyWblNo - 릴리즈코드/운송장번호 정보조회 SQL */
	  SELECT CASE WHEN OBHD.OBHDKEY = #{value} THEN #{value}
				  WHEN OBHD.WBLNO = #{value} THEN #{value}
				  WHEN NISHD.OBNISNO = #{value} THEN OBHD.OBHDKEY
			  END AS FIELD1
		FROM TWORK_INFO_OB_HD OBHD
	   INNER JOIN TWORK_MST_CT CT
		  ON OBHD.CTKEY = CT.CTKEY
	   INNER JOIN TWORK_MST_OW OW
		  ON OBHD.OWKEY = OW.OWKEY
		LEFT OUTER JOIN TWORK_INFO_OB_NIS_HD NISHD
		  ON OBHD.CTKEY = NISHD.CTKEY
		 AND OBHD.OWKEY = NISHD.OWKEY
		 AND OBHD.OBHDKEY = NISHD.OBHDKEY
		 AND NISHD.CNFRMYN = 'Y'
	   WHERE OBHD.CTKEY = COALESCE(#{ctkey}, #{sctkey})
		 AND OBHD.OWKEY = COALESCE(#{owkey}, #{sowkey})
		<if test="value != null and value != ''">
		 AND (OBHD.OBHDKEY = #{value}
			  OR OBHD.WBLNO = #{value}
			  OR NISHD.OBNISNO = #{value})
		</if>
	   GROUP BY
			 OBHD.OBHDKEY
		   , OBHD.WBLNO
		   , NISHD.OBNISNO
	</sql>

	<select id="selectObHdKeyWblNoCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectObHdKeyWblNoCount - 릴리즈코드/운송장번호 정보조회 Count */
		SELECT COUNT(1)
		  FROM (
		<include refid="sql_obHdKeyWblNo"/>
		)
	</select>

	<select id="selectObHdKeyWblNo" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectObHdKeyWblNo - 릴리즈코드/운송장번호 정보조회 */
		<include refid="sql_pagingTop"/>
		<include refid="sql_obHdKeyWblNo"/>
		<include refid="sql_pagingBottom"/>
	</select>





	<sql id="sql_selectTWorkMstLoc">
		SELECT LC.LCKEY AS FIELD1
			 , LC.LCTYPECD AS FIELD2
			 , LC.LCSTORGTYPECD AS FIELD3
			 , COUNT(DISTINCT IVLC.ICKEY) AS FIELD4
			 , CASE WHEN COALESCE(LC.IVCNTRMGMTYN, 'N') = 'Y' THEN MAX(CASE IVLC.IVSERIALNO WHEN 'NA' THEN '' ELSE IVLC.IVSERIALNO END)
					ELSE '' END AS FIELD5
			 , ZN.ZNNM AS FIELD6
			 , AR.ARNM AS FIELD7
			 , LC.CTKEY
			 , LC.ZNKEY
			 , ZN.ZNNM
			 , LC.ARKEY
			 , AR.ARNM
			 , LC.LCKEY
			 , LC.LCTYPECD
			 , LC.LCSTORGTYPECD
			 , LCTYP.CTCDDTNM AS LCSTORGTYPENM /* 로케이션유형명 */
			 , LC.IVCNTRMGMTYN
			 , COUNT(DISTINCT IVLC.ICKEY) AS SKUCOUNT
			 , CASE WHEN COALESCE(LC.IVCNTRMGMTYN, 'N') = 'Y' THEN MAX(CASE IVLC.IVSERIALNO WHEN 'NA' THEN '' ELSE IVLC.IVSERIALNO END)
					ELSE '' END AS IVSERIALNO
			 , MAX(IVLC.IVSERIALDIVCD) AS IVSERIALDIVCD
			 , CASE WHEN COALESCE(LC.IVCNTRMGMTYN, 'N') = 'Y' AND MAX(CASE IVLC.IVSERIALNO WHEN 'NA' THEN '' ELSE IVLC.IVSERIALNO END) IS NOT NULL THEN LC.LCKEY||' ['||MAX(CASE IVLC.IVSERIALNO WHEN 'NA' THEN '' ELSE IVLC.IVSERIALNO END)||']'
					ELSE LC.LCKEY END AS LCKEYNM
		  FROM TWORK_MST_LC LC
		 INNER JOIN TWORK_MST_AR AR
			ON AR.CTKEY = LC.CTKEY
		   AND AR.ZNKEY = LC.ZNKEY
		   AND AR.ARKEY = LC.ARKEY
		 INNER JOIN TWORK_MST_ZN ZN
			ON ZN.CTKEY = LC.CTKEY
		   AND ZN.ZNKEY = LC.ZNKEY
		 INNER JOIN TWORK_MST_CT CT
			ON CT.CTKEY = LC.CTKEY
		  LEFT JOIN TWORK_INFO_IVATXLC IVLC
			ON IVLC.CTKEY = LC.CTKEY
		   AND IVLC.OWKEY = COALESCE(#{owkey}, #{sowkey})
		   AND IVLC.LCKEY = LC.LCKEY
		   AND IVLC.TOTQTY <![CDATA[ > ]]> 0
		  LEFT JOIN TWORK_MST_CTCD_DT LCTYP
			ON LCTYP.CTKEY = LC.CTKEY
		   AND LCTYP.CTCDHDKEY = 'LCSTORGTYPECD'
		   AND LCTYP.CTCDDTKEY = LC.LCSTORGTYPECD
		   AND LCTYP.LAKEY = #{slakey}

		<where>
			AND LC.CTKEY = COALESCE(#{ctkey}, #{sctkey})

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(znnm)">
				AND ZN.ZNNM LIKE '%' || #{znnm} || '%'
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(zntypecd)">
				AND ZN.ZNTYPECD = #{zntypecd}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(arkey)">
				AND (
					AR.ARKEY LIKE '%' || #{arkey} || '%'
				 OR
					AR.ARNM LIKE '%' || #{arkey} || '%'
				  )
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(lckey)">
				AND LC.LCKEY LIKE '%' || #{lckey} || '%'
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				AND LC.LCKEY LIKE '%' || #{value} || '%'
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(lcstorgtypecd)">
				AND LC.LCSTORGTYPECD = #{lcstorgtypecd}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(cellemptyyn)">
			    <choose>
					<when test='"Y".equals(cellemptyyn)'>
						AND IVLC.LCKEY IS NULL
					</when>
					<when test='"N".equals(cellemptyyn)'>
						AND IVLC.LCKEY IS NOT NULL
					</when>
				</choose>
			</if>


		</where>

		 GROUP BY
		       LC.CTKEY
			 , LC.ZNKEY
			 , ZN.ZNNM
			 , LC.ARKEY
			 , AR.ARNM
			 , LC.LCKEY
			 , LC.LCTYPECD
			 , LC.LCSTORGTYPECD
			 , LC.IVCNTRMGMTYN
			 , LCTYP.CTCDDTNM
	</sql>

	<select id="selectTWorkMstLocCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstLocCount - 로케이션 Count */
		SELECT COUNT(1)
		  FROM (
			<include refid="sql_selectTWorkMstLoc"/>
			 )
	</select>

	<select id="selectTWorkMstLocList" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstLocCount - 로케이션 List */
		<include refid="sql_pagingTop"/>
		<include refid="sql_selectTWorkMstLoc"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_TWorkMstCtg">
		  FROM TWORK_MST_CTG CTG
		 INNER JOIN TWORK_MST_CT CT
			ON CT.CTKEY = CTG.CTKEY
		 INNER JOIN TWORK_MST_OW OW
			ON OW.OWKEY = CTG.OWKEY

		<where>
			<if test="ctkeyList != null and ctkeyList.size > 0">
				<foreach item="ctkey" collection="ctkeyList" open=" AND CTG.CTKEY IN (" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="owkeyList != null and owkeyList.size > 0">
				<foreach item="owkey" collection="owkeyList" open=" AND CTG.OWKEY IN (" separator="," close=")">
					#{owkey}
				</foreach>
			</if>

			AND CTG.CTKEY = COALESCE(#{ctkey}, #{sctkey})
			AND CTG.OWKEY = COALESCE(#{owkey}, #{sowkey})
			AND CTG.DELYN <![CDATA[ <> ]]> 'Y'

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(uprctgkey)">
				AND CTG.UPRCTGKEY = #{uprctgkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(ctglv)">
				AND CTG.CTGLV = #{ctglv}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND CTG.CTGKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						CTG.CTGKEY ~ #{value}
						OR
						CTG.CTGNM ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						CTG.CTGKEY LIKE '%' || #{value} || '%'
						OR
						CTG.CTGNM LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<select id="selectItemCtgLevelList" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectItemCtgLevel1List - 카테고리 대/중/소 분류 */
		<include refid="sql_pagingTop"/>
		SELECT CTG.CTGKEY AS FIELD1
			 , CTG.CTGNM AS FIELD2
			 , CTG.CTGKEY
			 , CTG.CTGNM
			 , CTG.CTGLV
			 , CTG.UPRCTGKEY
		<include refid="sql_TWorkMstCtg"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<select id="selectTWorkMstBoxCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstBoxCount - BOX Count */
		SELECT COUNT(1)
		  FROM (
			<include refid="sql_selectTWorkMstBox"/>
			 )
	</select>

	<select id="selectTWorkMstBoxList" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstBoxList - BOX List */
		<include refid="sql_pagingTop"/>
		<include refid="sql_selectTWorkMstBox"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_selectTWorkMstBox">
		SELECT BOX.BOXBARCODE AS FIELD1 /*박스바코드*/
			 , BOX.BOXNM AS FIELD2 /*박스명*/
			 , CD.CTCDDTNM AS FIELD3 /*박스구분코드명*/
			 , BOX.WIDTH AS FIELD4 /*가로*/
			 , BOX.DEPTH AS FIELD5 /*세로*/
			 , BOX.HEIGHT AS FIELD6 /*높이*/
			 , BOX.CBMSTARTRNG AS FIELD7 /*CBM시작범위*/
			 , BOX.CBMCLOSRNG AS FIELD8 /*CBM종료범위*/
			 , BOX.USEYN AS FIELD9 /*사용여부*/
			 , BOX.CTKEY /*센터코드*/
			 , BOX.BOXBARCODE /*박스바코드*/
			 , BOX.BOXNM /*박스명*/
			 , BOX.BOXDIVCD /*박스구분코드*/
			 , CD.CTCDDTNM /*박스구분코드명*/
			 , BOX.WIDTH /*가로*/
			 , BOX.DEPTH /*세로*/
			 , BOX.HEIGHT /*높이*/
			 , BOX.CBMSTARTRNG /*CBM시작범위*/
			 , BOX.CBMCLOSRNG /*CBM종료범위*/
			 , BOX.ICKEY /*상폼코드*/
			 , IC.ICNM /*상품명*/
			 , BOX.USEYN /*사용여부*/
		  FROM TWORK_MST_BOX BOX
		 INNER JOIN TWORK_MST_CTCD_DT CD
		    ON BOX.CTKEY = CD.CTKEY
		   AND BOX.BOXDIVCD = CD.CTCDDTKEY
		   AND CD.CTCDHDKEY = 'BOXDIVCD'
		  LEFT OUTER JOIN TWORK_MST_IC IC
		    ON BOX.CTKEY = IC.CTKEY
		   AND BOX.ICKEY = IC.ICKEY
		<where>
			AND BOX.CTKEY = COALESCE(#{ctkey}, #{sctkey})

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND BOX.BOXNM = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						BOX.BOXBARCODE ~ #{value}
						OR
						BOX.BOXNM ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						BOX.BOXBARCODE ~ #{value}
						OR
						BOX.BOXNM ~ #{value}
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<sql id="sql_tWorkMstToCt">
		/* wms-common-sql-oracle.xml - sql_tWorkMstToCt - common 센터 조회 SQL */
		<where>
			AND A.CLOSDATE <![CDATA[ >= ]]> #{sysdate}
			AND A.CTTYPECD = '02'

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.CTKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.CTKEY ~ #{value}
						OR
						A.CTNM ~ #{value}
						OR
						B.CTCDDTNM ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.CTKEY LIKE '%' || #{value} || '%'
						OR
						A.CTNM LIKE '%' || #{value} || '%'
						OR
						B.CTCDDTNM LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

	<select id="selectTWorkMstToCtCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstToCtCount */
		<include refid="sql_Tcode"/>
		SELECT COUNT(1)
		  FROM TWORK_MST_CT A
		  LEFT OUTER JOIN T_CODE B
			ON B.CTKEY = A.CTKEY
		   AND B.CTCDHDKEY = 'CTTYPE'
		   AND B.CTCDDTKEY = A.CTTYPECD
		<include refid="sql_tWorkMstToCt"/>
	</select>

	<select id="selectTWorkMstToCt" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstToCt */
		<include refid="sql_Tcode"/>
		<include refid="sql_pagingTop"/>

		SELECT A.CTKEY AS FIELD1
			 , A.CTNM AS FIELD2
			 , B.CTCDDTNM AS FIELD3
			 , A.CTKEY
			 , A.CTNM
			 , A.CTTYPECD
		  FROM TWORK_MST_CT A
		  LEFT OUTER JOIN T_CODE B
			ON B.CTKEY = A.CTKEY
		   AND B.CTCDHDKEY = 'CTTYPE'
		   AND B.CTCDDTKEY = A.CTTYPECD
		<include refid="sql_tWorkMstToCt"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<insert id="insertTadminInfoUrHs">
		/* wms-common-sql-oracle.xml - insertTadminInfoUrHs */
		INSERT INTO TADMIN_INFO_URHS (
				ACSDATE
			 ,  ACSURKEY
			 ,  ACSIP
			 ,  ACSUSKEY
			 ,  SEARCHCOND
			 ,  PRGRBIZ
			 ,  INFOTGTCNT
			 ,  INSERTDATE
			 ,  INSERTURKEY
			 ,  UPDATEDATE
			 ,  UPDATEURKEY
		) VALUES (
				#{sysdate}
			 ,  #{surkey}
			 ,  #{acsip}
			 ,  #{menuId}
			 ,  #{resultParam}
			 ,  #{method}
			 ,  #{infotgtcnt}
			 ,  #{sysdate}
			 ,  #{surkey}
			 ,  #{sysdate}
			 ,  #{surkey}
		 )
	</insert>

</mapper>