	<sql id="sql_tWorkMstToLcBon2">
		FROM TWORK_MST_LC A
		LEFT OUTER JOIN T_CODE B
			ON B.CTKEY = A.CTKEY AND B.CTCD_HDKEY = 'LCTYPE' AND B.CTCD_DTKEY = A.LCTYPE
		LEFT OUTER JOIN T_CODE C
			ON C.CTKEY = A.CTKEY AND C.CTCD_HDKEY = 'LCHOLDTYPE' AND C.CTCD_DTKEY = A.LCHOLDTYPE

		WHERE A.LCKEY IN ('STAGE_A','STAGE_B','STAGE_C')
		AND A.CTKEY = COALESCE(#{ctkey}, #{sctkey})

		<if test="ctkeyList != null and ctkeyList.size > 0">
			AND A.CTKEY IN
			<foreach item="ctkey" collection="ctkeyList"
					 open="(" separator="," close=")">
				#{ctkey}
			</foreach>
		</if>

		<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
			<choose>
				<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
					AND A.LCKEY = #{value}
				</when>
				<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
					AND (
					A.LCKEY ~ #{value}
					OR
					A.LCTYPE ~ #{value}
					OR
					A.LCHOLDTYPE ~ #{value}
					)
				</when>
				<otherwise>
					AND (
					A.LCKEY LIKE '%' || #{value} || '%'
					OR
					A.LCTYPE LIKE '%' || #{value} || '%'
					OR
					A.LCHOLDTYPE LIKE '%' || #{value} || '%'
					)
				</otherwise>
			</choose>
		</if>
	</sql>

	<select id="selectTWorkMstToLcBonCount" resultType="java.lang.Integer">
		/* wms-common-sql-oracle.xml - selectTWorkMstToLcBonCount */
		<include refid="sql_Tcode"/>
		SELECT COUNT(*)
		FROM (
			SELECT B.LCKEY
			<include refid="sql_tWorkMstToLcBon"/>
			UNION ALL
			SELECT A.LCKEY
			<include refid="sql_tWorkMstToLcBon2"/>
		)
	</select>

	<select id="selectTWorkMstToLcBon" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstToLcBon */
		<include refid="sql_Tcode"/>
		<include refid="sql_pagingTop"/>
		SELECT
			  B.LCKEY AS FIELD1
			, B.LCTYPE AS FIELD2
			, B.LCHOLDTYPE AS FIELD3
		<include refid="sql_tWorkMstToLcBon"/>

		UNION ALL

		SELECT
		      A.LCKEY
			, A.LCTYPE
			, A.LCHOLDTYPE
		<include refid="sql_tWorkMstToLcBon2"/>
		<include refid="sql_pagingBottom"/>
	</select>

