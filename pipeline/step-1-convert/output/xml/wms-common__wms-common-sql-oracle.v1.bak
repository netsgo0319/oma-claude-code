	<select id="selectTWorkMstLcNonAuto" resultType="camelMap">
		/* wms-common-sql-oracle.xml - selectTWorkMstLcNonAuto */
		<include refid="sql_Tcode"/>
		<include refid="sql_pagingTop"/>
		SELECT	A.LCKEY AS FIELD1
		,C.CTCD_DTNAME AS FIELD2
		,D.CTCD_DTNAME AS FIELD3
		,A.ARKEY AS FIELD4
		,F.CTCD_DTNAME AS FIELD5
		<include refid="sql_tWorkMstLcNonAuto"/>
		<include refid="sql_pagingBottom"/>
	</select>

	<sql id="sql_tWorkMstLcNonAutoNormal">
		FROM TWORK_MST_LC A
		INNER JOIN (SELECT A.CTKEY
						, A.LCKEY
						, CASE WHEN SUM(COALESCE(B.TTQTY, 0)) > 0 THEN 'N' ELSE 'Y' END AS EMPTYLOCATION_YN
					FROM TWORK_MST_LC A
					LEFT OUTER JOIN TWORK_INFO_IVATXLCXULC B
								 ON A.CTKEY = B.CTKEY
								AND A.LCKEY = B.LCKEY
					GROUP BY A.CTKEY, A.LCKEY
			) B ON B.CTKEY = A.CTKEY AND B.LCKEY = A.LCKEY
		INNER JOIN TWORK_MST_AR C
			ON C.CTKEY = A.CTKEY AND C.ARKEY = A.ARKEY
		LEFT OUTER JOIN T_CODE D
			ON D.CTKEY = A.CTKEY AND D.CTCD_HDKEY = 'LCTYPE' AND D.CTCD_DTKEY = A.LCTYPE
		LEFT OUTER JOIN T_CODE E
			ON E.CTKEY = A.CTKEY AND E.CTCD_HDKEY = 'LCHOLDTYPE' AND E.CTCD_DTKEY = A.LCHOLDTYPE
		LEFT OUTER JOIN T_CODE F
			ON F.CTKEY = A.CTKEY AND F.CTCD_HDKEY = 'ERPSTLC' AND F.CTCD_DTKEY = A.ERPSTLC
		LEFT OUTER JOIN T_CODE G
			ON G.CTKEY = A.CTKEY AND G.CTCD_HDKEY = 'YESORNO' AND G.CTCD_DTKEY = B.EMPTYLOCATION_YN

		<where>
			AND A.CTKEY = COALESCE(#{ctkey}, #{sctkey})
			AND A.LCSTORTYPE NOT IN('40', '50')
			AND A.LCHOLDTYPE = '10'
			AND C.BONDTYPE = '1'

			<if test="ctkeyList != null and ctkeyList.size > 0">
				AND A.CTKEY IN
				<foreach item="ctkey" collection="ctkeyList"
						 open="(" separator="," close=")">
					#{ctkey}
				</foreach>
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(arkey)">
				AND A.ARKEY = #{arkey}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(erpstlc)">
				AND A.ERPSTLC = #{erpstlc}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(lcstortype)">
				AND A.LCSTORTYPE = #{lcstortype}
			</if>

			<if test="@com.kns.framework.util.StringUtil@isNotEmpty(value)">
				<choose>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "=".equals(opval)'>
						AND A.LCKEY = #{value}
					</when>
					<when test='@com.kns.framework.util.StringUtil@isNotEmpty(opval) and "IN".equals(opval)'>
						AND (
						A.LCKEY ~ #{value}
						OR
						A.LCTYPE ~ #{value}
						OR
						A.LCHOLDTYPE ~ #{value}
						OR
						A.ARKEY ~ #{value}
						OR
						A.ERPSTLC ~ #{value}
						)
					</when>
					<otherwise>
						AND (
						A.LCKEY LIKE '%' || #{value} || '%'
						OR
						A.LCTYPE LIKE '%' || #{value} || '%'
						OR
						A.LCHOLDTYPE LIKE '%' || #{value} || '%'
						OR
						A.ARKEY LIKE '%' || #{value} || '%'
						OR
						A.ERPSTLC LIKE '%' || #{value} || '%'
						)
					</otherwise>
				</choose>
			</if>
		</where>
	</sql>

