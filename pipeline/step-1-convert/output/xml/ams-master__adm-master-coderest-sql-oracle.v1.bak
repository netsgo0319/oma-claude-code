				   AND OH.REQUESTDT = #{requestDt}
				  LEFT JOIN TADMIN_MST_ADCD_HD M
				    ON T.ADCDHDKEY = M.ADCDHDKEY
		       ) T
		 WHERE T.SAVEYN = 'Y'
	</insert>
	
