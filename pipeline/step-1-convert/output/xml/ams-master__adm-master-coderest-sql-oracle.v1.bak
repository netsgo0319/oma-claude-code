            , INSERTDATE    /*입력 일시*/
            , INSERTURKEY    /*입력 사용자 ID*/
            , UPDATEDATE    /*수정 일시*/
            , UPDATEURKEY    /*수정 사용자 ID*/

        )
        SELECT T.ADCDHDKEY AS TMCD_HDKEY
             , T.ADCDHDNM AS TMCD_HDNAME
             , 'N' AS DELYN
             , #{interfaceDate} AS INSERTDATE    /*입력일자*/
             , #{interfaceUrkey} AS INSERTURKEY    /*입력사용자*/
             , #{interfaceDate} AS UPDATEDATE    /*수정일자*/
             , #{interfaceUrkey} AS UPDATEURKEY    /*수정사용자*/
          FROM (
                SELECT T.ADCDHDKEY
                     , OH.OWCDHDNM AS ADCDHDNM
                     , CASE WHEN M.TMCD_HDKEY IS NULL THEN 'Y' ELSE 'N' END AS SAVEYN
                  FROM (
                        <foreach collection="interfaceList" item="item" separator="UNION ALL">
                            SELECT #{owkey} AS OWKEY    /*화주*/
                                 , #{item.owcdHdkey} AS OWCDHDKEY    /*화주공통 헤더키*/
                                 , #{item.adcdHdkey} AS ADCDHDKEY    /*화주공통 헤더명*/
                        </foreach>  
                       ) T
                  JOIN TADMIN_INTF_OWCD_HD OH
                    ON T.OWCDHDKEY = OH.OWCDHDKEY
                   AND OH.IFID = #{interfaceId}
                   AND OH.REQUESTDT = #{requestDt}
                  LEFT JOIN TT_MST_TMCD_HD M
                    ON T.ADCDHDKEY = M.TMCD_HDKEY
               ) T
         WHERE T.SAVEYN = 'Y'
    </insert>
    
    <update id="updateTmsDetailCodes">
        /* adm-master-coderest-sql-oracle.xml  updateTmsDetailCodes */
        UPDATE TT_MST_TMCD_DT M 
           SET (      
                      TMCD_DTNAME   /*관리자 기준 코드 상세 명*/
                    , UPDATEDATE    /*수정 일시*/
                    , UPDATEURKEY    /*수정 사용자 ID*/

                )
             = (
                SELECT OD.OWCDDTNM AS TMCD_DTNAME
                     , #{interfaceDate} AS UPDATEDATE    /*수정일시*/
                     , #{interfaceUrkey} AS UPDATEURKEY    /*수정사용자 ID*/
                  FROM (
                        <foreach collection="interfaceList" item="item" separator="UNION ALL">
                            SELECT #{owkey} AS OWKEY    /*화주*/
                                 , #{item.owcdHdkey} AS OWCDHDKEY    /*화주공통 헤더키*/
                                 , #{item.adcdHdkey} AS ADCDHDKEY    /*화주공통 헤더명*/
                        </foreach>  
                       ) T
                  JOIN TADMIN_INTF_OWCD_DT OD
                    ON T.OWCDHDKEY = OD.OWCDHDKEY
                   AND OD.IFID = #{interfaceId}
                   AND OD.REQUESTDT = #{requestDt} 
                 WHERE T.ADCD_HDKEY = M.TMCD_HDKEY  
                   AND OD.OWCDDTKEY = M.TMCD_DTKEY
                   AND M.LAKEY = 'KOR' 
               )
         WHERE EXISTS (
                        SELECT 1
                          FROM (
                                <foreach collection="interfaceList" item="item" separator="UNION ALL">
                                    SELECT #{owkey} AS OWKEY    /*화주*/
                                         , #{item.owcdHdkey} AS OWCDHDKEY    /*화주공통 헤더키*/
                                         , #{item.adcdHdkey} AS ADCDHDKEY    /*화주공통 헤더명*/
                                </foreach>  
                               ) T
                          JOIN TADMIN_INTF_OWCD_DT OD
                            ON T.OWCDHDKEY = OD.OWCDHDKEY
                           AND OD.IFID = #{interfaceId}
                           AND OD.REQUESTDT = #{requestDt}
                         WHERE T.ADCDHDKEY = M.TMCD_HDKEY
                           AND OD.OWCDDTKEY = M.TMCD_DTKEY
                           AND M.LAKEY = 'KOR' 
                      )
    </update>
    
    <insert id="insertTmsDetailCodes">
        /* Tms-item-itemrest-sql-oracle.xml  insertTmsDetailCodes */
        INSERT INTO TT_MST_TMCD_DT
        (
              TMCD_HDKEY   /*관리자 기준 코드 공통 코드*/
            , TMCD_DTKEY   /*관리자 기준 코드 상세 코드*/
            , LAKEY    /*국가별 언어 코드*/
            , TMCD_DTORDER   /*관리자 기준 코드 상세 순서*/
            , TMCD_DTNAME   /*관리자 기준 코드 상세 명*/
            , DELYN    /*삭제여부*/
            , INSERTDATE    /*입력 일시*/
            , INSERTURKEY    /*입력 사용자 ID*/
            , UPDATEDATE    /*수정 일시*/
            , UPDATEURKEY    /*수정 사용자 ID*/

        )
        SELECT TT.ADCDHDKEY AS TMCD_HDKEY
             , TT.ADCDDTKEY AS TMCD_DTKEY
             , 'KOR' AS LAKEY    /*국가별 언어 코드*/
             , ROW_NUMBER() OVER(PARTITION BY TT.ADCDHDKEY ORDER BY TT.ADCDDTKEY) + COALESCE(RM.ADCDDTORDER, 0) AS TMCD_DTORDER
             , TT.ADCDDTNM AS TMCD_DTNAME
             , 'N' AS DELYN
             , #{interfaceDate} AS INSERTDATE    /*입력일자*/
             , #{interfaceUrkey} AS INSERTURKEY    /*입력사용자*/
             , #{interfaceDate} AS UPDATEDATE    /*수정일자*/
             , #{interfaceUrkey} AS UPDATEURKEY    /*수정사용자*/
          FROM (
                SELECT T.ADCD_HDKEY
                     , OD.OWCDDTKEY AS ADCDDTKEY
                     , OD.OWCDDTNAME AS ADCDDTNM
                     , CASE WHEN M.TMCD_HDKEY IS NULL THEN 'Y' ELSE 'N' END AS SAVEYN
                  FROM (
                        <foreach collection="interfaceList" item="item" separator="UNION ALL">
                            SELECT #{owkey} AS OWKEY    /*화주*/
                                 , #{item.owcdHdkey} AS OWCDHDKEY    /*화주공통 헤더키*/
                                 , #{item.adcdHdkey} AS ADCDHDKEY    /*화주공통 헤더명*/
                        </foreach>  
                       ) T
                  JOIN TADMIN_INTF_OWCD_DT OD
                    ON T.OWCDHDKEY = OD.OWCDHDKEY
                   AND OD.IFID = #{interfaceId}
                   AND OD.REQUESTDT = #{requestDt}
                  LEFT JOIN TT_MST_TMCD_DT M
                    ON T.ADCD_HDKEY = M.TMCD_HDKEY  
                   AND OD.OWCD_DTKEY = M.TMCD_DTKEY
                   AND M.LAKEY = 'KOR'
               ) TT
          LEFT JOIN (
                SELECT MAX(M.TMCD_DTORDER) AS ADCDDTORDER
                     , T.ADCDHDKEY
                  FROM (
                        <foreach collection="interfaceList" item="item" separator="UNION ALL">
                            SELECT #{owkey} AS OWKEY    /*화주*/
                                 , #{item.owcdHdkey} AS OWCDHDKEY    /*화주공통 헤더키*/
                                 , #{item.adcdHdkey} AS ADCDHDKEY    /*화주공통 헤더명*/
                        </foreach>  
                       ) T
                  JOIN TADMIN_INTF_OWCD_DT OD
                    ON T.OWCDHDKEY = OD.OWCDHDKEY
                   AND OD.IFID = #{interfaceId}
                   AND OD.REQUESTDT = #{requestDt}
                  JOIN TT_MST_TMCD_DT M
                    ON T.ADCDHDKEY = M.TMCD_HDKEY
                   AND OD.OWCDDTKEY = M.TMCD_DTKEY
                   AND M.LAKEY = 'KOR'
                 GROUP BY T.ADCDHDKEY
               ) RM
            ON TT.ADCDHDKEY = RM.ADCDHDKEY
         WHERE TT.SAVEYN = 'Y'
    </insert>
</mapper>