	<insert id="insertWmsDetailCodes">
		/* wms-item-itemrest-sql-oracle.xml  insertWmsDetailCodes */
		INSERT INTO TWORK_MST_CTCD_DT
		(
			  CTKEY   /*센터 코드*/
			, CTCD_HDKEY   /*센터 기준 코드 공통 코드*/
			, CTCD_DTKEY   /*센터 기준 코드 상세 코드*/
			, LAKEY    /*국가별 언어 코드*/
			, CTCD_DTORDER   /*센터 기준 코드 상세 순서*/
			, CTCD_DTNAME   /*센터 기준 코드 상세 명*/
			, DELYN    /*삭제여부*/
			, INSERTDATE    /*입력 일시*/
			, INSERTURKEY    /*입력 사용자 ID*/
			, UPDATEDATE    /*수정 일시*/
			, UPDATEURKEY    /*수정 사용자 ID*/

		)
		SELECT TT.CTKEY
		     , TT.ADCDHDKEY AS CTCD_HDKEY
			 , TT.ADCDDTKEY AS CTCD_DTKEY
			 , 'KOR' AS LAKEY    /*국가별 언어 코드*/
			 , ROW_NUMBER() OVER(PARTITION BY TT.ADCDHDKEY ORDER BY TT.ADCDDTKEY) + COALESCE(RM.ADCDDTORDER, 0) AS CTCDDTORDER
			 , TT.ADCDDTNM AS CTCD_DTNAME
			 , 'N' AS DELYN
			 , #{interfaceDate} AS INSERTDATE    /*입력일자*/
		     , #{interfaceUrkey} AS INSERTURKEY    /*입력사용자*/
		     , #{interfaceDate} AS UPDATEDATE    /*수정일자*/
		     , #{interfaceUrkey} AS UPDATEURKEY    /*수정사용자*/
		  FROM (
		  		SELECT T.ADCDHDKEY
					 , OD.OWCDDTKEY AS ADCDDTKEY
					 , OD.OWCDDTNM AS ADCDDTNM
					 , CT.CTKEY
					 , CASE WHEN M.CTCD_HDKEY IS NULL THEN 'Y' ELSE 'N' END AS SAVEYN
				  FROM (
			      		<foreach collection="interfaceList" item="item" separator="UNION ALL">
							SELECT #{owkey} AS OWKEY    /*화주*/
								 , #{item.owcdHdkey} AS OWCDHDKEY    /*화주공통 헤더키*/
								 , #{item.adcdHdkey} AS ADCDHDKEY    /*화주공통 헤더명*/
						</foreach>	
			      	   ) T
			      JOIN TADMIN_INTF_OWCD_DT OD
			        ON T.OWCDHDKEY = OD.OWCDHDKEY
				   AND OD.IFID = #{interfaceId}
				   AND OD.REQUESTDT = #{requestDt}
				  JOIN TADMIN_MST_CT CT
				    ON CT.DELYN = 'N'
				   AND CT.MANAGEMENTYN = 'Y'
				  LEFT JOIN TWORK_MST_CTCD_DT M
				    ON T.ADCDHDKEY = M.CTCD_HDKEY
                   AND OD.OWCDDTKEY = M.CTCD_DTKEY
                   AND CT.CTKEY = M.CTKEY
                   AND M.LAKEY = 'KOR'
		       ) TT
		  LEFT JOIN (
		  		SELECT MAX(M.CTCDDTORDER) AS ADCDDTORDER
		             , T.ADCDHDKEY
		             , CT.CTKEY
				  FROM (
			      		<foreach collection="interfaceList" item="item" separator="UNION ALL">
							SELECT #{owkey} AS OWKEY    /*화주*/
								 , #{item.owcdHdkey} AS OWCDHDKEY    /*화주공통 헤더키*/
								 , #{item.adcdHdkey} AS ADCDHDKEY    /*화주공통 헤더명*/
						</foreach>	
			      	   ) T
			      JOIN TADMIN_INTF_OWCD_DT OD
			        ON T.OWCDHDKEY = OD.OWCDHDKEY
				   AND OD.IFID = #{interfaceId}
				   AND OD.REQUESTDT = #{requestDt}
				  JOIN TADMIN_MST_CT CT
				    ON CT.DELYN = 'N'
				   AND CT.MANAGEMENTYN = 'Y'
				  JOIN TWORK_MST_CTCD_DT M
				    ON T.ADCDHDKEY = M.CTCD_HDKEY
                   AND OD.OWCDDTKEY = M.CTCD_DTKEY
                   AND CT.CTKEY = M.CTKEY
                   AND M.LAKEY = 'KOR'
                 GROUP BY T.ADCDHDKEY, CT.CTKEY
		       ) RM
		    ON TT.ADCDHDKEY = RM.ADCDHDKEY
		   AND TT.CTKEY = RM.CTKEY
		 WHERE TT.SAVEYN = 'Y'
	</insert>
	
	<update id="updateTmsCodes">
        /* adm-master-coderest-sql-oracle.xml  updateTmsCodes */
        UPDATE TT_MST_TMCD_HD M 
           SET (  TMCD_HDNAME    /*관리자 기준 공통 코드 명*/
                , UPDATEDATE    /*수정 일시*/
                , UPDATEURKEY    /*수정 사용자 ID*/
                )
             = (
                SELECT OH.OWCDHDNM AS TMCD_HDNAME
                     , #{interfaceDate} AS UPDATEDATE    /*수정일시*/
                     , #{interfaceUrkey} AS UPDATEURKEY    /*수정사용자 ID*/
                  FROM (
                        <foreach collection="interfaceList" item="item" separator="UNION ALL">
                            SELECT #{owkey} AS OWKEY    /*화주*/
                                 , #{item.owcdHdkey} AS OWCDHDKEY    /*화주공통 헤더키*/
                                 , #{item.adcdHdkey} AS ADCDHDKEY    /*화주공통 헤더명*/
                        </foreach>  
                       ) T
                  JOIN TADMIN_INTF_OWCD_HD OH
                    ON T.OWCDHDKEY = OH.OWCDHDKEY
                   AND OH.IFID = #{interfaceId}
                   AND OH.REQUESTDT = #{requestDt} 
                 WHERE T.ADCDHDKEY = M.TMCD_HDKEY
               )
         WHERE EXISTS (
                        SELECT 1
                          FROM (
                                <foreach collection="interfaceList" item="item" separator="UNION ALL">
                                    SELECT #{owkey} AS OWKEY    /*화주*/
                                         , #{item.owcdHdkey} AS OWCDHDKEY    /*화주공통 헤더키*/
                                         , #{item.adcdHdkey} AS ADCDHDKEY    /*화주공통 헤더명*/
                                </foreach>  
                               ) T
                          JOIN TADMIN_INTF_OWCD_HD OH
                            ON T.OWCDHDKEY = OH.OWCDHDKEY
                           AND OH.IFID = #{interfaceId}
                           AND OH.REQUESTDT = #{requestDt} 
                         WHERE T.ADCDHDKEY = M.TMCD_HDKEY
                      )
    </update>
    
