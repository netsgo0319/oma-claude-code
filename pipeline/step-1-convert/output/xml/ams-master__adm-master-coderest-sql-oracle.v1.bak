	<insert id="insertAmsDetailCodes">
		/* wms-item-itemrest-sql-oracle.xml  insertAmsDetailCodes */
		INSERT INTO TADMIN_MST_ADCD_DT
		(
			  ADCDHDKEY    /*관리자 기준 코드 공통 코드*/
			, ADCDDTKEY    /*관리자 기준 코드 상세 코드*/
			, LAKEY    /*국가별 언어 코드*/
			, ADCDDTORDER    /*관리자 기준 코드 상세 순서*/
			, ADCDDTNM    /*관리자 기준 코드 상세 명*/
			, DELYN    /*삭제여부*/
			, INSERTDATE    /*입력 일시*/
			, INSERTURKEY    /*입력 사용자 ID*/
			, UPDATEDATE    /*수정 일시*/
			, UPDATEURKEY    /*수정 사용자 ID*/

		)
		SELECT TT.ADCDHDKEY    /*관리자 기준 코드 공통 코드*/
			 , TT.ADCDDTKEY    /*관리자 기준 코드 상세 코드*/
			 , 'KOR' AS LAKEY    /*국가별 언어 코드*/
			 , ROW_NUMBER() OVER(PARTITION BY TT.ADCD_HDKEY ORDER BY TT.ADCD_DTKEY) + COALESCE(RM.ADCDDTORDER, 0) AS ADCDDTORDER  /*관리자 기준 코드 상세 순서*/
			 , TT.ADCDDTNM    /*관리자 기준 코드 상세 명*/
			 , 'N' AS DELYN
			 , #{interfaceDate} AS INSERTDATE    /*입력일자*/
		     , #{interfaceUrkey} AS INSERTURKEY    /*입력사용자*/
		     , #{interfaceDate} AS UPDATEDATE    /*수정일자*/
		     , #{interfaceUrkey} AS UPDATEURKEY    /*수정사용자*/
		  FROM (
		  		SELECT T.ADCDHDKEY
					 , OD.OWCDDTKEY AS ADCDDTKEY
					 , OD.OWCDDTNM AS ADCDDTNM
					 , CASE WHEN M.ADCDHDKEY IS NULL THEN 'Y' ELSE 'N' END AS SAVEYN
				  FROM (
			      		<foreach collection="interfaceList" item="item" separator="UNION ALL">
							SELECT #{owkey} AS OWKEY    /*화주*/
								 , #{item.owcdHdkey} AS OWCDHDKEY    /*화주공통 헤더키*/
								 , #{item.adcdHdkey} AS ADCDHDKEY    /*화주공통 헤더명*/
						</foreach>	
			      	   ) T
			      JOIN TADMIN_INTF_OWCD_DT OD
			        ON T.OWCDHDKEY = OD.OWCDHDKEY
				   AND OD.IFID = #{interfaceId}
				   AND OD.REQUESTDT = #{requestDt}
				  LEFT JOIN TADMIN_MST_ADCD_DT M
				    ON T.ADCDHDKEY = M.ADCDHDKEY
                   AND OD.OWCDDTKEY = M.ADCDDTKEY
                   AND M.LAKEY = 'KOR'
		       ) TT
		  LEFT JOIN (
		  		SELECT MAX(M.ADCDDTORDER) AS ADCDDTORDER
		             , T.ADCDHDKEY
				  FROM (
			      		<foreach collection="interfaceList" item="item" separator="UNION ALL">
							SELECT #{owkey} AS OWKEY    /*화주*/
								 , #{item.owcdHdkey} AS OWCDHDKEY    /*화주공통 헤더키*/
								 , #{item.adcdHdkey} AS ADCDHDKEY    /*화주공통 헤더명*/
						</foreach>	
			      	   ) T
			      JOIN TADMIN_INTF_OWCD_DT OD
			        ON T.OWCDHDKEY = OD.OWCDHDKEY
				   AND OD.IFID = #{interfaceId}
				   AND OD.REQUESTDT = #{requestDt}
				  JOIN TADMIN_MST_ADCD_DT M
				    ON T.ADCDHDKEY = M.ADCDHDKEY
                   AND OD.OWCDDTKEY = M.ADCDDTKEY
                   AND M.LAKEY = 'KOR'
                 GROUP BY T.ADCDHDKEY
		       ) RM
		    ON TT.ADCDHDKEY = RM.ADCDHDKEY
		 WHERE TT.SAVEYN = 'Y'
	</insert>
	
	<update id="updateWmsCodes">
