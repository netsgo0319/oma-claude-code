			, ADCDHDNM    /*관리자 기준코드 공통 명*/
			, DELYN    /*삭제여부*/
			, INSERTDATE    /*입력 일시*/
			, INSERTURKEY    /*입력 사용자 ID*/
			, UPDATEDATE    /*수정 일시*/
			, UPDATEURKEY    /*수정 사용자 ID*/

		)
		SELECT T.ADCDHDKEY    /*관리자 기준 코드 공통 코드*/
