					 OWKEY
                   , CTKEY
                   , REQORDERUNIT
                   , CRITUNIT
                   , CRITSET
                   , NUMRNG
                   , DELYN
		           , INSERTDATE
		           , INSERTURKEY
		           , UPDATEDATE
		           , UPDATEURKEY
					)
		        VALUES	(
				     #{owkey}
                   , #{ctkey}
                   , #{reqorderunit}
                   , #{critunit}
                   , #{critset}
                   , #{numrng}
                   , #{delyn}
		           , #{sysdate}
		           , #{surkey}
		           , #{sysdate}
		           , #{surkey}
		        )
	</insert>

