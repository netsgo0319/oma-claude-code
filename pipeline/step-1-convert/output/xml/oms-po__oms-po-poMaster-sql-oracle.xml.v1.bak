		   , #{surkey}
		   , #{sysdate}
		   , #{surkey}
		)
	</insert>

	<update id="updateCtCapa">
		/* oms-po-poMaster-sql-oracle.xml - updateCtCapa */
		UPDATE TORDER_MST_CT_CAPA
		   SET CAPA        = #{capa}
		     , DELYN       = #{delyn}
		     , UPDATEURKEY = #{surkey}
		     , UPDATEDATE  = #{sysdate}
		WHERE OWKEY        = #{owkey}
	      AND CTKEY        = #{ctkey}
	</update>



	<select id="selectTorderMstB2bgrtdays" resultType="camelMap" >
		/* oms-po-poMaster-sql-oracle.xml - selectTorderMstB2bgrtdays */
		#{GRIDPAGING_ROWNUMTYPE_TOP}
		WITH CMN_TB AS (
			SELECT
				A.CTKEY,
				A.CTNM,
				B.OWKEY,
				C.ICKEY,
				C.ICNM
			FROM TORDER_MST_CT A
			INNER JOIN TORDER_MST_ICXCT B
				ON A.CTKEY = B.CTKEY
			INNER JOIN TORDER_MST_IC C
				ON B.OWKEY  = C.OWKEY
			   AND B.ICKEY = C.ICKEY
			WHERE A.CTKEY = #{ctkey}
			  AND C.OWKEY = #{owkey}
			  AND C.POABLEYN = 'Y'
		)

		SELECT
			'0' AS CHK,
			CMN_TB.OWKEY,
			CMN_TB.CTKEY,
			CMN_TB.CTNM,
			CMN_TB.ICKEY,
			CMN_TB.ICNM,
			D.B2BCTKEY,
			E.CTNM AS B2BCTNM,
			D.B2BCTGRTDAYS,
			D.INSERTDATE,
			D.INSERTURKEY,
			D.UPDATEDATE,
			D.UPDATEURKEY
		FROM CMN_TB
		INNER JOIN TORDER_MST_B2BGRTDAYS D
			ON CMN_TB.CTKEY = D.CTKEY
		   AND CMN_TB.OWKEY = D.OWKEY
		   AND CMN_TB.ICKEY = D.ICKEY
		INNER JOIN TORDER_MST_CT E
			ON D.B2BCTKEY = E.CTKEY

		UNION ALL

		SELECT
			'0' AS CHK,
			CMN_TB.OWKEY,
			CMN_TB.CTKEY,
			CMN_TB.CTNM,
			CMN_TB.ICKEY,
			CMN_TB.ICNM,
			D.CTKEY AS B2BCTKEY,
			D.CTNM AS B2BCTNM,
			0 AS B2BCTGRTDAYS,
			''  AS INSERTDATE,
			'' AS INSERTURKEY,
			'' AS UPDATEDATE,
			'' AS UPDATEURKEY
		FROM CMN_TB
		INNER JOIN TORDER_MST_CT D
			ON D.CTKEY IN ('01','04','05')  -- 남사, 부산, 안성
		WHERE NOT EXISTS (
			SELECT 1
			FROM TORDER_MST_B2BGRTDAYS F
			WHERE F.ICKEY = CMN_TB.ICKEY
			  AND F.OWKEY = CMN_TB.OWKEY
			  AND F.CTKEY = CMN_TB.CTKEY
		)
		ORDER BY ICKEY, B2BCTKEY, UPDATEDATE
		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>

	<select id="selectTorderMstB2bgrtdaysCount" resultType="java.lang.Integer" >
		/* oms-po-poMaster-sql-oracle.xml - selectTorderMstB2bgrtdaysCount */
        SELECT count(1)
		FROM TORDER_MST_CT A
        INNER JOIN TORDER_MST_ICXCT B
                ON A.CTKEY = B.CTKEY
        INNER JOIN TORDER_MST_IC C
                ON B.OWKEY  = C.OWKEY
               AND B.ICKEY = C.ICKEY
               AND C.POABLEYN  = 'Y'
        LEFT JOIN TORDER_MST_B2BGRTDAYS D
               ON A.CTKEY = D.CTKEY
              AND C.OWKEY = D.OWKEY
              AND C.ICKEY = D.ICKEY
        LEFT JOIN TORDER_MST_CT E
               ON E.CTKEY IN ('01','04','05')  -- 01:  남사,  04 : 부산 , 05:안성
        WHERE 1=1
          AND C.OWKEY = #{owkey}
		  AND A.CTKEY = #{ctkey}
        ORDER BY D.UPDATEDATE,C.ICKEY, E.CTKEY
	</select>

	<insert id="mergeB2bgrtdays">
		/* oms-po-poMaster-sql-oracle.xml - mergeB2bgrtdays */
		MERGE INTO TORDER_MST_B2BGRTDAYS A
			USING DUAL
			ON (    OWKEY    = #{owkey}
				AND CTKEY    = #{ctkey}
				AND ICKEY    = #{ickey}
		        AND B2BCTKEY = #{b2bctkey}
		        )
			WHEN MATCHED THEN
				 UPDATE
					SET B2BCTGRTDAYS 	= #{b2bctgrtdays}
					  , UPDATEURKEY 	= #{surkey}
					  , UPDATEDATE  	= #{sysdate}
			WHEN NOT MATCHED THEN
			INSERT
				(
					 OWKEY
				   , CTKEY
				   , ICKEY
				   , B2BCTKEY
				   , B2BCTGRTDAYS
				   , INSERTDATE
				   , INSERTURKEY
				   , UPDATEDATE
				   , UPDATEURKEY
					)
				VALUES	(
					 #{owkey}
				   , #{ctkey}
				   , #{ickey}
				   , #{b2bctkey}
				   , #{b2bctgrtdays}
				   , #{sysdate}
				   , #{surkey}
				   , #{sysdate}
				   , #{surkey}
				)
	</insert>

	<select id="selectCritModeByCenter" resultType="java.lang.String">
	/* oms-po-poMaster-sql-oracle.xml - selectCritModeByCenter */
	
	   SELECT COALESCE(CRITMODE, 'SINGLE') AS CRITMODE
		 FROM TORDER_MST_CT
		WHERE CTKEY = #{ctkey}
	</select>
</mapper>
	