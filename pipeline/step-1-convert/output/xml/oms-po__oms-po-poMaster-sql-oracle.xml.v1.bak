	      AND REQORDERUNIT = #{reqorderunit}
	</update>

	<select id="selectTorderMstCtCapa" resultType="camelMap" >
		/* oms-po-poMaster-sql-oracle.xml - selectTorderMstCtCapa */
		#{GRIDPAGING_ROWNUMTYPE_TOP}
		SELECT '0' AS CHK
              , CP.OWKEY
              , CP.CTKEY
		      , C.CTNM
              , CP.CAPA
              , CP.DELYN
		      , CP.INSERTDATE
		      , CP.INSERTURKEY
		      , CP.UPDATEDATE
		      , CP.UPDATEURKEY
		FROM TORDER_MST_CT_CAPA CP
		INNER JOIN TORDER_MST_CT C
		        ON CP.CTKEY = C.CTKEY
		WHERE 1 = 1
		  AND CP.OWKEY = #{owkey}
		  AND CP.CTKEY = #{ctkey}
		ORDER BY CP.UPDATEDATE DESC

		#{GRIDPAGING_ROWNUMTYPE_BOTTOM}
	</select>

	<select id="selectTorderMstCtCapaCount" resultType="java.lang.Integer" >
		/* oms-po-poMaster-sql-oracle.xml - selectTorderMstCtCapaCount */
        SELECT count(1)
		FROM TORDER_MST_CT_CAPA CP
		INNER JOIN TORDER_MST_CT C
		        ON CP.CTKEY = C.CTKEY
		WHERE 1 = 1
		  AND CP.OWKEY = #{owkey}
		  AND CP.CTKEY = #{ctkey}

	</select>

