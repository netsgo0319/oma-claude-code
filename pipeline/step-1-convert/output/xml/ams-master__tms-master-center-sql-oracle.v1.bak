<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
	
<mapper namespace="com.daiso.ams.master.mapper.CenterTmsMapper">
	
	<insert id="insertTTMstCt" >
		/* tms-master-center-sql-oracle.xml - insertTTMstCt */
		MERGE INTO TT_MST_CT
		USING DUAL
		ON( CTKEY= #{ctkey} )
		WHEN MATCHED THEN
			UPDATE  
			SET
					 CTTYPE = #{cttype}
					,CTNAME = #{ctname}
					,ADDRID	 = #{addrid}
					,ZIPCODE	 = #{zipcode}
                    ,ADDRESS1	 = #{address1}
                    ,ADDRESS2	 = #{address2}
                    ,TEL	 	 = #{tel}
                    ,REGNO 		 = #{regno}
					,LOADING_UNIT = #{loadingUnit}
                    ,REPORTCTNAME = #{reportctname}
					,CLOSDATE = #{closdate}
			        ,UPDATEDATE = #{sysdate}
			        ,UPDATEURKEY = #{surkey}
		WHEN NOT MATCHED THEN
			INSERT (
			         CTKEY
			        ,CTTYPE
			        ,CTNAME
			        ,COUNTRYCODE
			        ,ADDRID
			        ,ZIPCODE
			        ,ADDRESS1
			        ,ADDRESS2
                    ,TEL
                    ,REGNO
                    ,REPORTCTNAME
					,LOADING_UNIT
			        ,INSERTDATE
			        ,INSERTURKEY
			        ,UPDATEDATE
			        ,UPDATEURKEY
			        ,CLOSDATE
			    ) VALUES (
					 #{ctkey}
					,#{cttype}
					,#{ctname}
					,#{lakey}
					,#{addrid}
					,#{zipcode}
					,#{address1}
					,#{address2}
					,#{tel}
					,#{regno}
					,#{reportctname}
					,#{loadingUnit}
					,#{sysdate}
					,#{surkey}
					,#{sysdate}
					,#{surkey}
					,#{closdate}
				)
	</insert>
	
	<update id="updateTTMstCt">
		/* tms-master-center-sql-oracle.xml - updateTTMstCt */
		MERGE INTO TT_MST_CT
		USING DUAL
		ON( CTKEY= #{ctkey} )
		WHEN MATCHED THEN
			UPDATE  
			SET
					 CTTYPE = #{cttype}
					,CTNAME = #{ctname}
					,ADDRID	 = #{addrid}
					,ZIPCODE	 = #{zipcode}
                    ,ADDRESS1	 = #{address1}
                    ,ADDRESS2	 = #{address2}
                    ,TEL	 	 = #{tel}
                    ,REGNO 		 = #{regno}
			    	,LOADING_UNIT = #{loadingUnit}
                    ,REPORTCTNAME = #{reportctname}
					,CLOSDATE = #{closdate}
			        ,UPDATEDATE = #{sysdate}
			        ,UPDATEURKEY = #{surkey}
					,DELYN = #{delyn}
		WHEN NOT MATCHED THEN
			INSERT (
			         CTKEY
			        ,CTTYPE
			        ,CTNAME
			        ,COUNTRYCODE
			        ,ADDRID
			        ,ZIPCODE
			        ,ADDRESS1
			        ,ADDRESS2
                    ,TEL
                    ,REGNO
                    ,REPORTCTNAME
			        ,INSERTDATE
			        ,INSERTURKEY
			        ,UPDATEDATE
			        ,UPDATEURKEY
			        ,CLOSDATE
			    ) VALUES (
					 #{ctkey}
					,#{cttype}
					,#{ctname}
					,#{lakey}
					,#{addrid}
					,#{zipcode}
					,#{address1}
					,#{address2}
					,#{tel}
					,#{regno}
					,#{reportctname}
					,#{sysdate}
					,#{surkey}
					,#{sysdate}
					,#{surkey}
					,#{closdate}
				)
	</update>
	
	<delete id="deleteTTMstCt">
		/* tms-master-center-sql-oracle.xml - deleteTTMstCt */
			UPDATE 	TT_MST_CT
			SET		DELYN = 'Y'
			WHERE 	CTKEY=#{ctkey}
	</delete>
	
</mapper>	