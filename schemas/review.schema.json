{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review Result",
  "description": "validate-and-fix 에이전트의 출력. 실패 원인 분석 및 수정안.",
  "type": "object",
  "required": ["version", "query_id", "failure_type", "root_cause", "fix_applied", "previous_sql", "fixed_sql", "attempt", "max_attempts"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "query_id": { "type": "string" },
    "failure_type": { "type": "string", "enum": ["SYNTAX_ERROR", "RUNTIME_ERROR", "DATA_MISMATCH", "UNKNOWN"] },
    "failure_subtype": { "type": "string" },
    "root_cause": { "type": "string" },
    "fix_applied": { "type": "string" },
    "previous_sql": { "type": "string" },
    "fixed_sql": { "type": "string" },
    "attempt": { "type": "integer", "minimum": 1 },
    "max_attempts": { "type": "integer", "default": 3 },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
  }
}
