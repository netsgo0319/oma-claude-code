{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Query Tracking",
  "description": "мҝјлҰ¬ лӢЁмң„ ліҖнҷҳ/кІҖмҰқ/л№„көҗ м¶”м Ғ. Stepлі„лЎң м җм§„м ҒмңјлЎң мұ„мӣҢм§„лӢӨ.",
  "type": "object",
  "required": ["version", "file", "queries"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "file": { "type": "string", "description": "мҶҢмҠӨ XML нҢҢмқјлӘ… (= query-matrix.jsonмқҳ original_file)" },
    "file_version": { "type": "integer", "description": "ліҖнҷҳ лІ„м „ (v1, v2, ...)" },
    "ts": { "type": "integer", "description": "UTC Unix timestamp (мғқм„ұ мӢңк°Ғ)" },
    "created_at": { "type": "string", "description": "ISO 8601 мғқм„ұ мӢңк°Ғ (мҪ”л“ң мӢӨм ң н•„л“ң)" },
    "updated_at": { "type": "string", "description": "ISO 8601 л§Ҳм§Җл§ү к°ұмӢ  (мҪ”л“ң мӢӨм ң н•„л“ң)" },
    "queries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["query_id", "type", "status"],
        "properties": {
          "query_id": { "type": "string", "description": "мҝјлҰ¬ ID (мң мқј мӢқлі„мһҗ)" },
          "type": { "type": "string", "enum": ["select", "insert", "update", "delete", "procedure"] },
          "status": {
            "type": "string",
            "description": "лӮҙл¶Җ мІҳлҰ¬ мғҒнғң (вҶ’ query-matrix.jsonмқҳ final_stateлЎң ліҖнҷҳлҗЁ)",
            "enum": ["pending", "parsed", "analyzed", "converting", "converted", "validating", "failed", "escalated", "success"]
          },
          "complexity": { "type": "string", "enum": ["L0", "L1", "L2", "L3", "L4"] },
          "layer": { "type": "integer" },

          "oracle_sql": { "type": "string", "description": "ліҖнҷҳ м „ Oracle SQL (вҶ’ query-matrixмқҳ sql_before)" },
          "pg_sql": { "type": "string", "description": "ліҖнҷҳ нӣ„ PG SQL (вҶ’ query-matrixмқҳ sql_after)" },
          "oracle_patterns": { "type": "array", "items": { "type": "string" } },
          "conversion_method": { "type": "string", "enum": ["rule", "llm", "no_change", "hybrid"] },
          "rules_applied": { "type": "array", "items": { "type": "string" } },

          "conversion_history": {
            "type": "array",
            "description": "ліҖнҷҳ мқҙл Ҙ. converter м—җмқҙм „нҠёк°Җ кё°лЎқ.",
            "items": {
              "type": "object",
              "properties": {
                "ts": { "type": "integer", "description": "UTC Unix timestamp" },
                "pattern": { "type": "string" },
                "approach": { "type": "string" },
                "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
                "notes": { "type": "string" }
              }
            }
          },

          "dynamic_elements": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "tag": { "type": "string" },
                "test": { "type": "string" },
                "content": { "type": "string" }
              }
            }
          },
          "parameters": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "jdbc_type": { "type": ["string", "null"] },
                "notation": { "type": "string" }
              }
            }
          },

          "explain": {
            "type": "object",
            "description": "EXPLAIN кІ°кіј (вҶ’ query-matrixмқҳ explain_statusлЎң flat ліҖнҷҳ)",
            "properties": {
              "status": { "type": "string", "enum": ["pass", "fail", "not_tested"] },
              "error": { "type": ["string", "null"] },
              "ts": { "type": "integer", "description": "UTC Unix timestamp" },
              "duration_ms": { "type": "integer" },
              "validation_source": { "type": "string", "enum": ["static", "mybatis"] }
            }
          },

          "execution": {
            "type": "object",
            "properties": {
              "status": { "type": "string", "enum": ["pass", "fail", "skipped"] },
              "row_count": { "type": "integer" },
              "duration_ms": { "type": "integer" },
              "error": { "type": ["string", "null"] },
              "ts": { "type": "integer" }
            }
          },

          "compare_results": {
            "type": "array",
            "description": "Compare кІ°кіј (вҶ’ query-matrixмқҳ compare_statusлЎң flat ліҖнҷҳ)",
            "items": {
              "type": "object",
              "properties": {
                "test_id": { "type": "string" },
                "oracle_rows": { "type": ["integer", "null"] },
                "pg_rows": { "type": ["integer", "null"] },
                "match": { "type": "boolean" },
                "reason": { "type": "string" }
              }
            }
          },

          "test_cases": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string", "description": "TC мқҙлҰ„ (= query-matrixмқҳ test_cases[].name)" },
                "params": { "type": "object", "description": "л°”мқёл“ң нҢҢлқјлҜён„° (= query-matrixмқҳ test_cases[].params)" },
                "source": { "type": "string", "description": "TC мҶҢмҠӨ (CUSTOM/SAMPLE_DATA/INFERRED л“ұ)" },
                "oracle_result": {
                  "type": "object",
                  "properties": {
                    "rows": { "type": "integer" },
                    "duration_ms": { "type": "integer" }
                  }
                },
                "pg_result": {
                  "type": "object",
                  "properties": {
                    "rows": { "type": "integer" },
                    "duration_ms": { "type": "integer" }
                  }
                },
                "match": { "type": "boolean" }
              }
            }
          },

          "attempts": {
            "type": "array",
            "description": "мҲҳм • мӢңлҸ„ мқҙл Ҙ. validate-and-fix м—җмқҙм „нҠёк°Җ кё°лЎқ.",
            "items": {
              "type": "object",
              "properties": {
                "attempt": { "type": "integer" },
                "ts": { "type": "integer", "description": "UTC Unix timestamp" },
                "error_category": { "type": ["string", "null"] },
                "error_detail": { "type": ["string", "null"] },
                "fix_applied": { "type": "string" },
                "result": { "type": "string", "enum": ["pass", "fail"] }
              }
            }
          }
        }
      }
    }
  },

  "_field_mapping": {
    "description": "query-tracking.json вҶ” query-matrix.json н•„л“ң л§Өн•‘ м°ёмЎ°",
    "file вҶ’ original_file": "trackingмқҳ file = matrixмқҳ original_file",
    "oracle_sql вҶ’ sql_before": "trackingмқҳ oracle_sql = matrixмқҳ sql_before",
    "pg_sql вҶ’ sql_after": "trackingмқҳ pg_sql = matrixмқҳ sql_after",
    "status вҶ’ final_state": "trackingмқҳ status(лӮҙл¶Җ) вҶ’ matrixмқҳ final_state(14-state, кі„мӮ°лҗЁ)",
    "explain.status вҶ’ explain_status": "trackingмқҳ мӨ‘мІ© вҶ’ matrixмқҳ flat",
    "compare_results[].match вҶ’ compare_status": "trackingмқҳ boolean л°°м—ҙ вҶ’ matrixмқҳ pass/fail string",
    "test_cases[].name/params": "trackingкіј matrixм—җм„ң лҸҷмқј н•„л“ңлӘ… мӮ¬мҡ©",
    "attempts[].ts": "UTC Unix int нҶөмқј"
  }
}
