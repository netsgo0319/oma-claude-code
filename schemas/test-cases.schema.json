{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Test Cases",
  "description": "test-generator 에이전트의 출력. Oracle 딕셔너리 기반 테스트 케이스.",
  "type": "object",
  "required": ["version", "source_file", "query_test_cases"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "source_file": { "type": "string" },
    "query_test_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["query_id", "parameters", "test_cases"],
        "properties": {
          "query_id": { "type": "string" },
          "parameters": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" }
              }
            }
          },
          "oracle_metadata": { "type": "object" },
          "expected_rows_hint": { "type": ["integer", "null"] },
          "test_cases": {
            "type": "array",
            "minItems": 3,
            "maxItems": 10,
            "items": {
              "type": "object",
              "required": ["case_id", "description", "source", "binds"],
              "properties": {
                "case_id": { "type": "string" },
                "description": { "type": "string" },
                "source": { "type": "string", "enum": ["V$SQL_BIND_CAPTURE", "ALL_TAB_COL_STATISTICS", "dynamic_sql_branch", "oracle_null_semantics", "FK_RELATIONSHIP", "SAMPLE_DATA"] },
                "binds": { "type": "object" },
                "not_null_columns": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    }
  }
}
